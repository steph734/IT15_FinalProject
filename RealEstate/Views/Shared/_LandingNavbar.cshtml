    /* Mobile Responsive */
    @@media (max-width: 991.98px) {
        .navbar-toggle {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .navbar-menu {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            flex-direction: column;
            background: white;
            box-shadow: 0 10px 30px rgba(30, 58, 95, 0.1);
            gap: 0;
            padding: 10px 0;
            border-radius: 0;
            justify-content: flex-start;
            display: none;
            width: 100%;
            border-top: 1px solid #E5E7EB;
        }

        .navbar-menu.active {
            display: flex;
        }

        .nav-item {
            width: 100%;
        }

        .nav-link {
            padding: 12px 20px;
        }

        .dropdown-menu {
            position: static;
            display: none;
            box-shadow: none;
            background: #F8F9FA;
            border: none;
        }

        .has-dropdown:hover .dropdown-menu,
        .has-dropdown.active .dropdown-menu {
            display: block;
        }

        .dropdown-menu a {
            padding: 10px 40px;
        }

        .navbar-right {
            margin-left: auto;
            margin-right: 15px;
