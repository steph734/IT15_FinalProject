@{
    var isHomeLanding = ViewData["IsHomeLanding"] as bool? ?? false;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EstateFlow</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RealEstate.styles.css" asp-append-version="true" />
    <style>
        /* Mobile Responsive Styles for Layout */
        @@media (max-width: 768px) {
            .site-footer .row {
                flex-direction: column;
                text-align: center;
            }

            .site-footer .col-md-6 {
                margin-bottom: 1rem;
            }

            .site-footer .text-md-end {
                text-align: center !important;
            }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(isHomeLanding ? "landing-body" : "site-inner-body")">
    @if (!isHomeLanding)
    {
        <partial name="_LandingNavbar" />
    }
    <div class="@(isHomeLanding ? "" : "container-fluid px-0")" style="@(isHomeLanding ? "" : "padding-top: 80px;")">
        <main role="main" class="@(isHomeLanding ? "pb-0" : "pb-4")">
            @RenderBody()
        </main>
    </div>

    @if (!isHomeLanding)
    {
        <footer class="site-footer border-top bg-site-soft mt-auto py-4">
            <div class="container">
                <div class="row g-3 align-items-center">
                    <div class="col-md-6">
                        <span class="brand-wordmark brand-wordmark--footer small"><span class="brand-estate">Estate</span><span class="brand-flow">Flow</span></span>
                        <span class="text-site-muted small ms-2">&copy; @DateTime.UtcNow.Year</span>
                    </div>
                    <div class="col-md-6 text-md-end small">
                        <a class="text-site-muted text-decoration-none me-3" asp-controller="Properties" asp-action="Index">Properties</a>
                        <a class="text-site-muted text-decoration-none me-3" asp-controller="Agents" asp-action="Index">Agents</a>
                        <a class="text-site-muted text-decoration-none me-3" asp-controller="Home" asp-action="Contact">Contact</a>
                        <a class="text-site-muted text-decoration-none" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </div>
                </div>
            </div>
        </footer>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- SignalR and PeerJS for Video Calling -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
