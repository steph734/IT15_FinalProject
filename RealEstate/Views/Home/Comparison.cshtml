@{
    ViewData["Title"] = "Compare Properties - EstateFlow";
}

<div class="estateflow-page-wrapper">
    <!-- Page Header -->
    <section class="page-header-modern">
        <div class="container">
            <div class="page-header-content">
                <span class="page-label">SIDE BY SIDE</span>
                <h1 class="page-title">Compare Properties</h1>
                <p class="page-subtitle">Compare features, prices, and details of your favorite properties</p>
            </div>
        </div>
    </section>

    <!-- Comparison Content -->
    <section class="comparison-section">
        <div class="container-fluid">
            <div class="comparison-wrapper">
                <!-- Comparison Table -->
                <div class="comparison-table-responsive">
                    <table class="comparison-table">
                        <thead>
                            <tr>
                                <th class="label-column">Features</th>
                                <th class="property-column">
                                    <button class="btn-remove-property" title="Remove">
                                        <i class="fas fa-times"></i>
                                    </button>
                                    <div class="property-card-mini">
                                        <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=300&q=80" alt="Property 1">
                                        <div class="mini-info">
                                            <h4>Modern Luxury Apartment</h4>
                                            <p class="price">$450,000</p>
                                            <p class="location">Downtown District</p>
                                        </div>
                                    </div>
                                </th>
                                <th class="property-column">
                                    <button class="btn-remove-property" title="Remove">
                                        <i class="fas fa-times"></i>
                                    </button>
                                    <div class="property-card-mini">
                                        <img src="https://images.unsplash.com/photo-1570129477492-45c003edd2be?auto=format&fit=crop&w=300&q=80" alt="Property 2">
                                        <div class="mini-info">
                                            <h4>Spacious Family Home</h4>
                                            <p class="price">$3,500/mo</p>
                                            <p class="location">Suburban Heights</p>
                                        </div>
                                    </div>
                                </th>
                                <th class="property-column">
                                    <button class="btn-remove-property" title="Remove">
                                        <i class="fas fa-times"></i>
                                    </button>
                                    <div class="property-card-mini">
                                        <img src="https://images.unsplash.com/photo-1568605117036-5fe5e7bab0b7?auto=format&fit=crop&w=300&q=80" alt="Property 3">
                                        <div class="mini-info">
                                            <h4>Cozy Studio Condo</h4>
                                            <p class="price">$250,000</p>
                                            <p class="location">Midtown Plaza</p>
                                        </div>
                                    </div>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Price -->
                            <tr>
                                <td class="label-column">
                                    <strong>Price</strong>
                                </td>
                                <td>$450,000</td>
                                <td>$3,500/month</td>
                                <td>$250,000</td>
                            </tr>

                            <!-- Type -->
                            <tr>
                                <td class="label-column">
                                    <strong>Property Type</strong>
                                </td>
                                <td>Apartment</td>
                                <td>House</td>
                                <td>Condo</td>
                            </tr>

                            <!-- Status -->
                            <tr>
                                <td class="label-column">
                                    <strong>Listing Status</strong>
                                </td>
                                <td>
                                    <span class="badge badge-sale">For Sale</span>
                                </td>
                                <td>
                                    <span class="badge badge-rent">For Rent</span>
                                </td>
                                <td>
                                    <span class="badge badge-sale">For Sale</span>
                                </td>
                            </tr>

                            <!-- Bedrooms -->
                            <tr>
                                <td class="label-column">
                                    <i class="fas fa-bed"></i> <strong>Bedrooms</strong>
                                </td>
                                <td class="highlight">3</td>
                                <td class="highlight">4</td>
                                <td>1</td>
                            </tr>

                            <!-- Bathrooms -->
                            <tr>
                                <td class="label-column">
                                    <i class="fas fa-bath"></i> <strong>Bathrooms</strong>
                                </td>
                                <td>2</td>
                                <td class="highlight">3</td>
                                <td>1</td>
                            </tr>

                            <!-- Square Footage -->
                            <tr>
                                <td class="label-column">
                                    <i class="fas fa-ruler-combined"></i> <strong>Square Feet</strong>
                                </td>
                                <td>1,800 sqft</td>
                                <td class="highlight">2,500 sqft</td>
                                <td>600 sqft</td>
                            </tr>

                            <!-- Year Built -->
                            <tr>
                                <td class="label-column">
                                    <strong>Year Built</strong>
                                </td>
                                <td class="highlight">2022</td>
                                <td>2015</td>
                                <td>2020</td>
                            </tr>

                            <!-- Parking -->
                            <tr>
                                <td class="label-column">
                                    <i class="fas fa-car"></i> <strong>Parking Spaces</strong>
                                </td>
                                <td>1</td>
                                <td class="highlight">3</td>
                                <td>1</td>
                            </tr>

                            <!-- Garage -->
                            <tr>
                                <td class="label-column">
                                    <strong>Garage</strong>
                                </td>
                                <td>
                                    <i class="fas fa-times" style="color: #EF4444;"></i>
                                </td>
                                <td>
                                    <i class="fas fa-check" style="color: #10B981;"></i>
                                </td>
                                <td>
                                    <i class="fas fa-times" style="color: #EF4444;"></i>
                                </td>
                            </tr>

                            <!-- Pool -->
                            <tr>
                                <td class="label-column">
                                    <strong>Swimming Pool</strong>
                                </td>
                                <td>
                                    <i class="fas fa-times" style="color: #EF4444;"></i>
                                </td>
                                <td class="highlight">
                                    <i class="fas fa-check" style="color: #10B981;"></i>
                                </td>
                                <td>
                                    <i class="fas fa-times" style="color: #EF4444;"></i>
                                </td>
                            </tr>

                            <!-- Garden -->
                            <tr>
                                <td class="label-column">
                                    <strong>Garden/Yard</strong>
                                </td>
                                <td>
                                    <i class="fas fa-times" style="color: #EF4444;"></i>
                                </td>
                                <td class="highlight">
                                    <i class="fas fa-check" style="color: #10B981;"></i>
                                </td>
                                <td>
                                    <i class="fas fa-times" style="color: #EF4444;"></i>
                                </td>
                            </tr>

                            <!-- HOA Fees -->
                            <tr>
                                <td class="label-column">
                                    <strong>HOA Fees</strong>
                                </td>
                                <td>$300/month</td>
                                <td>None</td>
                                <td>$200/month</td>
                            </tr>

                            <!-- Property Tax -->
                            <tr>
                                <td class="label-column">
                                    <strong>Annual Tax</strong>
                                </td>
                                <td>$5,400</td>
                                <td>$4,800</td>
                                <td>$3,000</td>
                            </tr>

                            <!-- Utilities -->
                            <tr>
                                <td class="label-column">
                                    <strong>Utilities Avg/Month</strong>
                                </td>
                                <td>$150</td>
                                <td class="highlight">$250</td>
                                <td>$100</td>
                            </tr>

                            <!-- Amenities -->
                            <tr>
                                <td class="label-column">
                                    <strong>Amenities</strong>
                                </td>
                                <td>
                                    <div class="amenities-list">
                                        <span class="amenity">Gym</span>
                                        <span class="amenity">Parking</span>
                                        <span class="amenity">Doorman</span>
                                    </div>
                                </td>
                                <td class="highlight">
                                    <div class="amenities-list">
                                        <span class="amenity">Pool</span>
                                        <span class="amenity">Garden</span>
                                        <span class="amenity">Garage</span>
                                        <span class="amenity">Deck</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="amenities-list">
                                        <span class="amenity">Parking</span>
                                        <span class="amenity">Pet-Friendly</span>
                                    </div>
                                </td>
                            </tr>

                            <!-- Actions -->
                            <tr>
                                <td class="label-column"></td>
                                <td>
                                    <a href="#" class="btn-compare-action">View Details</a>
                                </td>
                                <td>
                                    <a href="#" class="btn-compare-action">View Details</a>
                                </td>
                                <td>
                                    <a href="#" class="btn-compare-action">View Details</a>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Comparison Summary -->
            <div class="comparison-summary">
                <div class="summary-card">
                    <h4 class="summary-heading">Quick Verdict</h4>
                    <div class="verdict-list">
                        <div class="verdict-item">
                            <strong>Best for Families:</strong>
                            <span>Spacious Family Home (More bedrooms & amenities)</span>
                        </div>
                        <div class="verdict-item">
                            <strong>Best Value:</strong>
                            <span>Cozy Studio Condo (Most affordable)</span>
                        </div>
                        <div class="verdict-item">
                            <strong>Best Location:</strong>
                            <span>Modern Luxury Apartment (Downtown access)</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-section-modern">
        <div class="container text-center">
            <h2 class="cta-title">Ready to Make a Decision?</h2>
            <p class="cta-subtitle">Schedule viewings for your top choices</p>
            <a href="/Checkout" class="btn-primary-modern btn-lg">Schedule Viewings</a>
        </div>
    </section>
</div>

<style>
    .comparison-section {
        padding: 60px 0;
        background: white;
    }

    .comparison-wrapper {
        overflow-x: auto;
        border-radius: 12px;
        border: 1px solid #E5E7EB;
    }

    .comparison-table {
        width: 100%;
        border-collapse: collapse;
    }

    .comparison-table thead {
        background: white;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .comparison-table th {
        padding: 20px;
        border-bottom: 2px solid #E0F2F1;
    }

    .label-column {
        width: 200px;
        min-width: 200px;
        background: #F8F9FA;
        font-weight: 600;
        text-align: left;
    }

    .property-column {
        min-width: 250px;
        position: relative;
    }

    /* Property Card Mini -->
    .property-card-mini {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .property-card-mini img {
        width: 100%;
        height: 120px;
        object-fit: cover;
        border-radius: 6px;
    }

    .mini-info h4 {
        font-size: 0.95rem;
        font-weight: 700;
        color: #1E3A5F;
        margin: 0;
    }

    .mini-info p {
        margin: 4px 0;
        font-size: 0.85rem;
    }

    .mini-info .price {
        color: #16A39E;
        font-weight: 600;
    }

    .mini-info .location {
        color: #6B7280;
    }

    .btn-remove-property {
        position: absolute;
        top: 10px;
        right: 10px;
        background: #EF4444;
        color: white;
        border: none;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
    }

    .btn-remove-property:hover {
        background: #DC2626;
        transform: scale(1.1);
    }

    /* Table Body -->
    .comparison-table tbody tr {
        border-bottom: 1px solid #E5E7EB;
        transition: background 0.3s;
    }

    .comparison-table tbody tr:hover {
        background: #F8F9FA;
    }

    .comparison-table td {
        padding: 16px 20px;
        font-size: 0.95rem;
        color: #6B7280;
    }

    .comparison-table td.label-column {
        background: #F8F9FA;
        font-weight: 500;
        color: #1E3A5F;
    }

    .comparison-table td.highlight {
        background: #E0F2F1;
        font-weight: 600;
        color: #16A39E;
    }

    /* Badges -->
    .badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
    }

    .badge-sale {
        background: #E0F2F1;
        color: #16A39E;
    }

    .badge-rent {
        background: #FEF3C7;
        color: #D97706;
    }

    /* Amenities List -->
    .amenities-list {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .amenity {
        display: inline-block;
        background: #E0F2F1;
        color: #16A39E;
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.8rem;
        white-space: nowrap;
    }

    /* Actions -->
    .btn-compare-action {
        display: inline-block;
        background: #16A39E;
        color: white;
        padding: 8px 16px;
        border-radius: 4px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.3s;
    }

    .btn-compare-action:hover {
        background: #0F8B84;
        text-decoration: none;
    }

    /* Comparison Summary -->
    .comparison-summary {
        margin-top: 40px;
    }

    .summary-card {
        background: linear-gradient(135deg, #E0F2F1, #F8F9FA);
        padding: 30px;
        border-radius: 12px;
        border: 1px solid #D0EAE7;
    }

    .summary-heading {
        font-size: 1.2rem;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: 20px;
    }

    .verdict-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
    }

    .verdict-item {
        padding: 15px;
        background: white;
        border-radius: 8px;
        border-left: 4px solid #16A39E;
    }

    .verdict-item strong {
        display: block;
        color: #1E3A5F;
        margin-bottom: 6px;
    }

    .verdict-item span {
        color: #6B7280;
        font-size: 0.9rem;
    }

    @@media (max-width: 991.98px) {
        .comparison-wrapper {
            overflow-x: auto;
        }

        .comparison-table {
            font-size: 0.85rem;
        }

        .comparison-table td,
        .comparison-table th {
            padding: 12px 15px;
        }

        .label-column {
            width: 150px;
            min-width: 150px;
        }

        .property-column {
            min-width: 180px;
        }
    }

    @@media (max-width: 767.98px) {
        .comparison-section {
            padding: 30px 0;
        }

        .comparison-table {
            font-size: 0.75rem;
        }

        .comparison-table td,
        .comparison-table th {
            padding: 8px 10px;
        }

        .label-column {
            width: 100px;
            min-width: 100px;
        }

        .property-column {
            min-width: 130px;
        }

        .property-card-mini img {
            height: 80px;
        }

        .verdict-list {
            grid-template-columns: 1fr;
        }
    }
</style>
