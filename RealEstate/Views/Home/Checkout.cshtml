@{
    ViewData["Title"] = "Checkout - EstateFlow";
}

<div class="estateflow-page-wrapper">
    <!-- Page Header -->
    <section class="page-header-modern">
        <div class="container">
            <div class="page-header-content">
                <span class="page-label">FINALIZE YOUR CHOICE</span>
                <h1 class="page-title">Checkout</h1>
                <p class="page-subtitle">Complete your inquiry and schedule property viewings</p>
            </div>
        </div>
    </section>

    <!-- Checkout Content -->
    <section class="checkout-section">
        <div class="container">
            <div class="row g-4">
                <!-- Checkout Form -->
                <div class="col-lg-8">
                    <!-- Progress Steps -->
                    <div class="checkout-progress">
                        <div class="progress-step active">
                            <div class="progress-circle">1</div>
                            <span class="progress-label">Personal Info</span>
                        </div>
                        <div class="progress-line"></div>
                        <div class="progress-step active">
                            <div class="progress-circle">2</div>
                            <span class="progress-label">Review</span>
                        </div>
                        <div class="progress-line"></div>
                        <div class="progress-step">
                            <div class="progress-circle">3</div>
                            <span class="progress-label">Confirmation</span>
                        </div>
                    </div>

                    <!-- Checkout Form -->
                    <form class="checkout-form">
                        <!-- Personal Information -->
                        <div class="form-section">
                            <h3 class="form-section-title">Personal Information</h3>
                            
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">First Name *</label>
                                    <input type="text" class="form-control" placeholder="John" required>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Last Name *</label>
                                    <input type="text" class="form-control" placeholder="Doe" required>
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Email Address *</label>
                                <input type="email" class="form-control" placeholder="john@example.com" required>
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Phone Number *</label>
                                    <input type="tel" class="form-control" placeholder="+1 (555) 123-4567" required>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Country *</label>
                                    <select class="form-control" required>
                                        <option value="">Select Country</option>
                                        <option value="us">United States</option>
                                        <option value="ca">Canada</option>
                                        <option value="uk">United Kingdom</option>
                                        <option value="au">Australia</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Property Interest -->
                        <div class="form-section">
                            <h3 class="form-section-title">Property Interests</h3>

                            <div class="form-group">
                                <label class="form-label">Which properties are you interested in? *</label>
                                <div class="property-checkboxes">
                                    <label class="checkbox-item">
                                        <input type="checkbox" name="properties" value="modern-apartment">
                                        <span>Modern Luxury Apartment - $450,000</span>
                                    </label>
                                    <label class="checkbox-item">
                                        <input type="checkbox" name="properties" value="family-home">
                                        <span>Spacious Family Home - $3,500/month</span>
                                    </label>
                                    <label class="checkbox-item">
                                        <input type="checkbox" name="properties" value="studio-condo">
                                        <span>Cozy Studio Condo - $250,000</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Viewing Preferences -->
                        <div class="form-section">
                            <h3 class="form-section-title">Viewing Preferences</h3>

                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Preferred Viewing Date *</label>
                                    <input type="date" class="form-control" required>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Preferred Time *</label>
                                    <select class="form-control" required>
                                        <option value="">Select Time</option>
                                        <option value="09:00">09:00 AM</option>
                                        <option value="10:00">10:00 AM</option>
                                        <option value="11:00">11:00 AM</option>
                                        <option value="14:00">02:00 PM</option>
                                        <option value="15:00">03:00 PM</option>
                                        <option value="16:00">04:00 PM</option>
                                    </select>
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Additional Notes (Optional)</label>
                                <textarea class="form-control" rows="4" placeholder="Any special requests or questions..."></textarea>
                            </div>
                        </div>

                        <!-- Agreement -->
                        <div class="form-section">
                            <label class="checkbox-item checkbox-large">
                                <input type="checkbox" required>
                                <span>I agree to the Terms & Conditions and Privacy Policy</span>
                            </label>
                            <label class="checkbox-item">
                                <input type="checkbox">
                                <span>Subscribe to our newsletter for new property updates</span>
                            </label>
                        </div>

                        <!-- Action Buttons -->
                        <div class="form-actions">
                            <a href="/Cart" class="btn-secondary">
                                <i class="fas fa-arrow-left"></i> Back to Cart
                            </a>
                            <button type="submit" class="btn-primary">
                                <i class="fas fa-check"></i> Complete Inquiry
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Order Summary Sidebar -->
                <div class="col-lg-4">
                    <div class="order-summary-wrapper">
                        <div class="summary-card">
                            <h4 class="summary-title">Inquiry Summary</h4>

                            <!-- Summary Items -->
                            <div class="summary-items">
                                <div class="summary-item-entry">
                                    <div class="entry-header">
                                        <span class="entry-name">Modern Luxury Apartment</span>
                                        <button class="btn-remove-entry" type="button">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                    <div class="entry-details">
                                        <span class="entry-price">$450,000</span>
                                        <span class="entry-type">For Sale</span>
                                    </div>
                                </div>

                                <div class="summary-item-entry">
                                    <div class="entry-header">
                                        <span class="entry-name">Spacious Family Home</span>
                                        <button class="btn-remove-entry" type="button">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                    <div class="entry-details">
                                        <span class="entry-price">$3,500/mo</span>
                                        <span class="entry-type">For Rent</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Info Box -->
                            <div class="info-box">
                                <i class="fas fa-info-circle"></i>
                                <p>Our agents will contact you within 24 hours to confirm your viewings and answer any questions.</p>
                            </div>

                            <!-- Quick Stats -->
                            <div class="stats-box">
                                <div class="stat">
                                    <span class="stat-label">Properties</span>
                                    <span class="stat-value">2</span>
                                </div>
                                <div class="stat">
                                    <span class="stat-label">Avg Price</span>
                                    <span class="stat-value">$226.75K</span>
                                </div>
                            </div>

                            <!-- Security Badge -->
                            <div class="security-badge">
                                <i class="fas fa-lock"></i>
                                <span>Secure & Encrypted</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Trust Section -->
    <section class="trust-section">
        <div class="container">
            <div class="trust-grid">
                <div class="trust-item">
                    <i class="fas fa-shield-alt"></i>
                    <h4>100% Secure</h4>
                    <p>Your data is encrypted and protected</p>
                </div>
                <div class="trust-item">
                    <i class="fas fa-clock"></i>
                    <h4>Fast Response</h4>
                    <p>Contact within 24 hours guaranteed</p>
                </div>
                <div class="trust-item">
                    <i class="fas fa-users"></i>
                    <h4>Expert Agents</h4>
                    <p>Experienced professionals ready to help</p>
                </div>
                <div class="trust-item">
                    <i class="fas fa-undo"></i>
                    <h4>No Commitment</h4>
                    <p>Browse and inquire at your own pace</p>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
    .checkout-section {
        padding: 60px 0;
    }

    /* Progress Steps */
    .checkout-progress {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 50px;
    }

    .progress-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    .progress-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #E5E7EB;
        color: #6B7280;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        transition: all 0.3s;
    }

    .progress-step.active .progress-circle {
        background: #16A39E;
        color: white;
    }

    .progress-label {
        font-size: 0.85rem;
        color: #6B7280;
        white-space: nowrap;
    }

    .progress-step.active .progress-label {
        color: #16A39E;
        font-weight: 600;
    }

    .progress-line {
        flex: 1;
        height: 2px;
        background: #E5E7EB;
        margin: 0 20px;
        min-width: 100px;
    }

    .progress-step.active ~ .progress-line {
        background: #E5E7EB;
    }

    /* Checkout Form */
    .checkout-form {
        background: white;
        border-radius: 12px;
        padding: 40px;
        border: 1px solid #E5E7EB;
    }

    .form-section {
        margin-bottom: 35px;
    }

    .form-section:last-child {
        margin-bottom: 0;
    }

    .form-section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid #E0F2F1;
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-label {
        font-size: 0.9rem;
        font-weight: 600;
        color: #1E3A5F;
        margin-bottom: 8px;
    }

    .form-control {
        padding: 12px;
        border: 1px solid #E5E7EB;
        border-radius: 6px;
        font-size: 0.95rem;
        transition: all 0.3s;
    }

    .form-control:focus {
        outline: none;
        border-color: #16A39E;
        box-shadow: 0 0 0 3px rgba(22, 163, 158, 0.1);
    }

    /* Checkboxes */
    .property-checkboxes {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .checkbox-item {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        padding: 12px;
        border-radius: 6px;
        transition: all 0.3s;
    }

    .checkbox-item:hover {
        background: #F8F9FA;
    }

    .checkbox-item input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
        accent-color: #16A39E;
    }

    .checkbox-item span {
        color: #6B7280;
        font-size: 0.95rem;
    }

    .checkbox-item.checkbox-large {
        padding: 16px;
        margin-bottom: 12px;
    }

    .checkbox-item.checkbox-large span {
        color: #1E3A5F;
        font-weight: 500;
    }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 16px;
        margin-top: 35px;
        padding-top: 35px;
        border-top: 1px solid #E5E7EB;
    }

    .btn-secondary,
    .btn-primary {
        padding: 12px 30px;
        border-radius: 6px;
        border: none;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        text-align: center;
        justify-content: center;
    }

    .btn-secondary {
        background: #E5E7EB;
        color: #1E3A5F;
    }

    .btn-secondary:hover {
        background: #D1D5DB;
        text-decoration: none;
    }

    .btn-primary {
        background: #16A39E;
        color: white;
        flex: 1;
    }

    .btn-primary:hover {
        background: #0F8B84;
        text-decoration: none;
    }

    /* Order Summary */
    .order-summary-wrapper {
        position: sticky;
        top: 20px;
    }

    .summary-card {
        background: white;
        border-radius: 12px;
        padding: 25px;
        border: 1px solid #E5E7EB;
    }

    .summary-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid #E0F2F1;
    }

    /* Summary Items */
    .summary-items {
        margin-bottom: 20px;
    }

    .summary-item-entry {
        padding: 15px;
        background: #F8F9FA;
        border-radius: 6px;
        margin-bottom: 12px;
    }

    .entry-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 8px;
    }

    .entry-name {
        font-weight: 600;
        color: #1E3A5F;
        font-size: 0.9rem;
    }

    .btn-remove-entry {
        background: none;
        border: none;
        color: #EF4444;
        cursor: pointer;
        font-size: 1rem;
        transition: transform 0.3s;
    }

    .btn-remove-entry:hover {
        transform: scale(1.2);
    }

    .entry-details {
        display: flex;
        gap: 12px;
        font-size: 0.85rem;
    }

    .entry-price {
        color: #16A39E;
        font-weight: 600;
    }

    .entry-type {
        color: #6B7280;
        background: white;
        padding: 2px 8px;
        border-radius: 3px;
    }

    /* Info Box */
    .info-box {
        background: #E0F2F1;
        padding: 15px;
        border-radius: 6px;
        margin-bottom: 20px;
        display: flex;
        gap: 12px;
        color: #1E3A5F;
        font-size: 0.9rem;
        line-height: 1.5;
    }

    .info-box i {
        color: #16A39E;
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    /* Stats Box */
    .stats-box {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 20px;
        padding-bottom: 20px;
        border-bottom: 1px solid #E5E7EB;
    }

    .stat {
        text-align: center;
    }

    .stat-label {
        font-size: 0.8rem;
        color: #6B7280;
        display: block;
        margin-bottom: 4px;
    }

    .stat-value {
        font-size: 1.3rem;
        font-weight: 800;
        color: #16A39E;
        display: block;
    }

    /* Security Badge */
    .security-badge {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        color: #16A39E;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .security-badge i {
        font-size: 1.1rem;
    }

    /* Trust Section */
    .trust-section {
        background: #F8F9FA;
        padding: 60px 0;
    }

    .trust-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 30px;
    }

    .trust-item {
        text-align: center;
        padding: 20px;
    }

    .trust-item i {
        font-size: 2.5rem;
        color: #16A39E;
        margin-bottom: 12px;
        display: block;
    }

    .trust-item h4 {
        color: #1E3A5F;
        margin-bottom: 8px;
    }

    .trust-item p {
        color: #6B7280;
        font-size: 0.9rem;
    }

    @@media (max-width: 991.98px) {
        .checkout-form {
            padding: 30px;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .order-summary-wrapper {
            position: static;
            margin-top: 30px;
        }
    }

    @@media (max-width: 767.98px) {
        .checkout-progress {
            margin-bottom: 30px;
            overflow-x: auto;
        }

        .progress-line {
            min-width: 50px;
            margin: 0 10px;
        }

        .checkout-form {
            padding: 20px;
        }

        .form-actions {
            flex-direction: column;
        }

        .btn-primary,
        .btn-secondary {
            width: 100%;
        }

        .trust-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .trust-item {
            padding: 15px;
        }
    }
</style>
