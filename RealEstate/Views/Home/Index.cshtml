</div>

<style>
    /* Modern CityScape-Inspired Design */
    
    .realestate-landing-modern {
        background: #fff;
    }

    /* HERO SECTION */
    .hero-section-modern {
        background: #f8f9fa;
        padding: 60px 0;
        position: relative;
        overflow: hidden;
    }

    .hero-content-wrapper {
        display: flex;
        align-items: center;
        padding: 60px 40px;
    }

    .hero-content {
        max-width: 500px;
    }

    .hero-label {
        display: inline-block;
        color: #16A39E;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 2px;
        margin-bottom: 20px;
        text-transform: uppercase;
    }

    .hero-title-modern {
        font-size: 3.5rem;
        font-weight: 800;
        line-height: 1.2;
        color: #1E3A5F;
        margin-bottom: 20px;
        font-family: 'Georgia', serif;
