                <div class="text-center mb-5">
                    <span class="section-label-modern">OUR GALLERY</span>
                    <h2 class="section-title-modern">Unlocking the door to your a the new home</h2>
                </div>

                <div class="property-gallery-grid">
                    <div class="gallery-item gallery-item-large">
                        <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=600&q=80" alt="Modern House with Pool" class="w-100 h-100 object-fit-cover">
                    </div>
                    <div class="gallery-item gallery-item-large">
                        <img src="https://images.unsplash.com/photo-1570129477492-45c003edd2be?auto=format&fit=crop&w=600&q=80" alt="Luxury Villa" class="w-100 h-100 object-fit-cover">
                    </div>
                    <div class="gallery-item gallery-item-large">
                        <img src="https://images.unsplash.com/photo-1580587771525-78991c7aef33?auto=format&fit=crop&w=600&q=80" alt="Contemporary Home" class="w-100 h-100 object-fit-cover">
                    </div>
                    <div class="gallery-item gallery-item-large">
                        <img src="https://images.unsplash.com/photo-1568605117036-5fe5e7bab0b7?auto=format&fit=crop&w=600&q=80" alt="Elegant Residence" class="w-100 h-100 object-fit-cover">
                    </div>
                </div>
            </div>
        </section>

        <!-- LATEST OFFERS SECTION -->
        <section class="latest-offers-section">
            <div class="container">
                <div class="offers-header">
                    <div>
                        <span class="section-label-modern">LATEST OFFER</span>
                        <h2 class="section-title-modern">Live Your Best Life in a New Home</h2>
                    </div>
                    <div class="carousel-nav-buttons">
                        <button class="nav-btn prev-btn" onclick="scrollOffersCarousel(-1)">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <button class="nav-btn next-btn" onclick="scrollOffersCarousel(1)">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                </div>

                <div class="offers-carousel-wrapper">
                    <div class="offers-carousel" id="offersCarousel">
                        @if (featuredSource.Any())
                        {
                            foreach (var property in featuredSource.Take(6))
                            {
                                var imageUrl = property.ImageUrls.FirstOrDefault() ?? "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=400&q=80";
                                <div class="offer-card">
                                    <div class="offer-image">
                                        <img src="@imageUrl" alt="@property.Title" class="w-100 h-100 object-fit-cover">
                                    </div>
                                    <div class="offer-content">
                                        <div class="offer-price">@(property.ListingType == PropertyListingType.Buy ? property.Price.ToString("C0", ph) : property.Price.ToString("C0", ph) + "/month")</div>
                                        <div class="offer-type">@(property.ListingType == PropertyListingType.Buy ? "For Sale" : property.ListingType == PropertyListingType.Rent ? "For Rent" : "For Lease")</div>
                                        <h4 class="offer-title">@property.Title</h4>
                                        <div class="offer-location">
                                            <i class="fas fa-map-marker-alt"></i>
                                            @property.Location
                                        </div>
                                        <div class="offer-details">
                                            <span class="detail-item">
                                                <i class="fas fa-bed"></i> @property.Bedrooms Beds
                                            </span>
                                            <span class="detail-item">
                                                <i class="fas fa-bath"></i> @property.Bathrooms Baths
                                            </span>
                                        </div>
                                        <a asp-controller="Properties" asp-action="Details" asp-route-id="@property.Id" class="btn-book-now">BOOK NOW <i class="fas fa-arrow-right"></i></a>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="offer-card">
                                <div class="offer-image">
                                    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=400&q=80" alt="Luxury Home 1" class="w-100 h-100 object-fit-cover">
                                </div>
                                <div class="offer-content">
                                    <div class="offer-price">$500.00</div>
                                    <div class="offer-type">For Sale</div>
                                    <h4 class="offer-title">Paramount Investments Prestige Property Management</h4>
                                    <div class="offer-location">
                                        <i class="fas fa-map-marker-alt"></i>
                                        66 Brooklyant, New York America
                                    </div>
                                    <div class="offer-details">
                                        <span class="detail-item">
                                            <i class="fas fa-bed"></i> 3 Beds
                                        </span>
                                        <span class="detail-item">
                                            <i class="fas fa-bath"></i> 3 Baths
                                        </span>
                                    </div>
                                    <a href="#" class="btn-book-now">BOOK NOW <i class="fas fa-arrow-right"></i></a>
                                </div>
                            </div>
                            <div class="offer-card">
                                <div class="offer-image">
                                    <img src="https://images.unsplash.com/photo-1570129477492-45c003edd2be?auto=format&fit=crop&w=400&q=80" alt="Luxury Home 2" class="w-100 h-100 object-fit-cover">
                                </div>
                                <div class="offer-content">
                                    <div class="offer-price">$500.00</div>
                                    <div class="offer-type">For Sale</div>
                                    <h4 class="offer-title">Paramount Investments Prestige Property Management</h4>
                                    <div class="offer-location">
                                        <i class="fas fa-map-marker-alt"></i>
                                        66 Brooklyant, New York America
                                    </div>
                                    <div class="offer-details">
                                        <span class="detail-item">
                                            <i class="fas fa-bed"></i> 3 Beds
                                        </span>
                                        <span class="detail-item">
                                            <i class="fas fa-bath"></i> 3 Baths
                                        </span>
                                    </div>
                                    <a href="#" class="btn-book-now">BOOK NOW <i class="fas fa-arrow-right"></i></a>
                                </div>
                            </div>
                            <div class="offer-card">
                                <div class="offer-image">
                                    <img src="https://images.unsplash.com/photo-1568605117036-5fe5e7bab0b7?auto=format&fit=crop&w=400&q=80" alt="Luxury Home 3" class="w-100 h-100 object-fit-cover">
                                </div>
                                <div class="offer-content">
                                    <div class="offer-price">$500.00</div>
                                    <div class="offer-type">For Sale</div>
                                    <h4 class="offer-title">Paramount Investments Prestige Property Management</h4>
                                    <div class="offer-location">
                                        <i class="fas fa-map-marker-alt"></i>
                                        66 Brooklyant, New York America
                                    </div>
                                    <div class="offer-details">
                                        <span class="detail-item">
                                            <i class="fas fa-bed"></i> 3 Beds
                                        </span>
                                        <span class="detail-item">
                                            <i class="fas fa-bath"></i> 3 Baths
                                        </span>
                                    </div>
                                    <a href="#" class="btn-book-now">BOOK NOW <i class="fas fa-arrow-right"></i></a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </section>

        <!-- WHY CHOOSE US SECTION -->
        <section class="why-choose-section-modern">
            <div class="container">
                <div class="text-center mb-5">
                    <h2 class="section-title-modern">Why Choose EstateFlow?</h2>
                    <p class="section-subtitle-modern">We provide premium real estate solutions with exceptional service</p>
                </div>

                <div class="row g-4">
                    <div class="col-lg-4 col-md-6">
                        <div class="feature-box-modern">
                            <div class="feature-icon-modern">
                                <i class="fas fa-search"></i>
                            </div>
                            <h5 class="feature-title-modern">Easy Search</h5>
                            <p class="feature-text-modern">Advanced filters to find exactly what you're looking for</p>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6">
                        <div class="feature-box-modern">
                            <div class="feature-icon-modern">
                                <i class="fas fa-shield-alt"></i>
                            </div>
                            <h5 class="feature-title-modern">Secure Transactions</h5>
                            <p class="feature-text-modern">100% verified listings with secure payment protection</p>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6">
                        <div class="feature-box-modern">
                            <div class="feature-icon-modern">
                                <i class="fas fa-headset"></i>
                            </div>
                            <h5 class="feature-title-modern">24/7 Support</h5>
