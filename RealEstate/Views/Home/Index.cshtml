            <div class="container py-5">
                <div class="text-center mb-5">
                    <span class="section-label-modern">CLIENTS TESTIMONIALS</span>
                    <h2 class="section-title-modern">Investing in Real Estate for Brighter Tomorrow</h2>
                </div>

                <div class="row g-4">
                    @if (featuredSource.Any())
                    {
                        var index = 0;
                        foreach (var property in featuredSource.Take(3))
                        {
                            index++;
                            var imageUrl = property.ImageUrls.FirstOrDefault() ?? "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1200&q=80";
                            <div class="col-lg-4 col-md-6">
                                <div class="property-card-modern">
                                    <div class="property-image-modern">
                                        <img src="@imageUrl" alt="@property.Title" class="w-100 h-100 object-fit-cover">
                                    </div>
                                    <div class="property-content-modern">
                                        <div class="property-number">0@index</div>
                                        <h4 class="property-title-modern">@property.Title</h4>
                                        <p class="property-desc-modern">Real Estate is a vast industry that deals with the buying, selling and renting of properties.</p>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-lg-4 col-md-6">
                            <div class="property-card-modern">
                                <div class="property-image-modern">
                                    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1200&q=80" alt="Luxury Apartment" class="w-100 h-100 object-fit-cover">
                                </div>
                                <div class="property-content-modern">
                                    <div class="property-number">01</div>
                                    <h4 class="property-title-modern">Dream Dwell Properties</h4>
                                    <p class="property-desc-modern">Real Estate is a vast industry that deals with the buying, selling and renting of properties.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <div class="property-card-modern">
                                <div class="property-image-modern">
                                    <img src="https://images.unsplash.com/photo-1570129477492-45c003edd2be?auto=format&fit=crop&w=1200&q=80" alt="Modern Living" class="w-100 h-100 object-fit-cover">
                                </div>
                                <div class="property-content-modern">
                                    <div class="property-number">02</div>
                                    <h4 class="property-title-modern">Seamless Solutions</h4>
                                    <p class="property-desc-modern">Real Estate is a vast industry that deals with the buying, selling and renting of properties.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <div class="property-card-modern">
                                <div class="property-image-modern">
                                    <img src="https://images.unsplash.com/photo-1568605117036-5fe5e7bab0b7?auto=format&fit=crop&w=1200&q=80" alt="Skyline View" class="w-100 h-100 object-fit-cover">
                                </div>
                                <div class="property-content-modern">
                                    <div class="property-number">03</div>
                                    <h4 class="property-title-modern">Skyline Homes Realty</h4>
                                    <p class="property-desc-modern">Real Estate is a vast industry that deals with the buying, selling and renting of properties.</p>
                                </div>
                            </div>
                        </div>
