@model RealEstate.Models.HomeIndexViewModel
@using RealEstate.Models
@using System.Linq
@{
    ViewData["Title"] = "EstateFlow - Find Your Dream Home";
    ViewData["IsHomeLanding"] = true;
    var ph = Currency.PhilippinePeso;
    var featuredSource = Model?.FeaturedProperties?.Any() == true
        ? Model.FeaturedProperties
        : (Model?.SearchResults ?? Enumerable.Empty<Property>());
    var areaChips = Model?.TrendingAreas?.Take(6) ?? Enumerable.Empty<string>();
    var allProperties = featuredSource.Take(9).ToList();
}

<div class="realestate-landing">
    <partial name="_LandingNavbar" />

    <main>
        <section id="top" class="hero-section">
            <div class="hero-overlay"></div>
            <div class="container position-relative z-1 py-5 py-lg-6">
                <div class="row align-items-center gy-5">
                    <div class="col-lg-7 text-white">
                        <div class="hero-pill mb-3">#1 Real estate marketplace</div>
                        <h1 class="hero-title mb-3">Find your ideal home and start your best deal with our expertise</h1>
                        <p class="hero-subtitle mb-4">Discover a seamless property journey with trusted guidance, curated listings, and a simple search experience tailored for modern homebuyers.</p>

                        <div class="hero-stats d-flex flex-wrap gap-4 mb-4">
                            <div>
                                <div class="stat-value">350k+</div>
                                <div class="stat-label">Properties listed</div>
                            </div>
                            <div>
                                <div class="stat-value">120k+</div>
                                <div class="stat-label">Happy customers</div>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-3">
                            <a class="btn btn-dark rounded-pill px-4 py-3" asp-controller="Home" asp-action="Contact">Contact Us</a>
                            <a class="btn btn-outline-light rounded-pill px-4 py-3" asp-controller="Properties" asp-action="Index">Browse Properties</a>
                        </div>
                    </div>

                    <div class="col-lg-5 d-none d-lg-block">
                        <div class="hero-side-card shadow-lg">
                            <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1200&q=80" alt="Modern home" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="container position-relative z-2 pb-5 pb-lg-6">
                <div class="search-shell shadow-lg">
                    <div class="search-tabs">
                        <button type="button" class="active">Buy</button>
                        <button type="button">Sell</button>
                        <button type="button">Rent</button>
                    </div>

                    <form class="search-form" method="get" asp-controller="Properties" asp-action="Index">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label small text-uppercase fw-semibold text-secondary mb-1" for="searchLocation">Location</label>
                                <input type="text" id="searchLocation" name="location" class="form-control form-control-lg border-0 bg-light" placeholder="e.g. Makati, BGC, Cebu" value="@Model?.SearchLocation" autocomplete="off" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small text-uppercase fw-semibold text-secondary mb-1" for="searchType">Type</label>
                                <input type="text" id="searchType" name="propertyType" class="form-control form-control-lg border-0 bg-light" placeholder="House, condo, lot" />
                            </div>
                            <div class="col-md-4 col-lg-3">
                                <label class="form-label small text-uppercase fw-semibold text-secondary mb-1" for="searchMaxPrice">Price</label>
                                <input type="number" id="searchMaxPrice" name="maxPrice" class="form-control form-control-lg border-0 bg-light" min="0" step="1000" inputmode="numeric" placeholder="₱ 1,200,000" value="@(Model?.SearchMaxPrice?.ToString())" />
                            </div>
                            <div class="col-md-12 col-lg-1 d-grid">
                                <button type="submit" class="btn btn-dark rounded-pill search-btn">Search Properties</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </section>

        <section class="intro-section bg-white">
            <div class="container text-center py-5 py-lg-6">
                <div class="section-kicker mb-3">About Real Nest</div>
                <p class="intro-copy mx-auto mb-0">We are committed to delivering an effortless and enjoyable real estate journey for all our clients. Our platform combines a sleek, minimalistic design with cutting-edge functionality, making the property search process seamless and stress-free.</p>
            </div>
        </section>

        <section class="properties-section bg-white" id="properties">
            <div class="container py-5 py-lg-6">
                <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4 mb-lg-5">
                    <div>
                        <div class="section-kicker mb-2">Featured listings</div>
                        <h2 class="section-title mb-0">Explore our latest property</h2>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="chip active">All Type</span>
                        <span class="chip">Industrial House</span>
                        <span class="chip">Apartment</span>
                        <span class="chip">Villa</span>
                        <span class="chip">Duplex</span>
                        <span class="chip">Warehouse</span>
                        <span class="chip">Resort</span>
                    </div>
                </div>

                <div class="row g-4">
                    @if (featuredSource.Any())
                    {
                        foreach (var property in featuredSource.Take(6))
                        {
                            var imageUrl = property.ImageUrls.FirstOrDefault() ?? "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1200&q=80";
                            <div class="col-sm-6 col-lg-4">
                                <article class="property-card h-100 shadow-sm">
                                    <a asp-controller="Properties" asp-action="Details" asp-route-id="@property.Id" class="text-decoration-none text-reset">
                                        <div class="property-image ratio ratio-4x3">
                                            <img src="@imageUrl" alt="@property.Title" class="object-fit-cover w-100 h-100" />
                                        </div>
                                        <div class="property-body p-3 p-lg-4">
                                            <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                                <div>
                                                    <div class="property-price mb-1">@(property.ListingType == PropertyListingType.Buy ? property.Price.ToString("C0", ph) : property.Price.ToString("C0", ph) + "/mo")</div>
                                                    <h3 class="property-title mb-0">@property.Title</h3>
                                                </div>
                                                <span class="property-badge">View Detail</span>
                                            </div>
                                            <p class="property-location mb-3">@property.Location</p>
                                            <div class="property-meta d-flex flex-wrap gap-3 small text-muted">
                                                <span>@property.Bedrooms bd</span>
                                                <span>@property.Bathrooms ba</span>
                                                <span>@property.ParkingSlots pk</span>
                                                <span>@property.Sqft sqm</span>
                                            </div>
                                        </div>
                                    </a>
                                </article>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-sm-6 col-lg-4">
                            <article class="property-card h-100 shadow-sm">
                                <div class="property-image ratio ratio-4x3">
                                    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1200&q=80" alt="Rosewood Manor" class="object-fit-cover w-100 h-100" />
                                </div>
                                <div class="property-body p-3 p-lg-4">
                                    <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                        <div>
                                            <div class="property-price mb-1">₱2,400,000</div>
                                            <h3 class="property-title mb-0">Rosewood Manor</h3>
                                        </div>
                                        <span class="property-badge">View Detail</span>
                                    </div>
                                    <p class="property-location mb-3">BGC, Taguig</p>
                                    <div class="property-meta d-flex flex-wrap gap-3 small text-muted">
                                        <span>4 bd</span>
                                        <span>3 ba</span>
                                        <span>2 pk</span>
                                        <span>180 sqm</span>
                                    </div>
                                </div>
                            </article>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <article class="property-card h-100 shadow-sm">
                                <div class="property-image ratio ratio-4x3">
                                    <img src="https://images.unsplash.com/photo-1570129477492-45c003edd2be?auto=format&fit=crop&w=1200&q=80" alt="Seabreeze Villa" class="object-fit-cover w-100 h-100" />
                                </div>
                                <div class="property-body p-3 p-lg-4">
                                    <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                        <div>
                                            <div class="property-price mb-1">₱1,500,000</div>
                                            <h3 class="property-title mb-0">Seabreeze Villa</h3>
                                        </div>
                                        <span class="property-badge">View Detail</span>
                                    </div>
                                    <p class="property-location mb-3">Cebu City, Cebu</p>
                                    <div class="property-meta d-flex flex-wrap gap-3 small text-muted">
                                        <span>3 bd</span>
                                        <span>2 ba</span>
                                        <span>1 pk</span>
                                        <span>140 sqm</span>
                                    </div>
                                </div>
                            </article>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <article class="property-card h-100 shadow-sm">
                                <div class="property-image ratio ratio-4x3">
                                    <img src="https://images.unsplash.com/photo-1568605117036-5fe5e7bab0b7?auto=format&fit=crop&w=1200&q=80" alt="Willow Cottage" class="object-fit-cover w-100 h-100" />
                                </div>
                                <div class="property-body p-3 p-lg-4">
                                    <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                        <div>
                                            <div class="property-price mb-1">₱1,600,000</div>
                                            <h3 class="property-title mb-0">Willow Cottage</h3>
                                        </div>
                                        <span class="property-badge">View Detail</span>
                                    </div>
                                    <p class="property-location mb-3">Davao City, Davao</p>
                                    <div class="property-meta d-flex flex-wrap gap-3 small text-muted">
                                        <span>2 bd</span>
                                        <span>2 ba</span>
                                        <span>1 pk</span>
                                        <span>120 sqm</span>
                                    </div>
                                </div>
                            </article>
                        </div>
                    }
                </div>
            </div>
        </section>

        <section class="contact-section bg-light" id="contact">
            <div class="container py-5 py-lg-6">
                <div class="row g-4 align-items-center">
                    <div class="col-lg-5">
                        <div class="agent-feature-card shadow-lg">
                            <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=1200&q=80" alt="Our agent" />
                            <div class="agent-feature-overlay">
                                <div class="agent-tag">Our Agent</div>
                                <h3>Tailored property solutions for business growth</h3>
                                <p>Our expert real estate agents are here to guide you every step of the way.</p>
                                <a class="btn btn-dark rounded-pill px-4" asp-controller="Home" asp-action="Contact">Contact Us</a>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-7">
                        <div class="d-flex flex-column flex-md-row align-items-md-end justify-content-between gap-3 mb-4">
                            <div>
                                <div class="section-kicker mb-2">Contact with our top agents</div>
                                <h2 class="section-title mb-0">Speak with trusted real estate professionals</h2>
                            </div>
                            <a class="btn btn-outline-dark rounded-pill px-4" asp-controller="Home" asp-action="Contact">Send a message</a>
                        </div>

                        <div class="row g-3">
                            <div class="col-sm-6 col-xl-3">
                                <div class="agent-card shadow-sm">
                                    <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=600&q=80" alt="Jacob" />
                                    <div class="p-3">
                                        <div class="fw-semibold">Jacob</div>
                                        <div class="text-muted small">Agent</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6 col-xl-3">
                                <div class="agent-card shadow-sm">
                                    <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?auto=format&fit=crop&w=600&q=80" alt="Kristin" />
                                    <div class="p-3">
                                        <div class="fw-semibold">Kristin</div>
                                        <div class="text-muted small">Agent</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6 col-xl-3">
                                <div class="agent-card shadow-sm">
                                    <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=600&q=80" alt="Robert" />
                                    <div class="p-3">
                                        <div class="fw-semibold">Robert</div>
                                        <div class="text-muted small">Agent</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6 col-xl-3">
                                <div class="agent-card shadow-sm">
                                    <img src="https://images.unsplash.com/photo-1544723795-3fb6469f5b39?auto=format&fit=crop&w=600&q=80" alt="Mia" />
                                    <div class="p-3">
                                        <div class="fw-semibold">Mia</div>
                                        <div class="text-muted small">Agent</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="journey-section bg-white">
            <div class="container py-5 py-lg-6 text-center">
                <h2 class="section-title mb-3">Peace of mind at every step of your journey home</h2>
                <p class="text-muted mx-auto mb-5 landing-max-w">Simple, transparent guidance from discovery to closing, so every step feels clear and stress-free.</p>

                <div class="row g-4 justify-content-center">
                    <div class="col-6 col-md-3">
                        <div class="journey-step">
                            <div class="step-circle active">1</div>
                            <div class="step-label">Discover Houses</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="journey-step">
                            <div class="step-circle">2</div>
                            <div class="step-label">Schedule to visit</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="journey-step">
                            <div class="step-circle">3</div>
                            <div class="step-label">Hassle free purchase</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="journey-step">
                            <div class="step-circle">4</div>
                            <div class="step-label">Buy back guarantee</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="trust-section bg-light">
            <div class="container py-5 py-lg-6">
                <div class="trust-card shadow-lg overflow-hidden">
                    <div class="row g-0 align-items-stretch">
                        <div class="col-lg-5">
                            <div class="p-4 p-lg-5 h-100 bg-white">
                                <div class="section-kicker mb-3">100% Trusted</div>
                                <h2 class="section-title mb-3">We are committed to delivering enjoyable real estate journey</h2>
                                <p class="text-muted mb-4">Discover a range of residential homes and investment-ready properties with flexible options designed to fit your goals.</p>
                                <a class="btn btn-dark rounded-pill px-4" asp-controller="Properties" asp-action="Index">Explore all property</a>
                            </div>
                        </div>
                        <div class="col-lg-7">
                            <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=1600&q=80" alt="Modern property" class="w-100 h-100 object-fit-cover trust-image" />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="testimonials-section bg-white">
            <div class="container py-5 py-lg-6">
                <div class="text-center mb-5">
                    <div class="section-kicker mb-3">Testimonials</div>
                    <h2 class="section-title mb-0">What client say about us</h2>
                </div>

                <div class="row g-4 align-items-stretch">
                    <div class="col-lg-3">
                        <div class="testimonial-card h-100 shadow-sm">
                            <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=600&q=80" alt="Client" />
                            <div class="p-4">
                                <p class="mb-3">I was blown away by the level of service. They listened to my needs and answered all my questions.</p>
                                <div class="fw-semibold">Alex Stone</div>
                                <div class="text-muted small">Home buyer</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="testimonial-card testimonial-card-large h-100 shadow-sm">
                            <div class="row g-0 h-100">
                                <div class="col-md-5">
                                    <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?auto=format&fit=crop&w=900&q=80" alt="Happy client" class="w-100 h-100 object-fit-cover" />
                                </div>
                                <div class="col-md-7 d-flex align-items-center">
                                    <div class="p-4 p-lg-5">
                                        <p class="quote-mark mb-3">“</p>
                                        <p class="mb-4">I was blown away by the level of service. They listened to my needs, answered all my questions, and made the entire process feel smooth and clear.</p>
                                        <div class="fw-semibold">Jayson Cruz</div>
                                        <div class="text-muted small">Property investor</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3">
                        <div class="testimonial-card h-100 shadow-sm">
                            <img src="https://images.unsplash.com/photo-1544723795-3fb6469f5b39?auto=format&fit=crop&w=600&q=80" alt="Client" />
                            <div class="p-4">
                                <p class="mb-3">Fast response, great guidance, and an easy experience from first inquiry to viewing.</p>
                                <div class="fw-semibold">Mica Reyes</div>
                                <div class="text-muted small">Seller</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <footer class="landing-footer bg-light">
            <div class="container py-5 py-lg-6">
                <div class="row g-4 align-items-start">
                    <div class="col-lg-4">
                        <h4 class="mb-3">Subscribe to our Newsletter</h4>
                        <p class="text-muted mb-4">To begin the property buying process, simply contact one of our real estate agents.</p>
                        <form class="d-flex gap-2" asp-controller="Subscriptions" asp-action="Index" method="get">
                            <input type="email" class="form-control rounded-pill" placeholder="Email address" />
                            <button type="submit" class="btn btn-dark rounded-pill px-4">Get Started</button>
                        </form>
                    </div>
                    <div class="col-6 col-lg-2">
                        <h6 class="mb-3">Company</h6>
                        <div class="footer-links d-flex flex-column gap-2">
                            <a asp-controller="Home" asp-action="Index">Home</a>
                            <a asp-controller="Properties" asp-action="Index">Properties</a>
                            <a asp-controller="Home" asp-action="Contact">Contact</a>
                        </div>
                    </div>
                    <div class="col-6 col-lg-2">
                        <h6 class="mb-3">Important Link</h6>
                        <div class="footer-links d-flex flex-column gap-2">
                            <a asp-controller="Properties" asp-action="Index" asp-route-listingType="Sell">Sell Property</a>
                            <a asp-controller="Properties" asp-action="Index" asp-route-listingType="Rent">Rent</a>
                            <a asp-controller="Properties" asp-action="Index">Buy Property</a>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <h6 class="mb-3">Social Media</h6>
                        <div class="footer-links d-flex flex-column gap-2">
                            <a href="#">Instagram</a>
                            <a href="#">Twitter</a>
                            <a href="#">LinkedIn</a>
                        </div>
                    </div>
                </div>
            </div>
        </footer>
    </main>
</div>

<style>
    .realestate-landing {
        background: #f3f4f6;
    }

    .hero-section {
        position: relative;
        overflow: hidden;
        background: linear-gradient(180deg, rgba(33, 89, 139, 0.95), rgba(52, 115, 163, 0.9));
        padding-top: 6.5rem;
    }

    .hero-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background: url('https://images.unsplash.com/photo-1560185007-cde436f6a4d0?auto=format&fit=crop&w=2000&q=80') center/cover no-repeat;
        opacity: 0.42;
        transform: scale(1.02);
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(20,45,75,0.25), rgba(20,45,75,0.52));
        z-index: 1;
    }

    .hero-pill {
        display: inline-flex;
        align-items: center;
        border: 1px solid rgba(255,255,255,.4);
        border-radius: 999px;
        padding: 6px 14px;
        font-size: 12px;
        backdrop-filter: blur(10px);
        background: rgba(255,255,255,.08);
    }

    .hero-title {
        font-size: clamp(2.5rem, 5vw, 4.2rem);
        line-height: 1.02;
        max-width: 12ch;
        letter-spacing: -0.04em;
    }

    .hero-subtitle {
        max-width: 560px;
        color: rgba(255,255,255,.88);
        font-size: 1.05rem;
    }

    .hero-stats .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1;
    }

    .hero-stats .stat-label {
        color: rgba(255,255,255,.78);
        font-size: .9rem;
    }

    .hero-side-card {
        border-radius: 28px;
        overflow: hidden;
        min-height: 440px;
        border: 1px solid rgba(255,255,255,.2);
        background: rgba(255,255,255,.08);
        backdrop-filter: blur(10px);
    }

    .hero-side-card img {
        width: 100%;
        height: 100%;
        min-height: 440px;
        object-fit: cover;
        display: block;
    }

    .search-shell {
        margin-top: 2rem;
        background: rgba(255,255,255,.96);
        border-radius: 26px;
        padding: 0;
        overflow: hidden;
    }

    .search-tabs {
        display: flex;
        gap: 0;
        padding-left: 1rem;
        border-bottom: 1px solid #eef2f7;
        background: #fff;
    }

    .search-tabs button {
        border: 0;
        background: transparent;
        padding: 1rem 1.25rem;
        color: #64748b;
        font-weight: 600;
    }

    .search-tabs button.active {
        color: #0f172a;
        position: relative;
    }

    .search-tabs button.active::after {
        content: '';
        position: absolute;
        left: 1rem;
        right: 1rem;
        bottom: 0;
        height: 3px;
        border-radius: 999px;
        background: #0f172a;
    }

    .search-form {
        padding: 1.25rem;
    }

    .search-btn {
        min-height: 54px;
    }

    .section-kicker {
        display: inline-block;
        padding: .4rem .9rem;
        border-radius: 999px;
        background: #eef4fb;
        color: #6b7280;
        font-size: .85rem;
        font-weight: 600;
    }

    .intro-copy {
        max-width: 920px;
