@model RealEstate.Models.HomeIndexViewModel
@using RealEstate.Models
@using System.Linq
@{
    ViewData["Title"] = "EstateFlow - Find Your Dream Home";
    ViewData["IsHomeLanding"] = true;
    var ph = Currency.PhilippinePeso;
    var featuredSource = Model?.FeaturedProperties?.Any() == true
        ? Model.FeaturedProperties
        : (Model?.SearchResults ?? Enumerable.Empty<Property>());
    var areaChips = Model?.TrendingAreas?.Take(6) ?? Enumerable.Empty<string>();
}

<div class="realestate-landing-modern">
    <partial name="_LandingNavbar" />

    <main>
        <!-- HERO SECTION - MODERN CITYSCAPE STYLE -->
        <section class="hero-section-modern">
            <div class="container-fluid px-0">
                <div class="row g-0 align-items-center min-vh-100">
                    <div class="col-lg-6 hero-content-wrapper">
                        <div class="hero-content">
                            <span class="hero-label">LUXURY REAL ESTATE</span>
                            <h1 class="hero-title-modern">Beyond Walls We Build Dreams</h1>
                            <p class="hero-subtitle">Unlock the power of real estate making your real estate dreams a reality. Discover premium properties tailored to your lifestyle.</p>
                            <a href="#properties" class="btn-primary-modern">EXPLORE PROPERTIES</a>
                        </div>
                    </div>
                    <div class="col-lg-6 hero-image-wrapper">
                        <div class="hero-image-container">
                            <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=800&q=80" alt="Modern Building" class="hero-image">
                            <div class="hero-shape-overlay"></div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- STATISTICS SECTION -->
        <section class="stats-section-modern">
            <div class="container">
                <div class="row g-4 text-center">
                    <div class="col-md-3 col-sm-6">
                        <div class="stat-item-modern">
                            <div class="stat-number-modern">25K+</div>
                            <div class="stat-label-modern">Happy Clients</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="stat-item-modern">
                            <div class="stat-number-modern">45K+</div>
                            <div class="stat-label-modern">Properties</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="stat-item-modern">
                            <div class="stat-number-modern">50+</div>
                            <div class="stat-label-modern">Cities</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="stat-item-modern">
                            <div class="stat-number-modern">800+</div>
                            <div class="stat-label-modern">Expert Agents</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- FEATURED PROPERTIES SECTION -->
