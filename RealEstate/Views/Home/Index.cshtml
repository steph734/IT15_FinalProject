                <div class="row align-items-center g-5">
                    <div class="col-lg-5">
                        <div class="image-collage-modern">
                            <div class="collage-item large">
                                <img src="https://images.unsplash.com/photo-1486325212027-8081e485255e?auto=format&fit=crop&w=500&q=80" alt="Modern Building" class="w-100 h-100 object-fit-cover rounded-lg">
                            </div>
                            <div class="collage-item small rounded">
                                <img src="https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?auto=format&fit=crop&w=300&q=80" alt="Property Interior" class="w-100 h-100 object-fit-cover rounded-circle">
                            </div>
                            <div class="collage-item small">
                                <img src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=300&q=80" alt="Keys" class="w-100 h-100 object-fit-cover rounded-lg">
                            </div>
                            <div class="stat-badge-modern">
                                <div class="stat-number-badge">25K+</div>
                                <div class="stat-text-badge">Services We Provide</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-7">
                        <span class="section-label-modern">ABOUT US</span>
                        <h2 class="about-title-modern">Unlocking the door to your the new home</h2>
                        
                        <div class="about-points">
                            <div class="point-item">
                                <i class="fas fa-check"></i>
                                <span>Prestige Property Management Your Dream Home Awaits</span>
                            </div>
                            <div class="point-item">
                                <i class="fas fa-check"></i>
                                <span>Real Estate is a vast industry that deals with the buying, selling</span>
                            </div>
                        </div>

                        <p class="about-description">Real Estate is a vast industry that deals with the buying, selling, and renting of properties. It involves transactions related to residential, commercial, and industrial properties.</p>

                        <a href="#" class="read-more-link">READ MORE <i class="fas fa-arrow-right"></i></a>
                    </div>
                </div>
            </div>
        </section>

        <!-- PROPERTY GALLERY SECTION -->
