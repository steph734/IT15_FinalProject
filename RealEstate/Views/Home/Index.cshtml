                                    <img src="https://images.unsplash.com/photo-1544723795-3fb6469f5b39?auto=format&fit=crop&w=100&q=80" alt="Client">
                                </div>
                                <div>
                                    <div class="author-name">Michael Chen</div>
                                    <div class="author-title">Homeowner</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA SECTION -->
        <section class="cta-section-modern">
            <div class="container text-center">
                <h2 class="cta-title">Ready to Find Your Dream Home?</h2>
                <p class="cta-subtitle">Contact our expert agents today and start your real estate journey</p>
                <a href="#" class="btn-primary-modern btn-lg">GET IN TOUCH</a>
            </div>
        </section>

        <!-- FOOTER -->
        <footer class="footer-modern">
            <div class="container">
                <div class="row g-4 py-5 mb-5">
                    <div class="col-lg-3 col-md-6">
                        <h5 class="footer-title">About EstateFlow</h5>
                        <p class="footer-text">Premium real estate solutions for your property needs. Expert agents, verified listings, and seamless transactions.</p>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <h5 class="footer-title">Quick Links</h5>
                        <ul class="footer-links">
                            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                            <li><a asp-controller="Properties" asp-action="Index">Properties</a></li>
                            <li><a asp-controller="Agents" asp-action="Index">Our Agents</a></li>
                            <li><a asp-controller="Home" asp-action="Contact">Contact Us</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <h5 class="footer-title">Property Types</h5>
                        <ul class="footer-links">
                            <li><a asp-controller="Properties" asp-action="Index">Apartments</a></li>
                            <li><a asp-controller="Properties" asp-action="Index">Houses</a></li>
                            <li><a asp-controller="Properties" asp-action="Index">Condos</a></li>
                            <li><a asp-controller="Properties" asp-action="Index">Commercial</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <h5 class="footer-title">Newsletter</h5>
                        <p class="footer-text">Subscribe to get latest updates on new properties</p>
                        <form class="newsletter-form">
                            <input type="email" placeholder="Your email" class="form-control form-control-sm mb-2">
                            <button type="submit" class="btn-primary-small w-100">Subscribe</button>
                        </form>
                    </div>
                </div>
                <hr>
                <div class="footer-bottom text-center py-3">
                    <p>&copy; 2024 EstateFlow. All rights reserved. | <a href="#">Privacy Policy</a> | <a href="#">Terms of Service</a></p>
                </div>
            </div>
        </footer>
