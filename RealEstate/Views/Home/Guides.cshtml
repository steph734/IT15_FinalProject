@{
    ViewData["Title"] = "Real Estate Guides - EstateFlow";
}

<div class="estateflow-page-wrapper">
    <!-- Page Header -->
    <section class="page-header-modern">
        <div class="container">
            <div class="page-header-content">
                <span class="page-label">KNOWLEDGE BASE</span>
                <h1 class="page-title">Guides & Tips</h1>
                <p class="page-subtitle">Expert advice and helpful guides for real estate buyers and renters</p>
            </div>
        </div>
    </section>

    <!-- Guides Content -->
    <section class="guides-section">
        <div class="container">
            <!-- Search & Filter -->
            <div class="guides-header">
                <div class="search-box">
                    <input type="text" placeholder="Search guides...">
                    <i class="fas fa-search"></i>
                </div>
                <div class="category-filter">
                    <button class="filter-btn active">All</button>
                    <button class="filter-btn">Buying</button>
                    <button class="filter-btn">Renting</button>
                    <button class="filter-btn">Investing</button>
                    <button class="filter-btn">Tips & Tricks</button>
                </div>
            </div>

            <!-- Featured Guide -->
            <div class="featured-guide">
                <div class="featured-image">
                    <img src="https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?auto=format&fit=crop&w=800&q=80" alt="Featured Guide">
                    <div class="featured-label">Featured</div>
                </div>
                <div class="featured-content">
                    <span class="guide-category">Buying Guide</span>
                    <h2 class="featured-title">Complete Guide to Buying Your First Home</h2>
                    <p class="featured-excerpt">Learn the essential steps, from pre-approval to closing the deal. Our comprehensive guide covers everything you need to know about purchasing your first property.</p>
                    <div class="featured-meta">
                        <span><i class="fas fa-user"></i> By Jane Smith</span>
                        <span><i class="fas fa-calendar"></i> March 15, 2024</span>
                        <span><i class="fas fa-clock"></i> 8 min read</span>
                    </div>
                    <a href="#" class="btn-read-guide">
                        <i class="fas fa-arrow-right"></i> Read Full Guide
                    </a>
                </div>
            </div>

            <!-- Guides Grid -->
            <div class="guides-grid">
                <!-- Guide Card 1 -->
                <div class="guide-card">
                    <div class="guide-image">
                        <img src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=400&q=80" alt="Guide">
                        <span class="guide-category-badge">Investing</span>
                    </div>
                    <div class="guide-content">
                        <h3 class="guide-title">Real Estate Investment Strategies</h3>
                        <p class="guide-description">Discover proven strategies to build wealth through real estate investment and maximize your returns.</p>
                        <div class="guide-meta">
                            <span><i class="fas fa-calendar"></i> Mar 12, 2024</span>
                            <span><i class="fas fa-clock"></i> 6 min</span>
                        </div>
                        <a href="#" class="guide-link">
                            Read More <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Guide Card 2 -->
                <div class="guide-card">
                    <div class="guide-image">
                        <img src="https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?auto=format&fit=crop&w=400&q=80" alt="Guide">
                        <span class="guide-category-badge renting">Renting</span>
                    </div>
                    <div class="guide-content">
                        <h3 class="guide-title">What to Look for in a Rental Property</h3>
                        <p class="guide-description">Essential checklist and tips for finding the perfect rental that fits your lifestyle and budget.</p>
                        <div class="guide-meta">
                            <span><i class="fas fa-calendar"></i> Mar 10, 2024</span>
                            <span><i class="fas fa-clock"></i> 5 min</span>
                        </div>
                        <a href="#" class="guide-link">
                            Read More <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Guide Card 3 -->
                <div class="guide-card">
                    <div class="guide-image">
                        <img src="https://images.unsplash.com/photo-1552784289-3bdcf9e2b03f?auto=format&fit=crop&w=400&q=80" alt="Guide">
                        <span class="guide-category-badge tips">Tips</span>
                    </div>
                    <div class="guide-content">
                        <h3 class="guide-title">Home Inspection Checklist</h3>
                        <p class="guide-description">A detailed checklist to guide you through a home inspection and identify potential issues.</p>
                        <div class="guide-meta">
                            <span><i class="fas fa-calendar"></i> Mar 08, 2024</span>
                            <span><i class="fas fa-clock"></i> 4 min</span>
                        </div>
                        <a href="#" class="guide-link">
                            Read More <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Guide Card 4 -->
                <div class="guide-card">
                    <div class="guide-image">
                        <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=400&q=80" alt="Guide">
                        <span class="guide-category-badge buying">Buying</span>
                    </div>
                    <div class="guide-content">
                        <h3 class="guide-title">Understanding Mortgage Options</h3>
                        <p class="guide-description">Compare different mortgage types and find the one that works best for your financial situation.</p>
                        <div class="guide-meta">
                            <span><i class="fas fa-calendar"></i> Mar 05, 2024</span>
                            <span><i class="fas fa-clock"></i> 7 min</span>
                        </div>
                        <a href="#" class="guide-link">
                            Read More <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Guide Card 5 -->
                <div class="guide-card">
                    <div class="guide-image">
                        <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?auto=format&fit=crop&w=400&q=80" alt="Guide">
                        <span class="guide-category-badge tips">Tips</span>
                    </div>
                    <div class="guide-content">
                        <h3 class="guide-title">Negotiating the Best Price</h3>
                        <p class="guide-description">Expert negotiation techniques to help you get the best deal on your dream property.</p>
                        <div class="guide-meta">
                            <span><i class="fas fa-calendar"></i> Mar 01, 2024</span>
                            <span><i class="fas fa-clock"></i> 6 min</span>
                        </div>
                        <a href="#" class="guide-link">
                            Read More <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Guide Card 6 -->
                <div class="guide-card">
                    <div class="guide-image">
                        <img src="https://images.unsplash.com/photo-1552884642-540cda3c514d?auto=format&fit=crop&w=400&q=80" alt="Guide">
                        <span class="guide-category-badge investing">Investing</span>
                    </div>
                    <div class="guide-content">
                        <h3 class="guide-title">Building Your Real Estate Portfolio</h3>
                        <p class="guide-description">Step-by-step guide to diversifying your investments across different property types.</p>
                        <div class="guide-meta">
                            <span><i class="fas fa-calendar"></i> Feb 28, 2024</span>
                            <span><i class="fas fa-clock"></i> 9 min</span>
                        </div>
                        <a href="#" class="guide-link">
                            Read More <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Pagination -->
            <div class="pagination-wrapper mt-5">
                <nav aria-label="Guides pagination">
                    <ul class="pagination">
                        <li class="page-item disabled">
                            <a class="page-link" href="#">Previous</a>
                        </li>
                        <li class="page-item active">
                            <a class="page-link" href="#">1</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="#">2</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="#">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-6">
                    <h2 class="section-heading">Frequently Asked Questions</h2>
                    <div class="faq-list">
                        <div class="faq-item">
                            <button class="faq-question">
                                <span>What documents do I need to buy a property?</span>
                                <i class="fas fa-chevron-down"></i>
                            </button>
                            <div class="faq-answer">
                                <p>You'll typically need pre-approval letter, identification, proof of income, bank statements, employment verification, and credit report.</p>
                            </div>
                        </div>
                        <div class="faq-item">
                            <button class="faq-question">
                                <span>How long does the buying process take?</span>
                                <i class="fas fa-chevron-down"></i>
                            </button>
                            <div class="faq-answer">
                                <p>On average, the process takes 30-45 days from offer to closing, but it can vary depending on various factors.</p>
                            </div>
                        </div>
                        <div class="faq-item">
                            <button class="faq-question">
                                <span>What is the average down payment percentage?</span>
                                <i class="fas fa-chevron-down"></i>
                            </button>
                            <div class="faq-answer">
                                <p>Most lenders require 10-20% down payment, though some programs allow as low as 3-5%.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <h2 class="section-heading">Quick Tips</h2>
                    <div class="tips-list">
                        <div class="tip-item">
                            <i class="fas fa-lightbulb"></i>
                            <div class="tip-content">
                                <strong>Improve Your Credit Score</strong>
                                <p>A higher credit score can get you better mortgage rates and save thousands.</p>
                            </div>
                        </div>
                        <div class="tip-item">
                            <i class="fas fa-lightbulb"></i>
                            <div class="tip-content">
                                <strong>Get Pre-Approved First</strong>
                                <p>Pre-approval strengthens your offer and shows sellers you're serious.</p>
                            </div>
                        </div>
                        <div class="tip-item">
                            <i class="fas fa-lightbulb"></i>
                            <div class="tip-content">
                                <strong>Consider Neighborhood Trends</strong>
                                <p>Research area growth, amenities, and future development plans.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Newsletter CTA -->
    <section class="newsletter-cta">
        <div class="container">
            <div class="cta-content">
                <h2>Get Expert Real Estate Tips</h2>
                <p>Subscribe to our newsletter for weekly guides and market insights</p>
                <form class="newsletter-form">
                    <input type="email" placeholder="Your email address" required>
                    <button type="submit" class="btn-subscribe">Subscribe</button>
                </form>
            </div>
        </div>
    </section>
</div>

<style>
    .guides-section {
        padding: 60px 0;
    }

    /* Header -->
    .guides-header {
        display: flex;
        gap: 30px;
        margin-bottom: 50px;
        flex-wrap: wrap;
        align-items: center;
    }

    .search-box {
        position: relative;
        flex: 1;
        min-width: 250px;
    }

    .search-box input {
        width: 100%;
        padding: 12px 15px 12px 40px;
        border: 1px solid #E5E7EB;
        border-radius: 8px;
        font-size: 0.9rem;
    }

    .search-box i {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #9CA3AF;
    }

    .category-filter {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .filter-btn {
        padding: 8px 16px;
        border: 1px solid #E5E7EB;
        background: white;
        border-radius: 20px;
        cursor: pointer;
        font-weight: 500;
        font-size: 0.9rem;
        transition: all 0.3s;
        color: #6B7280;
    }

    .filter-btn:hover,
    .filter-btn.active {
        background: #16A39E;
        color: white;
        border-color: #16A39E;
    }

    /* Featured Guide -->
    .featured-guide {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        align-items: center;
        margin-bottom: 60px;
        background: white;
        padding: 40px;
        border-radius: 12px;
        border: 1px solid #E5E7EB;
    }

    .featured-image {
        position: relative;
        width: 100%;
        height: 350px;
        border-radius: 8px;
        overflow: hidden;
    }

    .featured-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .featured-label {
        position: absolute;
        top: 20px;
        left: 20px;
        background: #FF9500;
        color: white;
        padding: 8px 16px;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.8rem;
    }

    .featured-content {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .guide-category {
        display: inline-block;
        background: #E0F2F1;
        color: #16A39E;
        padding: 6px 12px;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: 600;
        width: fit-content;
    }

    .featured-title {
        font-size: 2rem;
        font-weight: 800;
        color: #1E3A5F;
    }

    .featured-excerpt {
        color: #6B7280;
        line-height: 1.7;
        font-size: 1rem;
    }

    .featured-meta {
        display: flex;
        gap: 20px;
        color: #6B7280;
        font-size: 0.9rem;
    }

    .featured-meta span {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .btn-read-guide {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #16A39E;
        color: white;
        padding: 12px 28px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        width: fit-content;
        transition: all 0.3s;
    }

    .btn-read-guide:hover {
        background: #0F8B84;
        text-decoration: none;
    }

    /* Guides Grid -->
    .guides-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 25px;
    }

    .guide-card {
        background: white;
        border: 1px solid #E5E7EB;
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s;
    }

    .guide-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(22, 163, 158, 0.15);
    }

    .guide-image {
        position: relative;
        width: 100%;
        height: 200px;
        overflow: hidden;
        background: #F0F0F0;
    }

    .guide-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s;
    }

    .guide-card:hover .guide-image img {
        transform: scale(1.08);
    }

    .guide-category-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        background: #16A39E;
        color: white;
        padding: 6px 12px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .guide-category-badge.buying {
        background: #FF9500;
    }

    .guide-category-badge.renting {
        background: #F59E0B;
    }

    .guide-category-badge.tips {
        background: #3B82F6;
    }

    .guide-content {
        padding: 20px;
    }

    .guide-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: 12px;
    }

    .guide-description {
        color: #6B7280;
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 12px;
    }

    .guide-meta {
        display: flex;
        gap: 16px;
        color: #9CA3AF;
        font-size: 0.85rem;
        margin-bottom: 16px;
        padding-bottom: 16px;
        border-bottom: 1px solid #E5E7EB;
    }

    .guide-meta span {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .guide-link {
        color: #16A39E;
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: gap 0.3s;
    }

    .guide-link:hover {
        gap: 10px;
    }

    /* FAQ Section -->
    .faq-section {
        background: #F8F9FA;
        padding: 60px 0;
    }

    .section-heading {
        font-size: 1.8rem;
        font-weight: 800;
        color: #1E3A5F;
        margin-bottom: 30px;
    }

    .faq-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .faq-item {
        background: white;
        border-radius: 8px;
        border: 1px solid #E5E7EB;
    }

    .faq-question {
        width: 100%;
        padding: 20px;
        background: white;
        border: none;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
        color: #1E3A5F;
        transition: all 0.3s;
    }

    .faq-question:hover {
        background: #E0F2F1;
    }

    .faq-question i {
        transition: transform 0.3s;
    }

    .faq-item.open .faq-question i {
        transform: rotate(180deg);
    }

    .faq-answer {
        display: none;
        padding: 0 20px 20px 20px;
        color: #6B7280;
        line-height: 1.6;
    }

    .faq-item.open .faq-answer {
        display: block;
    }

    /* Tips List -->
    .tips-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .tip-item {
        display: flex;
        gap: 16px;
        padding: 20px;
        background: white;
        border-radius: 8px;
        border-left: 4px solid #FF9500;
    }

    .tip-item i {
        font-size: 1.5rem;
        color: #FF9500;
        flex-shrink: 0;
    }

    .tip-content strong {
        color: #1E3A5F;
        display: block;
        margin-bottom: 6px;
    }

    .tip-content p {
        color: #6B7280;
        font-size: 0.9rem;
    }

    /* Newsletter CTA -->
    .newsletter-cta {
        background: linear-gradient(135deg, #16A39E, #1E3A5F);
        color: white;
        padding: 60px 0;
    }

    .cta-content {
        text-align: center;
    }

    .cta-content h2 {
        font-size: 2rem;
        margin-bottom: 12px;
    }

    .cta-content p {
        font-size: 1.1rem;
        margin-bottom: 30px;
        opacity: 0.95;
    }

    .newsletter-form {
        display: flex;
        gap: 12px;
        max-width: 500px;
        margin: 0 auto;
    }

    .newsletter-form input {
        flex: 1;
        padding: 12px 16px;
        border: none;
        border-radius: 6px;
        font-size: 0.95rem;
    }

    .btn-subscribe {
        padding: 12px 28px;
        background: #FF9500;
        color: white;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-subscribe:hover {
        background: #FF8C00;
    }

    @@media (max-width: 991.98px) {
        .featured-guide {
            grid-template-columns: 1fr;
            gap: 25px;
        }

        .featured-image {
            height: 280px;
        }

        .featured-title {
            font-size: 1.5rem;
        }
    }

    @@media (max-width: 767.98px) {
        .guides-header {
            flex-direction: column;
        }

        .search-box {
            width: 100%;
        }

        .category-filter {
            justify-content: center;
        }

        .guides-grid {
            grid-template-columns: 1fr;
        }

        .newsletter-form {
            flex-direction: column;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // FAQ Accordion
        const faqQuestions = document.querySelectorAll('.faq-question');
        faqQuestions.forEach(question => {
            question.addEventListener('click', function() {
                const faqItem = this.parentElement;
                faqItem.classList.toggle('open');
            });
        });
    });
</script>
