@model RealEstate.Models.PropertyDetailsViewModel
@{
    ViewData["Title"] = "Request a Property Viewing";
    var p = Model?.Property;
}

<style>
    .request-viewing-page {
        background: #F8F9FA;
        min-height: 100vh;
        padding: 40px 0;
    }

    .viewing-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .viewing-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .viewing-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: 10px;
    }

    .viewing-header p {
        font-size: 1rem;
        color: #6B7280;
    }

    .viewing-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
    }

    .property-preview-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #E5E7EB;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .property-preview-image {
        width: 100%;
        height: 200px;
        background: #F0F0F0;
        overflow: hidden;
    }

    .property-preview-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .property-preview-details {
        padding: 20px;
    }

    .property-preview-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: 10px;
    }

    .property-preview-location {
        font-size: 0.95rem;
        color: #6B7280;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .property-preview-specs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .spec-item {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .spec-icon {
        width: 40px;
        height: 40px;
        background: #FFF3E0;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #FF9500;
        font-size: 1rem;
    }

    .spec-content {
        display: flex;
        flex-direction: column;
    }

    .spec-label {
        font-size: 0.75rem;
        color: #9CA3AF;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .spec-value {
        font-size: 0.95rem;
        font-weight: 600;
        color: #1E3A5F;
    }

    .property-preview-price {
        border-top: 1px solid #E5E7EB;
        margin-top: 15px;
        padding-top: 15px;
        font-size: 1.5rem;
        font-weight: 800;
        color: #FF9500;
    }

    .viewing-form-card {
        background: white;
        border-radius: 12px;
        padding: 30px;
        border: 1px solid #E5E7EB;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        height: fit-content;
    }

    .form-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-title i {
        color: #FF9500;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-size: 0.9rem;
        font-weight: 600;
        color: #1E3A5F;
        margin-bottom: 8px;
    }

    .form-group input,
    .form-group textarea,
    .form-group select {
        width: 100%;
        padding: 12px 14px;
        border: 1px solid #E5E7EB;
        border-radius: 6px;
        font-size: 0.95rem;
        color: #1E3A5F;
        font-family: inherit;
        transition: all 0.3s;
    }

    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
        outline: none;
        border-color: #FF9500;
        box-shadow: 0 0 0 3px rgba(255, 149, 0, 0.1);
    }

    .form-group textarea {
        resize: vertical;
        min-height: 100px;
    }

    .form-group-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .form-hint {
        font-size: 0.8rem;
        color: #9CA3AF;
        margin-top: 6px;
    }

    /* Photo Upload Styles */
    .photo-upload-container {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 20px;
    }

    .photo-preview {
        display: none;
        position: relative;
        width: 100px;
        height: 100px;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid #E5E7EB;
    }

    .photo-preview.active {
        display: flex;
    }

    .photo-preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .photo-preview-remove {
        position: absolute;
        top: 5px;
        right: 5px;
        background: rgba(220, 38, 38, 0.9);
        color: white;
        border: none;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        transition: all 0.3s;
    }

    .photo-preview-remove:hover {
        background: rgba(220, 38, 38, 1);
    }

    .file-input-wrapper {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .file-input-label {
        padding: 10px 16px;
        background: #F3F4F6;
        color: #1E3A5F;
        border: 2px dashed #E5E7EB;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
    }

    .file-input-label:hover {
        background: #E5E7EB;
        border-color: #FF9500;
    }

    .file-input-label i {
        color: #FF9500;
    }

    input[type="file"]#customerPhoto {
        display: none;
    }

    .photo-upload-hint {
        font-size: 0.8rem;
        color: #9CA3AF;
        margin-top: 6px;
    }

    .btn-submit {
        padding: 10px 24px;
        background: linear-gradient(135deg, #FF9500 0%, #FF8C00 100%);
        color: white;
        border: none;
        border-radius: 6px;
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(255, 149, 0, 0.3);
    }

    .btn-cancel {
        padding: 10px 24px;
        background: transparent;
        color: #FF9500;
        border: 2px solid #FF9500;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s;
        margin-top: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .btn-cancel:hover {
        background: #FFF3E0;
    }

    .button-group-submit {
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: flex-start;
    }

    /* Progress Bar Styles */
    .progress-bar-container {
        margin-bottom: 40px;
        background: linear-gradient(135deg, #FFF3E0 0%, rgba(255, 149, 0, 0.05) 100%);
        padding: 30px;
        border-radius: 12px;
        border: 1px solid rgba(255, 149, 0, 0.2);
    }

    .progress-bar-label {
        font-size: 0.75rem;
        font-weight: 700;
        color: #FF9500;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 15px;
        display: block;
    }

    .progress-bar-fill {
        height: 6px;
        background: #E5E7EB;
        border-radius: 3px;
        margin-bottom: 20px;
        overflow: hidden;
        position: relative;
    }

    .progress-bar-fill-inner {
        height: 100%;
        background: linear-gradient(90deg, #FF9500 0%, #FF8C00 100%);
        border-radius: 3px;
        transition: width 0.5s ease;
        width: 0%;
    }

    .progress-steps {
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
    }

    .progress-steps::before {
        content: '';
        position: absolute;
        top: 20px;
        left: 0;
        right: 0;
        height: 2px;
        background: #E5E7EB;
        z-index: 0;
    }

    .progress-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        z-index: 1;
        flex: 1;
    }

    .step-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #E5E7EB;
        border: 2px solid #E5E7EB;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: #9CA3AF;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        margin-bottom: 10px;
    }

    .step-circle.active {
        background: #FF9500;
        border-color: #FF9500;
        color: white;
        box-shadow: 0 0 0 4px rgba(255, 149, 0, 0.1);
        transform: scale(1.1);
    }

    .step-circle.completed {
        background: #10B981;
        border-color: #10B981;
        color: white;
    }

    .step-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: #6B7280;
        text-align: center;
        max-width: 100px;
        line-height: 1.3;
    }

    .step-label.active {
        color: #FF9500;
        font-weight: 700;
    }

    .step-label.completed {
        color: #10B981;
    }

    /* Form Steps */
    .form-step {
        display: none;
    }

    .form-step.active {
        display: block;
    }

    .step-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid #FFF3E0;
    }

    .step-description {
        font-size: 0.9rem;
        color: #6B7280;
        margin-bottom: 25px;
    }

    /* Review Step */
    .review-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .review-item {
        background: #F8F9FA;
        padding: 15px;
        border-radius: 8px;
        border-left: 4px solid #FF9500;
    }

    .review-label {
        font-size: 0.8rem;
        color: #9CA3AF;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 5px;
    }

    .review-value {
        font-size: 1rem;
        font-weight: 600;
        color: #1E3A5F;
    }

    /* Receipt Style */
    .receipt-container {
        background: white;
        border: 2px dashed #E5E7EB;
        border-radius: 12px;
        padding: 30px;
        max-width: 500px;
        margin: 0 auto;
    }

    .receipt-header {
        text-align: center;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid #E5E7EB;
    }

    .receipt-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: 5px;
    }

    .receipt-subtitle {
        font-size: 0.9rem;
        color: #6B7280;
    }

    .receipt-section {
        margin-bottom: 25px;
        padding-bottom: 20px;
        border-bottom: 1px solid #E5E7EB;
    }

    .receipt-section:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .receipt-section-title {
        font-size: 0.85rem;
        font-weight: 700;
        color: #FF9500;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 15px;
    }

    .receipt-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 12px;
        font-size: 0.95rem;
    }

    .receipt-row:last-child {
        margin-bottom: 0;
    }

    .receipt-label {
        color: #6B7280;
        font-weight: 500;
    }

    .receipt-value {
        color: #1E3A5F;
        font-weight: 600;
        text-align: right;
        max-width: 50%;
        word-break: break-word;
    }

    .receipt-footer {
        text-align: center;
        padding-top: 20px;
        border-top: 2px solid #E5E7EB;
        font-size: 0.85rem;
        color: #9CA3AF;
    }

    .receipt-footer-time {
        font-size: 0.8rem;
        color: #9CA3AF;
        margin-top: 10px;
    }

    /* Confirmation Step */
    .confirmation-icon {
        text-align: center;
        margin-bottom: 30px;
    }

    .confirmation-icon i {
        font-size: 4rem;
        color: #10B981;
    }

    .confirmation-message {
        text-align: center;
        margin-bottom: 30px;
    }

    .confirmation-message h2 {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: 10px;
    }

    .confirmation-message p {
        font-size: 1rem;
        color: #6B7280;
        line-height: 1.6;
    }

    .confirmation-details {
        background: #F0FDF4;
        border: 2px solid #10B981;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 30px;
    }

    .confirmation-details h3 {
        font-size: 1rem;
        font-weight: 700;
        color: #065F46;
        margin-bottom: 15px;
    }

    .confirmation-item {
        font-size: 0.95rem;
        color: #047857;
        margin-bottom: 8px;
        padding-left: 20px;
        position: relative;
    }

    .confirmation-item::before {
        content: '✓';
        position: absolute;
        left: 0;
        font-weight: bold;
    }

    /* Navigation Buttons */
    .form-navigation {
        display: flex;
        gap: 12px;
        margin-top: 30px;
        justify-content: space-between;
    }

    .btn-prev {
        padding: 10px 24px;
        background: #F3F4F6;
        color: #6B7280;
        border: 1px solid #E5E7EB;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .btn-prev:hover {
        background: #E5E7EB;
    }

    .btn-next {
        padding: 10px 24px;
        background: #FF9500;
        color: white;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .btn-next:hover {
        background: #FF8C00;
    }

    .btn-next:disabled {
        background: #D1D5DB;
        cursor: not-allowed;
    }

    .validation-error {
        color: #DC2626;
        font-size: 0.8rem;
        margin-top: 6px;
        display: none;
    }

    .no-property-message {
        background: white;
        border-radius: 12px;
        padding: 40px 20px;
        text-align: center;
        border: 1px solid #E5E7EB;
    }

    .no-property-message h2 {
        font-size: 1.5rem;
        color: #1E3A5F;
        margin-bottom: 10px;
    }

    .no-property-message p {
        color: #6B7280;
        margin-bottom: 20px;
    }

    .btn-back {
        display: inline-block;
        padding: 10px 20px;
        background: #FF9500;
        color: white;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 600;
        transition: all 0.3s;
    }

    .btn-back:hover {
        background: #FF8C00;
        text-decoration: none;
    }

    @@media (max-width: 768px) {
        .viewing-content {
            grid-template-columns: 1fr;
        }

        .viewing-header h1 {
            font-size: 1.8rem;
        }

        .property-preview-card {
            order: 2;
        }

        .viewing-form-card {
            order: 1;
        }

        .form-group-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="request-viewing-page">
    <div class="container-fluid px-4">
        <div class="viewing-container">
            <!-- Header -->
            <div class="viewing-header">
                <h1>Request a Property Viewing</h1>
                <p>Schedule a convenient time to visit this amazing property</p>
            </div>

            <!-- Main Content -->
            @if (p != null)
            {
                <div class="viewing-content">
                    <!-- Property Preview (Left) -->
                    <div class="property-preview-card">
                        <div class="property-preview-image">
                            @if (p.ImageUrls.Count > 0)
                            {
                                <img src="@p.ImageUrls[0]" alt="@p.Title" />
                            }
                        </div>
                        <div class="property-preview-details">
                            <div class="property-preview-title">@p.Title</div>
                            <div class="property-preview-location">
                                <i class="fas fa-map-marker-alt"></i>
                                @p.Location
                            </div>

                            <div class="property-preview-specs">
                                <div class="spec-item">
                                    <div class="spec-icon"><i class="fas fa-bed"></i></div>
                                    <div class="spec-content">
                                        <span class="spec-label">Bedrooms</span>
                                        <span class="spec-value">@p.Bedrooms</span>
                                    </div>
                                </div>
                                <div class="spec-item">
                                    <div class="spec-icon"><i class="fas fa-bath"></i></div>
                                    <div class="spec-content">
                                        <span class="spec-label">Bathrooms</span>
                                        <span class="spec-value">@p.Bathrooms</span>
                                    </div>
                                </div>
                                <div class="spec-item">
                                    <div class="spec-icon"><i class="fas fa-ruler-combined"></i></div>
                                    <div class="spec-content">
                                        <span class="spec-label">Size</span>
                                        <span class="spec-value">@(p.Sqft / 1000)k sqft</span>
                                    </div>
                                </div>
                                <div class="spec-item">
                                    <div class="spec-icon"><i class="fas fa-car"></i></div>
                                    <div class="spec-content">
                                        <span class="spec-label">Parking</span>
                                        <span class="spec-value">@p.ParkingSlots</span>
                                    </div>
                                </div>
                            </div>

                            <div class="property-preview-price">
                                @if (p.ListingType == PropertyListingType.Buy)
                                {
                                    <span>@p.Price.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</span>
                                }
                                else
                                {
                                    <span>@p.Price.ToString("C0", new System.Globalization.CultureInfo("en-PH"))/mo</span>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Viewing Request Form (Right) -->
                    <div class="viewing-form-card">
                        <div class="form-title">
                            <i class="fas fa-calendar-check"></i> Schedule Your Visit
                        </div>

                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div style="background: #FEE2E2; border: 1px solid #FECACA; color: #DC2626; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 0.9rem;">
                                <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                            </div>
                        }
                        @if (TempData["WarningMessage"] != null)
                        {
                            <div style="background: #FEF3C7; border: 1px solid #FDE68A; color: #D97706; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 0.9rem;">
                                <i class="fas fa-exclamation-triangle"></i> @TempData["WarningMessage"]
                            </div>
                        }

                        <!-- Progress Bar -->
                        <div class="progress-bar-container">
                            <span class="progress-bar-label">Step <span id="currentStepNum">1</span> of 4</span>
                            <div class="progress-bar-fill">
                                <div class="progress-bar-fill-inner" id="progressBarFill"></div>
                            </div>
                            <div class="progress-steps">
                                <div class="progress-step">
                                    <div class="step-circle active" id="circle1">1</div>
                                    <div class="step-label active">Personal Details</div>
                                </div>
                                <div class="progress-step">
                                    <div class="step-circle" id="circle2">2</div>
                                    <div class="step-label">Schedule & Reason</div>
                                </div>
                                <div class="progress-step">
                                    <div class="step-circle" id="circle3">3</div>
                                    <div class="step-label">Review Details</div>
                                </div>
                                <div class="progress-step">
                                    <div class="step-circle" id="circle4">4</div>
                                    <div class="step-label">Confirmation</div>
                                </div>
                            </div>
                        </div>

                        <form id="viewingForm" novalidate>
                            <input type="hidden" asp-for="Schedule.PropertyId" />

                            <!-- Step 1: Personal Details -->
                            <div class="form-step active" id="step1">
                                <div class="step-title">Personal Details</div>
                                <div class="step-description">Let us know who you are so we can contact you about your viewing.</div>

                                <!-- Full Name -->
                                <div class="form-group">
                                    <label asp-for="Schedule.Name">
                                        <i class="fas fa-user"></i> Full Name
                                    </label>
                                    <input type="text" asp-for="Schedule.Name" placeholder="John Doe" required />
                                    <span asp-validation-for="Schedule.Name" class="validation-error"></span>
                                    <div class="form-hint">We'll use this name for the viewing appointment</div>
                                </div>

                                <!-- Email & Phone Row -->
                                <div class="form-group-row">
                                    <div class="form-group">
                                        <label asp-for="Schedule.Email">
                                            <i class="fas fa-envelope"></i> Email Address
                                        </label>
                                        <input type="email" asp-for="Schedule.Email" placeholder="your@email.com" required />
                                        <span asp-validation-for="Schedule.Email" class="validation-error"></span>
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="Schedule.Phone">
                                            <i class="fas fa-phone"></i> Phone Number
                                        </label>
                                        <input type="tel" asp-for="Schedule.Phone" placeholder="+63 9XX XXX XXXX" required />
                                        <span asp-validation-for="Schedule.Phone" class="validation-error"></span>
                                    </div>
                                </div>

                                <!-- Profile Photo -->
                                <div class="form-group">
                                    <label>
                                        <i class="fas fa-image"></i> Profile Photo <span style="color: #9CA3AF; font-weight: 400;">(Optional)</span>
                                    </label>
                                    <div class="photo-upload-container">
                                        <div class="photo-preview" id="photoPreview">
                                            <img id="photoPreviewImg" src="" alt="Preview" />
                                            <button type="button" class="photo-preview-remove" onclick="removePhoto()">✕</button>
                                        </div>
                                        <div class="file-input-wrapper">
                                            <label for="customerPhoto" class="file-input-label">
                                                <i class="fas fa-cloud-upload-alt"></i> Choose Photo
                                            </label>
                                            <input type="file" id="customerPhoto" name="Schedule.CustomerPhotoUrl" accept="image/*" />
                                            <span id="photoFileName" style="font-size: 0.85rem; color: #6B7280;"></span>
                                        </div>
                                    </div>
                                    <div class="photo-upload-hint">
                                        <i class="fas fa-info-circle"></i> JPG, PNG or GIF (Max 2MB). This helps us identify you during the viewing.
                                    </div>
                                </div>
                            </div>

                            <!-- Step 2: Schedule & Reason for Viewing -->
                            <div class="form-step" id="step2">
                                <div class="step-title">Schedule & Reason for Viewing</div>
                                <div class="step-description">Tell us when you'd like to visit and help us understand your needs.</div>

                                <!-- Date & Time Row -->
                                <div class="form-group-row">
                                    <div class="form-group">
                                        <label asp-for="Schedule.PreferredDate">
                                            <i class="fas fa-calendar"></i> Preferred Date
                                        </label>
                                        <input type="date" asp-for="Schedule.PreferredDate" required />
                                        <span asp-validation-for="Schedule.PreferredDate" class="validation-error"></span>
                                        <div class="form-hint">Select a date that works best for you</div>
                                    </div>
                                    <div class="form-group">
                                        <label for="preferredTime">
                                            <i class="fas fa-clock"></i> Preferred Time
                                        </label>
                                        <select id="preferredTime" name="Schedule.PreferredTime">
                                            <option value="">Select time slot</option>
                                            <option value="09:00 AM">09:00 AM</option>
                                            <option value="10:00 AM">10:00 AM</option>
                                            <option value="11:00 AM">11:00 AM</option>
                                            <option value="01:00 PM">01:00 PM</option>
                                            <option value="02:00 PM">02:00 PM</option>
                                            <option value="03:00 PM">03:00 PM</option>
                                            <option value="04:00 PM">04:00 PM</option>
                                            <option value="05:00 PM">05:00 PM</option>
                                        </select>
                                    </div>
                                </div>

                                <!-- Number of Visitors & Buyer Type Row -->
                                <div class="form-group-row">
                                    <div class="form-group">
                                        <label for="numberOfVisitors">
                                            <i class="fas fa-users"></i> Number of Visitors
                                        </label>
                                        <select id="numberOfVisitors" name="Schedule.NumberOfVisitors">
                                            <option value="1">Just me (1 person)</option>
                                            <option value="2">2 people</option>
                                            <option value="3">3 people</option>
                                            <option value="4">4 people</option>
                                            <option value="5">5+ people</option>
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label for="buyerType">
                                            <i class="fas fa-user-tie"></i> Buyer Type
                                        </label>
                                        <select id="buyerType" name="Schedule.BuyerType">
                                            <option value="">Select buyer type</option>
                                            <option value="first-time">First-time Buyer</option>
                                            <option value="experienced">Experienced Buyer</option>
                                            <option value="investor">Investor</option>
                                            <option value="renter">Renter</option>
                                        </select>
                                    </div>
                                </div>

                                <!-- Financing Status & Information Source Row -->
                                <div class="form-group-row">
                                    <div class="form-group">
                                        <label for="financingStatus">
                                            <i class="fas fa-credit-card"></i> Financing Status
                                        </label>
                                        <select id="financingStatus" name="Schedule.FinancingStatus">
                                            <option value="">Select financing status</option>
                                            <option value="preapproved">Pre-approved</option>
                                            <option value="need-financing">Need Financing</option>
                                            <option value="cash">Paying Cash</option>
                                            <option value="undecided">Still Deciding</option>
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label for="informationSource">
                                            <i class="fas fa-search"></i> How Did You Hear About Us?
                                        </label>
                                        <select id="informationSource" name="Schedule.InformationSource">
                                            <option value="">Select source</option>
                                            <option value="website">Website</option>
                                            <option value="social-media">Social Media</option>
                                            <option value="referral">Referral</option>
                                            <option value="agent">Real Estate Agent</option>
                                            <option value="other">Other</option>
                                        </select>
                                    </div>
                                </div>

                                <!-- Notes -->
                                <div class="form-group">
                                    <label asp-for="Schedule.Notes">
                                        <i class="fas fa-sticky-note"></i> Additional Notes
                                    </label>
                                    <textarea asp-for="Schedule.Notes" placeholder="Tell us anything we should know about your visit..." rows="4"></textarea>
                                    <span asp-validation-for="Schedule.Notes" class="validation-error"></span>
                                    <div class="form-hint">Optional: Special requests, accessibility needs, etc.</div>
                                </div>
                            </div>

                            <!-- Step 3: Review Details - Receipt Style -->
                            <div class="form-step" id="step3">
                                <div class="step-title">Review Your Request</div>
                                <div class="step-description">Please verify all information before confirming your viewing request.</div>

                                <div class="receipt-container">
                                    <!-- Receipt Header -->
                                    <div class="receipt-header">
                                        <div class="receipt-title"><i class="fas fa-receipt"></i> Viewing Request</div>
                                        <div class="receipt-subtitle">Property Viewing Request Form</div>
                                    </div>

                                    <!-- Personal Information Section -->
                                    <div class="receipt-section">
                                        <div class="receipt-section-title">Personal Information</div>
                                        <div style="display: flex; gap: 15px; margin-bottom: 15px; align-items: flex-start;">
                                            <div id="receipt-photo-preview" style="display: none;">
                                                <img id="receipt-photo-img" src="" alt="Your Photo" style="width: 80px; height: 80px; border-radius: 8px; object-fit: cover; border: 2px solid #E5E7EB;" />
                                            </div>
                                            <div style="flex: 1;">
                                                <div class="receipt-row">
                                                    <span class="receipt-label">Name:</span>
                                                    <span class="receipt-value" id="receipt-name">-</span>
                                                </div>
                                                <div class="receipt-row">
                                                    <span class="receipt-label">Email:</span>
                                                    <span class="receipt-value" id="receipt-email">-</span>
                                                </div>
                                                <div class="receipt-row">
                                                    <span class="receipt-label">Phone:</span>
                                                    <span class="receipt-value" id="receipt-phone">-</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Viewing Details Section -->
                                    <div class="receipt-section">
                                        <div class="receipt-section-title">Viewing Details</div>
                                        <div class="receipt-row">
                                            <span class="receipt-label">Date:</span>
                                            <span class="receipt-value" id="receipt-date">-</span>
                                        </div>
                                        <div class="receipt-row">
                                            <span class="receipt-label">Time:</span>
                                            <span class="receipt-value" id="receipt-time">-</span>
                                        </div>
                                        <div class="receipt-row">
                                            <span class="receipt-label">Visitors:</span>
                                            <span class="receipt-value" id="receipt-visitors">-</span>
                                        </div>
                                        <div class="receipt-row">
                                            <span class="receipt-label">Buyer Type:</span>
                                            <span class="receipt-value" id="receipt-buyer">-</span>
                                        </div>
                                        <div class="receipt-row">
                                            <span class="receipt-label">Financing:</span>
                                            <span class="receipt-value" id="receipt-financing">-</span>
                                        </div>
                                        <div class="receipt-row">
                                            <span class="receipt-label">Source:</span>
                                            <span class="receipt-value" id="receipt-source">-</span>
                                        </div>
                                    </div>

                                    <!-- Special Requests Section -->
                                    <div class="receipt-section">
                                        <div class="receipt-section-title">Additional Notes</div>
                                        <div style="background: #FFF3E0; padding: 12px; border-radius: 6px; font-size: 0.9rem; color: #6B7280; min-height: 60px; white-space: pre-wrap;" id="receipt-notes">-</div>
                                    </div>

                                    <!-- Footer -->
                                    <div class="receipt-footer">
                                        <div style="font-size: 0.9rem; margin-bottom: 5px;">✓ Request Ready for Submission</div>
                                        <div class="receipt-footer-time" id="receipt-datetime"></div>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 4: Confirmation -->
                            <div class="form-step" id="step4">
                                <div class="confirmation-icon">
                                    <i class="fas fa-check-circle"></i>
                                </div>
                                <div class="confirmation-message">
                                    <h2>Request Submitted Successfully!</h2>
                                    <p>Your viewing request has been received. Our team will contact you shortly to confirm the appointment details.</p>
                                </div>
                                <div class="confirmation-details">
                                    <h3><i class="fas fa-info-circle"></i> What Happens Next?</h3>
                                    <div class="confirmation-item">We'll review your information and preferences</div>
                                    <div class="confirmation-item">You'll receive a confirmation email within 24 hours</div>
                                    <div class="confirmation-item">We may call to confirm the exact viewing time</div>
                                    <div class="confirmation-item">Our agent will meet you at the property on your scheduled date</div>
                                </div>
                            </div>

                            <!-- Navigation Buttons -->
                            <div class="form-navigation">
                                <button type="button" class="btn-prev" id="prevBtn" onclick="changeStep(-1)" style="display: none;">
                                    <i class="fas fa-arrow-left"></i> Previous
                                </button>
                                <button type="button" class="btn-next" id="nextBtn" onclick="changeStep(1)">
                                    Next <i class="fas fa-arrow-right"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="no-property-message">
                    <h2>Property Not Found</h2>
                    <p>We couldn't find the property you're trying to schedule a viewing for.</p>
                    <a href="@Url.Action("Index", "Properties")" class="btn-back">
                        <i class="fas fa-arrow-left"></i> Back to Properties
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        let currentStep = @(TempData["ViewingSuccess"] != null ? 4 : 1);
        const totalSteps = 4;

        // Photo upload handling
        document.addEventListener('DOMContentLoaded', function() {
            const photoInput = document.getElementById('customerPhoto');
            if (photoInput) {
                photoInput.addEventListener('change', function(e) {
                    handlePhotoChange(e);
                });
            }
            updateUI();
        });

        function handlePhotoChange(e) {
            const file = e.target.files[0];
            if (file) {
                // Validate file size (2MB max)
                const maxSize = 2 * 1024 * 1024; // 2MB
                if (file.size > maxSize) {
                    alert('File size must be less than 2MB');
                    document.getElementById('customerPhoto').value = '';
                    return;
                }

                // Validate file type
                const allowedTypes = ['image/jpeg', 'image/png', 'image/gif'];
                if (!allowedTypes.includes(file.type)) {
                    alert('Please select a JPG, PNG, or GIF image');
                    document.getElementById('customerPhoto').value = '';
                    return;
                }

                // Show preview
                const reader = new FileReader();
                reader.onload = function(event) {
                    const photoPreview = document.getElementById('photoPreview');
                    const photoPreviewImg = document.getElementById('photoPreviewImg');
                    photoPreviewImg.src = event.target.result;
                    photoPreview.classList.add('active');
                    document.getElementById('photoFileName').textContent = file.name;
                };
                reader.readAsDataURL(file);
            }
        }

        function removePhoto() {
            document.getElementById('customerPhoto').value = '';
            document.getElementById('photoPreview').classList.remove('active');
            document.getElementById('photoFileName').textContent = '';
        }

        function changeStep(direction) {
            if (direction === 1) {
                // Moving to next step - validate current step
                if (!validateStep(currentStep)) {
                    return;
                }

                // Update review before moving to review step
                if (currentStep === 2) {
                    updateReview();
                }
            }

            currentStep += direction;

            // Clamp between 1 and totalSteps
            if (currentStep < 1) currentStep = 1;
            if (currentStep > totalSteps) currentStep = totalSteps;

            updateUI();
        }

        function updateUI() {
            // Hide all steps
            for (let i = 1; i <= totalSteps; i++) {
                document.getElementById("step" + i).classList.remove('active');
            }

            // Show current step
            document.getElementById("step" + currentStep).classList.add('active');

            // Update progress bar fill
            const progressPercent = (currentStep / totalSteps) * 100;
            document.getElementById('progressBarFill').style.width = progressPercent + '%';
            document.getElementById('currentStepNum').textContent = currentStep;

            // Update progress circles and labels
            for (let i = 1; i <= totalSteps; i++) {
                const circle = document.getElementById("circle" + i);
                const label = document.querySelector(".progress-step:nth-child(" + i + ") .step-label");

                if (i < currentStep) {
                    circle.classList.remove('active');
                    circle.classList.add('completed');
                    label.classList.remove('active');
                    label.classList.add('completed');
                } else if (i === currentStep) {
                    circle.classList.remove('completed');
                    circle.classList.add('active');
                    label.classList.remove('completed');
                    label.classList.add('active');
                } else {
                    circle.classList.remove('active', 'completed');
                    label.classList.remove('active', 'completed');
                }
            }

            // Update button visibility
            const prevBtn = document.getElementById('prevBtn');
            const nextBtn = document.getElementById('nextBtn');

            if (currentStep === 1) {
                prevBtn.style.display = 'none';
                nextBtn.innerHTML = 'Next <i class="fas fa-arrow-right"><\/i>';
            } else if (currentStep === 4) {
                prevBtn.style.display = 'flex';
                nextBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Submit Request';
                nextBtn.onclick = submitForm;
            } else if (currentStep === totalSteps) {
                prevBtn.style.display = 'none';
                nextBtn.style.display = 'none';
            } else {
                prevBtn.style.display = 'flex';
                nextBtn.innerHTML = 'Next <i class="fas fa-arrow-right"><\/i>';
                nextBtn.onclick = () => changeStep(1);
            }
        }

        function validateStep(step) {
            const form = document.getElementById('viewingForm');

            if (step === 1) {
                // Validate personal details
                const name = form.querySelector('input[name="Schedule.Name"]').value.trim();
                const email = form.querySelector('input[name="Schedule.Email"]').value.trim();
                const phone = form.querySelector('input[name="Schedule.Phone"]').value.trim();

                if (!name || !email || !phone) {
                    alert('Please fill in all required fields in Step 1.');
                    return false;
                }

                // Email validation - check for symbol and dot
                const atSymbol = String.fromCharCode(64);
                const dotSymbol = '.';
                if (email.indexOf(atSymbol) === -1 || email.indexOf(dotSymbol) === -1) {
                    alert('Please enter a valid email address.');
                    return false;
                }

                return true;
            } else if (step === 2) {
                // Validate schedule and reason
                const date = form.querySelector('input[name="Schedule.PreferredDate"]').value;
                const buyerType = form.querySelector('select[name="Schedule.BuyerType"]').value;

                if (!date || !buyerType) {
                    alert('Please fill in the date and buyer type.');
                    return false;
                }

                return true;
            }

            return true;
        }

        function updateReview() {
            const form = document.getElementById('viewingForm');

            // Get all values
            const name = form.querySelector('input[name="Schedule.Name"]').value;
            const email = form.querySelector('input[name="Schedule.Email"]').value;
            const phone = form.querySelector('input[name="Schedule.Phone"]').value;
            const date = form.querySelector('input[name="Schedule.PreferredDate"]').value;
            const time = form.querySelector('select[name="Schedule.PreferredTime"]').value;
            const visitors = form.querySelector('select[name="Schedule.NumberOfVisitors"]').value;
            const buyerType = form.querySelector('select[name="Schedule.BuyerType"]').value;
            const financing = form.querySelector('select[name="Schedule.FinancingStatus"]').value;
            const source = form.querySelector('select[name="Schedule.InformationSource"]').value;
            const notes = form.querySelector('textarea[name="Schedule.Notes"]').value;

            // Update receipt display - Personal Information
            document.getElementById('receipt-name').textContent = name || '-';
            document.getElementById('receipt-email').textContent = email || '-';
            document.getElementById('receipt-phone').textContent = phone || '-';

            // Update photo preview in receipt
            const photoInput = document.getElementById('customerPhoto');
            if (photoInput && photoInput.files.length > 0) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('receipt-photo-img').src = e.target.result;
                    document.getElementById('receipt-photo-preview').style.display = 'flex';
                };
                reader.readAsDataURL(photoInput.files[0]);
            } else {
                document.getElementById('receipt-photo-preview').style.display = 'none';
            }

            // Update receipt display - Viewing Details
            const dateObj = new Date(date);
            const formattedDate = dateObj.toLocaleDateString('en-US', { 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
            });
            document.getElementById('receipt-date').textContent = date ? formattedDate : '-';
            document.getElementById('receipt-time').textContent = time || '-';
            document.getElementById('receipt-visitors').textContent = visitors === '1' ? 'Just me' : visitors + ' people';
            document.getElementById('receipt-buyer').textContent = buyerType || '-';
            document.getElementById('receipt-financing').textContent = financing || '-';
            document.getElementById('receipt-source').textContent = source || '-';
            document.getElementById('receipt-notes').textContent = notes || 'None';

            // Update footer with current date/time
            const now = new Date();
            const dateTime = now.toLocaleDateString('en-US', { 
                year: 'numeric', 
                month: 'short', 
                day: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
            });
            document.getElementById('receipt-datetime').textContent = 'Generated: ' + dateTime;
        }

        function submitForm() {
            const form = document.getElementById('viewingForm');

            // Create a FormData object to handle file upload
            const formData = new FormData();

            // Add all form fields
            for (let input of form.querySelectorAll('input, select, textarea')) {
                if (input.name && input.type !== 'file') {
                    formData.append(input.name, input.value);
                }
            }

            // Add photo file if selected
            const photoInput = document.getElementById('customerPhoto');
            if (photoInput && photoInput.files.length > 0) {
                formData.append('photoFile', photoInput.files[0]);
            }

            // Add anti-forgery token if exists
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                formData.append('__RequestVerificationToken', token.value);
            }

            // Create a real form for submission
            const realForm = document.createElement('form');
            realForm.method = 'post';
            realForm.action = '@Html.Raw(Url.Action("ScheduleViewing", "Properties"))';
            realForm.enctype = 'multipart/form-data';

            // Convert FormData to hidden inputs
            for (let [key, value] of formData.entries()) {
                if (key !== 'photoFile' && key !== '__RequestVerificationToken') {
                    const field = document.createElement('input');
                    field.type = 'hidden';
                    field.name = key;
                    field.value = value;
                    realForm.appendChild(field);
                }
            }

            // Add token
            if (token) {
                const tokenField = document.createElement('input');
                tokenField.type = 'hidden';
                tokenField.name = '__RequestVerificationToken';
                tokenField.value = token.value;
                realForm.appendChild(tokenField);
            }

            document.body.appendChild(realForm);
            realForm.submit();
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            updateUI();
        });
    </script>
}

