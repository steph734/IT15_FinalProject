@model RealEstate.Models.PropertiesIndexViewModel
@using RealEstate.Models
@{
    ViewData["Title"] = "Properties";
    var ph = Currency.PhilippinePeso;
    var loc = Model.Location?.Trim() ?? "";
    var maxPx = Model.MaxPrice;
}

<div class="site-page py-4 py-lg-5">
    <div class="container">
        <div class="row g-4 align-items-end mb-4">
            <div class="col-lg-8">
                <h1 class="h2 fw-bold text-site-dark mb-2">All properties</h1>
                <p class="text-site-muted mb-0">Sale and rental listings together—filter by location and price. Click a card for full details.</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a class="btn btn-site-primary text-white rounded-pill px-4" asp-controller="Home" asp-action="Index">Back to home</a>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <form method="get" asp-controller="Properties" asp-action="Index" class="row g-3 align-items-end">
                    <div class="col-md-6 col-lg-5">
                        <label class="form-label small fw-semibold text-site-muted" for="filterLocation">Location</label>
                        <input type="text" class="form-control rounded-3" id="filterLocation" name="location" value="@loc"
                               placeholder="Neighborhood, city, or keyword" autocomplete="off" />
                    </div>
                    <div class="col-md-6 col-lg-5">
                        <label class="form-label small fw-semibold text-site-muted" for="filterMaxPrice">Max price (PHP)</label>
                        <input type="number" class="form-control rounded-3" id="filterMaxPrice" name="maxPrice" min="0" step="1000"
                               inputmode="numeric" value="@(maxPx?.ToString(System.Globalization.CultureInfo.InvariantCulture))"
                               placeholder="Sale total or monthly rent cap" />
                    </div>
                    <div class="col-md-12 col-lg-2">
                        <button type="submit" class="btn btn-site-primary text-white w-100 rounded-3 py-2 fw-semibold">Apply</button>
                    </div>
                </form>
                <p class="small text-site-muted mb-0 mt-3">
                    Location matches any part of the listing address. Max price applies to sale totals or monthly rent.
                </p>
            </div>
        </div>

        @if (Model.Properties.Count == 0)
        {
            <div class="alert alert-light border rounded-4">No properties match your filters. Try broadening location or price.</div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var p in Model.Properties)
                {
                    <div class="col-sm-6 col-xl-4">
                        <article class="site-property-card h-100 bg-white rounded-4 border overflow-hidden shadow-sm">
                            <a asp-action="Details" asp-route-id="@p.Id" class="text-decoration-none text-reset d-block">
                                <div class="ratio ratio-4x3">
                                    <img src="@p.ImageUrls[0]" alt="" class="object-fit-cover w-100 h-100" />
                                </div>
                                <div class="p-3 p-lg-4">
                                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                        <h2 class="h6 fw-semibold text-site-dark mb-0">@p.Title</h2>
                                        <span class="badge rounded-pill @(p.ListingType == PropertyListingType.Buy ? "text-bg-primary" : "text-bg-success")">@p.ListingType</span>
                                    </div>
                                    <p class="small text-site-muted d-flex align-items-center gap-1 mb-3">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-site flex-shrink-0" aria-hidden="true"><path d="M12 21s7-4.35 7-10a7 7 0 1 0-14 0c0 5.65 7 10 7 10z" stroke="currentColor" stroke-width="2" /></svg>
                                        @p.Location
                                    </p>
                                    <div class="d-flex justify-content-between align-items-center small">
                                        <span class="text-site-muted">@p.Sqft.ToString("N0") sqm</span>
                                        <span class="fw-bold text-site">
                                            @if (p.ListingType == PropertyListingType.Buy)
                                            {
                                                @p.Price.ToString("C0", ph)
                                            }
                                            else
                                            {
                                                @($"{p.Price.ToString("C0", ph)}/mo")
                                            }
                                        </span>
                                    </div>
                                </div>
                            </a>
                        </article>
                    </div>
                }
            </div>
            <nav class="mt-4" aria-label="Properties pagination">
                @{ 
                    var totalPages = (int)Math.Ceiling(Model.TotalCount / (double)Model.PageSize);
                    var startItem = Math.Min(((Model.Page - 1) * Model.PageSize) + 1, Model.TotalCount == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1);
                    var endItem = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
                }

                <div class="d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="text-site-muted small">Showing <strong>@startItem</strong>–<strong>@endItem</strong> of <strong>@Model.TotalCount</strong> properties</div>

                        <form method="get" asp-controller="Properties" asp-action="Index" class="d-flex align-items-center">
                            <input type="hidden" name="location" value="@(Model.Location ?? string.Empty)" />
                            <input type="hidden" name="priceRange" value="@(Model.PriceRange ?? string.Empty)" />
                            <input type="hidden" name="maxPrice" value="@(Model.MaxPrice?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty)" />
                            <label class="me-2 small text-site-muted mb-0">Per page</label>
                            <select name="pageSize" class="form-select form-select-sm" style="width:80px;" onchange="this.form.submit()">
                                @{ var options = new[] {5, 9, 12}; }
                                @foreach (var opt in options)
                                {
                                    <option value="@opt" selected="@(opt == Model.PageSize ? "selected" : null)">@opt</option>
                                }
                            </select>
                            <input type="hidden" name="page" value="1" />
                        </form>
                    </div>

                    @if (totalPages > 1)
                    {
                        <div class="d-flex justify-content-center">
                            <ul class="pagination mb-0">
                                <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                                    <a class="page-link rounded-pill px-3" href="@Url.Action("Index", new { location = Model.Location, priceRange = Model.PriceRange, maxPrice = Model.MaxPrice, page = Model.Page - 1, pageSize = Model.PageSize })" aria-label="Previous">
                                        <span aria-hidden="true">‹</span>
                                    </a>
                                </li>

                                @* show up to 4 page buttons centered around current page when possible *@
                                @{
                                    var maxButtons = 4;
                                    var first = Math.Max(1, Model.Page - maxButtons / 2);
                                    var last = Math.Min(totalPages, first + maxButtons - 1);
                                    if (last - first + 1 < maxButtons)
                                        first = Math.Max(1, last - maxButtons + 1);
                                }

                                @if (first > 1)
                                {
                                    <li class="page-item"><a class="page-link" href="@Url.Action("Index", new { location = Model.Location, priceRange = Model.PriceRange, maxPrice = Model.MaxPrice, page = 1, pageSize = Model.PageSize })">1</a></li>
                                    @if (first > 2)
                                    {
                                        <li class="page-item disabled"><span class="page-link">…</span></li>
                                    }
                                }

                                @for (int i = first; i <= last; i++)
                                {
                                    <li class="page-item @(i == Model.Page ? "active" : "")" aria-current="@(i == Model.Page ? "page" : null)"><a class="page-link" href="@Url.Action("Index", new { location = Model.Location, priceRange = Model.PriceRange, maxPrice = Model.MaxPrice, page = i, pageSize = Model.PageSize })">@i</a></li>
                                }

                                @if (last < totalPages)
                                {
                                    @if (last < totalPages - 1)
                                    {
                                        <li class="page-item disabled"><span class="page-link">…</span></li>
                                    }
                                    <li class="page-item"><a class="page-link" href="@Url.Action("Index", new { location = Model.Location, priceRange = Model.PriceRange, maxPrice = Model.MaxPrice, page = totalPages, pageSize = Model.PageSize })">@totalPages</a></li>
                                }

                                <li class="page-item @(Model.Page >= totalPages ? "disabled" : "")">
                                    <a class="page-link rounded-pill px-3" href="@Url.Action("Index", new { location = Model.Location, priceRange = Model.PriceRange, maxPrice = Model.MaxPrice, page = Model.Page + 1, pageSize = Model.PageSize })" aria-label="Next">
                                        <span aria-hidden="true">›</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </nav>
        }
    </div>
</div>
