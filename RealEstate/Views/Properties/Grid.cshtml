@model RealEstate.Models.PropertiesIndexViewModel
@using RealEstate.Models
@{
    ViewData["Title"] = "Properties Grid";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #FAFBFC;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    .grid-wrapper {
        display: flex;
        gap: 32px;
        max-width: 1600px;
        margin: 0 auto;
        padding: 32px 24px;
        min-height: 100vh;
    }

    /* ─────────────────── SIDEBAR ─────────────────── */
    .grid-sidebar {
        width: 280px;
        position: sticky;
        top: 32px;
        height: fit-content;
    }

    .sidebar-section {
        background: white;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 24px;
        box-shadow: 0 2px 8px rgba(30, 58, 95, 0.08);
    }

    .sidebar-title {
        font-size: 18px;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .filter-group {
        margin-bottom: 16px;
    }

    .filter-label {
        font-size: 13px;
        font-weight: 600;
        color: #6B7280;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
        display: block;
    }

    .filter-input,
    .filter-select {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #E5E7EB;
        border-radius: 8px;
        font-size: 14px;
        color: #374151;
        transition: all 0.3s;
    }

    .filter-input:focus,
    .filter-select:focus {
        outline: none;
        border-color: #FF9500;
        box-shadow: 0 0 0 3px rgba(255, 149, 0, 0.1);
    }

    .price-range-inputs {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .price-range-inputs input {
        flex: 1;
        padding: 8px 10px;
        border: 1px solid #E5E7EB;
        border-radius: 6px;
        font-size: 13px;
    }

    .price-range-sep {
        color: #9CA3AF;
        font-weight: 600;
    }

    .checkbox-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .checkbox-item {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
    }

    .checkbox-item input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
        accent-color: #FF9500;
    }

    .checkbox-item label {
        flex: 1;
        cursor: pointer;
        font-size: 14px;
        color: #374151;
    }

    .bedroom-buttons {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

    .bedroom-btn {
        padding: 10px 12px;
        border: 2px solid #E5E7EB;
        background: white;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 13px;
        color: #6B7280;
        transition: all 0.3s;
    }

    .bedroom-btn:hover {
        border-color: #FF9500;
        color: #FF9500;
    }

    .bedroom-btn.active {
        background: #6366F1;
        border-color: #6366F1;
        color: white;
    }

    .apply-btn {
        width: 100%;
        padding: 12px 16px;
        background: linear-gradient(135deg, #FF9500, #FF8C00);
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 700;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.3s;
        margin-top: 8px;
    }

    .apply-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(255, 149, 0, 0.3);
    }

    /* ─────────────────── MAIN CONTENT ─────────────────── */
    .grid-content {
        flex: 1;
    }

    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .content-title {
        font-size: 28px;
        font-weight: 700;
        color: #1E3A5F;
    }

    .properties-count {
        font-size: 14px;
        color: #6B7280;
    }

    .sort-options {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .sort-select {
        padding: 10px 16px;
        border: 1px solid #E5E7EB;
        border-radius: 8px;
        background: white;
        cursor: pointer;
        font-size: 14px;
        color: #374151;
    }

    /* ─────────────────── GRID LAYOUT ─────────────────── */
    .properties-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 28px;
        margin-bottom: 48px;
    }

    .property-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(30, 58, 95, 0.08);
        transition: all 0.3s ease;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .property-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 32px rgba(30, 58, 95, 0.15);
    }

    /* Image Container */
    .property-image-wrapper {
        position: relative;
        width: 100%;
        height: 260px;
        overflow: hidden;
        background: #E5E7EB;
    }

    .property-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .property-card:hover .property-image {
        transform: scale(1.08);
    }

    .property-badge {
        position: absolute;
        top: 16px;
        right: 16px;
        background: #FF9500;
        color: white;
        padding: 8px 16px;
        border-radius: 24px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .property-badge.rent {
        background: #10B981;
    }

    .property-badge.sold {
        background: #EF4444;
    }

    /* Card Content */
    .property-content {
        padding: 24px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .property-header {
        display: flex;
        gap: 12px;
        margin-bottom: 16px;
    }

    .property-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #FF9500, #FF8C00);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 20px;
        flex-shrink: 0;
    }

    .property-title {
        font-size: 16px;
        font-weight: 700;
        color: #1E3A5F;
        line-height: 1.4;
        margin-bottom: 8px;
    }

    .property-location {
        font-size: 13px;
        color: #9CA3AF;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .property-specs {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
        padding: 16px 0;
        border-top: 1px solid #F3F4F6;
        border-bottom: 1px solid #F3F4F6;
        margin: 16px 0;
    }

    .spec-item {
        text-align: center;
    }

    .spec-icon {
        font-size: 18px;
        color: #FF9500;
        margin-bottom: 4px;
    }

    .spec-value {
        font-size: 14px;
        font-weight: 700;
        color: #1E3A5F;
    }

    .spec-label {
        font-size: 11px;
        color: #9CA3AF;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .property-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: auto;
    }

    .property-price {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .price-value {
        font-size: 20px;
        font-weight: 800;
        color: #FF9500;
    }

    .price-label {
        font-size: 11px;
        color: #9CA3AF;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .inquiry-link {
        color: #6366F1;
        text-decoration: none;
        font-weight: 700;
        font-size: 13px;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .inquiry-link:hover {
        color: #FF9500;
        gap: 8px;
    }

    /* ─────────────────── EMPTY STATE ─────────────────── */
    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 80px 40px;
    }

    .empty-icon {
        font-size: 80px;
        opacity: 0.2;
        margin-bottom: 24px;
    }

    .empty-title {
        font-size: 24px;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: 12px;
    }

    .empty-desc {
        color: #6B7280;
        margin-bottom: 24px;
    }

    .empty-btn {
        display: inline-block;
        background: linear-gradient(135deg, #FF9500, #FF8C00);
        color: white;
        padding: 12px 32px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 700;
        transition: all 0.3s;
    }

    .empty-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(255, 149, 0, 0.3);
    }

    /* ─────────────────── PAGINATION ─────────────────── */
    .pagination-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin-top: 48px;
        padding-top: 32px;
        border-top: 1px solid #E5E7EB;
    }

    .pagination-btn {
        padding: 10px 14px;
        border: 1px solid #E5E7EB;
        background: white;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 13px;
        color: #6B7280;
        transition: all 0.3s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .pagination-btn:hover:not(.disabled) {
        background: #FF9500;
        color: white;
        border-color: #FF9500;
    }

    .pagination-btn.active {
        background: #FF9500;
        color: white;
        border-color: #FF9500;
    }

    .pagination-btn.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    /* ─────────────────── RESPONSIVE ─────────────────── */
    @@media (max-width: 1200px) {
        .grid-wrapper {
            gap: 24px;
            padding: 20px 16px;
        }

        .grid-sidebar {
            width: 240px;
        }

        .properties-grid {
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }
    }

    @@media (max-width: 992px) {
        .grid-wrapper {
            flex-direction: column;
        }

        .grid-sidebar {
            width: 100%;
            position: static;
        }

        .sidebar-section {
            padding: 16px;
        }

        .properties-grid {
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        }

        .property-image-wrapper {
            height: 220px;
        }
    }

    @@media (max-width: 768px) {
        .grid-wrapper {
            padding: 16px 12px;
            gap: 16px;
        }

        .content-header {
            margin-bottom: 20px;
        }

        .content-title {
            font-size: 22px;
        }

        .properties-grid {
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 16px;
        }

        .property-content {
            padding: 16px;
        }

        .property-specs {
            gap: 8px;
            padding: 12px 0;
        }

        .property-image-wrapper {
            height: 180px;
        }

        .sidebar-section {
            display: none;
        }
    }

    @@media (max-width: 480px) {
        .grid-wrapper {
            padding: 12px 8px;
        }

        .properties-grid {
            grid-template-columns: 1fr;
        }

        .content-title {
            font-size: 18px;
        }

        .property-specs {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>

<div class="grid-wrapper">
    <!-- SIDEBAR FILTERS -->
    <aside class="grid-sidebar">
        <form method="get" action="@Url.Action("Grid", "Properties")">
            <!-- Search Section -->
            <div class="sidebar-section">
                <h3 class="sidebar-title">
                    <i class="fas fa-search"></i> Properties
                </h3>
                <p style="color: #6B7280; font-size: 13px; margin-bottom: 16px;">
                    Show @Model.TotalCount Properties
                </p>
                <div class="filter-group">
                    <label class="filter-label">Location</label>
                    <input type="text" name="location" class="filter-input" placeholder="Enter location..." value="@Model.Location" />
                </div>
            </div>

            <!-- Price Range Section -->
            <div class="sidebar-section">
                <h3 class="sidebar-title">
                    <i class="fas fa-money-bill-wave"></i> Price Range
                </h3>
                <div class="price-range-inputs">
                    <input type="number" name="minPrice" class="filter-input" placeholder="Min" value="" />
                    <span class="price-range-sep">to</span>
                    <input type="number" name="maxPrice" class="filter-input" placeholder="Max" value="@Model.MaxPrice" />
                </div>
            </div>

            <!-- Property Type Section -->
            <div class="sidebar-section">
                <h3 class="sidebar-title">
                    <i class="fas fa-home"></i> Property Type
                </h3>
                <div class="checkbox-group">
                    <div class="checkbox-item">
                        <input type="checkbox" id="type-all" checked />
                        <label for="type-all">All Properties</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="type-villa" />
                        <label for="type-villa">Villa</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="type-apartment" />
                        <label for="type-apartment">Apartment</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="type-house" />
                        <label for="type-house">House</label>
                    </div>
                </div>
            </div>

            <!-- Bedrooms Section -->
            <div class="sidebar-section">
                <h3 class="sidebar-title">
                    <i class="fas fa-bed"></i> Bedrooms
                </h3>
                <div class="bedroom-buttons">
                    <button type="button" class="bedroom-btn">1 BHK</button>
                    <button type="button" class="bedroom-btn">2 BHK</button>
                    <button type="button" class="bedroom-btn">3 BHK</button>
                    <button type="button" class="bedroom-btn">4 & 5 BHK</button>
                </div>
            </div>

            <!-- Accessibility Features -->
            <div class="sidebar-section">
                <h3 class="sidebar-title">
                    <i class="fas fa-check-circle"></i> Features
                </h3>
                <div class="checkbox-group">
                    <div class="checkbox-item">
                        <input type="checkbox" id="feature-pool" />
                        <label for="feature-pool">Pool</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="feature-gym" />
                        <label for="feature-gym">Gym</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="feature-parking" />
                        <label for="feature-parking">Parking</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="feature-security" />
                        <label for="feature-security">Security</label>
                    </div>
                </div>
            </div>

            <button type="submit" class="apply-btn">
                <i class="fas fa-check"></i> Apply Filters
            </button>
        </form>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="grid-content">
        <div class="content-header">
            <div>
                <h1 class="content-title">Listing Grid</h1>
                <p class="properties-count">
                    <strong>Properties</strong>
                    <span style="color: #9CA3AF;">Show @Model.TotalCount Properties</span>
                </p>
            </div>
            <div class="sort-options">
                <label style="font-size: 13px; color: #6B7280; font-weight: 600;">Sort by:</label>
                <select class="sort-select">
                    <option>Newest</option>
                    <option>Price: Low to High</option>
                    <option>Price: High to Low</option>
                    <option>Most Popular</option>
                </select>
            </div>
        </div>

        @if (Model.Properties.Any())
        {
            <div class="properties-grid">
                @foreach (var property in Model.Properties)
                {
                    <div class="property-card" onclick="location.href='@Url.Action("Details", "Properties", new { id = property.Id })'">
                        <div class="property-image-wrapper">
                            @{
                                var coverImage = !string.IsNullOrEmpty(property.CoverImage) ? property.CoverImage : "https://images.unsplash.com/photo-1600585154084-4e5fe7c39198?auto=format&fit=crop&w=500&q=60";
                            }
                            <img src="@coverImage" alt="@property.Title" class="property-image" />
                            <span class="property-badge @(property.ListingType == PropertyListingType.Rent ? "rent" : "")">
                                @(property.ListingType == PropertyListingType.Rent ? "For Rent" : "For Sale")
                            </span>
                        </div>

                        <div class="property-content">
                            <div class="property-header">
                                <div class="property-icon">
                                    <i class="fas fa-building"></i>
                                </div>
                                <div>
                                    <div class="property-title">@property.Title</div>
                                    <div class="property-location">
                                        <i class="fas fa-map-marker-alt"></i> @property.Location
                                    </div>
                                </div>
                            </div>

                            <div class="property-specs">
                                <div class="spec-item">
                                    <div class="spec-icon"><i class="fas fa-bed"></i></div>
                                    <div class="spec-value">@property.Bedrooms</div>
                                    <div class="spec-label">Beds</div>
                                </div>
                                <div class="spec-item">
                                    <div class="spec-icon"><i class="fas fa-bath"></i></div>
                                    <div class="spec-value">@property.Bathrooms</div>
                                    <div class="spec-label">Baths</div>
                                </div>
                                <div class="spec-item">
                                    <div class="spec-icon"><i class="fas fa-ruler"></i></div>
                                    <div class="spec-value">@(property.Sqft / 1000)k</div>
                                    <div class="spec-label">Sqft</div>
                                </div>
                            </div>

                            <div class="property-footer">
                                <div class="property-price">
                                    <div class="price-value">₱@(property.FinalPrice?.ToString("N0") ?? property.BasePrice.ToString("N0"))</div>
                                    <div class="price-label">@property.PropertyType</div>
                                </div>
                                <a href="@Url.Action("SendInquiry", "Properties", new { propertyId = property.Id })" class="inquiry-link" onclick="event.stopPropagation();">
                                    More Inquiry
                                    <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalCount > Model.PageSize)
            {
                var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
                <div class="pagination-wrapper">
                    @if (Model.Page > 1)
                    {
                        <a href="@Url.Action("Grid", "Properties", new { page = Model.Page - 1, location = Model.Location, priceRange = Model.PriceRange, maxPrice = Model.MaxPrice })" class="pagination-btn">
                            <i class="fas fa-chevron-left"></i> Previous
                        </a>
                    }

                    @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(totalPages, Model.Page + 2); i++)
                    {
                        <a href="@Url.Action("Grid", "Properties", new { page = i, location = Model.Location, priceRange = Model.PriceRange, maxPrice = Model.MaxPrice })" 
                           class="pagination-btn @(i == Model.Page ? "active" : "")">
                            @i
                        </a>
                    }

                    @if (Model.Page < totalPages)
                    {
                        <a href="@Url.Action("Grid", "Properties", new { page = Model.Page + 1, location = Model.Location, priceRange = Model.PriceRange, maxPrice = Model.MaxPrice })" class="pagination-btn">
                            Next <i class="fas fa-chevron-right"></i>
                        </a>
                    }
                </div>
            }
        }
        else
        {
            <div class="properties-grid">
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-inbox"></i>
                    </div>
                    <h3 class="empty-title">No Properties Found</h3>
                    <p class="empty-desc">Try adjusting your search filters to find properties you're looking for.</p>
                    <a href="@Url.Action("Grid", "Properties")" class="empty-btn">
                        Clear All Filters
                    </a>
                </div>
            </div>
        }
    </main>
</div>

<script>
    document.querySelectorAll('.bedroom-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            document.querySelectorAll('.bedroom-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        });
    });
</script>
