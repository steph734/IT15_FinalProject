@model RealEstate.Models.AgentInquiryViewModel
@{
    ViewData["Title"] = "Send Inquiry";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var propertyTitle = ViewBag.PropertyTitle as string ?? "Property #" + Model.PropertyId;
}

<!-- Hero Section -->
<section class="page-header py-5 bg-light" style="background: linear-gradient(135deg, rgba(249, 115, 22, 0.1) 0%, rgba(234, 88, 12, 0.05) 100%);">
    <div class="container text-center py-4">
        <h1 class="display-4 fw-bold text-dark mb-3">Send an Inquiry</h1>
        <p class="lead text-muted mx-auto" style="max-width: 600px;">
            Interested in <strong class="text-primary">@propertyTitle</strong>? Fill out the form below and we'll connect you with the assigned agent.
        </p>
    </div>
</section>

<!-- Form Section -->
<section class="py-5 my-4">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7 col-md-10">
                <div class="card border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">
                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 px-md-5">
                        <div class="d-flex align-items-center mb-2">
                            <div class="icon-circle bg-primary bg-opacity-10 text-primary me-3" style="width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px;">
                                <i class="fas fa-paper-plane"></i>
                            </div>
                            <h4 class="mb-0 fw-bold">Contact Agent</h4>
                        </div>
                    </div>
                    <div class="card-body p-4 p-md-5 pt-4">
                        
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger rounded-3 mb-4">
                                <i class="fas fa-exclamation-triangle me-2"></i> Please correct the errors below.
                            </div>
                        }

                        <form asp-action="SendInquiry" asp-controller="Properties" method="post">
                            <input type="hidden" asp-for="PropertyId" />
                            <input type="hidden" asp-for="AgentId" />
                            
                            <div class="mb-4">
                                <label asp-for="Name" class="form-label fw-bold text-dark">Your Name <span class="text-danger">*</span></label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-user text-muted"></i></span>
                                    <input asp-for="Name" class="form-control bg-light border-start-0" placeholder="e.g. John Doe" />
                                </div>
                                <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                            </div>
                            
                            <div class="mb-4">
                                <label asp-for="Email" class="form-label fw-bold text-dark">Email Address <span class="text-danger">*</span></label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-envelope text-muted"></i></span>
                                    <input asp-for="Email" class="form-control bg-light border-start-0" placeholder="e.g. john@example.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                            </div>
                            
                            <div class="mb-4">
                                <label asp-for="Message" class="form-label fw-bold text-dark">Your Message <span class="text-danger">*</span></label>
                                <textarea asp-for="Message" class="form-control bg-light p-3" rows="5" placeholder="I am interested in learning more about this property..."></textarea>
                                <span asp-validation-for="Message" class="text-danger small mt-1 d-block"></span>
                            </div>
                            
                            <div class="d-grid mt-5">
                                <button type="submit" class="btn btn-primary btn-lg rounded-pill py-3 fw-bold" style="background: linear-gradient(135deg, #f97316 0%, #ea580c 100%); border: none;">
                                    <i class="fas fa-paper-plane me-2"></i> Send Inquiry
                                </button>
                            </div>
                            <div class="text-center mt-3">
                                <a href="@Url.Action("Details", "Properties", new { id = Model.PropertyId })" class="text-muted text-decoration-none">
                                    <i class="fas fa-arrow-left me-1"></i> Back to Property
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
