<script>
    document.addEventListener('DOMContentLoaded', function() {
        // View toggle functionality
        const viewBtns = document.querySelectorAll('.view-btn');
        const propertiesGrid = document.getElementById('propertiesGrid');
        
        viewBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                viewBtns.forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                
                const view = this.dataset.view;
                if (view === 'list') {
                    propertiesGrid.style.gridTemplateColumns = '1fr';
                } else {
                    propertiesGrid.style.gridTemplateColumns = 'repeat(auto-fill, minmax(320px, 1fr))';
                }
            });
        });

        // Assign Agent Modal functionality
        const assignAgentBtns = document.querySelectorAll('.assign-agent-btn');
        const assignAgentModal = document.getElementById('assignAgentModal');
        const modalPropertyName = document.getElementById('modalPropertyName');
        const modalPropertyLocation = document.getElementById('modalPropertyLocation');
        
        assignAgentBtns.forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                const propertyId = this.dataset.propertyId;
                const propertyCard = this.closest('.property-card');
                const title = propertyCard.querySelector('.property-title').textContent;
                const location = propertyCard.querySelector('.property-location span').textContent;
                
                modalPropertyName.textContent = title;
                modalPropertyLocation.textContent = location;
                
                const modal = new bootstrap.Modal(assignAgentModal);
                modal.show();
            });
        });

        // Confirm Assign Agent
        const confirmAssignBtn = document.getElementById('confirmAssignAgent');
        if (confirmAssignBtn) {
            confirmAssignBtn.addEventListener('click', function() {
                const selectedAgent = document.querySelector('input[name="agent"]:checked');
                if (selectedAgent) {
                    // Here you would typically send the assignment to the server
                    const modal = bootstrap.Modal.getInstance(assignAgentModal);
                    modal.hide();
                    
                    // Show success message
                    alert('Agent assigned successfully!');
                } else {
                    alert('Please select an agent to assign.');
                }
            });
        }

        // Favorite button functionality
        const favoriteBtns = document.querySelectorAll('.property-favorite');
        favoriteBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                const icon = this.querySelector('i');
                if (icon.classList.contains('far')) {
                    icon.classList.remove('far');
                    icon.classList.add('fas');
                } else {
                    icon.classList.remove('fas');
                    icon.classList.add('far');
                }
            });
        });

        // Inspection Checklist functionality
        const inspectionCards = document.querySelectorAll('.inspection-card');
        inspectionCards.forEach(card => {
            card.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-2px)';
            });
            
            card.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0)';
            });
        });

        // Animate progress bars on scroll
        const progressBars = document.querySelectorAll('.progress-fill');
        const observerOptions = {
            threshold: 0.5,
            rootMargin: '0px'
        };

        const progressObserver = new IntersectionObserver(function(entries) {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const progressBar = entry.target;
                    // Simulate progress animation (you can replace with actual progress data)
                    setTimeout(() => {
                        progressBar.style.width = '25%'; // Example progress
                        const percentageText = progressBar.closest('.inspection-card').querySelector('.progress-percentage');
                        if (percentageText) {
                            percentageText.textContent = '25%';
                        }
                    }, 300);
                    progressObserver.unobserve(progressBar);
                }
            });
        }, observerOptions);

        progressBars.forEach(bar => {
            progressObserver.observe(bar);
        });
    });

    // Show quick notes section
    function showQuickNotes(listingId) {
        const notesSection = document.getElementById(`quick-notes-${listingId}`);
        if (notesSection) {
            notesSection.style.display = notesSection.style.display === 'none' ? 'block' : 'none';
            
            // Focus on textarea when shown
            if (notesSection.style.display === 'block') {
                const textarea = notesSection.querySelector('textarea');
                if (textarea) {
                    setTimeout(() => textarea.focus(), 100);
                }
            }
        }
    }

    // Hide quick notes section
    function hideQuickNotes(listingId) {
        const notesSection = document.getElementById(`quick-notes-${listingId}`);
        if (notesSection) {
            notesSection.style.display = 'none';
        }
    }

    // View property details
    function viewProperty(listingId) {
        window.location.href = `/manager/sellers/listings/${listingId}`;
    }
</script>
