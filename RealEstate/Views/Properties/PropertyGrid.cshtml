@using RealEstate.Models
@{
    ViewData["Title"] = "Property Grid";
    Layout = "~/Views/Shared/_PropertiesLayout.cshtml";
    
    // Get inspection listings for the checklist section
    var inspectionListings = ViewBag.InspectionListings as List<Property> ?? new List<Property>();
}

<div class="property-grid-page">
    <!-- Page Header -->
    <section class="page-header-modern">
        <div class="container">
            <div class="page-header-content">
                <span class="page-label">PROPERTY LISTINGS</span>
                <h1 class="page-title">Property Grid</h1>
                <p class="page-subtitle">Browse our comprehensive collection of properties</p>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <section class="properties-grid-section">
        <div class="container">
            <div class="row">
                <!-- Sidebar Filters -->
                <div class="col-lg-3">
                    <div class="sidebar-filters">
                        <h2 class="listing-grid-title">Listing Grid</h2>
                        
                        <div class="filter-header">
                            <h5 class="filter-section-title">Properties</h5>
                            <span class="property-count">Show @Model.TotalCount Properties</span>
                        </div>

                        <div class="filter-divider"></div>

                        <!-- Properties Location -->
                        <div class="filter-group">
                            <label class="filter-label">Properties Location</label>
                            <div class="custom-select-wrapper">
                                <select class="custom-select">
                                    <option>Choose a city</option>
                                    <option>New York</option>
                                    <option>Los Angeles</option>
                                    <option>Chicago</option>
                                    <option>Miami</option>
                                    <option>San Francisco</option>
                                </select>
                                <i class="fas fa-chevron-down select-icon"></i>
                            </div>
                        </div>

                        <!-- Type Of Place -->
                        <div class="filter-group">
                            <label class="filter-label">Type Of Place</label>
                            <input type="text" class="custom-input" placeholder="">
                        </div>

                        <!-- Custom Price Range -->
                        <div class="filter-group">
                            <label class="filter-label">Custom Price Range :</label>
                            <div class="range-slider-container">
                                <div class="range-slider-track">
                                    <div class="range-slider-fill"></div>
                                    <div class="range-thumb range-thumb-left"></div>
                                    <div class="range-thumb range-thumb-right"></div>
                                </div>
                            </div>
                            <div class="range-inputs">
                                <div class="range-input-wrapper">
                                    <span class="range-currency">$</span>
                                    <input type="text" class="range-input" value="6000" id="minPrice">
                                </div>
                                <span class="range-separator">to</span>
                                <div class="range-input-wrapper">
                                    <span class="range-currency">$</span>
                                    <input type="text" class="range-input" value="100000" id="maxPrice">
                                </div>
                            </div>
                        </div>

                        <!-- Accessibility Features -->
                        <div class="filter-group">
                            <label class="filter-label">Accessibility Features :</label>
                            <div class="checkbox-grid">
                                <label class="custom-checkbox">
                                    <input type="checkbox">
                                    <span class="checkmark"></span>
                                    <span class="checkbox-label">For Rent</span>
                                </label>
                                <label class="custom-checkbox">
                                    <input type="checkbox">
                                    <span class="checkmark"></span>
                                    <span class="checkbox-label">For Sale</span>
                                </label>
                                <label class="custom-checkbox">
                                    <input type="checkbox">
                                    <span class="checkmark"></span>
                                    <span class="checkbox-label">Balcony</span>
                                </label>
                                <label class="custom-checkbox">
                                    <input type="checkbox">
                                    <span class="checkmark"></span>
                                    <span class="checkbox-label">Parking</span>
                                </label>
                                <label class="custom-checkbox">
                                    <input type="checkbox">
                                    <span class="checkmark"></span>
                                    <span class="checkbox-label">Spa</span>
                                </label>
                                <label class="custom-checkbox">
                                    <input type="checkbox">
                                    <span class="checkmark"></span>
                                    <span class="checkbox-label">Pool</span>
                                </label>
                                <label class="custom-checkbox">
                                    <input type="checkbox">
                                    <span class="checkmark"></span>
                                    <span class="checkbox-label">Restaurant</span>
                                </label>
                                <label class="custom-checkbox">
                                    <input type="checkbox">
                                    <span class="checkmark"></span>
                                    <span class="checkbox-label">Fitness Club</span>
                                </label>
                            </div>
                        </div>

                        <!-- Properties Type -->
                        <div class="filter-group">
                            <label class="filter-label">Properties Type :</label>
                            <div class="checkbox-grid">
                                <label class="custom-checkbox">
                                    <input type="checkbox" checked>
                                    <span class="checkmark"></span>
                                    <span class="checkbox-label">All Properties</span>
                                </label>
                                <label class="custom-checkbox">
                                    <input type="checkbox">
                                    <span class="checkmark"></span>
                                    <span class="checkbox-label">Cottage</span>
                                </label>
                                <label class="custom-checkbox">
                                    <input type="checkbox">
                                    <span class="checkmark"></span>
                                    <span class="checkbox-label">Villas</span>
                                </label>
                                <label class="custom-checkbox">
                                    <input type="checkbox">
                                    <span class="checkmark"></span>
                                    <span class="checkbox-label">Apartment</span>
                                </label>
                                <label class="custom-checkbox full-width">
                                    <input type="checkbox">
                                    <span class="checkmark"></span>
                                    <span class="checkbox-label">Duplex Bungalow</span>
                                </label>
                            </div>
                        </div>

                        <button class="apply-btn">Apply</button>
                    </div>
                </div>

                <!-- Properties Grid -->
                <div class="col-lg-9">
                    <!-- Sorting and View Options -->
                    <div class="properties-controls">
                        <div class="results-info">
                            <span>Showing <strong>1-8</strong> of <strong>23</strong> properties</span>
                        </div>
                        <div class="view-controls">
                            <div class="view-toggle">
                                <button class="view-btn active" data-view="grid">
                                    <i class="fas fa-th"></i>
                                </button>
                                <button class="view-btn" data-view="list">
                                    <i class="fas fa-list"></i>
                                </button>
                            </div>
                            <select class="sort-select">
                                <option>Sort by: Newest</option>
                                <option>Price: Low to High</option>
                                <option>Price: High to Low</option>
                                <option>Most Popular</option>
                            </select>
                        </div>
                    </div>

                    <!-- Property Cards Grid -->
                    <div class="properties-grid" id="propertiesGrid">
                        @foreach (var property in Model.Properties)
                        {
                            var coverImage = !string.IsNullOrEmpty(property.CoverImage) ? property.CoverImage : "https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=600&q=80";
                            var isRent = property.ListingType == 1;
                            <div class="property-card">
                                <div class="property-image">
                                    <img src="@coverImage" alt="@property.Title" loading="lazy">
                                    <div class="property-status @(isRent ? "for-rent" : "for-sale")">
                                        @(isRent ? "For Rent" : "For Sale")
                                    </div>
                                    <div class="property-favorite">
                                        <i class="far fa-heart"></i>
                                    </div>
                                </div>

                                <div class="property-content">
                                    <div class="property-price">
                                        ₱@(property.FinalPrice?.ToString("N0") ?? property.BasePrice.ToString("N0"))
                                        @if (isRent)
                                        {
                                            <span class="price-period">/month</span>
                                        }
                                    </div>

                                    <h3 class="property-title">@property.Title</h3>

                                    <div class="property-location">
                                        <i class="fas fa-map-marker-alt"></i>
                                        <span>@property.Location</span>
                                    </div>

                                    <div class="property-features">
                                        <div class="feature">
                                            <i class="fas fa-bed"></i>
                                            <span>@property.Bedrooms Beds</span>
                                        </div>
                                        <div class="feature">
                                            <i class="fas fa-bath"></i>
                                            <span>@property.Bathrooms Baths</span>
                                        </div>
                                        <div class="feature">
                                            <i class="fas fa-ruler-combined"></i>
                                            <span>@property.Sqft sqft</span>
                                        </div>
                                        <div class="feature">
                                            <i class="fas fa-car"></i>
                                            <span>@property.ParkingSlots Parking</span>
                                        </div>
                                    </div>

                                    <div class="property-description">
                                        @property.Description
                                    </div>

                                    <div class="property-actions">
                                        <a href="/Properties/Details/@property.PropertyId" class="btn-primary property-details-btn">
                                            View Details
                                        </a>
                                        <div class="dropdown more-inquiry-dropdown">
                                            <button class="btn-secondary more-inquiry-btn" data-bs-toggle="dropdown">
                                                More Inquiry
                                            </button>
                                            <ul class="dropdown-menu">
                                                <li><a class="dropdown-item" href="/Properties/SendInquiry/@property.PropertyId"><i class="fas fa-envelope"></i> Send Message</a></li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Pagination -->
                    <div class="pagination-wrapper">
                        <ul class="pagination">
                            <li class="page-item disabled">
                                <a class="page-link" href="#" tabindex="-1">Previous</a>
                            </li>
                            <li class="page-item active"><a class="page-link" href="#">1</a></li>
                            <li class="page-item"><a class="page-link" href="#">2</a></li>
                            <li class="page-item"><a class="page-link" href="#">3</a></li>
                            <li class="page-item"><a class="page-link" href="#">Next</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Inspection Checklist Section -->
    @if (inspectionListings.Any())
    {
        <section class="inspection-checklist-section">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="fas fa-clipboard-check me-3"></i>Property Inspection Checklist
                    </h2>
                    <p class="section-subtitle">Complete inspections for properties currently under review</p>
                </div>

                <div class="inspection-grid">
                    @foreach (var listing in inspectionListings)
                    {
                        <div class="inspection-card">
                            <div class="inspection-header">
                                <div class="property-info">
                                    <h4 class="property-title">@listing.Title</h4>
                                    <p class="property-location">
                                        <i class="fas fa-map-marker-alt me-2"></i>@listing.Location
                                    </p>
                                    <div class="property-details">
                                        <span class="detail-item">
                                            <i class="fas fa-bed me-1"></i>@listing.Bedrooms Beds
                                        </span>
                                        <span class="detail-item">
                                            <i class="fas fa-bath me-1"></i>@listing.Bathrooms Baths
                                        </span>
                                        <span class="detail-item">
                                            <i class="fas fa-ruler-combined me-1"></i>@listing.Sqft sqft
                                        </span>
                                    </div>
                                </div>
                                <div class="inspection-status">
                                    <span class="status-badge status-inspection">
                                        <i class="fas fa-search me-2"></i>Inspection
                                    </span>
                                </div>
                            </div>

                            <div class="inspection-progress">
                                <div class="progress-info">
                                    <span class="progress-label">Inspection Progress</span>
                                    <span class="progress-percentage">0%</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: 0%"></div>
                                </div>
                            </div>

                            <div class="inspection-actions">
                                <a href="/manager/sellers/listings/@listing.Id/inspection-checklist" 
                                   class="btn-inspection-checklist">
                                    <i class="fas fa-clipboard-list me-2"></i>Open Checklist
                                </a>
                                <div class="quick-actions">
                                    <button class="btn-quick-notes" onclick="showQuickNotes(@listing.Id)">
                                        <i class="fas fa-sticky-note"></i>
                                    </button>
                                    <button class="btn-view-property" onclick="viewProperty(@listing.Id)">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="inspection-notes" id="quick-notes-@listing.Id" style="display: none;">
                                <form method="post" action="/manager/sellers/listings/@listing.Id/complete-inspection">
                                    @Html.AntiForgeryToken()
                                    <div class="form-group">
                                        <label class="form-label">Quick Inspection Notes</label>
                                        <textarea name="inspectionNotes" class="form-control" rows="3" 
                                                  placeholder="Add quick inspection notes..."></textarea>
                                    </div>
                                    <div class="form-actions">
                                        <button type="submit" class="btn-complete-quick">
                                            <i class="fas fa-check me-2"></i>Complete Inspection
                                        </button>
                                        <button type="button" class="btn-cancel-notes" onclick="hideQuickNotes(@listing.Id)">
                                            Cancel
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
</div>

<!-- Assign Agent Modal -->
<div class="modal fade" id="assignAgentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Assign Agent to Property</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="property-summary mb-3">
                    <h6>Property Details</h6>
                    <div id="selectedPropertyInfo">
                        <p class="mb-1"><strong>Property:</strong> <span id="modalPropertyName">Modern Apartment</span></p>
                        <p class="mb-0"><strong>Location:</strong> <span id="modalPropertyLocation">66 Brooklynt, New York</span></p>
                    </div>
                </div>
                
                <div class="agent-selection">
                    <h6>Select Agent</h6>
                    <div class="agent-list">
                        <div class="agent-option">
                            <label class="agent-card">
                                <input type="radio" name="agent" value="1">
                                <div class="agent-info">
                                    <img src="https://i.pravatar.cc/40?u=agent1" alt="Agent">
                                    <div class="agent-details">
                                        <div class="agent-name">John Smith</div>
                                        <div class="agent-specialty">Luxury Properties</div>
                                        <div class="agent-rating">
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star-half-alt"></i>
                                            <span>4.8</span>
                                        </div>
                                    </div>
                                </div>
                            </label>
                        </div>
                        
                        <div class="agent-option">
                            <label class="agent-card">
                                <input type="radio" name="agent" value="2">
                                <div class="agent-info">
                                    <img src="https://i.pravatar.cc/40?u=agent2" alt="Agent">
                                    <div class="agent-details">
                                        <div class="agent-name">Maria Garcia</div>
                                        <div class="agent-specialty">Downtown Area</div>
                                        <div class="agent-rating">
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star"></i>
                                            <span>5.0</span>
                                        </div>
                                    </div>
                                </div>
                            </label>
                        </div>
                        
                        <div class="agent-option">
                            <label class="agent-card">
                                <input type="radio" name="agent" value="3">
                                <div class="agent-info">
                                    <img src="https://i.pravatar.cc/40?u=agent3" alt="Agent">
                                    <div class="agent-details">
                                        <div class="agent-name">Robert Johnson</div>
                                        <div class="agent-specialty">Family Homes</div>
                                        <div class="agent-rating">
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star"></i>
                                            <i class="far fa-star"></i>
                                            <span>4.2</span>
                                        </div>
                                    </div>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>
                
                <div class="assignment-notes mt-3">
                    <label for="assignmentNotes" class="form-label">Assignment Notes (Optional)</label>
                    <textarea class="form-control" id="assignmentNotes" rows="3" placeholder="Add any special instructions or notes for the agent..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmAssignAgent">Assign Agent</button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Page Header */
    .page-header-modern {
        background: linear-gradient(135deg, #1E3A5F 0%, #16A39E 100%);
        color: white;
        padding: 80px 0 60px;
        text-align: center;
    }

    .page-label {
        display: inline-block;
        background: rgba(255, 255, 255, 0.2);
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 16px;
    }

    .page-title {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .page-subtitle {
        font-size: 1.2rem;
        opacity: 0.9;
        max-width: 600px;
        margin: 0 auto;
    }

    /* Properties Grid Section */
    .properties-grid-section {
        padding: 60px 0;
    }

    /* Sidebar Filters - Listing Grid Style */
    .sidebar-filters {
        background: white;
        border-radius: 16px;
        padding: 28px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    }

    .listing-grid-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #5B6B8A;
        margin-bottom: 20px;
    }

    .filter-header {
        margin-bottom: 12px;
    }

    .filter-section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #4A5568;
        margin-bottom: 4px;
    }

    .property-count {
        font-size: 0.9rem;
        color: #718096;
    }

    .filter-divider {
        height: 1px;
        background: #E2E8F0;
        margin: 20px 0;
    }

    .filter-group {
        margin-bottom: 24px;
    }

    .filter-label {
        display: block;
        font-size: 0.95rem;
        font-weight: 600;
        color: #4A5568;
        margin-bottom: 10px;
    }

    /* Custom Select */
    .custom-select-wrapper {
        position: relative;
    }

    .custom-select {
        width: 100%;
        padding: 12px 40px 12px 16px;
        border: 1px solid #E2E8F0;
        border-radius: 10px;
        background: white;
        color: #718096;
        font-size: 0.9rem;
        appearance: none;
        -webkit-appearance: none;
        cursor: pointer;
        outline: none;
        transition: border-color 0.2s;
    }

    .custom-select:focus {
        border-color: #6B4EE6;
    }

    .select-icon {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #718096;
        font-size: 0.8rem;
        pointer-events: none;
    }

    /* Custom Input */
    .custom-input {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid #E2E8F0;
        border-radius: 10px;
        background: white;
        color: #2D3748;
        font-size: 0.9rem;
        outline: none;
        transition: border-color 0.2s;
    }

    .custom-input:focus {
        border-color: #6B4EE6;
    }

    /* Range Slider */
    .range-slider-container {
        padding: 20px 8px 16px;
    }

    .range-slider-track {
        position: relative;
        height: 6px;
        background: #E2E8F0;
        border-radius: 3px;
    }

    .range-slider-fill {
        position: absolute;
        left: 10%;
        right: 20%;
        top: 0;
        height: 100%;
        background: #6B4EE6;
        border-radius: 3px;
    }

    .range-thumb {
        position: absolute;
        top: 50%;
        transform: translate(-50%, -50%);
        width: 18px;
        height: 18px;
        background: #6B4EE6;
        border: 3px solid white;
        border-radius: 50%;
        box-shadow: 0 2px 6px rgba(107, 78, 230, 0.4);
        cursor: pointer;
    }

    .range-thumb-left {
        left: 10%;
    }

    .range-thumb-right {
        left: 80%;
    }

    /* Range Inputs */
    .range-inputs {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .range-input-wrapper {
        flex: 1;
        position: relative;
        display: flex;
        align-items: center;
    }

    .range-currency {
        position: absolute;
        left: 12px;
        color: #718096;
        font-size: 0.9rem;
    }

    .range-input {
        width: 100%;
        padding: 10px 12px 10px 28px;
        border: 1px solid #E2E8F0;
        border-radius: 10px;
        background: white;
        color: #2D3748;
        font-size: 0.9rem;
        text-align: center;
        outline: none;
    }

    .range-separator {
        color: #718096;
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    /* Checkbox Grid */
    .checkbox-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .custom-checkbox {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        position: relative;
    }

    .custom-checkbox input {
        position: absolute;
        opacity: 0;
        cursor: pointer;
    }

    .checkmark {
        width: 18px;
        height: 18px;
        border: 1.5px solid #CBD5E0;
        border-radius: 4px;
        background: white;
        transition: all 0.2s;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .custom-checkbox input:checked + .checkmark {
        background: #6B4EE6;
        border-color: #6B4EE6;
    }

    .custom-checkbox input:checked + .checkmark::after {
        content: '\2713';
        color: white;
        font-size: 11px;
        font-weight: bold;
    }

    .checkbox-label {
        font-size: 0.9rem;
        color: #4A5568;
        user-select: none;
    }

    .custom-checkbox.full-width {
        grid-column: 1 / -1;
    }

    /* Apply Button */
    .apply-btn {
        width: 100%;
        padding: 14px;
        background: #6B4EE6;
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        margin-top: 8px;
    }

    .apply-btn:hover {
        background: #5a3fd4;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(107, 78, 230, 0.3);
    }

    /* Properties Controls */
    .properties-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
    }

    .results-info {
        color: #6B7280;
        font-size: 0.95rem;
    }

    .results-info strong {
        color: #1E3A5F;
    }

    .view-controls {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .view-toggle {
        display: flex;
        gap: 8px;
    }

    .view-btn {
        width: 40px;
        height: 40px;
        border: 1px solid #E5E7EB;
