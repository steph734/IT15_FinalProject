    function calculateManagerFloorPrice() {
        const targetNet = parseFloat(document.getElementById('managerTargetNet').value) || 0;
        const frictionRate = parseFloat(document.getElementById('managerCustomFriction').value) || 13.5;
        
        const keepPercentage = 1 - (frictionRate / 100);
        const floorPrice = targetNet / keepPercentage;
        
        document.getElementById('managerDisplayTargetNet').textContent = '₱' + targetNet.toLocaleString('en-PH');
        document.getElementById('managerDisplayFriction').textContent = frictionRate + '%';
        document.getElementById('managerDisplayKeepPercentage').textContent = (keepPercentage * 100).toFixed(1) + '%';
        document.getElementById('managerDisplayFloorPrice').textContent = '₱' + Math.floor(floorPrice).toLocaleString('en-PH');
        document.getElementById('finalFloorPrice').value = Math.floor(floorPrice).toLocaleString('en-PH');
    }

    function performZonalAudit() {
        const area = parseFloat(document.getElementById('auditPropertyArea').value) || 0;
        const zonalRate = parseFloat(document.getElementById('auditZonalRate').value) || 0;
        const floorPrice = parseFloat(document.getElementById('auditFloorPrice').value) || 0;
        
        const zonalValue = area * zonalRate;
        document.getElementById('auditZonalValue').value = zonalValue.toLocaleString('en-PH');
        
        document.getElementById('auditDisplayFloorPrice').textContent = '₱' + floorPrice.toLocaleString('en-PH');
        document.getElementById('auditDisplayZonalValue').textContent = '₱' + zonalValue.toLocaleString('en-PH');
        
        const auditAlert = document.getElementById('auditAlert');
        const auditStatus = document.getElementById('auditStatus');
        const auditMessage = document.getElementById('auditMessage');
        
        auditAlert.style.display = 'block';
        
        if (zonalValue > floorPrice) {
            auditStatus.textContent = 'ACTION REQUIRED';
            auditStatus.style.color = '#DC2626';
            auditAlert.className = 'alert alert-danger';
            auditMessage.textContent = 'Zonal Value (₱' + zonalValue.toLocaleString('en-PH') + ') is higher than Floor Price (₱' + floorPrice.toLocaleString('en-PH') + '). You must increase the price because BIR will tax based on the higher amount.';
        } else {
            auditStatus.textContent = 'PASSED';
            auditStatus.style.color = '#10B981';
            auditAlert.className = 'alert alert-success';
            auditMessage.textContent = 'Floor Price (₱' + floorPrice.toLocaleString('en-PH') + ') is higher than Zonal Value (₱' + zonalValue.toLocaleString('en-PH') + '). No action required.';
