    function updatePaymentBreakdown() {
        const propertyType = document.querySelector('input[name="propertyType"]').value;
        if (propertyType !== 'Rent') return;

        const basePrice = @p.BasePrice;
        const monthlyPayment = document.getElementById('monthlyPayment').checked;
        const yearlyPayment = document.getElementById('yearlyPayment').checked;

        const discountRow = document.getElementById('discountRow');
        const totalAmountDisplay = document.getElementById('totalAmountDisplay');
        const totalAmountInput = document.getElementById('totalAmountInput');
        const paymentFrequencyLabel = document.getElementById('paymentFrequencyLabel');
        const monthlyEquivalent = document.getElementById('monthlyEquivalent');

        if (yearlyPayment) {
            // Yearly payment with 10% discount
            const yearlyRent = basePrice * 12;
            const discount = yearlyRent * 0.1;
            const totalAmount = yearlyRent + basePrice + 5000 - discount; // 12 months rent + deposit + fee - discount
            
            discountRow.style.display = 'flex';
            totalAmountDisplay.textContent = '₱' + totalAmount.toLocaleString('en-PH');
            totalAmountInput.value = totalAmount;
            paymentFrequencyLabel.textContent = 'Yearly Payment (12 months)';
            monthlyEquivalent.textContent = 'Monthly: ₱' + basePrice.toLocaleString('en-PH');
            
            document.getElementById('paymentFrequency').value = 'Yearly';
        } else {
            // Monthly payment
            const totalAmount = basePrice * 2 + 5000; // First month + deposit + fee
            
            discountRow.style.display = 'none';
            totalAmountDisplay.textContent = '₱' + totalAmount.toLocaleString('en-PH');
            totalAmountInput.value = totalAmount;
            paymentFrequencyLabel.textContent = 'First Month + Deposit + Fee';
            monthlyEquivalent.textContent = 'Monthly: ₱' + basePrice.toLocaleString('en-PH');
            
            document.getElementById('paymentFrequency').value = 'Monthly';
        }
    }

    function updateReview() {
        document.getElementById('reviewName').textContent = document.getElementById('buyFullName').value;
        document.getElementById('reviewEmail').textContent = document.getElementById('buyEmail').value;
        document.getElementById('reviewPhone').textContent = document.getElementById('buyPhone').value;
        
        const paymentMethods = {
            'GCash': 'GCash',
            'PayMaya': 'PayMaya',
            'Debit': 'Debit Card',
            'Cash': 'Cash'
        };
        document.getElementById('reviewPayment').textContent = paymentMethods[document.getElementById('selectedPayment').value];

