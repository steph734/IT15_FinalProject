    function updateStepDisplay() {
        console.log('updateStepDisplay called, currentStep:', currentStep);
        
        // Hide all steps and reset indicators
        for (let i = 1; i <= totalSteps; i++) {
            const stepContent = document.getElementById('buyStep' + i);
            console.log('Step ' + i + ' element:', stepContent);
            if (stepContent) {
                stepContent.style.display = 'none';
                console.log('Step ' + i + ' hidden');
            }
            
            const indicator = document.getElementById('buyStep' + i + 'Indicator');
            if (indicator) {
                indicator.classList.remove('active', 'completed');
                const circle = indicator.querySelector('.step-circle');
                if (circle) {
                    circle.textContent = i;
                    circle.innerHTML = i;
                }
            }
        }

        // Show current step
        const currentStepContent = document.getElementById('buyStep' + currentStep);
        console.log('Current step element (buyStep' + currentStep + '):', currentStepContent);
        if (currentStepContent) {
            currentStepContent.style.display = 'block';
            console.log('Step ' + currentStep + ' shown');
        }
        
        const currentIndicator = document.getElementById('buyStep' + currentStep + 'Indicator');
        if (currentIndicator) {
            currentIndicator.classList.add('active');
        }

        // Mark previous steps as completed
        for (let i = 1; i < currentStep; i++) {
            const prevIndicator = document.getElementById('buyStep' + i + 'Indicator');
            if (prevIndicator) {
                prevIndicator.classList.add('completed');
                const prevCircle = prevIndicator.querySelector('.step-circle');
                if (prevCircle) {
                    prevCircle.innerHTML = '<i class="fas fa-check"></i>';
                }
            }
        }

        // Update lines
        for (let i = 1; i < totalSteps; i++) {
            const line = document.getElementById('buyLine' + i);
            if (line) {
                if (i < currentStep) {
                    line.classList.add('completed');
                } else {
                    line.classList.remove('completed');
                }
            }
        }

        // Update buttons
        const prevBtn = document.getElementById('buyPrevStep');
        const nextBtn = document.getElementById('buyNextStep');
        const submitBtn = document.getElementById('buySubmitPurchase');
        
        if (prevBtn) prevBtn.style.display = currentStep > 1 ? 'inline-block' : 'none';
        if (nextBtn) nextBtn.style.display = currentStep < totalSteps - 1 ? 'inline-block' : 'none';
        if (submitBtn) submitBtn.style.display = currentStep === totalSteps - 1 ? 'inline-block' : 'none';

        // Update review on step 4
        if (currentStep === 4) {
            updateReview();
        }
    }

    function nextStep() {
        if (currentStep < totalSteps - 1) {
            // Validate current step
            if (currentStep === 1 && !validateStep1()) return;
            if (currentStep === 3 && !validateStep3()) return;

            currentStep++;
            updateStepDisplay();
        }
    }

    function previousStep() {
        if (currentStep > 1) {
            currentStep--;
            updateStepDisplay();
        }
    }

