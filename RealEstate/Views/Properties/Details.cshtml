        console.log('Stored client coordinates:', storedClientLatitude, storedClientLongitude);

        // If property coordinates are not available, use a warning but allow proceeding
        if (!agentPropertyLat || !agentPropertyLng) {
            console.warn('Property coordinates are missing from database');
            alert('Warning: Property coordinates are not set in the database. The map may not be accurate. Please contact support to update property location.');
            // Use Davao coordinates as fallback for this specific case
            agentPropertyLat = 7.0731; // Davao City center
            agentPropertyLng = 125.6128;
            console.log('Using Davao fallback coordinates:', agentPropertyLat, agentPropertyLng);
        }
        
        // If client coordinates are not available, use a warning but allow proceeding
        if (!storedClientLatitude || !storedClientLongitude) {
            console.warn('Client coordinates are missing from geolocation');
            alert('Warning: Your location was not captured. The map may not be accurate. Please enable location services.');
            // Use a reasonable offset from property for demonstration
            const typicalDistanceKm = 14.2; // Based on user's real distance
            const degreesPerKm = 1 / 111;
            const offset = typicalDistanceKm * degreesPerKm;
            targetClientLat = agentPropertyLat + offset;
            targetClientLng = agentPropertyLng + offset;
            console.log('Using estimated client coordinates based on 14.2km distance:', targetClientLat, targetClientLng);
        } else {
            targetClientLat = storedClientLatitude;
            targetClientLng = storedClientLongitude;
            console.log('Using actual client coordinates from geolocation');
        }

        // Set initial agent location at property
        currentAgentLat = agentPropertyLat;
        currentAgentLng = agentPropertyLng;

        // Calculate distance from property to client location
        const distance = calculateDistance(agentPropertyLat, agentPropertyLng, targetClientLat, targetClientLng);
        console.log('Calculated distance:', distance, 'km');
        
        // Calculate ETA based on average speed (adjusting for urban conditions)
        // Use a more realistic average speed of 25-35 km/h depending on distance
        let averageSpeedKmh;
        if (distance < 2) {
            averageSpeedKmh = 25; // Slower in dense urban areas for short distances
        } else if (distance < 5) {
            averageSpeedKmh = 30; // Moderate speed for medium distances
        } else {
            averageSpeedKmh = 35; // Faster for longer distances
        }
        const etaMinutes = (distance / averageSpeedKmh) * 60;
        console.log('Average speed:', averageSpeedKmh, 'km/h');
        console.log('ETA:', etaMinutes, 'minutes');

        // Update UI with real distance and ETA
        document.getElementById('trackingETA').textContent = `${Math.round(etaMinutes)} minutes`;
        document.getElementById('trackingDistance').textContent = `${distance.toFixed(2)} km`;

        // Center map between property and client locations
        const centerLat = (agentPropertyLat + targetClientLat) / 2;
        const centerLng = (agentPropertyLng + targetClientLng) / 2;
        agentTrackingMap = L.map('agentTrackingMap').setView([centerLat, centerLng], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(agentTrackingMap);

        // Add property location marker (orange)
        const propertyIcon = L.divIcon({
            className: 'custom-marker',
            html: '<div style="background:#FF9500;width:20px;height:20px;border-radius:50%;border:3px solid white;box-shadow:0 2px 8px rgba(0,0,0,0.3);"></div>',
            iconSize: [20, 20],
            iconAnchor: [10, 10]
        });

        L.marker([agentPropertyLat, agentPropertyLng], { icon: propertyIcon }).addTo(agentTrackingMap)
            .bindPopup('Property Location');

        // Add client location marker (red)
        const clientIcon = L.divIcon({
            className: 'custom-marker',
            html: '<div style="background:#DC2626;width:20px;height:20px;border-radius:50%;border:3px solid white;box-shadow:0 2px 8px rgba(0,0,0,0.3);"></div>',
            iconSize: [20, 20],
            iconAnchor: [10, 10]
        });

        L.marker([targetClientLat, targetClientLng], { icon: clientIcon }).addTo(agentTrackingMap)
            .bindPopup('Your Location');

        // Add agent location marker (blue) - starts at property
        const agentIcon = L.divIcon({
            className: 'custom-marker',
            html: '<div style="background:#3B82F6;width:20px;height:20px;border-radius:50%;border:3px solid white;box-shadow:0 2px 8px rgba(0,0,0,0.3);"></div>',
            iconSize: [20, 20],
            iconAnchor: [10, 10]
        });

        agentLocationMarker = L.marker([currentAgentLat, currentAgentLng], { icon: agentIcon }).addTo(agentTrackingMap)
            .bindPopup('Agent Location');

        // Draw route line from property to client location
        const routeLine = L.polyline([
            [agentPropertyLat, agentPropertyLng],
            [targetClientLat, targetClientLng]
        ], {
            color: '#10B981',
            weight: 4,
            opacity: 0.7,
            dashArray: '10, 10'
        }).addTo(agentTrackingMap);

        // Fit map to show all markers
        const group = L.featureGroup([
            L.marker([agentPropertyLat, agentPropertyLng]),
            L.marker([targetClientLat, targetClientLng]),
            agentLocationMarker
        ]);
        agentTrackingMap.fitBounds(group.getBounds().pad(0.1));

        // Start polling for broker location updates from backend
        startBrokerLocationPolling();
    }

    function startBrokerLocationPolling() {
        // Poll for broker location every 10 seconds
        brokerLocationPollingInterval = setInterval(() => {
            fetchBrokerLocation();
        }, 10000); // 10 seconds
    }

    async function fetchBrokerLocation() {
        if (!currentAppointmentId) {
            return;
        }

        try {
            const response = await fetch(`/broker/api/pickup-appointments/${currentAppointmentId}/location`);
            const data = await response.json();

            if (data.success && data.latitude && data.longitude) {
                // Update agent location marker with broker location from backend
                if (agentLocationMarker) {
                    agentLocationMarker.setLatLng([data.latitude, data.longitude]);
                    
                    // Update current agent coordinates
                    currentAgentLat = data.latitude;
                    currentAgentLng = data.longitude;

                    // Calculate remaining distance
                    const remainingDistance = calculateDistance(currentAgentLat, currentAgentLng, targetClientLat, targetClientLng);
                    
                    // Calculate remaining ETA with dynamic speed based on distance
                    let averageSpeedKmh;
                    if (remainingDistance < 2) {
                        averageSpeedKmh = 25;
                    } else if (remainingDistance < 5) {
                        averageSpeedKmh = 30;
                    } else {
                        averageSpeedKmh = 35;
                    }
                    const remainingEtaMinutes = (remainingDistance / averageSpeedKmh) * 60;

                    // Update UI
                    document.getElementById('trackingETA').textContent = `${Math.round(remainingEtaMinutes)} minutes`;
                    document.getElementById('trackingDistance').textContent = `${remainingDistance.toFixed(2)} km`;

                    // Check if broker has arrived
                    if (remainingDistance < 0.01) {
                        clearInterval(brokerLocationPollingInterval);
                        document.getElementById('trackingETA').textContent = 'Arrived';
                        document.getElementById('trackingDistance').textContent = '0 km';
                        
                        // Update agent status to show arrival
                        const agentStatusDiv = document.querySelector('.alert-info');
                        if (agentStatusDiv) {
                            agentStatusDiv.innerHTML = `
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fas fa-check-circle me-2" style="color:#10B981;"></i>
                                    <strong>Agent has arrived!</strong>
                                </div>
                                <div style="font-size:0.85rem;">
                                    Your agent is now at your pickup location.
                                </div>
                            `;
                            agentStatusDiv.className = 'alert alert-success';
                        }
                        
                        alert('Your agent has arrived at the pickup location!');
                    }
                }
            }
        } catch (error) {
            console.error('Error fetching broker location:', error);
        }
    }

    // Haversine formula to calculate distance between two coordinates in kilometers
    function calculateDistance(lat1, lon1, lat2, lon2) {
        const R = 6371; // Earth's radius in kilometers
        const dLat = toRadians(lat2 - lat1);
        const dLon = toRadians(lon2 - lon1);
        
        const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                  Math.cos(toRadians(lat1)) * Math.cos(toRadians(lat2)) *
                  Math.sin(dLon / 2) * Math.sin(dLon / 2);
        
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        const distance = R * c;
        
        return distance;
    }

    function toRadians(degrees) {
        return degrees * (Math.PI / 180);
    }

