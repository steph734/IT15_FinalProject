        if (propertyType === 'Rent') {
            const paymentFrequency = document.querySelector('input[name="paymentFrequencyOption"]:checked').value;
            const totalAmount = document.getElementById('totalAmountInput').value;
            document.getElementById('reviewTotalAmount').textContent = '₱' + parseFloat(totalAmount).toLocaleString('en-PH');
            
            if (paymentFrequency === 'Yearly') {
                document.getElementById('reviewDiscountRow').style.display = 'flex';
                document.getElementById('reviewPaymentFrequency').textContent = 'Yearly Payment (12 months) - 10% Discount Applied';
            } else {
                document.getElementById('reviewDiscountRow').style.display = 'none';
                document.getElementById('reviewPaymentFrequency').textContent = 'First Month + Deposit + Fee';
            }
        }
    }

    async function submitForm() {
        // Validate terms and conditions
        const agreeTerms = document.getElementById('agreeTerms');
        if (!agreeTerms || !agreeTerms.checked) {
            alert('Please agree to the Terms and Conditions to proceed');
            return false;
        }

        // Get form data
        const form = document.getElementById('buyPropertyForm');
        const formData = new FormData(form);
        
        // Convert to JSON object
        const data = {
            propertyId: parseInt(formData.get('propertyId')),
            propertyType: formData.get('propertyType'),
            fullName: formData.get('fullName'),
            email: formData.get('email'),
            phoneNumber: formData.get('phoneNumber'),
            address: formData.get('address'),
            totalAmount: parseFloat(formData.get('totalAmount')),
            paymentMethod: formData.get('paymentMethod'),
            paymentFrequency: formData.get('paymentFrequency') || null
        };

        console.log('Submitting buy property request:', data);

        try {
            const response = await fetch('/Properties/BuyProperty', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (result.success) {
                // Move to confirmation step
                currentStep = 5;
                updateStepDisplay();
                
                // Hide footer buttons
                document.getElementById('prevStep').style.display = 'none';
                document.getElementById('nextStep').style.display = 'none';
                document.getElementById('submitPurchase').style.display = 'none';
            } else {
                alert('Purchase failed: ' + result.error);
            }
        } catch (error) {
            console.error('Error submitting purchase:', error);
            alert('An error occurred while processing your request. Please try again.');
        }

        return false;
    }

