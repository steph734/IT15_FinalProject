    // Calculate and display route (simplified - straight line for demo)
    function calculateRoute() {
        const startAddress = document.getElementById('clientStartLocation').value.trim();
        
        if (!startAddress) {
            alert('Please enter your starting location.');
            return;
        }
        
        // For demo: Geocode the address (in real app, use proper geocoding service)
        // Here we'll simulate by placing a marker at a random offset or using stored coordinates
        
        // Check if address contains lat/lng (from detectClientLocation)
        let clientLat, clientLng;
        const latLngMatch = startAddress.match(/Lat:\s*([\d.]+).*Lng:\s*([\d.]+)/);
        
        if (latLngMatch) {
            clientLat = parseFloat(latLngMatch[1]);
            clientLng = parseFloat(latLngMatch[2]);
        } else {
            // Simulate geocoding - for demo, offset from property by random amount
            // In real app, you'd call your geocoding API here
            alert('Geocoding address... (Demo: Using approximate location)');
            clientLat = parseFloat(propertyLat) + (Math.random() - 0.5) * 0.05;
            clientLng = parseFloat(propertyLng) + (Math.random() - 0.5) * 0.05;
        }
        
        // Add client marker
        addClientMarker(clientLat, clientLng);
        
        // Draw route line
        if (routeLine) {
            routeMap.removeLayer(routeLine);
        }
        
        routeLine = L.polyline(
            [[clientLat, clientLng], [parseFloat(propertyLat), parseFloat(propertyLng)]],
            { color: '#10B981', weight: 4, opacity: 0.8, dashArray: '10, 10' }
        ).addTo(routeMap);
        
        // Calculate distance (Haversine formula)
        const distance = calculateDistance(clientLat, clientLng, parseFloat(propertyLat), parseFloat(propertyLng));
        const timeMinutes = Math.round(distance / 40 * 60); // Assume 40 km/h average speed
        
        // Show route info
        document.getElementById('routeDistance').textContent = distance.toFixed(1) + ' km';
        document.getElementById('routeTime').textContent = timeMinutes + ' mins';
        document.getElementById('routeInfo').classList.remove('d-none');
        
        // Build Google Maps link
        const googleMapsUrl = `https://www.google.com/maps/dir/?api=1&origin=${clientLat},${clientLng}&destination=${propertyLat},${propertyLng}&travelmode=driving`;
        document.getElementById('googleMapsLink').href = googleMapsUrl;
        document.getElementById('googleMapsLink').classList.remove('d-none');
        
        // Fit map to show both markers
        fitMapToBounds();
    }
    
    // Calculate distance between two points using Haversine formula
    function calculateDistance(lat1, lng1, lat2, lng2) {
        const R = 6371; // Earth's radius in km
        const dLat = (lat2 - lat1) * Math.PI / 180;
        const dLng = (lng2 - lng1) * Math.PI / 180;
        const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
                  Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                  Math.sin(dLng/2) * Math.sin(dLng/2);
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
        return R * c;
    }
    
    // Fit map to show both property and client markers
    function fitMapToBounds() {
        if (!routeMap) return;
        
        const bounds = L.latLngBounds();
        bounds.extend([parseFloat(propertyLat), parseFloat(propertyLng)]);
        
        if (clientMarker) {
            const clientLatLng = clientMarker.getLatLng();
            bounds.extend([clientLatLng.lat, clientLatLng.lng]);
        }
        
        routeMap.fitBounds(bounds, { padding: [50, 50] });
    }
    
