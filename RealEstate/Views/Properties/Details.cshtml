                            <div class="mb-3 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                <div style="font-size:0.8rem;color:#6B7280;font-weight:600;margin-bottom:5px;">PERSONAL INFORMATION</div>
                                <div id="pickupReviewName" style="font-weight:700;color:#1E3A5F;"></div>
                                <div id="pickupReviewEmail" style="font-size:0.85rem;color:#6B7280;"></div>
                                <div id="pickupReviewPhone" style="font-size:0.85rem;color:#6B7280;"></div>
                            </div>
                            <div class="mb-3 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                <div style="font-size:0.8rem;color:#6B7280;font-weight:600;margin-bottom:5px;">SCHEDULE</div>
                                <div id="pickupReviewDateTime" style="font-weight:700;color:#1E3A5F;"></div>
                            </div>
                            <div class="mb-3">
                                <div style="font-size:0.8rem;color:#6B7280;font-weight:600;margin-bottom:5px;">PICKUP LOCATION</div>
                                <div id="pickupReviewAddress" style="font-weight:700;color:#1E3A5F;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>

            <div class="modal-footer" style="border-top:1px solid #E5E7EB;padding:16px 24px;background:#F8F9FA;">
                <div class="d-flex justify-content-between w-100">
                    <button type="button" class="btn btn-outline-secondary" onclick="backToAppointmentType()" style="border-radius:8px;padding:10px 24px;">
                        <i class="fas fa-times me-2"></i>Cancel
                    </button>
                    <div>
                        <button type="button" class="btn btn-outline-secondary me-2" onclick="pickupPreviousStep()" id="pickupPrevBtn" style="display:none;border-radius:8px;padding:10px 24px;">
                            <i class="fas fa-arrow-left me-2"></i>Previous
                        </button>
                        <button type="button" class="btn btn-primary" onclick="pickupNextStep()" id="pickupNextBtn" style="background:linear-gradient(135deg,#3B82F6,#2563EB);border:none;padding:10px 32px;font-weight:600;border-radius:8px;">
                            Next <i class="fas fa-arrow-right ms-2"></i>
                        </button>
                        <button type="button" class="btn btn-success" onclick="proceedToLocationTracking()" id="pickupSubmitBtn" style="display:none;background:linear-gradient(135deg,#22C55E,#16A34A);border:none;padding:10px 32px;font-weight:600;border-radius:8px;">
                            <i class="fas fa-check me-2"></i>Submit & Track Agent
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Agent Location Tracking Modal -->
<div class="modal fade" id="agentTrackingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:none;overflow:hidden;">
            <div class="modal-header" style="background:linear-gradient(135deg,#3B82F6,#2563EB);color:white;border:none;padding:24px;">
                <div>
                    <h5 class="modal-title" style="font-weight:700;font-size:1.3rem;">
                        <i class="fas fa-map-marked-alt me-2"></i>Track Agent Location
                    </h5>
                    <p style="margin:5px 0 0;font-size:0.85rem;opacity:0.9;">Monitor your agent's location in real-time</p>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding:24px;">
                <div class="row g-3">
                    <!-- Left: Agent Info -->
                    <div class="col-md-5">
                        <div class="mb-3">
                            <label class="form-label" style="font-weight:600;color:#1E3A5F;">
                                <i class="fas fa-user me-2" style="color:#3B82F6;"></i>Agent Status
                            </label>
                            <div class="alert alert-info" style="border-radius:8px;">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fas fa-spinner fa-spin me-2"></i>
                                    <strong>Agent is on the way</strong>
                                </div>
                                <div style="font-size:0.85rem;">
                                    Your agent will arrive at your pickup location soon.
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="font-weight:600;color:#1E3A5F;">
                                <i class="fas fa-building me-2" style="color:#FF9500;"></i>Property Location
                            </label>
                            <div class="alert alert-warning" style="border-radius:8px;">
                                <div id="trackingPropertyAddress" style="font-size:0.85rem;">@Model.Property?.Location ?? "Property Address"</div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="font-weight:600;color:#1E3A5F;">
                                <i class="fas fa-map-marker-alt me-2 text-danger"></i>Your Location
                            </label>
                            <div class="alert alert-secondary" style="border-radius:8px;">
                                <div id="trackingPickupAddress" style="font-size:0.85rem;"></div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="font-weight:600;color:#1E3A5F;">
                                <i class="fas fa-clock me-2" style="color:#3B82F6;"></i>Estimated Arrival
                            </label>
                            <div class="alert alert-success" style="border-radius:8px;">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fas fa-car me-2"></i>
                                    <strong>ETA: <span id="trackingETA">Calculating...</span></strong>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-road me-2"></i>
                                    <strong>Distance: <span id="trackingDistance">-</span></strong>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4">
                            <button type="button" class="btn btn-outline-primary w-100 mb-2" onclick="refreshAgentLocation()" style="border-radius:8px;">
                                <i class="fas fa-sync-alt me-2"></i>Refresh Location
                            </button>
                            <button type="button" class="btn btn-success w-100" onclick="closeTrackingModal()" style="border-radius:8px;background:linear-gradient(135deg,#22C55E,#16A34A);border:none;">
                                <i class="fas fa-check me-2"></i>Done
                            </button>
                        </div>
                    </div>

                    <!-- Right: Map -->
                    <div class="col-md-7">
                        <div id="agentTrackingMap" style="height:400px;border-radius:12px;border:2px solid #E5E7EB;background-color:#f0f0f0;"></div>
                        <div class="mt-2 d-flex gap-3" style="font-size:0.8rem;">
                            <span><i class="fas fa-building text-warning me-1"></i>Property Location</span>
                            <span><i class="fas fa-map-marker-alt text-danger me-1"></i>Your Location</span>
                            <span><i class="fas fa-car text-primary me-1"></i>Agent Location</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Schedule Viewing Modal -->
<div class="modal fade" id="scheduleViewingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:none;overflow:hidden;">
                        <div class="modal-header" style="background:linear-gradient(135deg,#FF9500,#FF8C00);color:white;border:none;padding:24px;">
                            <div>
                                <h5 class="modal-title" style="font-weight:700;font-size:1.3rem;">
                                    <i class="fas fa-calendar-alt me-2"></i>Schedule Viewing
                                </h5>
                                <p style="margin:5px 0 0;font-size:0.85rem;opacity:0.9;"><span id="stepCounter">Step 1 of 5</span> - Book a visit to see this property</p>
                            </div>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>

                        <!-- Progress Bar -->
                        <div style="padding:20px 24px;background:#F8F9FA;border-bottom:1px solid #E5E7EB;">
                            <div style="display:flex;justify-content:space-between;align-items:center;position:relative;margin-bottom:15px;">
                                <div style="position:absolute;top:20px;left:0;right:0;height:2px;background:#E5E7EB;z-index:0;"></div>
                                <div class="progress-step" style="flex:1;display:flex;flex-direction:column;align-items:center;position:relative;z-index:1;">
                                    <div class="step-indicator active" style="width:40px;height:40px;border-radius:50%;background:#FF9500;color:white;display:flex;align-items:center;justify-content:center;font-weight:700;margin-bottom:8px;">1</div>
                                    <div style="font-size:0.8rem;font-weight:600;color:#FF9500;text-align:center;">Personal</div>
                                </div>
                                <div class="progress-step" style="flex:1;display:flex;flex-direction:column;align-items:center;position:relative;z-index:1;">
                                    <div class="step-indicator" style="width:40px;height:40px;border-radius:50%;background:#E5E7EB;color:#9CA3AF;display:flex;align-items:center;justify-content:center;font-weight:700;margin-bottom:8px;">2</div>
                                    <div style="font-size:0.8rem;font-weight:600;color:#6B7280;text-align:center;">Schedule</div>
                                </div>
                                <div class="progress-step" style="flex:1;display:flex;flex-direction:column;align-items:center;position:relative;z-index:1;">
                                    <div class="step-indicator" style="width:40px;height:40px;border-radius:50%;background:#E5E7EB;color:#9CA3AF;display:flex;align-items:center;justify-content:center;font-weight:700;margin-bottom:8px;">3</div>
                                    <div style="font-size:0.8rem;font-weight:600;color:#6B7280;text-align:center;">Review</div>
                                </div>
                                <div class="progress-step" style="flex:1;display:flex;flex-direction:column;align-items:center;position:relative;z-index:1;">
                                    <div class="step-indicator" style="width:40px;height:40px;border-radius:50%;background:#E5E7EB;color:#9CA3AF;display:flex;align-items:center;justify-content:center;font-weight:700;margin-bottom:8px;">4</div>
                                    <div style="font-size:0.8rem;font-weight:600;color:#6B7280;text-align:center;">Payment</div>
                                </div>
                                <div class="progress-step" style="flex:1;display:flex;flex-direction:column;align-items:center;position:relative;z-index:1;">
                                    <div class="step-indicator" style="width:40px;height:40px;border-radius:50%;background:#E5E7EB;color:#9CA3AF;display:flex;align-items:center;justify-content:center;font-weight:700;margin-bottom:8px;">5</div>
                                    <div style="font-size:0.8rem;font-weight:600;color:#6B7280;text-align:center;">Done</div>
                                </div>
                            </div>
                            <div style="height:4px;background:#E5E7EB;border-radius:2px;overflow:hidden;">
                                <div id="progressFill" style="height:100%;background:linear-gradient(90deg,#FF9500,#FF8C00);width:20%;transition:width 0.3s;"></div>
                            </div>
                        </div>

                        <form id="scheduleViewingForm" method="post" action="/Properties/ScheduleViewing">
                            <input type="hidden" name="propertyId" value="@p.Id" />
                            <input type="hidden" name="appointmentType" id="appointmentTypeField" value="self" />
                            @Html.AntiForgeryToken()
                            <div class="modal-body" style="padding:24px;max-height:600px;overflow-y:auto;">

                                <!-- Step 1: Personal Details -->
                                <div class="form-step active" id="step1" style="display:block;">
                                    <h6 style="font-weight:700;color:#1E3A5F;margin-bottom:20px;"><i class="fas fa-user me-2" style="color:#FF9500;"></i>Personal Details</h6>
                                    
                                    <!-- Pickup Address (shown only when pickup is selected) -->
                                    <div class="mb-3" id="pickupAddressContainer" style="display:none;">
                                        <label for="customerAddress" class="form-label" style="font-weight:600;color:#1E3A5F;">
                                            <i class="fas fa-map-marker-alt me-2" style="color:#FF9500;"></i>Your Pickup Address <span class="text-danger">*</span>
                                        </label>
                                        <textarea class="form-control" id="customerAddress" name="Schedule.CustomerAddress" rows="2" placeholder="Enter your complete address for pickup..." style="border-radius:8px;padding:12px;"></textarea>
                                        <div class="form-text" style="font-size:0.8rem;color:#6B7280;">
                                            Our agent will pick you up from this location.
                                        </div>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label for="viewingFullName" class="form-label" style="font-weight:600;color:#1E3A5F;">Full Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="viewingFullName" name="Schedule.Name" required placeholder="Juan Dela Cruz" style="border-radius:8px;padding:12px;" />
                                    </div>
                                    <div class="mb-3">
                                        <label for="viewingEmail" class="form-label" style="font-weight:600;color:#1E3A5F;">Email Address <span class="text-danger">*</span></label>
                                        <input type="email" class="form-control" id="viewingEmail" name="Schedule.Email" required placeholder="juan@email.com" style="border-radius:8px;padding:12px;" />
                                    </div>
                                    <div class="mb-3">
                                        <label for="viewingPhone" class="form-label" style="font-weight:600;color:#1E3A5F;">Phone Number <span class="text-danger">*</span></label>
                                        <input type="tel" class="form-control" id="viewingPhone" name="Schedule.Phone" required placeholder="+63 9XX XXX XXXX" style="border-radius:8px;padding:12px;" />
                                    </div>
                                    <div class="mb-3">
                                        <label for="viewingPhoto" class="form-label" style="font-weight:600;color:#1E3A5F;">Profile Photo <span style="color:#9CA3AF;">(Optional)</span></label>
                                        <div style="border:2px dashed #E5E7EB;border-radius:8px;padding:20px;text-align:center;cursor:pointer;" onclick="document.getElementById('viewingPhotoInput').click();">
                                            <i class="fas fa-cloud-upload-alt" style="font-size:2rem;color:#FF9500;margin-bottom:10px;display:block;"></i>
                                            <div style="font-weight:600;color:#1E3A5F;">Click to upload photo</div>
                                            <div style="font-size:0.85rem;color:#9CA3AF;">JPG, PNG or GIF (Max 2MB)</div>
                                        </div>
                                        <input type="file" id="viewingPhotoInput" name="Schedule.CustomerPhotoUrl" accept="image/*" style="display:none;" />
                                        <div id="photoPreview" style="margin-top:10px;display:none;">
                                            <img id="photoPreviewImg" src="" alt="Preview" style="max-width:100px;max-height:100px;border-radius:8px;" />
                                        </div>
                                    </div>
                                </div>

                                <!-- Step 2: Schedule & Preferences -->
                                <div class="form-step" id="step2" style="display:none;">
                                    <h6 style="font-weight:700;color:#1E3A5F;margin-bottom:20px;"><i class="fas fa-calendar me-2" style="color:#FF9500;"></i>Schedule & Preferences</h6>
                                    <div class="mb-3">
                                        <label for="viewingDate" class="form-label" style="font-weight:600;color:#1E3A5F;">Preferred Date <span class="text-danger">*</span></label>
                                        <input type="date" class="form-control" id="viewingDate" name="Schedule.PreferredDate" required style="border-radius:8px;padding:12px;" />
                                    </div>
                                    <div class="mb-3">
                                        <label for="viewingTime" class="form-label" style="font-weight:600;color:#1E3A5F;">Preferred Time</label>
                                        <select class="form-control" id="viewingTime" name="Schedule.PreferredTime" style="border-radius:8px;padding:12px;">
                                            <option value="">Select time slot</option>
                                            <option value="09:00 AM">09:00 AM</option>
                                            <option value="10:00 AM">10:00 AM</option>
                                            <option value="11:00 AM">11:00 AM</option>
                                            <option value="01:00 PM">01:00 PM</option>
                                            <option value="02:00 PM">02:00 PM</option>
                                            <option value="03:00 PM">03:00 PM</option>
                                            <option value="04:00 PM">04:00 PM</option>
                                            <option value="05:00 PM">05:00 PM</option>
                                        </select>
                                    </div>

                                    <!-- Weather Forecast Widget -->
                                    <div id="weatherWidget" style="display:none;"></div>

                                    <div class="mb-3">
                                        <label for="viewingVisitors" class="form-label" style="font-weight:600;color:#1E3A5F;">Number of Visitors</label>
                                        <select class="form-control" id="viewingVisitors" name="Schedule.NumberOfVisitors" style="border-radius:8px;padding:12px;">
                                            <option value="1">Just me (1 person)</option>
                                            <option value="2">2 people</option>
                                            <option value="3">3 people</option>
                                            <option value="4">4 people</option>
                                            <option value="5">5+ people</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label for="viewingBuyerType" class="form-label" style="font-weight:600;color:#1E3A5F;">Buyer Type <span class="text-danger">*</span></label>
                                        <select class="form-control" id="viewingBuyerType" name="Schedule.BuyerType" required style="border-radius:8px;padding:12px;">
                                            <option value="">Select buyer type</option>
                                            <option value="first-time">First-time Buyer</option>
                                            <option value="experienced">Experienced Buyer</option>
                                            <option value="investor">Investor</option>
                                            <option value="renter">Renter</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label for="viewingFinancing" class="form-label" style="font-weight:600;color:#1E3A5F;">Financing Status</label>
                                        <select class="form-control" id="viewingFinancing" name="Schedule.FinancingStatus" style="border-radius:8px;padding:12px;">
                                            <option value="">Select financing status</option>
                                            <option value="preapproved">Pre-approved</option>
                                            <option value="need-financing">Need Financing</option>
                                            <option value="cash">Paying Cash</option>
                                            <option value="undecided">Still Deciding</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label for="viewingSource" class="form-label" style="font-weight:600;color:#1E3A5F;">How Did You Hear About Us?</label>
                                        <select class="form-control" id="viewingSource" name="Schedule.InformationSource" style="border-radius:8px;padding:12px;">
                                            <option value="">Select source</option>
                                            <option value="website">Website</option>
                                            <option value="social-media">Social Media</option>
                                            <option value="referral">Referral</option>
                                            <option value="agent">Real Estate Agent</option>
                                            <option value="other">Other</option>
                                        </select>
                                    </div>
                                    <div class="mb-3" id="pickupAddressContainer" style="display:none;">
                                        <label for="customerAddress" class="form-label" style="font-weight:600;color:#1E3A5F;">
                                            <i class="fas fa-map-marker-alt me-2" style="color:#FF9500;"></i>Your Pickup Address <span class="text-danger">*</span>
                                        </label>
                                        <textarea class="form-control" id="customerAddress" name="Schedule.CustomerAddress" rows="2" placeholder="Enter your complete address for pickup..." style="border-radius:8px;padding:12px;"></textarea>
                                        <div class="form-text" style="font-size:0.8rem;color:#6B7280;">
                                            Our agent will pick you up from this location.
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label for="viewingNotes" class="form-label" style="font-weight:600;color:#1E3A5F;">Additional Notes</label>
                                        <textarea class="form-control" id="viewingNotes" name="Schedule.Notes" rows="3" placeholder="Tell us anything we should know..." style="border-radius:8px;padding:12px;"></textarea>
                                    </div>
                                </div>

                                <!-- Step 3: Review -->
                                <div class="form-step" id="step3" style="display:none;">
                                    <h6 style="font-weight:700;color:#1E3A5F;margin-bottom:20px;"><i class="fas fa-check me-2" style="color:#FF9500;"></i>Review Your Request</h6>
                                    <div style="background:#F8F9FA;padding:20px;border-radius:12px;">
                                        <div class="mb-3 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                            <div style="font-size:0.8rem;color:#9CA3AF;font-weight:600;margin-bottom:5px;">PERSONAL INFORMATION</div>
                                            <div id="reviewName" style="font-weight:700;color:#1E3A5F;"></div>
                                            <div id="reviewEmail" style="font-size:0.85rem;color:#6B7280;"></div>
                                            <div id="reviewPhone" style="font-size:0.85rem;color:#6B7280;"></div>
                                        </div>
                                        <div class="mb-3 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                            <div style="font-size:0.8rem;color:#9CA3AF;font-weight:600;margin-bottom:5px;">VIEWING DETAILS</div>
                                            <div id="reviewDate" style="font-weight:700;color:#1E3A5F;"></div>
                                            <div id="reviewTime" style="font-size:0.85rem;color:#6B7280;"></div>
                                            <div id="reviewVisitors" style="font-size:0.85rem;color:#6B7280;"></div>
                                            <div id="reviewBuyer" style="font-size:0.85rem;color:#6B7280;"></div>
                                            <div id="reviewFinancing" style="font-size:0.85rem;color:#6B7280;"></div>
                                            <div id="reviewSource" style="font-size:0.85rem;color:#6B7280;"></div>
                                        </div>
                                        <div id="reviewNotesSection" style="margin-bottom:15px;display:none;">
                                            <div style="font-size:0.8rem;color:#9CA3AF;font-weight:600;margin-bottom:5px;">ADDITIONAL NOTES</div>
                                            <div id="reviewNotes" style="font-size:0.85rem;color:#6B7280;font-style:italic;"></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Step 4: Payment -->
                                <div class="form-step" id="step4" style="display:none;">
                                    <h6 style="font-weight:700;color:#1E3A5F;margin-bottom:20px;"><i class="fas fa-credit-card me-2" style="color:#FF9500;"></i>Secure Your Viewing</h6>
                                    <div style="background:#F8F9FA;padding:20px;border-radius:12px;margin-bottom:20px;">
                                        <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                            <span style="font-weight:600;color:#6B7280;">Viewing Reservation Fee</span>
                                            <span style="font-weight:700;color:#1E3A5F;font-size:1.1rem;">₱500.00</span>
                                        </div>
                                        <div class="d-flex justify-content-between" style="font-size:1.2rem;">
                                            <span style="font-weight:700;color:#1E3A5F;">Total</span>
                                            <span style="font-weight:800;color:#FF9500;">₱500.00</span>
                                        </div>
                                    </div>
                                    <div style="margin-bottom:15px;">
                                        <div style="font-size:0.8rem;color:#9CA3AF;font-weight:600;margin-bottom:10px;">PAYMENT METHOD</div>
                                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                                            <div style="border:2px solid #E5E7EB;border-radius:8px;padding:15px;text-align:center;cursor:pointer;transition:all 0.3s;" onclick="selectPaymentModal(this, 'GCash')">
                                                <i class="fas fa-mobile-alt" style="font-size:1.5rem;color:#007BFF;margin-bottom:8px;display:block;"></i>
                                                <div style="font-weight:600;font-size:0.9rem;">GCash</div>
                                            </div>
                                            <div style="border:2px solid #E5E7EB;border-radius:8px;padding:15px;text-align:center;cursor:pointer;transition:all 0.3s;" onclick="selectPaymentModal(this, 'Maya')">
                                                <i class="fas fa-wallet" style="font-size:1.5rem;color:#8B5CF6;margin-bottom:8px;display:block;"></i>
                                                <div style="font-weight:600;font-size:0.9rem;">Maya</div>
                                            </div>
                                        </div>
                                    </div>
                                    <input type="hidden" id="selectedPaymentMethod" name="paymentMethod" />
                                </div>

                                <!-- Step 5: Confirmation -->
                                <div class="form-step" id="step5" style="display:none;text-align:center;">
                                    <div style="margin-bottom:20px;">
                                        <i class="fas fa-check-circle" style="font-size:3rem;color:#10B981;"></i>
                                    </div>
                                    <h6 style="font-weight:700;color:#1E3A5F;font-size:1.3rem;margin-bottom:10px;">Viewing Scheduled Successfully!</h6>
                                    <p style="color:#6B7280;margin-bottom:20px;">Your viewing appointment has been confirmed. Check your email for details.</p>
                                    <div style="background:#F0FDF4;border:2px solid #10B981;border-radius:8px;padding:15px;">
                                        <div style="font-weight:700;color:#065F46;margin-bottom:10px;">What happens next?</div>
                                        <ul style="list-style:none;padding:0;margin:0;text-align:left;">
                                            <li style="font-size:0.85rem;color:#047857;margin-bottom:8px;"><i class="fas fa-check" style="margin-right:8px;"></i>Confirmation email sent</li>
                                            <li style="font-size:0.85rem;color:#047857;margin-bottom:8px;"><i class="fas fa-check" style="margin-right:8px;"></i>Agent will contact you</li>
                                            <li style="font-size:0.85rem;color:#047857;"><i class="fas fa-check" style="margin-right:8px;"></i>Meet at property on scheduled date</li>
                                        </ul>
                                    </div>
                                </div>

                            </div>

                            <div class="modal-footer" style="border-top:1px solid #E5E7EB;padding:16px 24px;background:#F8F9FA;display:flex;justify-content:space-between;">
                                <button type="button" class="btn btn-secondary" id="prevBtn" onclick="previousStepModal()" style="border-radius:8px;padding:10px 24px;display:none;">
                                    <i class="fas fa-arrow-left me-2"></i>Previous
                                </button>
                                <button type="button" class="btn" id="nextBtn" onclick="nextStepModal()" style="background:linear-gradient(135deg,#FF9500,#FF8C00);color:white;border:none;border-radius:8px;padding:10px 24px;font-weight:600;">
                                    Next <i class="fas fa-arrow-right ms-2"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <script>
            let currentModalStep = 1;
            const totalModalSteps = 5;

            function openScheduleViewingModal() {
                currentModalStep = 1;
                updateModalUI();
                new bootstrap.Modal(document.getElementById('scheduleViewingModal')).show();
            }

            function nextStepModal() {
                if (validateStepModal(currentModalStep)) {
                    if (currentModalStep === 2) updateReviewStepModal();
                    if (currentModalStep === 4) {
                        document.getElementById('scheduleViewingForm').submit();
                        return;
                    }
                    currentModalStep++;
                    updateModalUI();
                }
            }

            function previousStepModal() {
                currentModalStep--;
                updateModalUI();
            }

            function updateModalUI() {
                // Hide all steps
                for (let i = 1; i <= totalModalSteps; i++) {
                    document.getElementById(`step${i}`).style.display = 'none';
                }
                document.getElementById(`step${currentModalStep}`).style.display = 'block';

                // Update step indicators
                document.querySelectorAll('.step-indicator').forEach((el, idx) => {
                    if (idx < currentModalStep - 1) {
                        el.style.background = '#10B981';
                        el.style.color = 'white';
                    } else if (idx === currentModalStep - 1) {
                        el.style.background = '#FF9500';
                        el.style.color = 'white';
                    } else {
                        el.style.background = '#E5E7EB';
                        el.style.color = '#9CA3AF';
                    }
                });

                // Update progress bar
                const progressPercent = (currentModalStep / totalModalSteps) * 100;
                document.getElementById('progressFill').style.width = progressPercent + '%';
                document.getElementById('stepCounter').textContent = `Step ${currentModalStep} of ${totalModalSteps}`;

                // Update buttons
                const prevBtn = document.getElementById('prevBtn');
                const nextBtn = document.getElementById('nextBtn');
                prevBtn.style.display = currentModalStep === 1 ? 'none' : 'block';
                nextBtn.innerHTML = currentModalStep === totalModalSteps ? '<i class="fas fa-check me-2"></i>Close' : 'Next <i class="fas fa-arrow-right ms-2"></i>';
            }

            function validateStepModal(step) {
                const form = document.getElementById('scheduleViewingForm');
                if (step === 1) {
                    const name = form.querySelector('[name="Schedule.Name"]').value;
                    const email = form.querySelector('[name="Schedule.Email"]').value;
                    const phone = form.querySelector('[name="Schedule.Phone"]').value;
                    if (!name || !email || !phone) {
                        alert('Please fill all required fields');
                        return false;
                    }
                }
                if (step === 2) {
                    const date = form.querySelector('[name="Schedule.PreferredDate"]').value;
                    const buyer = form.querySelector('[name="Schedule.BuyerType"]').value;
                    if (!date || !buyer) {
                        alert('Please fill all required fields');
                        return false;
                    }
                }
                return true;
            }

            function updateReviewStepModal() {
                const form = document.getElementById('scheduleViewingForm');
                const name = form.querySelector('[name="Schedule.Name"]').value;
                const email = form.querySelector('[name="Schedule.Email"]').value;
                const phone = form.querySelector('[name="Schedule.Phone"]').value;
                const date = form.querySelector('[name="Schedule.PreferredDate"]').value;
                const time = form.querySelector('[name="Schedule.PreferredTime"]').value;
                const visitors = form.querySelector('[name="Schedule.NumberOfVisitors"]').value;
                const buyer = form.querySelector('[name="Schedule.BuyerType"]').value;
                const financing = form.querySelector('[name="Schedule.FinancingStatus"]').value;
                const source = form.querySelector('[name="Schedule.InformationSource"]').value;
                const notes = form.querySelector('[name="Schedule.Notes"]').value;

                document.getElementById('reviewName').textContent = name;
                document.getElementById('reviewEmail').textContent = email;
                document.getElementById('reviewPhone').textContent = phone;
                document.getElementById('reviewDate').textContent = new Date(date).toLocaleDateString();
                document.getElementById('reviewTime').textContent = time || 'Not specified';
                document.getElementById('reviewVisitors').textContent = 'Visitors: ' + visitors;
                document.getElementById('reviewBuyer').textContent = 'Buyer Type: ' + buyer;
                document.getElementById('reviewFinancing').textContent = 'Financing: ' + (financing || 'Not specified');
                document.getElementById('reviewSource').textContent = 'Source: ' + (source || 'Not specified');
                if (notes) {
                    document.getElementById('reviewNotes').textContent = notes;
                    document.getElementById('reviewNotesSection').style.display = 'block';
                }
            }

            function selectPaymentModal(element, method) {
                document.querySelectorAll('[onclick*="selectPaymentModal"]').forEach(el => {
                    el.style.borderColor = '#E5E7EB';
                    el.style.background = 'white';
                });
                element.style.borderColor = '#FF9500';
                element.style.background = '#FFF3E0';
                document.getElementById('selectedPaymentMethod').value = method;
            }

            // Photo preview
            document.addEventListener('DOMContentLoaded', function() {
                const photoInput = document.getElementById('viewingPhotoInput');
                if (photoInput) {
                    photoInput.addEventListener('change', function(e) {
                        if (e.target.files && e.target.files[0]) {
                            const reader = new FileReader();
                            reader.onload = function(event) {
                                document.getElementById('photoPreviewImg').src = event.target.result;
                                document.getElementById('photoPreview').style.display = 'block';
                            };
                            reader.readAsDataURL(e.target.files[0]);
                        }
                    });
                }
            });
            
            function contactBroker() {
                alert('Contacting Broker: @(Model.Property.Agent?.DisplayName ?? "Agent")\n\nPhone: @(Model.Property.Agent?.PhoneNumber ?? "N/A")\nEmail: @(Model.Property.Agent?.Email ?? "N/A")');
            }
            </script>
        </div>
    </div>
</div>

<!-- Buy Property Modal -->
<div class="modal fade" id="buyPropertyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:none;overflow:hidden;">
            <div class="modal-header" style="background:linear-gradient(135deg,#10B981,#059669);color:white;border:none;padding:24px;">
                <div>
                    <h5 class="modal-title" style="font-weight:700;font-size:1.3rem;">
                        <i class="fas fa-shopping-cart me-2"></i>Buy Property
                    </h5>
                    <p style="margin:5px 0 0;font-size:0.85rem;opacity:0.9;">Complete your purchase in 5 easy steps</p>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding:24px;">
                <!-- Progress Timeline -->
                <div class="progress-timeline mb-4">
                    <div class="d-flex justify-content-between align-items-center position-relative">
                        <div class="step-item active" id="buyStep1Indicator">
                            <div class="step-circle">1</div>
                            <div class="step-label">Personal Details</div>
                        </div>
                        <div class="step-line" id="buyLine1"></div>
                        <div class="step-item" id="buyStep2Indicator">
                            <div class="step-circle">2</div>
                            <div class="step-label">Payment Breakdown</div>
                        </div>
                        <div class="step-line" id="buyLine2"></div>
                        <div class="step-item" id="buyStep3Indicator">
                            <div class="step-circle">3</div>
                            <div class="step-label">Payment Method</div>
                        </div>
                        <div class="step-line" id="buyLine3"></div>
                        <div class="step-item" id="buyStep4Indicator">
                            <div class="step-circle">4</div>
                            <div class="step-label">Review</div>
                        </div>
                        <div class="step-line" id="buyLine4"></div>
                        <div class="step-item" id="buyStep5Indicator">
                            <div class="step-circle">5</div>
                            <div class="step-label">Confirmation</div>
                        </div>
                    </div>
                </div>

                <form id="buyPropertyForm" method="post" action="/Properties/BuyProperty">
                    <input type="hidden" name="propertyId" value="@p.Id" />
                    <input type="hidden" name="propertyType" value="@p.ListingType" />
                    <input type="hidden" name="paymentFrequency" id="paymentFrequency" value="" />
                    @Html.AntiForgeryToken()
                    
                    <!-- Step 1: Personal Details -->
                    <div id="buyStep1" class="buy-step-content" style="display:block;">
                        <h6 style="font-weight:700;color:#1E3A5F;margin-bottom:20px;"><i class="fas fa-user me-2" style="color:#10B981;"></i>Personal Information</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="buyFullName" class="form-label" style="font-weight:600;">Full Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="buyFullName" name="fullName" required placeholder="Juan Dela Cruz" autocomplete="name" style="border-radius:8px;padding:12px;" />
                            </div>
                            <div class="col-md-6">
                                <label for="buyEmail" class="form-label" style="font-weight:600;">Email Address <span class="text-danger">*</span></label>
                                <input type="email" class="form-control" id="buyEmail" name="email" required placeholder="juan@email.com" autocomplete="email" style="border-radius:8px;padding:12px;" />
                            </div>
                            <div class="col-md-6">
                                <label for="buyPhone" class="form-label" style="font-weight:600;">Phone Number <span class="text-danger">*</span></label>
                                <input type="tel" class="form-control" id="buyPhone" name="phoneNumber" required placeholder="+63 9XX XXX XXXX" autocomplete="tel" style="border-radius:8px;padding:12px;" />
                            </div>
                            <div class="col-md-6">
                                <label for="buyAddress" class="form-label" style="font-weight:600;">Address</label>
                                <input type="text" class="form-control" id="buyAddress" name="address" placeholder="123 Main St, City" autocomplete="street-address" style="border-radius:8px;padding:12px;" />
                            </div>
                        </div>
                    </div>

                    <!-- Step 2: Payment Breakdown -->
                    <div id="buyStep2" class="buy-step-content" style="display:none;">
                        <h6 style="font-weight:700;color:#1E3A5F;margin-bottom:20px;"><i class="fas fa-calculator me-2" style="color:#10B981;"></i>Payment Breakdown</h6>
                        
                        <!-- Payment Type Selection -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Payment Type</label>
                            <div class="payment-type-options">
                                @if (p.ListingType == PropertyListingType.Rent)
                                {
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="paymentTypeOption" id="rentPayment" value="Rent" checked onchange="updatePaymentBreakdown()">
                                        <label class="form-check-label" for="rentPayment">
                                            <strong>Rent</strong>
                                        </label>
                                    </div>
                                }
                                else
                                {
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="paymentTypeOption" id="buyPayment" value="Buy" checked onchange="updatePaymentBreakdown()">
                                        <label class="form-check-label" for="buyPayment">
                                            <strong>Buy</strong>
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>

                        @if (p.ListingType == PropertyListingType.Rent)
                        {
                            <!-- Rent Payment Frequency -->
                            <div class="payment-frequency-options mb-4">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="paymentFrequencyOption" id="monthlyPayment" value="Monthly" checked onchange="updatePaymentBreakdown()">
                                    <label class="form-check-label" for="monthlyPayment">
                                        <strong>Monthly Payment</strong>
                                    </label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="paymentFrequencyOption" id="yearlyPayment" value="Yearly" onchange="updatePaymentBreakdown()">
                                    <label class="form-check-label" for="yearlyPayment">
                                        <strong>Yearly Payment (Save 10%)</strong>
                                    </label>
                                </div>
                            </div>
                            <div class="cost-breakdown" style="background:#F8F9FA;padding:20px;border-radius:12px;">
                                <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                    <span style="font-weight:600;color:#6B7280;">Gross Annual Income</span>
                                    <span style="font-weight:700;color:#1E3A5F;font-size:1.1rem;">₱@((p.BasePrice * 12m).ToString("N0"))</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2 pb-2" style="border-bottom:1px solid #E5E7EB;">
                                    <span style="font-weight:600;color:#6B7280;">HOA Dues (Est. ₱15,000/mo)</span>
                                    <span style="font-weight:600;color:#1E3A5F;">₱180,000</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2 pb-2" style="border-bottom:1px solid #E5E7EB;">
                                    <span style="font-weight:600;color:#6B7280;">Real Property Tax (Est.)</span>
                                    <span style="font-weight:600;color:#1E3A5F;">₱30,000</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2 pb-2" style="border-bottom:1px solid #E5E7EB;">
                                    <span style="font-weight:600;color:#6B7280;">Maintenance (Est. ₱5,000/mo)</span>
                                    <span style="font-weight:600;color:#1E3A5F;">₱60,000</span>
                                </div>
                                <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                    <span style="font-weight:700;color:#1E3A5F;">Net Operating Income (NOI)</span>
                                    <span style="font-weight:700;color:#10B981;">₱@((p.BasePrice * 12m - 180000m - 30000m - 60000m).ToString("N0"))</span>
                                </div>
                                <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                    <span style="font-weight:600;color:#6B7280;">Net Rental Yield</span>
                                    <span style="font-weight:700;color:#1E3A5F;">@((p.BasePrice * 12m - 180000m - 30000m - 60000m) / p.BasePrice * 100m).ToString("N2"))%</span>
                                </div>
                                <div class="mb-3 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span style="font-weight:600;color:#6B7280;">Monthly Rent</span>
                                        <span style="font-weight:600;">₱@p.BasePrice.ToString("N0")</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span style="font-weight:600;color:#6B7280;">Security Deposit (1 month)</span>
                                        <span style="font-weight:600;">₱@p.BasePrice.ToString("N0")</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span style="font-weight:600;color:#6B7280;">Processing Fee</span>
                                        <span style="font-weight:600;">₱5,000</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2" id="discountRow" style="display:none;">
                                        <span style="font-weight:600;color:#10B981;">Yearly Discount (10%)</span>
                                        <span style="font-weight:600;color:#10B981;">-₱@((p.BasePrice * 12 * 0.1m).ToString("N0"))</span>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between mb-3" style="font-size:1.2rem;">
                                    <span style="font-weight:700;color:#1E3A5F;">Total Amount Due</span>
                                    <span style="font-weight:800;color:#10B981;" id="totalAmountDisplay">₱@((p.BasePrice * 2 + 5000m).ToString("N0"))</span>
                                </div>
                                <div class="d-flex justify-content-between" style="font-size:0.9rem;color:#6B7280;">
                                    <span id="paymentFrequencyLabel">First Month + Deposit + Fee</span>
                                    <span id="monthlyEquivalent">Monthly: ₱@p.BasePrice.ToString("N0")</span>
                                </div>
                                <div class="alert alert-info" style="font-size:0.85rem;padding:10px;margin-top:15px;">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <strong>Note:</strong> Good rental yield is typically 5-7%. Current yield: @((p.BasePrice * 12m - 180000m - 30000m - 60000m) / p.BasePrice * 100m).ToString("N2"))%
                                </div>
                            </div>
                            <input type="hidden" name="totalAmount" id="totalAmountInput" value="@(p.BasePrice * 2 + 5000m)" />
                        }
                        else
                        {
                            <!-- Sale Payment Breakdown -->
                            <div class="cost-breakdown" style="background:#F8F9FA;padding:20px;border-radius:12px;">
                                <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                    <span style="font-weight:600;color:#6B7280;">Contract Price</span>
                                    <span style="font-weight:700;color:#1E3A5F;font-size:1.1rem;">@priceDisplay</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2 pb-2" style="border-bottom:1px solid #E5E7EB;">
                                    <span style="font-weight:600;color:#6B7280;">Capital Gains Tax (6%)</span>
                                    <span style="font-weight:600;color:#1E3A5F;">₱@((p.BasePrice * 0.06m).ToString("N0"))</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2 pb-2" style="border-bottom:1px solid #E5E7EB;">
                                    <span style="font-weight:600;color:#6B7280;">Broker's Commission (5%)</span>
                                    <span style="font-weight:600;color:#1E3A5F;">₱@((p.BasePrice * 0.05m).ToString("N0"))</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2 pb-2" style="border-bottom:1px solid #E5E7EB;">
                                    <span style="font-weight:600;color:#6B7280;">Notarial Fees (1%)</span>
                                    <span style="font-weight:600;color:#1E3A5F;">₱@((p.BasePrice * 0.01m).ToString("N0"))</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2 pb-2" style="border-bottom:1px solid #E5E7EB;">
                                    <span style="font-weight:600;color:#6B7280;">Documentation Fee</span>
                                    <span style="font-weight:600;color:#1E3A5F;">₱15,000</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2 pb-2" style="border-bottom:1px solid #E5E7EB;">
                                    <span style="font-weight:600;color:#6B7280;">Transfer Tax (1.5%)</span>
                                    <span style="font-weight:600;color:#1E3A5F;">₱@((p.BasePrice * 0.015m).ToString("N0"))</span>
                                </div>
                                <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                    <span style="font-weight:700;color:#1E3A5F;">Net Proceeds (Seller's Take Home)</span>
                                    <span style="font-weight:700;color:#10B981;">₱@((p.BasePrice - (p.BasePrice * 0.06m) - (p.BasePrice * 0.05m) - (p.BasePrice * 0.01m) - 15000m - (p.BasePrice * 0.015m)).ToString("N0"))</span>
                                </div>
                                <div class="alert alert-warning" style="font-size:0.85rem;padding:10px;margin-bottom:15px;">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <strong>Buyer's Additional Costs:</strong> Estimated ₱40,000 for Transfer Tax/Registration
                                </div>
                                <div class="d-flex justify-content-between mb-2 pb-2" style="border-bottom:1px solid #E5E7EB;">
                                    <span style="font-weight:600;color:#6B7280;">Buyer's Transfer Fees (Est.)</span>
                                    <span style="font-weight:600;color:#1E3A5F;">₱40,000</span>
                                </div>
                                <div class="d-flex justify-content-between mb-3" style="font-size:1.2rem;">
                                    <span style="font-weight:700;color:#1E3A5F;">Total for Buyer</span>
                                    <span style="font-weight:800;color:#10B981;">₱@((p.BasePrice + 40000m).ToString("N0"))</span>
                                </div>
                                <div class="alert alert-info" style="font-size:0.85rem;padding:10px;margin-top:15px;">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <strong>Note:</strong> Capital Gains Tax is calculated on the Contract Price
                                </div>
                            </div>
                            <input type="hidden" name="totalAmount" id="totalAmountInput" value="@((p.BasePrice + 40000m))" />
                        }
                    </div>

                    <!-- Step 3: Payment Method -->
                    <div id="buyStep3" class="buy-step-content" style="display:none;">
                        <h6 style="font-weight:700;color:#1E3A5F;margin-bottom:20px;"><i class="fas fa-credit-card me-2" style="color:#10B981;"></i>Select Payment Method</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="payment-option" onclick="selectPayment('GCash')" style="border:2px solid #E5E7EB;border-radius:12px;padding:20px;cursor:pointer;transition:all 0.3s;text-align:center;">
                                    <i class="fas fa-mobile-alt" style="font-size:2rem;color:#007BFF;margin-bottom:10px;"></i>
                                    <div style="font-weight:700;">GCash</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="payment-option" onclick="selectPayment('PayMaya')" style="border:2px solid #E5E7EB;border-radius:12px;padding:20px;cursor:pointer;transition:all 0.3s;text-align:center;">
                                    <i class="fas fa-wallet" style="font-size:2rem;color:#8B5CF6;margin-bottom:10px;"></i>
                                    <div style="font-weight:700;">PayMaya</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="payment-option" onclick="selectPayment('Debit')" style="border:2px solid #E5E7EB;border-radius:12px;padding:20px;cursor:pointer;transition:all 0.3s;text-align:center;">
                                    <i class="fas fa-credit-card" style="font-size:2rem;color:#10B981;margin-bottom:10px;"></i>
                                    <div style="font-weight:700;">Debit Card</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="payment-option" onclick="selectPayment('Cash')" style="border:2px solid #E5E7EB;border-radius:12px;padding:20px;cursor:pointer;transition:all 0.3s;text-align:center;">
