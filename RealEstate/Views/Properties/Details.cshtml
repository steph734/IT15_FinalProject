                return;
            }
            
            // Close route planning modal
            const routeModal = bootstrap.Modal.getInstance(document.getElementById('routePlanningModal'));
            if (routeModal) {
                routeModal.hide();
            }
            
            // Show success modal
            setTimeout(() => {
                const successModal = new bootstrap.Modal(document.getElementById('selfVisitSuccessModal'));
                successModal.show();
            }, 300);
            
        } catch (error) {
            console.error('Self-visit completion error:', error);
            alert('Failed to save self-visit data. Please try again. Error: ' + error.message);
        }
    }

    // ==================== WEATHER FORECAST INTEGRATION ====================

    let currentWeatherData = null;

    // Fetch weather forecast when date/time changes
    async function fetchWeatherForecast() {
        const propertyId = document.getElementById('viewingPropertyId')?.value || @Model.Property?.PropertyId;
        const dateInput = document.getElementById('viewingDate');
        const timeInput = document.getElementById('viewingTime');
        
        if (!dateInput?.value) return;

        // Combine date and time
        let appointmentDateTime = new Date(dateInput.value);
        if (timeInput?.value) {
            const [hours, minutes] = timeInput.value.split(':');
            const isPM = timeInput.value.includes('PM');
            let hour = parseInt(hours);
            if (isPM && hour !== 12) hour += 12;
            if (!isPM && hour === 12) hour = 0;
            appointmentDateTime.setHours(hour, parseInt(minutes) || 0);
        }

        // Only fetch if date is within 5 days (API limit)
        const maxDate = new Date();
        maxDate.setDate(maxDate.getDate() + 5);
        
        if (appointmentDateTime > maxDate) {
            showWeatherMessage('Weather forecast only available for next 5 days', 'info');
            return;
        }

        try {
            showWeatherLoading();
            
            const response = await fetch(`/Properties/GetWeatherForecast?propertyId=${propertyId}&appointmentDate=${appointmentDateTime.toISOString()}`, {
                method: 'GET',
                headers: { 'Accept': 'application/json' }
            });

            const data = await response.json();
            
            if (!response.ok) {
                // Handle specific error cases
                if (data.error?.includes('coordinates')) {
                    showWeatherMessage('Property location coordinates not available. Weather forecast disabled.', 'info');
                } else if (data.error?.includes('not found')) {
                    showWeatherMessage('Property not found.', 'error');
                } else {
                    showWeatherMessage(data.error || 'Weather service temporarily unavailable', 'warning');
                }
                return;
            }
            
            if (data.success) {
                currentWeatherData = data;
                displayWeatherWidget(data);
            } else {
                showWeatherMessage(data.error || 'Weather data unavailable', 'warning');
            }
        } catch (error) {
            console.error('Weather fetch error:', error);
            showWeatherMessage('Network error. Please check your connection.', 'error');
        }
    }

    function showWeatherLoading() {
        const container = document.getElementById('weatherWidget');
        if (container) {
            container.innerHTML = '<div class="text-center py-2"><i class="fas fa-spinner fa-spin text-warning"></i> Loading weather...</div>';
            container.style.display = 'block';
        }
    }

    function showWeatherMessage(message, type) {
        const container = document.getElementById('weatherWidget');
        if (!container) return;
        
        // Define styles for each message type
        const styles = {
            info: {
                background: '#DBEAFE',
                border: '#3B82F6',
                color: '#1E40AF',
                icon: 'fa-info-circle'
            },
            warning: {
                background: '#FEF3C7',
                border: '#FCD34D',
                color: '#92400E',
                icon: 'fa-exclamation-triangle'
            },
            error: {
                background: '#FEE2E2',
                border: '#FCA5A5',
                color: '#991B1B',
                icon: 'fa-exclamation-circle'
            }
        };
        
        const style = styles[type] || styles.warning;
        
        container.innerHTML = `<div style="background:${style.background};border:1px solid ${style.border};color:${style.color};padding:10px 12px;border-radius:8px;font-size:0.85rem;margin:0;">
            <i class="fas ${style.icon} me-2"></i>${message}
        </div>`;
        container.style.display = 'block';
    }

    function displayWeatherWidget(data) {
        const container = document.getElementById('weatherWidget');
        if (!container) return;

        const { weather, insight } = data;
        
        // Determine alert styling
        let alertClass = '';
        let alertIcon = '';
        let alertStyle = '';
        
        if (insight.alert) {
            if (insight.alertType === 'rain' || insight.alertType === 'storm') {
                alertClass = 'weather-alert-rain';
                alertIcon = 'fa-cloud-rain';
                alertStyle = 'background:linear-gradient(135deg,#DBEAFE,#BFDBFE);border-color:#3B82F6;';
            } else if (insight.alertType === 'heat') {
                alertClass = 'weather-alert-heat';
                alertIcon = 'fa-sun';
                alertStyle = 'background:linear-gradient(135deg,#FEF3C7,#FDE68A);border-color:#F59E0B;';
            }
        } else {
            alertClass = 'weather-alert-good';
            alertIcon = 'fa-check-circle';
            alertStyle = 'background:linear-gradient(135deg,#D1FAE5,#A7F3D0);border-color:#10B981;';
        }

        const html = `
            <div class="weather-widget ${alertClass}" style="border-radius:12px;padding:16px;margin-bottom:16px;${alertStyle}">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <img src="${weather.icon}" alt="${weather.description}" style="width:50px;height:50px;margin-right:12px;">
                        <div>
                            <div style="font-weight:700;color:#1F2937;font-size:1.1rem;">${Math.round(weather.temperature)}°C</div>
                            <div style="font-size:0.85rem;color:#6B7280;text-transform:capitalize;">${weather.description}</div>
                            <div style="font-size:0.75rem;color:#9CA3AF;">Feels like ${Math.round(weather.feelsLike)}°C • ${weather.humidity}% humidity</div>
                        </div>
                    </div>
                    <div class="text-end">
                        ${weather.rainProbability > 0 ? `<div style="font-size:0.8rem;color:#3B82F6;"><i class="fas fa-tint me-1"></i>${Math.round(weather.rainProbability)}% rain</div>` : ''}
                        <div style="font-size:0.75rem;color:#9CA3AF;"><i class="fas fa-wind me-1"></i>${weather.windSpeed.toFixed(1)} m/s</div>
                    </div>
                </div>
                ${insight.alert ? `
                <div class="weather-insight mt-3" style="background:rgba(255,255,255,0.7);border-radius:8px;padding:12px;">
                    <div style="font-weight:600;color:#1F2937;font-size:0.9rem;">
                        <i class="fas ${alertIcon} me-2" style="color:${insight.alertType === 'rain' || insight.alertType === 'storm' ? '#3B82F6' : '#F59E0B'}"></i>
                        ${insight.recommendation}
                    </div>
                    <div style="font-size:0.8rem;color:#4B5563;margin-top:4px;">${insight.message}</div>
                </div>
                ` : `
                <div class="weather-insight mt-3" style="background:rgba(255,255,255,0.7);border-radius:8px;padding:12px;">
                    <div style="font-weight:600;color:#059669;font-size:0.9rem;">
                        <i class="fas fa-check-circle me-2"></i>${insight.recommendation}
                    </div>
                    <div style="font-size:0.8rem;color:#4B5563;margin-top:4px;">${insight.message}</div>
                </div>
                `}
            </div>
        `;
        
        container.innerHTML = html;
        container.style.display = 'block';
    }

    // ==================== 7-DAY WEATHER FORECAST MODAL ====================

    async function fetch7DayForecast() {
        const propertyId = @Model.Property?.PropertyId ?? 0;
        
        // Show loading
        document.getElementById('weatherForecastLoading').style.display = 'block';
        document.getElementById('weatherForecastContainer').style.display = 'none';
        document.getElementById('weatherForecastError').style.display = 'none';

        try {
            const today = new Date();
            const dateStr = today.toISOString().split('T')[0]; // Format: YYYY-MM-DD
            
            const response = await fetch(`/Properties/GetDayWeatherForecast?propertyId=${propertyId}&date=${dateStr}`, {
                method: 'GET',
                headers: { 'Accept': 'application/json' }
            });

            const data = await response.json();
            
            if (!response.ok || !data.success) {
                document.getElementById('weatherForecastLoading').style.display = 'none';
                document.getElementById('weatherForecastError').style.display = 'block';
                return;
            }

            display7DayForecast(data.forecasts);
            
            document.getElementById('weatherForecastLoading').style.display = 'none';
            document.getElementById('weatherForecastContainer').style.display = 'block';
        } catch (error) {
            console.error('7-day forecast error:', error);
            document.getElementById('weatherForecastLoading').style.display = 'none';
            document.getElementById('weatherForecastError').style.display = 'block';
        }
    }

    // Helper function to safely get temperature
    function getTemp(value, defaultVal = 30) {
        const num = parseFloat(value);
        return isNaN(num) ? defaultVal : num;
    }

    function display7DayForecast(forecasts) {
        const forecastRow = document.getElementById('forecastRow');
        forecastRow.innerHTML = '';

        // Check if forecasts is valid
        if (!forecasts || !Array.isArray(forecasts) || forecasts.length === 0) {
            // Show error state if no data
            document.getElementById('weatherForecastContainer').style.display = 'none';
            document.getElementById('weatherForecastError').style.display = 'block';
            return;
        }

        // Display hourly forecasts (limit to 8 time slots for better UI)
        const hourlyForecasts = forecasts.slice(0, 8);
        
        // Set initial current weather to first forecast
        if (hourlyForecasts.length > 0) {
            const firstForecast = hourlyForecasts[0];
            const temp = getTemp(firstForecast.temperature, 30);
            document.getElementById('currentTemp').textContent = Math.round(temp) + '°';
            document.getElementById('currentCondition').textContent = firstForecast.description || 'Clear sky';
            document.getElementById('currentWeatherIcon').src = firstForecast.icon || 'https://openweathermap.org/img/wn/01d@2x.png';
            document.getElementById('currentHumidity').textContent = firstForecast.rainProbability || '65';
            document.getElementById('currentWind').textContent = '3.5';
            
            let recommendation = '';
            const status = (firstForecast.status || 'good').toLowerCase();
            if (status === 'rainy' || status === 'stormy') {
                recommendation = '⚠️ Rain expected. Bring umbrella or reschedule.';
            } else if (status === 'hot') {
                recommendation = '🌡️ High heat. AC will be turned on before arrival.';
            } else {
                recommendation = '✅ Perfect weather for property viewing!';
            }
            document.getElementById('currentRecommendation').textContent = recommendation;
        }

        // Create hourly forecast cards
        hourlyForecasts.forEach((forecast, index) => {
            const temp = getTemp(forecast.temperature, 30);
            const time = forecast.time || `${index * 3}:00 PM`;
            
            // Determine weather icon and style based on status
            let bgColor;
            const status = (forecast.status || 'good').toLowerCase();
            switch(status) {
                case 'rainy':
                case 'stormy':
                    bgColor = '#374151';
                    break;
                case 'hot':
                    bgColor = '#78350F';
                    break;
                case 'good':
                default:
                    bgColor = index === 0 ? '#3B82F6' : '#374151';
            }

            // Create forecast card
            const card = document.createElement('div');
            card.className = 'forecast-day';
            card.style.cssText = `
                min-width: 80px;
                text-align: center;
                padding: 16px 12px;
                border-radius: 12px;
                background: ${bgColor};
                color: white;
                cursor: pointer;
                transition: all 0.3s;
                border: 2px solid ${index === 0 ? '#FF9500' : 'transparent'};
            `;
            card.innerHTML = `
                <div style="font-size: 0.8rem; margin-bottom: 8px; opacity: 0.9;">${time}</div>
                <img src="${forecast.icon || 'https://openweathermap.org/img/wn/01d@2x.png'}" alt="${forecast.description || 'clear'}" style="width: 40px; height: 40px; margin: 4px 0;">
                <div style="font-size: 0.75rem; margin-top: 4px;">
                    <span style="font-weight: 600;">${Math.round(temp)}°</span>
                </div>
            `;
            
            // Add click handler to select this time slot
            card.onclick = function() {
                // Update current weather display
                document.getElementById('currentTemp').textContent = Math.round(temp) + '°';
                document.getElementById('currentCondition').textContent = forecast.description || 'Clear sky';
                document.getElementById('currentWeatherIcon').src = forecast.icon || 'https://openweathermap.org/img/wn/01d@2x.png';
                
                // Update styling for selected day
                document.querySelectorAll('.forecast-day').forEach(el => {
                    el.style.border = '2px solid transparent';
                });
                card.style.border = '2px solid #FF9500';
                
                // Update recommendation
                let recommendation = '';
                const status = (forecast.status || 'good').toLowerCase();
                if (status === 'rainy' || status === 'stormy') {
                    recommendation = '⚠️ Rain expected. Bring umbrella or reschedule.';
                } else if (status === 'hot') {
                    recommendation = '🌡️ High heat. AC will be turned on before arrival.';
                } else {
                    recommendation = '✅ Perfect weather for property viewing!';
                }
                document.getElementById('currentRecommendation').textContent = recommendation;
            };

            forecastRow.appendChild(card);
        });
    }

    function proceedFromWeatherToAppointment() {
        console.log('proceedFromWeatherToAppointment called');
        
        // Close weather modal
        const weatherModal = bootstrap.Modal.getInstance(document.getElementById('weatherForecastModal'));
        if (weatherModal) {
            weatherModal.hide();
            console.log('Weather modal hidden');
        } else {
            console.log('Weather modal not found');
        }
        
        // Open appointment type selection
        setTimeout(() => {
            console.log('Opening appointment type modal');
            const appointmentModal = new bootstrap.Modal(document.getElementById('appointmentTypeModal'));
            if (appointmentModal) {
                appointmentModal.show();
                console.log('Appointment type modal shown');
            } else {
                console.log('Appointment type modal not found');
            }
        }, 300);
    }

    
    // Self Visit Multi-Step Form Functions
    let selfVisitCurrentStep = 1;
    const selfVisitTotalSteps = 4;

    function selfVisitNextStep() {
        // Validate current step
        if (!validateSelfVisitStep(selfVisitCurrentStep)) {
            return;
        }

        // Hide current step
        document.getElementById('selfVisitStep' + selfVisitCurrentStep).style.display = 'none';
        
        // Move to next step
        selfVisitCurrentStep++;
        
        // Show next step
        document.getElementById('selfVisitStep' + selfVisitCurrentStep).style.display = 'block';
        
        // Update progress
        updateSelfVisitProgress();
        
        // Update buttons
        updateSelfVisitButtons();
        
        // If on review step, populate review data
        if (selfVisitCurrentStep === 4) {
            populateSelfVisitReview();
        }
    }

    function selfVisitPreviousStep() {
        // Hide current step
        document.getElementById('selfVisitStep' + selfVisitCurrentStep).style.display = 'none';
        
        // Move to previous step
        selfVisitCurrentStep--;
        
        // Show previous step
        document.getElementById('selfVisitStep' + selfVisitCurrentStep).style.display = 'block';
        
        // Update progress
        updateSelfVisitProgress();
        
        // Update buttons
        updateSelfVisitButtons();
    }

    function validateSelfVisitStep(step) {
        switch(step) {
            case 1:
                const fullName = document.getElementById('selfVisitFullName').value;
                const email = document.getElementById('selfVisitEmail').value;
                const phone = document.getElementById('selfVisitPhone').value;
                const preferredDate = document.getElementById('selfVisitDate').value;
                const preferredTime = document.getElementById('selfVisitTime').value;
                
                if (!fullName || !email || !phone || !preferredDate || !preferredTime) {
                    alert('Please fill in all required fields (Full Name, Email, Phone, Preferred Date, Preferred Time)');
                    return false;
                }
                
                // Basic email validation
                const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
                if (!emailRegex.test(email)) {
                    alert('Please enter a valid email address');
                    return false;
                }
                
                break;
                
            case 2:
                const idType = document.getElementById('selfVisitIdType').value;
                const idNumber = document.getElementById('selfVisitIdNumber').value;
                const agree = document.getElementById('selfVisitAgree').checked;
                
                if (!idType || !idNumber) {
                    alert('Please fill in all ID information fields');
                    return false;
                }
                
                if (!agree) {
                    alert('Please agree to bring a valid ID for verification');
                    return false;
                }
                
                break;
                
            case 3:
                // Transportation is optional, no validation needed
                break;
        }
        
        return true;
    }

    function updateSelfVisitProgress() {
        // Update progress bar
        const progressPercent = (selfVisitCurrentStep / selfVisitTotalSteps) * 100;
        document.getElementById('selfVisitProgressFill').style.width = progressPercent + '%';
        
        // Update step indicators
        for (let i = 1; i <= selfVisitTotalSteps; i++) {
            const stepElement = document.getElementById('selfVisitStep' + i);
            if (stepElement) {
                const parentDiv = stepElement.closest('.modal-body').previousElementSibling;
                if (parentDiv) {
                    const indicators = parentDiv.querySelectorAll('.step-indicator');
                    const labels = parentDiv.querySelectorAll('div[style*="font-size:0.8rem"]');
                    
                    if (indicators[i-1] && labels[i-1]) {
                        if (i < selfVisitCurrentStep) {
                            // Completed steps
                            indicators[i-1].style.background = '#22C55E';
                            indicators[i-1].innerHTML = '<i class="fas fa-check"></i>';
                            labels[i-1].style.color = '#22C55E';
                        } else if (i === selfVisitCurrentStep) {
                            // Current step
                            indicators[i-1].style.background = '#FF9500';
                            indicators[i-1].innerHTML = i;
                            labels[i-1].style.color = '#FF9500';
                        } else {
                            // Future steps
                            indicators[i-1].style.background = '#E5E7EB';
                            indicators[i-1].innerHTML = i;
                            labels[i-1].style.color = '#6B7280';
                        }
                    }
                }
            }
        }
    }

    function updateSelfVisitButtons() {
        const prevBtn = document.getElementById('selfVisitPrevBtn');
        const nextBtn = document.getElementById('selfVisitNextBtn');
        const submitBtn = document.getElementById('selfVisitSubmitBtn');
        
        // Show/hide previous button
        if (selfVisitCurrentStep === 1) {
            prevBtn.style.display = 'none';
        } else {
            prevBtn.style.display = 'inline-block';
        }
        
        // Show/hide next and submit buttons
        if (selfVisitCurrentStep === selfVisitTotalSteps) {
            nextBtn.style.display = 'none';
            submitBtn.style.display = 'inline-block';
        } else {
            nextBtn.style.display = 'inline-block';
            submitBtn.style.display = 'none';
        }
    }

    function populateSelfVisitReview() {
        // Get form values
        const fullName = document.getElementById('selfVisitFullName').value;
        const email = document.getElementById('selfVisitEmail').value;
        const phone = document.getElementById('selfVisitPhone').value;
        const preferredDate = document.getElementById('selfVisitDate').value;
        const preferredTime = document.getElementById('selfVisitTime').value;
        const idType = document.getElementById('selfVisitIdType').value;
        const idNumber = document.getElementById('selfVisitIdNumber').value;
        const transport = document.getElementById('selfVisitTransport').value;
        
        // Format ID type for display
        const idTypeDisplay = {
            'passport': 'Passport',
            'drivers_license': 'Driver\'s License',
            'national_id': 'National ID',
            'company_id': 'Company ID'
        }[idType] || idType;
        
        // Format transport for display
        const transportDisplay = {
            'private_car': 'Private Car',
            'public_transport': 'Public Transport',
            'taxi_rideshare': 'Taxi/Rideshare',
            'walking': 'Walking',
            'motorcycle': 'Motorcycle'
        }[transport] || 'Not specified';
        
        // Populate review fields
        document.getElementById('selfVisitReviewName').textContent = fullName;
        document.getElementById('selfVisitReviewEmail').textContent = email;
        document.getElementById('selfVisitReviewPhone').textContent = phone;
        document.getElementById('selfVisitReviewDateTime').textContent = `Preferred Date & Time: ${preferredDate} at ${preferredTime}`;
        document.getElementById('selfVisitReviewIdType').textContent = idTypeDisplay;
        document.getElementById('selfVisitReviewIdNumber').textContent = idNumber;
        document.getElementById('selfVisitReviewTransport').textContent = transportDisplay;
    }

    // Add event listeners when schedule modal opens
    document.addEventListener('DOMContentLoaded', function() {
        const dateInput = document.getElementById('viewingDate');
        const timeInput = document.getElementById('viewingTime');
        
        if (dateInput) {
            dateInput.addEventListener('change', fetchWeatherForecast);
        }
        if (timeInput) {
            timeInput.addEventListener('change', fetchWeatherForecast);
        }
        
        // Reset self visit form when modal opens
        const selfVisitModal = document.getElementById('selfVisitModal');
        if (selfVisitModal) {
            selfVisitModal.addEventListener('shown.bs.modal', function () {
                selfVisitCurrentStep = 1;
                document.getElementById('selfVisitStep1').style.display = 'block';
                for (let i = 2; i <= selfVisitTotalSteps; i++) {
                    document.getElementById('selfVisitStep' + i).style.display = 'none';
                }
                updateSelfVisitProgress();
                updateSelfVisitButtons();
                document.getElementById('selfVisitForm').reset();
            });
        }
    });

    // Buy Property Modal functions removed
</script>

