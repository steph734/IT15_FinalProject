    function verifyFunds() {
        const expectedAmount = parseFloat(document.getElementById('expectedAmount').value) || 0;
        const receivedAmount = parseFloat(document.getElementById('receivedAmount').value) || 0;
        
        document.getElementById('displayExpectedAmount').textContent = '₱' + expectedAmount.toLocaleString('en-PH');
        document.getElementById('displayReceivedAmount').textContent = '₱' + receivedAmount.toLocaleString('en-PH');
        
        const difference = receivedAmount - expectedAmount;
        document.getElementById('displayDifference').textContent = '₱' + difference.toLocaleString('en-PH');
        
        const fundVerificationAlert = document.getElementById('fundVerificationAlert');
        const fundVerificationStatus = document.getElementById('fundVerificationStatus');
        const fundVerificationMessage = document.getElementById('fundVerificationMessage');
        
        fundVerificationAlert.style.display = 'block';
        
        if (receivedAmount >= expectedAmount) {
            fundVerificationStatus.textContent = 'VERIFIED';
            fundVerificationStatus.style.color = '#10B981';
            fundVerificationAlert.className = 'alert alert-success';
            fundVerificationMessage.textContent = 'Funds verified successfully. Received amount meets or exceeds expected amount.';
        } else {
            fundVerificationStatus.textContent = 'INSUFFICIENT';
            fundVerificationStatus.style.color = '#DC2626';
            fundVerificationAlert.className = 'alert alert-danger';
            fundVerificationMessage.textContent = 'Insufficient funds. Received amount is ₱' + Math.abs(difference).toLocaleString('en-PH') + ' short of expected amount.';
        }
    }

    function calculateCGT() {
        const sellingPrice = parseFloat(document.getElementById('sellingPrice').value) || 0;
        const zonalValue = parseFloat(document.getElementById('zonalValue').value) || 0;
        
        document.getElementById('displaySellingPrice').textContent = '₱' + sellingPrice.toLocaleString('en-PH');
        document.getElementById('displayZonalValue').textContent = '₱' + zonalValue.toLocaleString('en-PH');
        
        // CGT Base is the higher of selling price or zonal value
        const cgtBase = Math.max(sellingPrice, zonalValue);
        document.getElementById('displayCGTBase').textContent = '₱' + cgtBase.toLocaleString('en-PH');
        
        // CGT is 6% of the base
        const cgt = cgtBase * 0.06;
        document.getElementById('displayCGT').textContent = '₱' + cgt.toLocaleString('en-PH');
    }

    function calculateCommission() {
        const sellingPrice = parseFloat(document.getElementById('commissionSellingPrice').value) || 0;
        const commissionRate = parseFloat(document.getElementById('commissionRate').value) || 5;
        const brokerName = document.getElementById('brokerName').value || 'Broker';
        
        document.getElementById('displayCommissionSellingPrice').textContent = '₱' + sellingPrice.toLocaleString('en-PH');
        document.getElementById('displayCommissionRate').textContent = commissionRate + '%';
        
        // Commission is selling price * rate
        const commission = sellingPrice * (commissionRate / 100);
        document.getElementById('displayCommission').textContent = '₱' + commission.toLocaleString('en-PH');
        
        document.getElementById('payoutAmount').textContent = commission.toLocaleString('en-PH');
        document.getElementById('payoutBroker').textContent = brokerName;
    }

