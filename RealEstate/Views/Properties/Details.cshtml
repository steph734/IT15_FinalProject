<script>
    // Buy Property Modal
    let currentStep = 1;
    const totalSteps = 5;

    // Seller Property Submission
    function openSellerSubmissionModal() {
        const modal = new bootstrap.Modal(document.getElementById('sellerSubmissionModal'));
        modal.show();
    }

    function calculateZonalValue() {
        const area = parseFloat(document.getElementById('propertyArea').value) || 0;
        const zonalRate = parseFloat(document.getElementById('zonalRate').value) || 0;
        
        const totalZonalValue = area * zonalRate;
        document.getElementById('calculatedZonalValue').value = totalZonalValue.toLocaleString('en-PH');
    }

    function submitSellerProperty() {
        const form = document.getElementById('sellerSubmissionForm');
        if (form.checkValidity()) {
            alert('Property submitted successfully! The inventory packet will be reviewed by the Manager.');
            const modal = bootstrap.Modal.getInstance(document.getElementById('sellerSubmissionModal'));
            modal.hide();
            form.reset();
        } else {
            form.reportValidity();
        }
    }

    // RPT Tracking System
    function openRPTTrackingModal() {
        const modal = new bootstrap.Modal(document.getElementById('rptTrackingModal'));
        modal.show();
    }

    function calculateRPT() {
        const assessedValue = parseFloat(document.getElementById('assessedValue').value) || 0;
        const taxRate = parseFloat(document.getElementById('taxRate').value) || 2;
        const discountPercentage = parseFloat(document.getElementById('discountPercentage').value) || 20;
        
        document.getElementById('displayAssessedValue').textContent = '₱' + assessedValue.toLocaleString('en-PH');
        document.getElementById('displayTaxRate').textContent = taxRate + '%';
        
        // Basic Tax = Assessed Value × Tax Rate
        const basicTax = assessedValue * (taxRate / 100);
        document.getElementById('displayBasicTax').textContent = '₱' + basicTax.toLocaleString('en-PH');
        
        // Check discount eligibility
        const paymentDeadline = document.getElementById('paymentDeadline').value;
        const paymentDate = document.getElementById('paymentDate').value;
        
        let discount = 0;
        let isEligible = false;
        
        if (paymentDate && paymentDeadline) {
            const deadline = new Date(paymentDeadline);
            const payment = new Date(paymentDate);
            isEligible = payment <= deadline;
        }
        
        if (isEligible) {
            discount = basicTax * (discountPercentage / 100);
        }
        
        document.getElementById('displayLGUDiscount').textContent = '-₱' + discount.toLocaleString('en-PH');
        
        const totalDue = basicTax - discount;
        document.getElementById('displayTotalDue').textContent = '₱' + totalDue.toLocaleString('en-PH');
        
        // Update discount alert
        const discountAlert = document.getElementById('discountAlert');
        const discountMessage = document.getElementById('discountMessage');
        
        if (isEligible) {
            discountAlert.className = 'alert alert-success';
            discountMessage.textContent = 'Payment is eligible for 20% LGU discount! You save ₱' + discount.toLocaleString('en-PH') + '.';
        } else if (paymentDate) {
            discountAlert.className = 'alert alert-warning';
            discountMessage.textContent = 'Payment is after the deadline. No LGU discount applied.';
        } else {
            discountAlert.className = 'alert alert-info';
            discountMessage.textContent = 'Pay before the deadline to receive 20% LGU discount.';
        }
    }

    function checkDiscountEligibility() {
        calculateRPT();
    }

    function saveRPT() {
        const taxYear = document.getElementById('taxYear').value;
        const propertyId = document.getElementById('propertyId').value;
        const assessedValue = document.getElementById('assessedValue').value;
        
        if (!taxYear || !propertyId || !assessedValue) {
            alert('Please fill in all required fields.');
            return;
        }
        
        alert('RPT record saved successfully for Tax Year ' + taxYear + '!');
        const modal = bootstrap.Modal.getInstance(document.getElementById('rptTrackingModal'));
        modal.hide();
    }

