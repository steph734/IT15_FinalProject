                                    <div style="font-weight:700;">Cash</div>
                                </div>
                            </div>
                        </div>
                        <input type="hidden" id="selectedPayment" name="paymentMethod" required />
                    </div>

                    <!-- Step 4: Review -->
                    <div id="buyStep4" class="buy-step-content" style="display:none;">
                        <h6 style="font-weight:700;color:#1E3A5F;margin-bottom:20px;"><i class="fas fa-receipt me-2" style="color:#10B981;"></i>Review Your Purchase</h6>
                        <div class="review-summary" style="background:#F8F9FA;padding:20px;border-radius:12px;border:2px dashed #10B981;">
                            <div class="text-center mb-4 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                <div style="font-size:0.8rem;color:#6B7280;font-weight:600;margin-bottom:5px;">RECEIPT</div>
                                <div style="font-weight:800;color:#10B981;font-size:1.5rem;">PURCHASE SUMMARY</div>
                            </div>
                            <div class="mb-3 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                <div style="font-size:0.8rem;color:#6B7280;font-weight:600;margin-bottom:5px;">PROPERTY</div>
                                <div style="font-weight:700;color:#1E3A5F;">@p.Title</div>
                                <div style="font-size:0.85rem;color:#6B7280;">@p.Location</div>
                                <div style="font-size:0.8rem;color:#6B7280;margin-top:5px;">Type: @p.ListingType.ToString()</div>
                            </div>
                            <div class="mb-3 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                <div style="font-size:0.8rem;color:#6B7280;font-weight:600;margin-bottom:5px;">BUYER INFORMATION</div>
                                <div id="reviewName" style="font-weight:700;color:#1E3A5F;"></div>
                                <div id="reviewEmail" style="font-size:0.85rem;color:#6B7280;"></div>
                                <div id="reviewPhone" style="font-size:0.85rem;color:#6B7280;"></div>
                            </div>
                            <div class="mb-3 pb-3" style="border-bottom:2px solid #E5E7EB;">
                                <div style="font-size:0.8rem;color:#6B7280;font-weight:600;margin-bottom:5px;">PAYMENT DETAILS</div>
                                <div id="reviewPayment" style="font-weight:700;color:#1E3A5F;"></div>
                                @if (p.ListingType == PropertyListingType.Rent)
                                {
                                    <div id="rentReceiptBreakdown" style="background:white;padding:15px;border-radius:8px;margin-top:10px;border:1px solid #E5E7EB;">
                                        <div class="d-flex justify-content-between mb-2">
                                            <span style="color:#6B7280;">Gross Annual Income</span>
                                            <span style="font-weight:600;">₱@((p.BasePrice * 12m).ToString("N0"))</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span style="color:#6B7280;">HOA Dues</span>
                                            <span style="font-weight:600;">₱180,000</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span style="color:#6B7280;">Real Property Tax</span>
                                            <span style="font-weight:600;">₱30,000</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span style="color:#6B7280;">Maintenance</span>
                                            <span style="font-weight:600;">₱60,000</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2" style="border-bottom:1px solid #E5E7EB;padding-bottom:8px;">
                                            <span style="color:#10B981;font-weight:600;">Net Operating Income</span>
                                            <span style="font-weight:600;color:#10B981;">₱@((p.BasePrice * 12m - 180000m - 30000m - 60000m).ToString("N0"))</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span style="color:#6B7280;">Monthly Rent</span>
                                            <span style="font-weight:600;">₱@p.BasePrice.ToString("N0")</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span style="color:#6B7280;">Security Deposit</span>
                                            <span style="font-weight:600;">₱@p.BasePrice.ToString("N0")</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span style="color:#6B7280;">Processing Fee</span>
                                            <span style="font-weight:600;">₱5,000</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2" id="reviewDiscountRow" style="display:none;">
                                            <span style="color:#10B981;">Yearly Discount (10%)</span>
                                            <span style="font-weight:600;color:#10B981;">-₱@((p.BasePrice * 12 * 0.1m).ToString("N0"))</span>
                                        </div>
                                        <div class="d-flex justify-content-between pt-2" style="border-top:2px solid #E5E7EB;font-size:1.1rem;">
                                            <span style="font-weight:700;color:#1E3A5F;">Total Due</span>
                                            <span style="font-weight:800;color:#10B981;" id="reviewTotalAmount">₱@((p.BasePrice * 2 + 5000m).ToString("N0"))</span>
                                        </div>
                                        <div class="d-flex justify-content-between mt-2" style="font-size:0.85rem;color:#6B7280;">
                                            <span id="reviewPaymentFrequency">First Month + Deposit + Fee</span>
                                        </div>
                                        <div class="mt-2 pt-2" style="border-top:1px solid #E5E7EB;font-size:0.85rem;">
                                            <span style="color:#6B7280;">Net Rental Yield: </span>
                                            <span style="font-weight:700;color:#10B981;">@((p.BasePrice * 12m - 180000m - 30000m - 60000m) / p.BasePrice * 100m).ToString("N2"))%</span>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div style="background:white;padding:15px;border-radius:8px;margin-top:10px;border:1px solid #E5E7EB;">
                                        <div class="d-flex justify-content-between mb-2">
                                            <span style="color:#6B7280;">Contract Price</span>
                                            <span style="font-weight:600;">@priceDisplay</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span style="color:#6B7280;">Capital Gains Tax (6%)</span>
                                            <span style="font-weight:600;">₱@((p.BasePrice * 0.06m).ToString("N0"))</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span style="color:#6B7280;">Broker's Commission (5%)</span>
                                            <span style="font-weight:600;">₱@((p.BasePrice * 0.05m).ToString("N0"))</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span style="color:#6B7280;">Notarial Fees (1%)</span>
                                            <span style="font-weight:600;">₱@((p.BasePrice * 0.01m).ToString("N0"))</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span style="color:#6B7280;">Documentation Fee</span>
                                            <span style="font-weight:600;">₱15,000</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span style="color:#6B7280;">Transfer Tax (1.5%)</span>
                                            <span style="font-weight:600;">₱@((p.BasePrice * 0.015m).ToString("N0"))</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2" style="border-bottom:1px solid #E5E7EB;padding-bottom:8px;">
                                            <span style="color:#10B981;font-weight:600;">Net Proceeds (Seller)</span>
                                            <span style="font-weight:600;color:#10B981;">₱@((p.BasePrice - (p.BasePrice * 0.06m) - (p.BasePrice * 0.05m) - (p.BasePrice * 0.01m) - 15000m - (p.BasePrice * 0.015m)).ToString("N0"))</span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span style="color:#6B7280;">Buyer's Transfer Fees (Est.)</span>
                                            <span style="font-weight:600;">₱40,000</span>
                                        </div>
                                        <div class="d-flex justify-content-between pt-2" style="border-top:2px solid #E5E7EB;font-size:1.1rem;">
                                            <span style="font-weight:700;color:#1E3A5F;">Total for Buyer</span>
                                            <span style="font-weight:800;color:#10B981;">₱@((p.BasePrice + 40000m).ToString("N0"))</span>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="agreeTerms" required style="cursor:pointer;">
                                <label class="form-check-label" for="agreeTerms" style="cursor:pointer;font-size:0.9rem;">
                                    I agree to the <a href="#" style="color:#10B981;">Terms and Conditions</a> and understand this is a binding purchase agreement
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Step 5: Confirmation -->
                    <div id="buyStep5" class="buy-step-content" style="display:none;">
                        <div class="text-center py-5">
                            <div style="margin-bottom:24px;">
                                <i class="fas fa-check-circle" style="font-size:5rem;color:#10B981;"></i>
                            </div>
                            <h4 style="font-weight:700;color:#1E3A5F;margin-bottom:12px;">Payment Successfully Recorded!</h4>
                            <p style="color:#6B7280;font-size:1rem;line-height:1.6;margin-bottom:24px;">
                                Your payment has been successfully recorded and submitted to the payments table in our database.
                            </p>
                            <div style="background:#F0FDF4;padding:20px;border-radius:12px;margin-bottom:24px;border-left:4px solid #10B981;">
                                <p style="margin:0;color:#065F46;font-size:0.9rem;">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <strong>Next Step:</strong> Our team will contact you within 24-48 hours to complete the purchase process
                                </p>
                            </div>
                            <button type="button" class="btn btn-primary" onclick="closeModalAndRefresh()" style="border-radius:12px;padding:14px 32px;">
                                <i class="fas fa-home me-2"></i>Return to Property
                            </button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="border-top:1px solid #E5E7EB;padding:16px 24px;background:#F8F9FA;">
                <button type="button" class="btn btn-secondary" id="buyPrevStep" onclick="previousStep()" style="border-radius:8px;padding:10px 24px;display:none;">
                    <i class="fas fa-arrow-left me-2"></i>Previous
                </button>
                <button type="button" class="btn" id="buyNextStep" onclick="nextStep()" style="background:linear-gradient(135deg,#10B981,#059669);color:white;border:none;border-radius:8px;padding:10px 24px;font-weight:600;">
                    Next Step<i class="fas fa-arrow-right ms-2"></i>
                </button>
                <button type="button" class="btn" id="buySubmitPurchase" onclick="submitForm()" style="background:linear-gradient(135deg,#10B981,#059669);color:white;border:none;border-radius:8px;padding:10px 24px;font-weight:600;display:none;">
                    <i class="fas fa-check me-2"></i>Confirm Purchase
                </button>
            </div>
        </div>
    </div>
</div>

