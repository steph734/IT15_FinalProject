    // Agent Pickup Form Functions
    let pickupCurrentStep = 1;

    function resetPickupForm() {
        pickupCurrentStep = 1;
        document.getElementById('pickupForm').reset();
        document.getElementById('pickupStep1').style.display = 'block';
        document.getElementById('pickupStep2').style.display = 'none';
        document.getElementById('pickupStep3').style.display = 'none';
        document.getElementById('pickupStep4').style.display = 'none';
        document.getElementById('pickupPrevBtn').style.display = 'none';
        document.getElementById('pickupNextBtn').style.display = 'inline-block';
        document.getElementById('pickupSubmitBtn').style.display = 'none';
        document.getElementById('pickupProgressFill').style.width = '25%';
        updatePickupProgressIndicators();
    }

    function pickupNextStep() {
        if (!validatePickupStep(pickupCurrentStep)) {
            return;
        }

        if (pickupCurrentStep < 4) {
            document.getElementById(`pickupStep${pickupCurrentStep}`).style.display = 'none';
            pickupCurrentStep++;
            document.getElementById(`pickupStep${pickupCurrentStep}`).style.display = 'block';

            if (pickupCurrentStep === 4) {
                populatePickupReview();
                document.getElementById('pickupPrevBtn').style.display = 'inline-block';
                document.getElementById('pickupNextBtn').style.display = 'none';
                document.getElementById('pickupSubmitBtn').style.display = 'inline-block';
            } else {
                document.getElementById('pickupPrevBtn').style.display = 'inline-block';
            }

            document.getElementById('pickupProgressFill').style.width = `${pickupCurrentStep * 25}%`;
            updatePickupProgressIndicators();
        }
    }

    function pickupPreviousStep() {
        if (pickupCurrentStep > 1) {
            document.getElementById(`pickupStep${pickupCurrentStep}`).style.display = 'none';
            pickupCurrentStep--;
            document.getElementById(`pickupStep${pickupCurrentStep}`).style.display = 'block';

            if (pickupCurrentStep === 1) {
                document.getElementById('pickupPrevBtn').style.display = 'none';
            }

            if (pickupCurrentStep === 3) {
                document.getElementById('pickupNextBtn').style.display = 'inline-block';
                document.getElementById('pickupSubmitBtn').style.display = 'none';
            }

            document.getElementById('pickupProgressFill').style.width = `${pickupCurrentStep * 25}%`;
            updatePickupProgressIndicators();
        }
    }

    function validatePickupStep(step) {
        if (step === 1) {
            const fullName = document.getElementById('pickupFullName').value;
            const email = document.getElementById('pickupEmail').value;
            const phone = document.getElementById('pickupPhone').value;

            if (!fullName || !email || !phone) {
                alert('Please fill in all required fields');
                return false;
            }
        } else if (step === 2) {
            const date = document.getElementById('pickupDate').value;
            const time = document.getElementById('pickupTime').value;

            if (!date || !time) {
                alert('Please select date and time');
                return false;
            }
        } else if (step === 3) {
            const address = document.getElementById('pickupAddress').value;

            if (!address) {
                alert('Please enter your pickup address');
                return false;
            }
        }
        return true;
    }

    function updatePickupProgressIndicators() {
        const indicators = document.querySelectorAll('#agentPickupModal .step-indicator');
        indicators.forEach((indicator, index) => {
            if (index < pickupCurrentStep) {
                indicator.style.background = '#3B82F6';
                indicator.style.color = 'white';
            } else {
                indicator.style.background = '#E5E7EB';
                indicator.style.color = '#9CA3AF';
            }
        });
    }

