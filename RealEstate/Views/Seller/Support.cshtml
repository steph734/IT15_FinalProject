@{
    ViewData["Title"] = "Help & Support";
    Layout = "~/Views/Shared/_SellerLayout.cshtml";
}

@section Styles {
<style>
    .page-header-section {
        margin-bottom: 32px;
    }
    
    .page-title {
        font-size: 32px;
        font-weight: 800;
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: #1f2937;
        margin: 0 0 8px 0;
    }
    
    .page-subtitle {
        color: #6b7280;
        font-size: 15px;
        margin: 0;
    }
    
    .faq-card {
        background: white;
        border-radius: 14px;
        padding: 28px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
        border: 1px solid rgba(0, 0, 0, 0.04);
        margin-bottom: 24px;
    }
    
    .section-title {
        font-size: 20px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 20px;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }
    
    .accordion-item {
        border: 1px solid #e5e7eb !important;
        border-radius: 10px !important;
        margin-bottom: 12px;
        overflow: hidden;
    }
    
    .accordion-button {
        font-weight: 600;
        font-size: 14px;
        color: #1f2937;
        padding: 16px 20px;
        background: white;
    }
    
    .accordion-button:not(.collapsed) {
        background: linear-gradient(135deg, rgba(14, 165, 233, 0.05), rgba(99, 102, 241, 0.05));
        color: #0ea5e9;
        box-shadow: none;
    }
    
    .accordion-button:focus {
        box-shadow: none;
        border-color: rgba(14, 165, 233, 0.3);
    }
    
    .accordion-button::after {
        filter: hue-rotate(180deg);
    }
    
    .accordion-body {
        font-size: 14px;
        color: #374151;
        padding: 16px 20px;
        background: #f9fafb;
    }
    
    .contact-card {
        background: white;
        border-radius: 14px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
        border: 1px solid rgba(0, 0, 0, 0.04);
        margin-bottom: 20px;
    }
    
    .contact-item {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 20px;
    }
    
    .contact-item:last-child {
        margin-bottom: 0;
    }
    
    .contact-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }
    
    .contact-icon.email {
        background: linear-gradient(135deg, rgba(14, 165, 233, 0.15), rgba(14, 165, 233, 0.05));
        color: #0ea5e9;
    }
    
    .contact-icon.phone {
        background: linear-gradient(135deg, rgba(5, 150, 105, 0.15), rgba(5, 150, 105, 0.05));
        color: #059669;
    }
    
    .contact-label {
        font-size: 12px;
        color: #6b7280;
        margin-bottom: 2px;
    }
    
    .contact-value {
        font-size: 14px;
        font-weight: 600;
        color: #1f2937;
    }
    
    .quick-links-card {
        background: white;
        border-radius: 14px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
        border: 1px solid rgba(0, 0, 0, 0.04);
    }
    
    .quick-link-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 12px;
        border: 2px solid #e5e7eb;
        border-radius: 10px;
        text-decoration: none;
        color: #6b7280;
        font-weight: 600;
        font-size: 13px;
        transition: all 0.3s;
        background: white;
        margin-bottom: 10px;
    }
    
    .quick-link-btn:last-child {
        margin-bottom: 0;
    }
    
    .quick-link-btn:hover {
        border-color: #0ea5e9;
        color: #0ea5e9;
        background: linear-gradient(135deg, rgba(14, 165, 233, 0.05), rgba(99, 102, 241, 0.05));
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(14, 165, 233, 0.15);
    }
    
    .quick-link-btn i {
        font-size: 16px;
    }
</style>
}

<!-- Page Header -->
<div class="page-header-section">
    <h1 class="page-title"><i class="fas fa-headset me-2" style="color:#0ea5e9;"></i>Help & Support</h1>
    <p class="page-subtitle">Find answers or get in touch with our support team.</p>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="faq-card">
            <div class="section-title">Frequently Asked Questions</div>
            <div class="accordion" id="faqAccordion">
                @{
                    var faqs = new[] {
                        ("How long does review take?", "Property reviews typically take 1-3 business days. You will receive a notification once reviewed."),
                        ("Can I edit my listing after submission?", "Currently, you cannot edit a submitted listing. Please contact support if you need changes."),
                        ("How is the final price determined?", "The manager reviews your suggested price and may apply a company markup to set the final selling price."),
                        ("When will I receive my earnings?", "Earnings are processed by the Accounting team after a sale is completed. Timeline is typically 5-7 business days."),
                        ("What documents are required?", "You need to provide proof of ownership such as TCT/CCT, tax declaration, or any government-issued property document.")
                    };
                    int idx = 0;
                }
                @foreach (var (q, a) in faqs)
                {
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button @(idx > 0 ? "collapsed" : "")" type="button" data-bs-toggle="collapse" data-bs-target="#faq@(idx)">
                                @q
                            </button>
                        </h2>
                        <div id="faq@(idx)" class="accordion-collapse collapse @(idx == 0 ? "show" : "")" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">@a</div>
                        </div>
                    </div>
                    idx++;
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="contact-card">
            <div class="section-title">Contact Support</div>
            <div class="contact-item">
                <div class="contact-icon email">
                    <i class="fas fa-envelope"></i>
                </div>
                <div>
                    <div class="contact-label">Email</div>
                    <div class="contact-value">support@estateflow.ph</div>
                </div>
            </div>
            <div class="contact-item">
                <div class="contact-icon phone">
                    <i class="fas fa-phone"></i>
                </div>
                <div>
                    <div class="contact-label">Phone</div>
                    <div class="contact-value">+63 2 8888 0000</div>
                </div>
            </div>
        </div>

        <div class="quick-links-card">
            <div class="section-title">Quick Links</div>
            <a href="/seller/my-listings" class="quick-link-btn">
                <i class="fas fa-building" style="color:#0ea5e9;"></i>
                My Listings
            </a>
            <a href="/seller/submit" class="quick-link-btn">
                <i class="fas fa-plus-circle" style="color:#10b981;"></i>
                Submit Property
            </a>
            <a href="/seller/earnings" class="quick-link-btn">
                <i class="fas fa-coins" style="color:#f59e0b;"></i>
                View Earnings
            </a>
        </div>
    </div>
</div>
