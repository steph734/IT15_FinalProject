@{
    ViewData["Title"] = "Submit Property";
    Layout = "~/Views/Shared/_SellerLayout.cshtml";
    var isEdit = Model != null && Model is RealEstate.Models.Property;
    var listing = isEdit ? (RealEstate.Models.Property)Model : null;
}

@if (isEdit)
{
    ViewData["Title"] = "Edit Listing";
}

@section Styles {
<!-- Leaflet CSS for Map -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<style>
    .page-header-section {
        margin-bottom: 32px;
    }
    
    .page-title {
        font-size: 32px;
        font-weight: 800;
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: #1f2937;
        margin: 0 0 8px 0;
    }
    
    .page-subtitle {
        color: #6b7280;
        font-size: 15px;
        margin: 0;
    }
    
    .form-card {
        background: white;
        border-radius: 16px;
        padding: 36px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
        border: 1px solid rgba(0, 0, 0, 0.04);
    }
    
    .section-divider {
        border: none;
        border-top: 2px solid #f3f4f6;
        margin: 32px 0;
    }
    
    .section-label {
        font-size: 14px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: #6b7280;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .section-label i {
        color: #0ea5e9;
    }
    
    .form-label-custom {
        font-size: 14px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 8px;
    }
    
    .form-control-custom,
    .form-select-custom {
        border-radius: 10px;
        border: 1.5px solid #e5e7eb;
        padding: 12px 16px;
        font-size: 14px;
        transition: all 0.2s;
    }
    
    .form-control-custom:focus,
    .form-select-custom:focus {
        border-color: #0ea5e9;
        box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
    }
    
    .upload-zone {
        border: 2px dashed #d1d5db;
        border-radius: 12px;
        padding: 32px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;
        color: #6b7280;
        background: #f9fafb;
    }
    
    .upload-zone:hover {
        border-color: #0ea5e9;
        background: linear-gradient(135deg, rgba(14, 165, 233, 0.05), rgba(99, 102, 241, 0.05));
        color: #0ea5e9;
    }
    
    .upload-zone i {
        font-size: 40px;
        margin-bottom: 12px;
        display: block;
    }
    
    .upload-zone-text {
        font-size: 14px;
        font-weight: 600;
    }
    
    .upload-zone-hint {
        font-size: 12px;
        margin-top: 8px;
        opacity: 0.7;
    }
    
    .submit-btn {
        width: 100%;
        padding: 16px;
        background: linear-gradient(135deg, #0ea5e9, #6366f1);
        color: white;
        font-size: 16px;
        font-weight: 700;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 4px 12px rgba(14, 165, 233, 0.3);
    }
    
    .submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(14, 165, 233, 0.4);
    }
    
    .property-type-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
        gap: 14px;
    }
    
    .type-card {
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;
        background: white;
    }
    
    .type-card:hover {
        border-color: #0ea5e9;
        background: linear-gradient(135deg, rgba(14, 165, 233, 0.05), rgba(99, 102, 241, 0.05));
        transform: translateY(-2px);
    }
    
    .type-card.selected {
        border-color: #0ea5e9;
        background: linear-gradient(135deg, rgba(14, 165, 233, 0.1), rgba(99, 102, 241, 0.1));
        box-shadow: 0 4px 12px rgba(14, 165, 233, 0.2);
    }
    
    .type-card i {
        font-size: 28px;
        display: block;
        margin-bottom: 10px;
        color: #6b7280;
    }
    
    .type-card.selected i {
        color: #0ea5e9;
    }
    
    .type-card label {
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        color: #374151;
    }
</style>
}

<div class="submit-wrapper">
    <div class="submit-header mb-4">
        @if (isEdit)
        {
            <h1><i class="fas fa-edit me-2" style="color:#f59e0b;"></i>Edit Listing</h1>
            <p class="text-muted">Update your property details and resubmit for review.</p>
        }
        else
        {
            <h1><i class="fas fa-plus-circle me-2" style="color:#0ea5e9;"></i>Submit Property</h1>
            <p class="text-muted">Fill in your property details and submit for manager review.</p>
        }
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger mb-3"><i class="fas fa-times-circle me-2"></i>@TempData["ErrorMessage"]</div>
    }

    <form method="post" action="@(isEdit ? $"/seller/listing/{listing.Id}/update" : "/seller/submit")" enctype="multipart/form-data" id="submitForm">
        @Html.AntiForgeryToken()
        @if (isEdit)
        {
            <input type="hidden" name="id" value="@listing.Id" />
        }

        <div class="form-card">
            <!-- Property Type -->
            <div class="section-label">Property Type</div>
            <div class="property-type-grid mb-4">
                @foreach (var type in new[] { ("House", "house", "House"), ("Condo", "city", "Condo"), ("Villa", "umbrella-beach", "Villa"), ("Townhouse", "home", "Townhouse"), ("Commercial", "store", "Commercial") })
                {
                    <div class="type-card @(type.Item1 == "House" ? "selected" : "")" onclick="selectType('@type.Item1', this)">
                        <i class="fas fa-@type.Item2"></i>
                        <label>@type.Item3</label>
                    </div>
                }
            </div>
            <input type="hidden" name="propertyType" id="propertyTypeInput" value="House" />

            <hr class="section-divider" />

            <!-- Basic Info -->
            <div class="section-label">Property Information</div>
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label">Property Title <span class="text-danger">*</span></label>
                    <input type="text" name="title" class="form-control" placeholder="e.g., Modern 3BR House in Makati" required />
                </div>
                <div class="col-12">
                    <label class="form-label">Location / Address <span class="text-danger">*</span></label>
                    <input type="text" name="location" id="locationInput" class="form-control" placeholder="e.g., Matina, Davao City or San Pedro St, Davao City" required />
                    <div class="form-text mt-2">
                        <i class="fas fa-info-circle text-info me-1"></i>
                        Type a Philippine address - the map will search automatically (e.g., "Matina, Davao City" or "San Pedro St, Davao City")
                    </div>
                </div>

                <!-- Map Verification Section -->
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="form-label mb-0">
                            <i class="fas fa-map-marker-alt text-danger me-2"></i>Location Map
                        </label>
                        <div id="searchIndicator" class="text-muted" style="font-size: 0.8rem; display: none;">
                            <i class="fas fa-spinner fa-spin me-1"></i>Searching...
                        </div>
                    </div>
                    
                    <!-- Map Container -->
                    <div id="locationMap" style="height: 350px; border-radius: 12px; border: 2px solid #e5e7eb; margin-bottom: 12px; position: relative;">
                        <!-- Loading Overlay -->
                        <div id="mapLoadingOverlay" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255,255,255,0.8); display: none; z-index: 1000; justify-content: center; align-items: center; border-radius: 12px;">
                            <div class="text-center">
                                <i class="fas fa-spinner fa-spin fa-2x text-primary mb-2"></i>
                                <p class="mb-0 text-muted" style="font-size: 0.85rem;">Finding location...</p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Map Instructions -->
                    <div class="alert alert-info d-flex align-items-center py-2" style="font-size: 0.85rem;">
                        <i class="fas fa-info-circle me-2"></i>
                        <span><strong>How it works:</strong> The map updates automatically as you type. Drag the pin to fine-tune the exact location.</span>
                    </div>
                    
                    <!-- Hidden Coordinate Fields -->
                    <input type="hidden" name="latitude" id="latitudeField" value="@(listing?.Latitude?.ToString() ?? "")" />
                    <input type="hidden" name="longitude" id="longitudeField" value="@(listing?.Longitude?.ToString() ?? "")" />
                    
                    <!-- Coordinate Display (Read-only) -->
                    <div class="row g-2 mt-2">
                        <div class="col-md-6">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text" style="background: #f8f9fa;"><i class="fas fa-globe"></i> Lat</span>
                                <input type="text" id="displayLat" class="form-control" readonly placeholder="--" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text" style="background: #f8f9fa;"><i class="fas fa-globe"></i> Lng</span>
                                <input type="text" id="displayLng" class="form-control" readonly placeholder="--" />
                            </div>
                        </div>
                    </div>
                    
                    <!-- Address Verification Status -->
                    <div id="geocodeStatus" class="mt-2" style="display: none;"></div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Bedrooms</label>
                    <input type="number" name="bedrooms" class="form-control" value="1" min="0" max="20" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Bathrooms</label>
                    <input type="number" name="bathrooms" class="form-control" value="1" min="0" max="20" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Parking Slots</label>
                    <input type="number" name="parkingSlots" class="form-control" value="0" min="0" max="20" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Floor Area (sqm)</label>
                    <input type="number" name="sqft" class="form-control" value="0" min="0" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Suggested Price (₱) <span class="text-danger">*</span></label>
                    <input type="number" name="suggestedPrice" class="form-control" placeholder="0" min="1" step="0.01" required />
                </div>
                <div class="col-12">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-control" rows="4" placeholder="Describe your property in detail..."></textarea>
                </div>
            </div>

            <hr class="section-divider" />

            <!-- Cover Image -->
            <div class="section-label">Cover Image</div>
            <div class="upload-zone mb-4" onclick="document.getElementById('coverImage').click()">
                <i class="fas fa-image"></i>
                <p class="mb-1 fw-semibold">Upload Cover Photo</p>
                <p style="font-size:12px;">Click to upload (JPG, PNG, max 5MB)</p>
                <input type="file" id="coverImage" name="coverImage" accept="image/*" style="display:none;" onchange="updateFileName('coverImage','coverLabel')" />
                <p id="coverLabel" style="font-size:12px; color:#0ea5e9;"></p>
            </div>

            <!-- Documents -->
            <div class="section-label">Ownership Documents</div>
            <div class="row g-3">
                @for (int i = 1; i <= 3; i++)
                {
                    <div class="col-md-4">
                        <div class="upload-zone" onclick="document.getElementById('doc@(i)').click()">
                            <i class="fas fa-file-alt" style="font-size:22px;"></i>
                            <p class="mb-0 fw-semibold" style="font-size:13px;">Document @i</p>
                            <input type="file" id="doc@(i)" name="document@(i)" accept=".pdf,.jpg,.jpeg,.png" style="display:none;" onchange="updateFileName('doc@(i)','doc@(i)Label')" />
                            <p id="doc@(i)Label" style="font-size:11px; color:#0ea5e9; margin:0;"></p>
                        </div>
                    </div>
                }
            </div>
            <p class="text-muted mt-2" style="font-size:12px;"><i class="fas fa-info-circle me-1"></i>Upload ownership title, tax declaration, or any proof of ownership (PDF or image).</p>

            <hr class="section-divider" />

            <button type="submit" class="submit-btn">
                <i class="fas fa-paper-plane me-2"></i>Submit for Review
            </button>
        </div>
    </form>
</div>

@section Scripts {
<!-- Leaflet JS for Map -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<script>
    // ==================== LEAFLET MAP & GEOCODING ====================

    let map = null;
    let marker = null;
    let isMapInitialized = false;

    // Default coordinates (Philippines center)
    const DEFAULT_LAT = 14.5995;
    const DEFAULT_LNG = 120.9842;

    // Initialize map when page loads
    document.addEventListener('DOMContentLoaded', function() {
        // Check if there's existing coordinates (editing mode)
        const existingLat = document.getElementById('latitudeField').value;
        const existingLng = document.getElementById('longitudeField').value;

        if (existingLat && existingLng) {
            // If editing, initialize map with existing coordinates
            initMap(parseFloat(existingLat), parseFloat(existingLng));
            updateCoordinateDisplay(existingLat, existingLng);
        }
        // Otherwise, map will be initialized when user clicks "Verify on Map"
    });

    function initMap(lat, lng) {
        if (isMapInitialized && map) {
            map.setView([lat, lng], 16);
            marker.setLatLng([lat, lng]);
            return;
        }

        // Initialize Leaflet map
        map = L.map('locationMap').setView([lat, lng], 16);

        // Add OpenStreetMap tiles
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
            maxZoom: 19
        }).addTo(map);

        // Add draggable marker
        marker = L.marker([lat, lng], { draggable: true }).addTo(map);

        // Handle marker drag event
        marker.on('dragend', function(e) {
            const position = e.target.getLatLng();
            updateCoordinates(position.lat, position.lng);
            reverseGeocode(position.lat, position.lng);
        });

        // Handle map click event
        map.on('click', function(e) {
            const position = e.latlng;
            marker.setLatLng(position);
            updateCoordinates(position.lat, position.lng);
            reverseGeocode(position.lat, position.lng);
        });

        isMapInitialized = true;

        // Update hidden fields and display
        updateCoordinates(lat, lng);
    }

    // ==================== AUTOMATIC GEOCODING WITH DEBOUNCE ====================

    let geocodeTimeout = null;
    let lastGeocodedAddress = '';
    const DEBOUNCE_DELAY = 800; // Wait 800ms after user stops typing

    // Set up automatic geocoding on page load
    document.addEventListener('DOMContentLoaded', function() {
        const locationInput = document.getElementById('locationInput');
        
        // Add input listener for automatic search
        locationInput.addEventListener('input', function() {
            const address = this.value.trim();
            
            // Clear existing timeout
            if (geocodeTimeout) {
                clearTimeout(geocodeTimeout);
            }
            
            // Don't search if empty or same as last search
            if (!address || address === lastGeocodedAddress) {
                return;
            }
            
            // Show searching indicator
            showSearchingIndicator(true);
            
            // Debounce the geocoding request
            geocodeTimeout = setTimeout(() => {
                geocodeAddressAutomatically(address);
            }, DEBOUNCE_DELAY);
        });
        
        // Also handle blur event (when user leaves the field)
        locationInput.addEventListener('blur', function() {
            const address = this.value.trim();
            if (address && address !== lastGeocodedAddress) {
                clearTimeout(geocodeTimeout);
                geocodeAddressAutomatically(address);
            }
        });
    });

    // Show/hide searching indicator
    function showSearchingIndicator(show) {
        const indicator = document.getElementById('searchIndicator');
        const overlay = document.getElementById('mapLoadingOverlay');
        
        if (indicator) {
            indicator.style.display = show ? 'block' : 'none';
        }
        if (overlay) {
            overlay.style.display = show ? 'flex' : 'none';
        }
    }

    // Geocode address automatically (without button)
    async function geocodeAddressAutomatically(address) {
        if (!address || address.length < 5) {
            showSearchingIndicator(false);
            return;
        }

        showSearchingIndicator(true);

        try {
            const response = await fetch(`/Properties/GeocodeAddress?address=${encodeURIComponent(address)}`, {
                method: 'GET',
                headers: { 'Accept': 'application/json' }
            });

            const data = await response.json();

            if (!response.ok || !data.success) {
                // Silently fail - don't show error for automatic search
                // Just clear the searching indicator
                showSearchingIndicator(false);
                return;
            }

            // Initialize or update map with coordinates
            initMap(data.latitude, data.longitude);

            // Update coordinate display
            updateCoordinateDisplay(data.latitude, data.longitude);

            // Remember this address was geocoded
            lastGeocodedAddress = address;

            // Show brief success in status area
            showStatus(`<i class="fas fa-check-circle me-1"></i> Location found`, 'success');

            // Auto-hide success message after 3 seconds
            setTimeout(() => {
                const statusDiv = document.getElementById('geocodeStatus');
                if (statusDiv) statusDiv.style.display = 'none';
            }, 3000);

        } catch (error) {
            console.error('Geocoding error:', error);
            // Silently fail for automatic search
        } finally {
            showSearchingIndicator(false);
        }
    }

    // Reverse geocode coordinates to address
    async function reverseGeocode(lat, lng) {
        try {
            const response = await fetch(`/Properties/ReverseGeocode?latitude=${lat}&longitude=${lng}`, {
                method: 'GET',
                headers: { 'Accept': 'application/json' }
            });

            const data = await response.json();

            if (data.success && data.address) {
                showStatus(`<strong>Location:</strong> ${data.address}`, 'info');
            }
        } catch (error) {
            console.error('Reverse geocoding error:', error);
        }
    }

    // Update coordinate fields and display
    function updateCoordinates(lat, lng) {
        document.getElementById('latitudeField').value = lat.toFixed(8);
        document.getElementById('longitudeField').value = lng.toFixed(8);
        updateCoordinateDisplay(lat.toFixed(8), lng.toFixed(8));
    }

    function updateCoordinateDisplay(lat, lng) {
        document.getElementById('displayLat').value = lat;
        document.getElementById('displayLng').value = lng;
    }

    // Show status message
    function showStatus(message, type) {
        const statusDiv = document.getElementById('geocodeStatus');
        const alertClass = type === 'success' ? 'alert-success' : type === 'danger' ? 'alert-danger' : 'alert-info';
        const icon = type === 'success' ? 'fa-check-circle' : type === 'danger' ? 'fa-exclamation-circle' : 'fa-info-circle';

        statusDiv.innerHTML = `<div class="alert ${alertClass} py-2 mb-0" style="font-size: 0.85rem;"><i class="fas ${icon} me-2"></i>${message}</div>`;
        statusDiv.style.display = 'block';

        // Auto-hide after 10 seconds for success messages
        if (type === 'success') {
            setTimeout(() => {
                statusDiv.style.display = 'none';
            }, 10000);
        }
    }

    // ==================== EXISTING FUNCTIONS ====================

    function selectType(type, el) {
        document.querySelectorAll('.type-card').forEach(c => c.classList.remove('selected'));
        el.classList.add('selected');
        document.getElementById('propertyTypeInput').value = type;
    }

    function updateFileName(inputId, labelId) {
        var input = document.getElementById(inputId);
        var label = document.getElementById(labelId);
        if (input && input.files && input.files.length > 0) {
            label.textContent = input.files[0].name;
        }
    }

    // Pre-fill form if in edit mode
    @if (isEdit && listing != null)
    {
        <text>
        document.addEventListener('DOMContentLoaded', function() {
            // Set property type
            var propertyType = '@listing.PropertyType';
            document.getElementById('propertyTypeInput').value = propertyType;
            document.querySelectorAll('.type-card').forEach(card => {
                card.classList.remove('selected');
                var label = card.querySelector('label');
                if (label && label.textContent === propertyType) {
                    card.classList.add('selected');
                }
            });

            // Fill form fields
            document.querySelector('input[name="title"]').value = '@listing.Title';
            document.querySelector('input[name="location"]').value = '@listing.Location';
            document.querySelector('input[name="bedrooms"]').value = '@listing.Bedrooms';
            document.querySelector('input[name="bathrooms"]').value = '@listing.Bathrooms';
            document.querySelector('input[name="parkingSlots"]').value = '@listing.ParkingSlots';
            document.querySelector('input[name="sqft"]').value = '@listing.Sqft';
            document.querySelector('textarea[name="description"]').value = '@listing.Description';
            document.querySelector('input[name="suggestedPrice"]').value = '@listing.SuggestedPrice';

            // Update submit button text
            document.querySelector('.submit-btn').innerHTML = '<i class="fas fa-save me-2"></i>Update Listing';
        });
        </text>
    }
</script>
}
