@{
    ViewData["Title"] = "Seller Profile";
    Layout = "~/Views/Shared/_SellerLayout.cshtml";
}

@section Styles {
<style>
    .profile-container {
        max-width: 800px;
    }
    
    .page-header-section {
        margin-bottom: 32px;
    }
    
    .page-title {
        font-size: 32px;
        font-weight: 800;
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: #1f2937;
        margin: 0 0 8px 0;
    }
    
    .page-subtitle {
        color: #6b7280;
        font-size: 15px;
        margin: 0;
    }
    
    .profile-card {
        background: white;
        border-radius: 14px;
        padding: 32px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
        border: 1px solid rgba(0, 0, 0, 0.04);
        margin-bottom: 24px;
    }
    
    .profile-header {
        display: flex;
        align-items: center;
        gap: 24px;
        margin-bottom: 32px;
        padding-bottom: 24px;
        border-bottom: 2px solid #f3f4f6;
    }
    
    .profile-avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #0ea5e9, #6366f1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        color: white;
        font-weight: 700;
        flex-shrink: 0;
        box-shadow: 0 4px 16px rgba(14, 165, 233, 0.3);
    }
    
    .profile-info h4 {
        font-size: 24px;
        font-weight: 700;
        color: #1f2937;
        margin: 0 0 8px 0;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }
    
    .role-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        background: linear-gradient(135deg, rgba(14, 165, 233, 0.1), rgba(99, 102, 241, 0.1));
        border: 2px solid rgba(14, 165, 233, 0.3);
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        color: #0ea5e9;
        letter-spacing: 0.5px;
    }
    
    .form-section {
        margin-bottom: 24px;
    }
    
    .form-section-title {
        font-size: 18px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 20px;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }
    
    .form-group {
        margin-bottom: 20px;
    }
    
    .form-label-custom {
        font-weight: 600;
        font-size: 13px;
        color: #374151;
        margin-bottom: 8px;
        display: block;
    }
    
    .form-control-readonly {
        border-radius: 10px;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        padding: 12px 16px;
        font-size: 14px;
        color: #6b7280;
    }
    
    .info-box {
        padding: 20px;
        border-radius: 12px;
        background: linear-gradient(135deg, rgba(14, 165, 233, 0.08), rgba(99, 102, 241, 0.08));
        border-left: 4px solid #0ea5e9;
        margin-top: 24px;
    }
    
    .info-box p {
        margin: 0;
        font-size: 14px;
        color: #0369a1;
    }
    
    .info-box i {
        color: #0ea5e9;
    }
    
    .quick-links-card {
        background: white;
        border-radius: 14px;
        padding: 28px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
        border: 1px solid rgba(0, 0, 0, 0.04);
    }
    
    .quick-links-title {
        font-size: 18px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 20px;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }
    
    .quick-link-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 14px;
        border: 2px solid #e5e7eb;
        border-radius: 10px;
        text-decoration: none;
        color: #6b7280;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.3s;
        background: white;
    }
    
    .quick-link-btn:hover {
        border-color: #0ea5e9;
        color: #0ea5e9;
        background: linear-gradient(135deg, rgba(14, 165, 233, 0.05), rgba(99, 102, 241, 0.05));
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(14, 165, 233, 0.15);
    }
    
    .quick-link-btn i {
        font-size: 18px;
    }
</style>
}

<div class="profile-container">
    <!-- Page Header -->
    <div class="page-header-section">
        <h1 class="page-title"><i class="fas fa-user me-2" style="color:#0ea5e9;"></i>My Profile</h1>
        <p class="page-subtitle">Manage your account information.</p>
    </div>

    <!-- Profile Card -->
    <div class="profile-card">
        <div class="profile-header">
            <div class="profile-avatar">
                @((ViewData["UserName"] as string ?? "S")[0].ToString().ToUpper())
            </div>
            <div class="profile-info">
                <h4>@(ViewData["UserName"] ?? "Seller")</h4>
                <div class="role-badge">
                    <i class="fas fa-tag"></i> SELLER
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section-title">Account Information</div>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label-custom">Full Name</label>
                        <input type="text" class="form-control form-control-readonly" value="@(ViewData["UserName"] ?? "")" readonly />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label-custom">Role</label>
                        <input type="text" class="form-control form-control-readonly" value="Seller" readonly />
                    </div>
                </div>
            </div>
        </div>

        <div class="info-box">
            <p>
                <i class="fas fa-info-circle me-2"></i>
                To update your personal information, please contact the administrator.
            </p>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="quick-links-card">
        <div class="quick-links-title">Quick Links</div>
        <div class="d-grid gap-3">
            <a href="/seller/my-listings" class="quick-link-btn">
                <i class="fas fa-building" style="color:#0ea5e9;"></i>
                My Listings
            </a>
            <a href="/seller/submit" class="quick-link-btn">
                <i class="fas fa-plus-circle" style="color:#10b981;"></i>
                Submit Property
            </a>
            <a href="/seller/earnings" class="quick-link-btn">
                <i class="fas fa-coins" style="color:#f59e0b;"></i>
                View Earnings
            </a>
        </div>
    </div>
</div>
