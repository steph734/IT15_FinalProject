@{
    var path = ViewContext.HttpContext.Request.Path.Value?.ToLowerInvariant() ?? "";
}
<nav class="navbar navbar-expand-lg navbar-dark sticky-top shadow-sm" style="background:linear-gradient(135deg,#0ea5e9 0%,#6366f1 100%);">
    <div class="container-fluid px-lg-4">
        <a class="navbar-brand fw-bold" href="/seller/dashboard">
            <span style="color:#fff;font-weight:800;">Estate</span><span style="color:#bae6fd;font-weight:800;">Flow</span>
            <span class="ms-2 badge" style="background:rgba(255,255,255,0.2);font-size:11px;font-weight:600;">SELLER</span>
        </a>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#sellerNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="sellerNavbar">
            <ul class="navbar-nav ms-auto gap-1">
                <li class="nav-item">
                    <a class="nav-link @(path.Contains("/seller/dashboard") ? "fw-semibold text-white" : "text-white-75")"
                       href="/seller/dashboard">
                        <i class="fas fa-chart-line me-1"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(path.Contains("/seller/my-listings") ? "fw-semibold text-white" : "text-white-75")"
                       href="/seller/my-listings">
                        <i class="fas fa-building me-1"></i> My Listings
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(path.Contains("/seller/submit") ? "fw-semibold text-white" : "text-white-75")"
                       href="/seller/submit">
                        <i class="fas fa-plus-circle me-1"></i> Submit Property
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(path.Contains("/seller/earnings") ? "fw-semibold text-white" : "text-white-75")"
                       href="/seller/earnings">
                        <i class="fas fa-coins me-1"></i> Earnings
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(path.Contains("/seller/support") ? "fw-semibold text-white" : "text-white-75")"
                       href="/seller/support">
                        <i class="fas fa-headset me-1"></i> Support
                    </a>
                </li>

                <li class="nav-item dropdown ms-3">
                    <a class="nav-link dropdown-toggle text-white" href="#" data-bs-toggle="dropdown">
                        <i class="fas fa-user-circle me-1"></i>
                        <span>@(ViewData["UserName"] as string ?? "Seller")</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="border-radius:10px;">
                        <li><a class="dropdown-item" href="/seller/profile"><i class="fas fa-user me-2 text-muted"></i>My Profile</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form method="post" action="/seller/logout">
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="fas fa-right-from-bracket me-2"></i>Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </li>
            </ul>
        </div>
    </div>
</nav>

<style>
    .text-white-75 { color: rgba(255,255,255,0.8) !important; transition: color 0.2s; }
    .text-white-75:hover { color: #fff !important; }
    .nav-link { font-weight: 500; font-size: 14px; }
    .dropdown-item { font-size: 14px; padding: 8px 16px; }
    .dropdown-item:hover { background: #f0f9ff; color: #0ea5e9; }
</style>
