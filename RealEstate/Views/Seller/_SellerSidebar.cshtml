<!-- Seller Sidebar Navigation -->
@{
    var currentPath = ViewContext.HttpContext.Request.Path.Value?.ToLowerInvariant() ?? "";
}
<aside class="seller-sidebar">
    <!-- Logo Section -->
    <div class="sidebar-logo">
        <div class="logo-container">
            <div class="logo-icon">
                <i class="fas fa-home"></i>
            </div>
            <div class="logo-text">
                <span class="logo-estate">Estate</span><span class="logo-flow">Flow</span>
            </div>
        </div>
        <div class="role-badge">
            <i class="fas fa-tag"></i> SELLER
        </div>
    </div>

    <!-- Search Section -->
    <div class="sidebar-search">
        <div class="search-wrapper">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Search..." />
        </div>
    </div>

    <!-- Menu Section -->
    <nav class="sidebar-menu">
        <div class="menu-section">
            <div class="menu-label">MAIN</div>
            <ul class="menu-items">
                <li class="menu-item">
                    <a href="/seller/dashboard" class="menu-link @(currentPath.Contains("/seller/dashboard") ? "active" : "")">
                        <i class="fas fa-chart-line"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="menu-section">
            <div class="menu-label">LISTINGS</div>
            <ul class="menu-items">
                <li class="menu-item">
                    <a href="/seller/my-listings" class="menu-link @(currentPath.Contains("/seller/my-listings") ? "active" : "")">
                        <i class="fas fa-building"></i>
                        <span>My Listings</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/seller/submit" class="menu-link @(currentPath.Contains("/seller/submit") ? "active" : "")">
                        <i class="fas fa-plus-circle"></i>
                        <span>Submit Property</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="menu-section">
            <div class="menu-label">FINANCES</div>
            <ul class="menu-items">
                <li class="menu-item">
                    <a href="/seller/earnings" class="menu-link @(currentPath.Contains("/seller/earnings") ? "active" : "")">
                        <i class="fas fa-coins"></i>
                        <span>Earnings</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="menu-section">
            <div class="menu-label">SUPPORT</div>
            <ul class="menu-items">
                <li class="menu-item">
                    <a href="/seller/support" class="menu-link @(currentPath.Contains("/seller/support") ? "active" : "")">
                        <i class="fas fa-headset"></i>
                        <span>Support</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="menu-section">
            <div class="menu-label">ACCOUNT</div>
            <ul class="menu-items">
                <li class="menu-item">
                    <a href="/seller/profile" class="menu-link @(currentPath.Contains("/seller/profile") ? "active" : "")">
                        <i class="fas fa-user"></i>
                        <span>Profile</span>
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- User Profile Section -->
    <div class="sidebar-footer">
        <div class="user-profile">
            <div class="user-avatar">
                <i class="fas fa-user-circle"></i>
            </div>
            <div class="user-info">
                <div class="user-name">@(ViewData["UserName"] as string ?? "Seller")</div>
                <div class="user-role">Seller</div>
            </div>
        </div>
        <form method="post" action="/seller/logout" class="mt-3">
            <button type="submit" class="logout-button">
                <i class="fas fa-right-from-bracket"></i>
                <span>Logout</span>
            </button>
        </form>
    </div>
</aside>

<style>
    .seller-sidebar {
        width: 260px;
        background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
        color: #e4e6eb;
        display: flex;
        flex-direction: column;
        height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        overflow-y: auto;
        box-shadow: 4px 0 16px rgba(0, 0, 0, 0.2);
        z-index: 1000;
    }

    /* Logo Section */
    .sidebar-logo {
        padding: 24px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .logo-container {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }

    .logo-icon {
        width: 42px;
        height: 42px;
        background: linear-gradient(135deg, #0ea5e9 0%, #6366f1 100%);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: white;
        box-shadow: 0 4px 12px rgba(14, 165, 233, 0.3);
    }

    .logo-text {
        font-size: 18px;
        font-weight: 800;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .logo-estate {
        color: #38bdf8;
    }

    .logo-flow {
        color: #e4e6eb;
    }

    .role-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        background: rgba(14, 165, 233, 0.15);
        border: 1px solid rgba(14, 165, 233, 0.3);
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        color: #38bdf8;
        letter-spacing: 0.5px;
    }

    .role-badge i {
        font-size: 10px;
    }

    /* Search Section */
    .sidebar-search {
        padding: 16px 12px;
    }

    .search-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .search-wrapper i {
        position: absolute;
        left: 12px;
        color: #9ca3af;
        font-size: 14px;
    }

    .search-wrapper input {
        width: 100%;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 10px;
        padding: 11px 12px 11px 38px;
        color: #e4e6eb;
        font-size: 13px;
        transition: all 0.3s ease;
    }

    .search-wrapper input::placeholder {
        color: #9ca3af;
    }

    .search-wrapper input:focus {
        outline: none;
        background: rgba(255, 255, 255, 0.12);
        border-color: rgba(14, 165, 233, 0.5);
        box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
    }

    /* Menu Section */
    .sidebar-menu {
        flex: 1;
        overflow-y: auto;
        padding: 16px 0;
    }

    .menu-section {
        margin-bottom: 8px;
    }

    .menu-label {
        padding: 12px 20px 8px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: #9ca3af;
    }

    .menu-items {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .menu-item {
        margin-bottom: 2px;
    }

    .menu-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 20px;
        color: #cbd5e1;
        text-decoration: none;
        transition: all 0.2s ease;
        font-size: 14px;
        font-weight: 500;
        border-left: 3px solid transparent;
    }

    .menu-link i {
        width: 20px;
        text-align: center;
        font-size: 16px;
        color: #94a3b8;
        transition: all 0.2s ease;
    }

    .menu-link:hover {
        background: rgba(14, 165, 233, 0.1);
        color: #fff;
        border-left-color: rgba(14, 165, 233, 0.5);
    }

    .menu-link:hover i {
        color: #38bdf8;
    }

    .menu-link.active {
        background: linear-gradient(90deg, rgba(14, 165, 233, 0.2), transparent);
        color: #38bdf8;
        border-left: 3px solid #0ea5e9;
        padding-left: 17px;
    }

    .menu-link.active i {
        color: #0ea5e9;
    }

    /* Scrollbar */
    .sidebar-menu::-webkit-scrollbar {
        width: 6px;
    }

    .sidebar-menu::-webkit-scrollbar-track {
        background: transparent;
    }

    .sidebar-menu::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 3px;
    }

    .sidebar-menu::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.2);
    }

    /* Footer Section */
    .sidebar-footer {
        padding: 20px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(0, 0, 0, 0.2);
    }

    .user-profile {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .user-avatar {
        width: 42px;
        height: 42px;
        background: linear-gradient(135deg, rgba(14, 165, 233, 0.2), rgba(99, 102, 241, 0.2));
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: #38bdf8;
        border: 2px solid rgba(14, 165, 233, 0.3);
    }

    .user-info {
        flex: 1;
        min-width: 0;
    }

    .user-name {
        font-size: 13px;
        font-weight: 600;
        color: #e4e6eb;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .user-role {
        font-size: 11px;
        color: #94a3b8;
    }

    .logout-button {
        width: 100%;
        border: 1px solid rgba(255, 255, 255, 0.15);
        background: rgba(239, 68, 68, 0.1);
        color: #fca5a5;
        border-radius: 10px;
        padding: 10px 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-size: 13px;
        font-weight: 500;
        transition: all 0.2s ease;
    }

    .logout-button:hover {
        background: rgba(239, 68, 68, 0.2);
        border-color: rgba(239, 68, 68, 0.3);
        color: #fecaca;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .seller-sidebar {
            width: 260px;
            transform: translateX(-100%);
            transition: transform 0.3s ease;
        }

        .seller-sidebar.active {
            transform: translateX(0);
        }
    }
</style>
