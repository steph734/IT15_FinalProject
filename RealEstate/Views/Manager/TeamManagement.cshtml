@{
    ViewData["Title"] = "Team Management";
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
}

<div class="container-fluid py-4">
    <h1 class="h4 fw-bold mb-4">👔 Team Management</h1>

    <!-- Add Member Button -->
    <div class="mb-4">
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addAgentModal">+ Add New Agent</button>
    </div>

    <!-- Team Members -->
    <div class="row g-4">
        @for (int i = 1; i <= 4; i++)
        {
            <div class="col-md-6">
                <div class="team-card">
                    <div class="card-header">
                        <div class="member-avatar">A@i</div>
                        <div class="member-info">
                            <div class="member-name">Agent @i</div>
                            <div class="member-status">Active</div>
                        </div>
                        <div class="member-menu">
                            <button class="btn-menu">⋯</button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="stat-item">
                            <span>Deals Closed:</span>
                            <span class="stat-value">@(i * 3)</span>
                        </div>
                        <div class="stat-item">
                            <span>Active Properties:</span>
                            <span class="stat-value">@(i * 2)</span>
                        </div>
                        <div class="stat-item">
                            <span>Total Sales:</span>
                            <span class="stat-value">₱@(i * 15)M</span>
                        </div>
                        <div class="stat-item">
                            <span>Rating:</span>
                            <span class="stat-value">⭐ 4.@(8 - i)</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Add Agent Modal -->
<div class="modal fade" id="addAgentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Agent</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input type="text" class="form-control" placeholder="Agent name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" placeholder="agent@email.com" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone</label>
                    <input type="tel" class="form-control" placeholder="+63 912 345 6789" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Specialization</label>
                    <select class="form-select">
                        <option>Residential</option>
                        <option>Commercial</option>
                        <option>Industrial</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary">Add Agent</button>
            </div>
        </div>
    </div>
</div>

<style>
    .team-card {
        background: white;
        border: 1px solid #e0e0ff;
        border-radius: 10px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .team-card:hover {
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15);
    }

    .card-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px;
        border-bottom: 1px solid #e0e0ff;
    }

    .member-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: white;
        font-size: 18px;
    }

    .member-info {
        flex: 1;
    }

    .member-name {
        font-weight: 600;
        margin-bottom: 2px;
    }

    .member-status {
        font-size: 0.8rem;
        color: #10b981;
    }

    .member-menu {
        display: flex;
        align-items: center;
    }

    .btn-menu {
        background: none;
        border: none;
        font-size: 18px;
        cursor: pointer;
        color: #999;
    }

    .card-body {
        padding: 16px;
    }

    .stat-item {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        font-size: 0.9rem;
        border-bottom: 1px solid #f0f0f0;
    }

    .stat-item:last-child {
        border-bottom: none;
    }

    .stat-value {
        font-weight: 600;
        color: #6366f1;
    }
</style>
