@model RealEstate.Models.Property
@{
    ViewData["Title"] = "Property Details";
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
}

@section Styles {
<!-- Leaflet CSS for Map -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/manager/sellers/listings" class="btn btn-outline-secondary btn-sm rounded-pill">
            <i class="fas fa-arrow-left me-1"></i> Back
        </a>
        <h2 class="mb-0"><i class="fas fa-building text-primary me-2"></i> @Model.Title</h2>
        
        @if (Model.Status == "Inspection")
        {
            <span class="badge bg-warning text-dark px-3 py-2 fs-6 ms-auto">Under Inspection</span>
        }
        else if (Model.Status == "PendingReview")
        {
            <span class="badge bg-info text-dark px-3 py-2 fs-6 ms-auto">Pending Review</span>
        }
        else if (Model.IsApproved)
        {
            <span class="badge bg-success px-3 py-2 fs-6 ms-auto">Approved</span>
        }
        else if (Model.IsRejected)
        {
            <span class="badge bg-danger px-3 py-2 fs-6 ms-auto">Rejected</span>
        }
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="row g-4">
        <div class="col-lg-8">
            <!-- Property Details Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Property Information</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label class="text-muted small fw-bold">Location</label>
                            <div>@Model.Location</div>
                        </div>
                        <div class="col-sm-6">
                            <label class="text-muted small fw-bold">Property Type</label>
                            <div>@Model.PropertyType</div>
                        </div>
                        <div class="col-sm-3">
                            <label class="text-muted small fw-bold">Bedrooms</label>
                            <div>@Model.Bedrooms</div>
                        </div>
                        <div class="col-sm-3">
                            <label class="text-muted small fw-bold">Bathrooms</label>
                            <div>@Model.Bathrooms</div>
                        </div>
                        <div class="col-sm-3">
                            <label class="text-muted small fw-bold">Parking</label>
                            <div>@Model.ParkingSlots</div>
                        </div>
                        <div class="col-sm-3">
                            <label class="text-muted small fw-bold">Area</label>
                            <div>@Model.Sqft sqm</div>
                        </div>
                        <div class="col-12 mt-3">
                            <label class="text-muted small fw-bold">Description</label>
                            <p class="mb-0">@Model.Description</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Documents Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Attached Documents</h5>
                </div>
                <div class="card-body">
                    @{
                        List<string>? docs = null;
                        try { docs = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.DocumentUrlsJson ?? "[]"); } catch { }
                    }
                    @if (docs != null && docs.Any())
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @for (int i = 0; i < docs.Count; i++)
                            {
                                <a href="@docs[i]" target="_blank" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-file-alt me-1"></i> Document @(i + 1)
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No documents attached.</p>
                    }
                </div>
            </div>

            <!-- Map Location Card -->
            @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
            {
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold"><i class="fas fa-map-marker-alt text-danger me-2"></i>Map Location</h5>
                    </div>
                    <div class="card-body">
                        <div id="propertyMap" style="height: 280px; border-radius: 12px; border: 2px solid #e5e7eb; background-color: #f0f0f0;"></div>
                        <div class="mt-3 row g-2">
                            <div class="col-md-6">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text" style="background: #f8f9fa;"><i class="fas fa-globe"></i> Lat</span>
                                    <input type="text" class="form-control" readonly value="@Model.Latitude.Value.ToString("F8")" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text" style="background: #f8f9fa;"><i class="fas fa-globe"></i> Lng</span>
                                    <input type="text" class="form-control" readonly value="@Model.Longitude.Value.ToString("F8")" />
                                </div>
                            </div>
                        </div>
                        <div class="mt-2" style="font-size: 0.8rem; color: #6b7280;">
                            <i class="fas fa-info-circle me-1"></i>
                            Property location verified and saved in database
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm border-0 mb-4" style="background: #fef3c7; border-left: 4px solid #f59e0b !important;">
                    <div class="card-header bg-white py-3" style="background: transparent !important;">
                        <h5 class="mb-0 fw-bold"><i class="fas fa-exclamation-triangle text-warning me-2"></i>Map Location Not Set</h5>
                    </div>
                    <div class="card-body">
                        <p style="font-size:14px; color:#92400e; margin-bottom: 12px;">
                            This property does not have map coordinates. The seller needs to edit the listing to add the exact location.
                        </p>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <!-- Pricing Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body text-center">
                    <h6 class="text-muted fw-bold">SELLER SUGGESTED PRICE</h6>
                    <h2 class="text-success fw-bold mb-0">₱@Model.SuggestedPrice?.ToString("N0")</h2>
                </div>
            </div>

            <!-- Action Card -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Manager Actions</h5>
                </div>
                <div class="card-body">
                    @if (Model.Status == "PendingReview")
                    {
                        <form action="/manager/properties/@Model.PropertyId/mark-inspection" method="post" class="mb-4">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Inspection Timeframe (Days)</label>
                                <input type="number" name="inspectionDays" class="form-control" value="3" min="1" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Notes for Inspector</label>
                                <textarea name="notes" class="form-control" rows="2" placeholder="Optional notes..."></textarea>
                            </div>
                            <button type="submit" class="btn btn-warning w-100 fw-bold mb-2">
                                <i class="fas fa-search me-1"></i> Mark for Inspection
                            </button>
                        </form>

                        <hr />
                        
                        <form action="/manager/properties/@Model.PropertyId/reject" method="post">
                            <div class="mb-2">
                                <label class="form-label fw-bold">Rejection Reason</label>
                                <textarea name="reason" class="form-control" rows="2" placeholder="Required for rejection..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-outline-danger w-100 fw-bold">
                                <i class="fas fa-times me-1"></i> Reject Property
                            </button>
                        </form>
                    }
                    else if (Model.Status == "Inspection")
                    {
                        <div class="alert alert-warning mb-4">
                            <strong><i class="fas fa-clock me-1"></i> Inspection Scheduled</strong><br />
                            Due by: @Model.InspectionScheduledDate?.ToString("MMM dd, yyyy")
                        </div>

                        <button type="button" class="btn btn-warning w-100 fw-bold btn-lg mb-4" data-bs-toggle="modal" data-bs-target="#inspectionModal">
                            <i class="fas fa-clipboard-check me-2"></i> Property Inspection
                        </button>

                        <hr />
                        
                        <form action="/manager/properties/@Model.PropertyId/reject" method="post">
                            <div class="mb-2">
                                <label class="form-label fw-bold">Rejection Reason</label>
                                <textarea name="reason" class="form-control" rows="2" placeholder="Required for rejection..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-outline-danger w-100 fw-bold">
                                <i class="fas fa-times me-1"></i> Reject Property
                            </button>
                        </form>
                    }
                    else if (Model.Status == "InspectionApproved" || Model.Status == "InspectionContactSeller" || Model.Status == "InspectionFailed")
                    {
                        if (Model.Status == "InspectionApproved")
                        {
                            <div class="alert alert-success mb-4">
                                <strong><i class="fas fa-check-circle me-1"></i> Inspection Approved</strong><br />
                                Property passed inspection. Ready for final approval and purchase.
                            </div>
                        }
                        else if (Model.Status == "InspectionContactSeller")
                        {
                            <div class="alert alert-primary mb-4">
                                <strong><i class="fas fa-phone me-1"></i> Contact Seller</strong><br />
                                Property needs follow-up with the seller before final approval.
                            </div>
                        }
                        else if (Model.Status == "InspectionFailed")
                        {
                            <div class="alert alert-danger mb-4">
                                <strong><i class="fas fa-ban me-1"></i> Inspection Failed</strong><br />
                                Property failed inspection. Proceed to reject.
                            </div>
                        }

                        if (Model.Status != "InspectionFailed")
                        {
                            <button type="button" class="btn btn-success w-100 fw-bold btn-lg mb-4" data-bs-toggle="modal" data-bs-target="#dealPaymentModal">
                                <i class="fas fa-handshake me-1"></i> Proceed to Deal & Payment
                            </button>
                            <hr />
                        }
                        
                        <form action="/manager/properties/@Model.PropertyId/reject" method="post">
                            <div class="mb-2">
                                <label class="form-label fw-bold">Rejection Reason</label>
                                <textarea name="reason" class="form-control" rows="2" placeholder="Required for rejection..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-outline-danger w-100 fw-bold">
                                <i class="fas fa-times me-1"></i> Reject Property
                            </button>
                        </form>
                    }
                    else if (Model.IsApproved || Model.IsRejected)
                    {
                        <div class="text-center">
                            <p class="mb-1 text-muted">Decision made on:</p>
                            <p class="fw-bold">@Model.DecisionAt?.ToString("MMM dd, yyyy hh:mm tt")</p>
                            
                            @if (Model.IsApproved)
                            {
                                <div class="p-3 bg-light rounded text-success fw-bold mb-3">
                                    Bought for ₱@Model.FinalPrice?.ToString("N2")
                                </div>

                                <!-- Set Listing Type Button - Opens Modal -->
                                <button type="button" class="btn btn-info w-100 fw-bold mb-3 text-white" data-bs-toggle="modal" data-bs-target="#setListingTypeModal">
                                    <i class="fas fa-tag me-2"></i> Set Listing Type
                                </button>

                                @if (!Model.IsReadyForListing)
                                {
                                    <button type="button" class="btn btn-success w-100 fw-bold mb-3" data-bs-toggle="modal" data-bs-target="#processSaleModal">
                                        <i class="fas fa-handshake me-2"></i> Process Sale
                                    </button>
                                }
                                else
                                {
                                    <div class="alert alert-@(Model.Status == "ReadyForSale" ? "primary" : "info")">
                                        <i class="fas fa-check-circle me-2"></i> 
                                        @(Model.Status == "ReadyForSale" ? "Ready for Sale" : "Ready for Rent")
                                    </div>
                                }
                                
                                var assignedAgent = ViewBag.AssignedAgent as RealEstate.Models.Agent;
                                @if (assignedAgent != null)
                                {
                                    <div class="assigned-agent-card mb-3">
                                        <div class="d-flex align-items-center gap-3 p-3 bg-white rounded border shadow-sm">
                                            <div class="agent-avatar">
                                                @if (!string.IsNullOrEmpty(assignedAgent.ProfilePhotoPath))
                                                {
                                                    <img src="@assignedAgent.ProfilePhotoPath" alt="@assignedAgent.DisplayName" class="rounded-circle" style="width: 48px; height: 48px; object-fit: cover;">
                                                }
                                                else
                                                {
                                                    <div class="rounded-circle bg-gradient d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                                        <i class="fas fa-user text-white"></i>
                                                    </div>
                                                }
                                            </div>
                                            <div class="agent-info text-start flex-grow-1">
                                                <div class="text-muted small">Assigned Agent</div>
                                                <div class="fw-bold text-dark">@assignedAgent.DisplayName</div>
                                                <div class="text-muted small">@assignedAgent.Email</div>
                                            </div>
                                        </div>
                                        <a href="/manager/agents/@assignedAgent.Id" class="btn btn-outline-primary w-100 fw-bold mt-2">
                                            <i class="fas fa-eye me-2"></i> View Agent Details
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-gradient-primary w-100 fw-bold" data-bs-toggle="modal" data-bs-target="#assignAgentModal" data-property-id="@Model.PropertyId" data-property-title="@Model.Title">
                                        <i class="fas fa-user-plus me-2"></i> Assign Agent
                                    </button>
                                }
                            }
                            else
                            {
                                <div class="p-3 bg-light rounded text-danger mb-0 text-start">
                                    <span class="fw-bold">Rejected:</span> @Model.RejectionReason
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.Status == "Inspection")
{
    var inspectionItems = (List<RealEstate.Models.InspectionItem>?)ViewBag.InspectionItems ?? new List<RealEstate.Models.InspectionItem>();
    var grouped = inspectionItems.GroupBy(i => i.Category);
    var totalItems = inspectionItems.Count;

    <!-- Inspection Modal -->
    <div class="modal fade" id="inspectionModal" tabindex="-1" aria-labelledby="inspectionModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-warning bg-gradient text-dark border-0 py-3">
                    <h5 class="modal-title fw-bold" id="inspectionModalLabel">
                        <i class="fas fa-clipboard-check me-2"></i> Property Inspection Checklist
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body px-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <p class="text-muted mb-0">Review each item for <strong>@Model.Title</strong></p>
                        <span class="badge bg-secondary fs-6" id="inspectionCounter">0 / @totalItems reviewed</span>
                    </div>

                    <!-- Progress Bar -->
                    <div class="progress mb-4" style="height: 8px;">
                        <div class="progress-bar bg-success" id="progressApproved" role="progressbar" style="width: 0%"></div>
                        <div class="progress-bar bg-primary" id="progressContact" role="progressbar" style="width: 0%"></div>
                        <div class="progress-bar bg-danger" id="progressFailed" role="progressbar" style="width: 0%"></div>
                    </div>

                    <div id="inspectionItemsList">
                        @foreach (var group in grouped)
                        {
                            <h6 class="fw-bold text-uppercase text-secondary mt-3 mb-2 d-flex align-items-center">
                                <i class="fas fa-folder-open me-2 text-warning"></i> @group.Key
                            </h6>
                            <div class="list-group list-group-flush mb-3">
                                @foreach (var item in group)
                                {
                                    <div class="list-group-item border rounded mb-2 inspection-item" data-item-id="@item.Id">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-circle bg-warning bg-opacity-10" style="width: 42px; height: 42px;">
                                                <i class="fas @item.Icon text-warning"></i>
                                            </div>
                                            <div class="flex-grow-1">
                                                <div class="fw-semibold">@item.Name</div>
                                                <small class="text-muted">@item.Criteria</small>
                                            </div>
                                            <button type="button" class="btn btn-sm btn-outline-secondary border-0 delete-item-btn" data-item-id="@item.Id" title="Remove item">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </div>
                                        <div class="btn-group w-100 mt-2" role="group">
                                            <button type="button" class="btn btn-outline-success inspection-action-btn" data-item-id="@item.Id" data-action="Approved">
                                                <i class="fas fa-check-circle me-1"></i> Approve
                                            </button>
                                            <button type="button" class="btn btn-outline-primary inspection-action-btn" data-item-id="@item.Id" data-action="ForContact">
                                                <i class="fas fa-phone-alt me-1"></i> For Contact
                                            </button>
                                            <button type="button" class="btn btn-outline-danger inspection-action-btn" data-item-id="@item.Id" data-action="Failed">
                                                <i class="fas fa-times-circle me-1"></i> Fail
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @if (!inspectionItems.Any())
                    {
                        <div class="text-center text-muted py-4" id="emptyState">
                            <i class="fas fa-info-circle fa-2x mb-2"></i>
                            <p>No inspection items found.</p>
                        </div>
                    }

                    <!-- Add New Item -->
                    <div class="card border-dashed mt-3">
                        <div class="card-body">
                            <h6 class="fw-bold mb-3"><i class="fas fa-plus-circle me-1 text-success"></i> Add Inspection Item</h6>
                            <div class="row g-2">
                                <div class="col-md-4">
                                    <input type="text" id="newItemCategory" class="form-control form-control-sm" placeholder="Category" />
                                </div>
                                <div class="col-md-4">
                                    <input type="text" id="newItemName" class="form-control form-control-sm" placeholder="Item Name" />
                                </div>
                                <div class="col-md-4">
                                    <input type="text" id="newItemCriteria" class="form-control form-control-sm" placeholder="Criteria" />
                                </div>
                            </div>
                            <button type="button" id="addItemBtn" class="btn btn-sm btn-success mt-2">
                                <i class="fas fa-plus me-1"></i> Add Item
                            </button>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4 d-flex justify-content-between" id="inspectionFooter">
                    <div id="dynamicActionBtns">
                        <!-- Dynamic buttons appear here based on selections -->
                    </div>
                    <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i> Close
                    </button>
                </div>
            </div>
        </div>
    </div>

    <style>
        .card.border-dashed { border: 2px dashed #dee2e6; }
        .inspection-item .btn-group .btn { font-size: 0.8rem; padding: 0.35rem 0.5rem; }
        .inspection-item .btn-group .btn.active { font-weight: 600; }
        .inspection-item { transition: background-color 0.2s; }
        .inspection-item.item-approved { border-left: 3px solid #198754 !important; background: #f0fdf4; }
        .inspection-item.item-contact { border-left: 3px solid #0d6efd !important; background: #eff6ff; }
        .inspection-item.item-failed { border-left: 3px solid #dc3545 !important; background: #fef2f2; }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var totalItems = @totalItems;
            var propertyId = @Model.PropertyId;

            function updateFooterAndProgress() {
                var items = document.querySelectorAll('.inspection-item');
                var total = items.length;
                var approved = 0, contact = 0, failed = 0;

                items.forEach(function (item) {
                    var activeBtn = item.querySelector('.inspection-action-btn.active');
                    if (activeBtn) {
                        var action = activeBtn.dataset.action;
                        if (action === 'Approved') approved++;
                        else if (action === 'ForContact') contact++;
                        else if (action === 'Failed') failed++;
                    }
                });

                var reviewed = approved + contact + failed;
                document.getElementById('inspectionCounter').textContent = reviewed + ' / ' + total + ' reviewed';

                // Progress bars
                var pct = total > 0 ? 100 / total : 0;
                document.getElementById('progressApproved').style.width = (approved * pct) + '%';
                document.getElementById('progressContact').style.width = (contact * pct) + '%';
                document.getElementById('progressFailed').style.width = (failed * pct) + '%';

                // Dynamic footer buttons
                var dynamicDiv = document.getElementById('dynamicActionBtns');
                dynamicDiv.innerHTML = '';

                if (total > 0 && reviewed === total) {
                    if (approved === total) {
                        dynamicDiv.innerHTML = '<form action="/manager/properties/' + propertyId + '/complete-inspection" method="POST"><input type="hidden" name="status" value="InspectionApproved" /><button type="submit" class="btn btn-success btn-lg fw-bold" id="approveInspectionBtn"><i class="fas fa-check-double me-2"></i>Approved Inspection</button></form>';
                    } else if (contact === total) {
                        dynamicDiv.innerHTML = '<form action="/manager/properties/' + propertyId + '/complete-inspection" method="POST"><input type="hidden" name="status" value="InspectionContactSeller" /><button type="submit" class="btn btn-primary btn-lg fw-bold" id="contactSellerBtn"><i class="fas fa-phone me-2"></i>Contact Seller</button></form>';
                    } else if (failed === total) {
                        dynamicDiv.innerHTML = '<form action="/manager/properties/' + propertyId + '/complete-inspection" method="POST"><input type="hidden" name="status" value="InspectionFailed" /><button type="submit" class="btn btn-danger btn-lg fw-bold" id="failInspectionBtn"><i class="fas fa-ban me-2"></i>Failed Inspection</button></form>';
                    } else if (approved > 0 && approved >= contact && approved >= failed) {
                        dynamicDiv.innerHTML = '<form action="/manager/properties/' + propertyId + '/complete-inspection" method="POST"><input type="hidden" name="status" value="InspectionApproved" /><button type="submit" class="btn btn-success btn-lg fw-bold" id="approveInspectionBtn"><i class="fas fa-check-double me-2"></i>Approved Inspection</button></form>';
                    } else if (contact > 0 && contact >= approved && contact >= failed) {
                        dynamicDiv.innerHTML = '<form action="/manager/properties/' + propertyId + '/complete-inspection" method="POST"><input type="hidden" name="status" value="InspectionContactSeller" /><button type="submit" class="btn btn-primary btn-lg fw-bold" id="contactSellerBtn"><i class="fas fa-phone me-2"></i>Contact Seller</button></form>';
                    } else if (failed > 0) {
                        dynamicDiv.innerHTML = '<form action="/manager/properties/' + propertyId + '/complete-inspection" method="POST"><input type="hidden" name="status" value="InspectionFailed" /><button type="submit" class="btn btn-danger btn-lg fw-bold" id="failInspectionBtn"><i class="fas fa-ban me-2"></i>Failed Inspection</button></form>';
                    }
                }
            }

            // Action button clicks
            document.querySelectorAll('.inspection-action-btn').forEach(function (btn) {
                btn.addEventListener('click', handleActionClick);
            });

            function handleActionClick() {
                var itemRow = this.closest('.inspection-item');
                var btnGroup = this.closest('.btn-group');

                btnGroup.querySelectorAll('.inspection-action-btn').forEach(function (b) {
                    b.classList.remove('active', 'btn-success', 'btn-primary', 'btn-danger');
                    if (b.dataset.action === 'Approved') b.classList.add('btn-outline-success');
                    else if (b.dataset.action === 'ForContact') b.classList.add('btn-outline-primary');
                    else if (b.dataset.action === 'Failed') b.classList.add('btn-outline-danger');
                });

                this.classList.add('active');
                itemRow.classList.remove('item-approved', 'item-contact', 'item-failed');

                if (this.dataset.action === 'Approved') {
                    this.classList.remove('btn-outline-success');
                    this.classList.add('btn-success');
                    itemRow.classList.add('item-approved');
                } else if (this.dataset.action === 'ForContact') {
                    this.classList.remove('btn-outline-primary');
                    this.classList.add('btn-primary');
                    itemRow.classList.add('item-contact');
                } else if (this.dataset.action === 'Failed') {
                    this.classList.remove('btn-outline-danger');
                    this.classList.add('btn-danger');
                    itemRow.classList.add('item-failed');
                }

                updateFooterAndProgress();
            }

            // Delete item
            document.querySelectorAll('.delete-item-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var itemId = this.dataset.itemId;
                    if (!confirm('Remove this inspection item?')) return;

                    fetch('/manager/inspection-items/' + itemId + '/delete', { method: 'POST' })
                        .then(function (res) { return res.json(); })
                        .then(function (data) {
                            if (data.success) {
                                var el = document.querySelector('.inspection-item[data-item-id="' + itemId + '"]');
                                if (el) el.remove();
                                totalItems--;
                                updateFooterAndProgress();
                            }
                        });
                });
            });

            // Add item
            document.getElementById('addItemBtn').addEventListener('click', function () {
                var category = document.getElementById('newItemCategory').value.trim();
                var name = document.getElementById('newItemName').value.trim();
                var criteria = document.getElementById('newItemCriteria').value.trim();

                if (!category || !name) { alert('Category and Name are required.'); return; }

                fetch('/manager/inspection-items/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ category: category, name: name, criteria: criteria })
                })
                .then(function (res) { return res.json(); })
                .then(function (data) {
                    if (data.success) {
                        var list = document.getElementById('inspectionItemsList');
                        var html = '<div class="list-group-item border rounded mb-2 inspection-item" data-item-id="' + data.id + '">'
                            + '<div class="d-flex align-items-center gap-3">'
                            + '<div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-circle bg-warning bg-opacity-10" style="width:42px;height:42px;">'
                            + '<i class="fas fa-clipboard text-warning"></i></div>'
                            + '<div class="flex-grow-1"><div class="fw-semibold">' + name + '</div>'
                            + '<small class="text-muted">' + (criteria || 'No criteria specified') + '</small></div>'
                            + '<button type="button" class="btn btn-sm btn-outline-secondary border-0 delete-item-btn" data-item-id="' + data.id + '" title="Remove item">'
                            + '<i class="fas fa-trash-alt"></i></button></div>'
                            + '<div class="btn-group w-100 mt-2" role="group">'
                            + '<button type="button" class="btn btn-outline-success inspection-action-btn" data-item-id="' + data.id + '" data-action="Approved">'
                            + '<i class="fas fa-check-circle me-1"></i> Approve</button>'
                            + '<button type="button" class="btn btn-outline-primary inspection-action-btn" data-item-id="' + data.id + '" data-action="ForContact">'
                            + '<i class="fas fa-phone-alt me-1"></i> For Contact</button>'
                            + '<button type="button" class="btn btn-outline-danger inspection-action-btn" data-item-id="' + data.id + '" data-action="Failed">'
                            + '<i class="fas fa-times-circle me-1"></i> Fail</button>'
                            + '</div></div>';
                        list.insertAdjacentHTML('beforeend', html);

                        // Rebind events for new item
                        var newEl = list.querySelector('.inspection-item[data-item-id="' + data.id + '"]');
                        newEl.querySelectorAll('.inspection-action-btn').forEach(function (b) {
                            b.addEventListener('click', handleActionClick);
                        });
                        newEl.querySelector('.delete-item-btn').addEventListener('click', function () {
                            var id = this.dataset.itemId;
                            if (!confirm('Remove this inspection item?')) return;
                            fetch('/manager/inspection-items/' + id + '/delete', { method: 'POST' })
                                .then(function (r) { return r.json(); })
                                .then(function (d) {
                                    if (d.success) { newEl.remove(); totalItems--; updateFooterAndProgress(); }
                                });
                        });

                        totalItems++;
                        document.getElementById('newItemCategory').value = '';
                        document.getElementById('newItemName').value = '';
                        document.getElementById('newItemCriteria').value = '';
                        updateFooterAndProgress();
                    }
                });
            });

            updateFooterAndProgress();
        });
    </script>
}

