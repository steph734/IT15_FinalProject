<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Assign Agent Modal functionality - Custom Pure JS
        var agents = [];
        var modalOverlay = document.getElementById('assignAgentModal');
        var closeModalBtn = document.getElementById('closeModalBtn');
        var cancelModalBtn = document.getElementById('cancelModalBtn');
        var assignAgentBtn = document.getElementById('assignAgentBtn');

        // Open modal function
        function openModal(propertyId, propertyTitle) {
            $('#modalPropertyId').val(propertyId);
            $('#modalPropertyName').val(propertyTitle);
            $('#assignmentNotes').val('');
            $('#agentSelect').val('');
            
            modalOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
            
            // Load agents
            loadAgents();
        }

        // Close modal function
        function closeModal() {
            modalOverlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        // Close modal on button clicks
        if (closeModalBtn) closeModalBtn.addEventListener('click', closeModal);
        if (cancelModalBtn) cancelModalBtn.addEventListener('click', closeModal);

        // Close modal on overlay click
        if (modalOverlay) {
            modalOverlay.addEventListener('click', function(e) {
                if (e.target === modalOverlay) {
                    closeModal();
                }
            });
        }

        // Close modal on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && modalOverlay && modalOverlay.classList.contains('active')) {
                closeModal();
            }
        });

        // Handle "Assign Agent" button clicks
        document.querySelectorAll('[data-bs-toggle="modal"][data-bs-target="#assignAgentModal"]').forEach(function(btn) {
            btn.addEventListener('click', function(event) {
                event.preventDefault();
                var propertyId = this.getAttribute('data-property-id');
                var propertyTitle = this.getAttribute('data-property-title');
                openModal(propertyId, propertyTitle);
            });
        });

        // Load agents from server
        function loadAgents() {
            $.ajax({
                url: '/manager/get-agents',
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    agents = data;
                    var select = $('#agentSelect');
                    select.empty();
                    select.append('<option value="" selected disabled>-- Choose an agent --</option>');
                    
                    $.each(data, function (index, agent) {
                        select.append('<option value="' + agent.agentId + '">' + agent.fullName + '</option>');
                    });
                },
                error: function (xhr, status, error) {
                    console.error('Error loading agents:', error);
                    alert('Failed to load agents. Please try again.');
                }
            });
        }

        // Assign agent button click
        if (assignAgentBtn) {
            assignAgentBtn.addEventListener('click', function () {
                var propertyId = $('#modalPropertyId').val();
                var agentId = $('#agentSelect').val();
                var notes = $('#assignmentNotes').val();

                if (!agentId) {
                    alert('Please select an agent.');
                    return;
                }

                $.ajax({
                    url: '/manager/assign-agent',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        propertyId: propertyId,
                        agentId: agentId,
                        notes: notes
                    }),
                    success: function (response) {
                        if (response.success) {
                            alert('Agent assigned successfully!');
                            closeModal();
                            location.reload();
                        } else {
                            alert('Failed to assign agent: ' + response.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('Error assigning agent:', error);
                        alert('Failed to assign agent. Please try again.');
                    }
                });
            });
        }
    });
</script>

<!-- Set Listing Type Modal -->
@if (Model.IsApproved)
{
    <div class="modal fade" id="setListingTypeModal" tabindex="-1" aria-labelledby="setListingTypeModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-info text-white border-0">
                    <h5 class="modal-title fw-bold" id="setListingTypeModalLabel">
                        <i class="fas fa-tag me-2"></i> Set Listing Type
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body px-4 py-4">
                    <p class="text-muted mb-4">Select how this property should be listed:</p>
                    
                    <div class="d-grid gap-3">
                        <button type="button" class="btn @(Model.ListingType == PropertyListingType.Buy ? "btn-primary" : "btn-outline-primary") btn-lg fw-bold py-3"
                                onclick="saveListingType(@Model.PropertyId, 'Buy')" id="btnForSale">
                            <i class="fas fa-home me-2"></i>For Sale
                            <div class="small fw-normal mt-1">Property will be listed for buyers to purchase</div>
                        </button>
                        
                        <button type="button" class="btn @(Model.ListingType == PropertyListingType.Rent ? "btn-info text-white" : "btn-outline-info") btn-lg fw-bold py-3"
                                onclick="saveListingType(@Model.PropertyId, 'Rent')" id="btnForRent">
                            <i class="fas fa-key me-2"></i>For Rent
                            <div class="small fw-normal mt-1">Property will be listed for tenants to rent</div>
                        </button>
                    </div>
                    
                    <div id="listingTypeSaveMessage" class="alert alert-success mt-3 d-none">
                        <i class="fas fa-check-circle me-2"></i>Listing type saved successfully!
                    </div>
                </div>
                <div class="modal-footer bg-light border-0 px-4 py-3">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        function saveListingType(propertyId, listingType) {
            fetch('/manager/set-listing-type', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ propertyId: propertyId, listingType: listingType })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    // Update button styles
                    var btnForSale = document.getElementById('btnForSale');
                    var btnForRent = document.getElementById('btnForRent');
                    
                    if (listingType === 'Buy') {
                        btnForSale.classList.remove('btn-outline-primary');
                        btnForSale.classList.add('btn-primary');
                        btnForRent.classList.remove('btn-info', 'text-white');
                        btnForRent.classList.add('btn-outline-info');
                    } else {
                        btnForRent.classList.remove('btn-outline-info');
                        btnForRent.classList.add('btn-info', 'text-white');
                        btnForSale.classList.remove('btn-primary');
                        btnForSale.classList.add('btn-outline-primary');
                    }
                    
                    // Show success message
                    var msg = document.getElementById('listingTypeSaveMessage');
                    msg.classList.remove('d-none');
                    setTimeout(() => {
                        msg.classList.add('d-none');
                        location.reload(); // Refresh to show updated state
                    }, 1500);
                } else {
                    alert('Failed to save: ' + data.message);
                }
            })
            .catch(err => {
                console.error('Error:', err);
                alert('Failed to save listing type');
            });
        }
    </script>
}

@section Scripts {
<!-- Leaflet JS for Map -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<script>
    // Initialize map if coordinates exist
    document.addEventListener('DOMContentLoaded', function() {
        @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
        {
            <text>
            // Wait for DOM to be fully rendered before initializing map
            setTimeout(function() {
                const lat = @Model.Latitude.Value.ToString("F0");
                const lng = @Model.Longitude.Value.ToString("F0");
                const propertyTitle = @Html.Raw(Json.Serialize(Model.Title));
                const propertyLocation = @Html.Raw(Json.Serialize(Model.Location));

                // Initialize map
                const map = L.map('propertyMap').setView([lat, lng], 16);

                // Add OpenStreetMap tiles with proper attribution
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
                    maxZoom: 19
                }).addTo(map);

                // Add marker with popup
                const marker = L.marker([lat, lng]).addTo(map);
                marker.bindPopup('<strong>' + propertyTitle + '</strong><br>' + propertyLocation).openPopup();

                // Force map to recalculate size and load tiles properly
                map.invalidateSize(true);
            }, 500);
            </text>
        }
    });
</script>
}
