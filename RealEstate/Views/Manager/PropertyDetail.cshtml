<!-- Process Sale Modal -->
@if (Model.IsApproved && !Model.IsReadyForListing)
{
    <div class="modal fade" id="processSaleModal" tabindex="-1" aria-labelledby="processSaleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-success text-white border-0">
                    <h5 class="modal-title fw-bold" id="processSaleModalLabel">
                        <i class="fas fa-handshake me-2"></i> Process Sale - Mark as @(Model.ListingType == PropertyListingType.Buy ? "Ready for Sale" : "Ready for Rent")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body px-4 py-4">
                    <div class="alert alert-@(Model.ListingType == PropertyListingType.Buy ? "primary" : "info") mb-4">
                        <i class="fas fa-info-circle me-2"></i> 
                        <strong>Listing Type:</strong> @(Model.ListingType == PropertyListingType.Buy ? "For Sale" : "For Rent")<br>
                        <small class="ms-4">This will process the sale and mark the property as @(Model.ListingType == PropertyListingType.Buy ? "Ready for Sale" : "Ready for Rent").</small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-success fs-5">
                            @(Model.ListingType == PropertyListingType.Buy ? "Final Sale Price (₱)" : "Monthly Rent (₱)")
                        </label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-success text-white fw-bold">₱</span>
                            <input type="number" id="salePrice" class="form-control text-success fw-bold fs-4" 
                                   value="@Model.FinalPrice" step="0.01" required />
                        </div>
                    </div>

                    @if (Model.ListingType == PropertyListingType.Rent)
                    {
                        <div class="mb-4">
                            <label class="form-label fw-bold text-info fs-5">
                                <i class="fas fa-calendar-alt me-2"></i>Lease Term
                            </label>
                            <select id="leaseTerm" class="form-select form-select-lg">
                                <option value="1" selected>1 Year (100% of 1 month)</option>
                                <option value="2">2 Years (150% of 1 month)</option>
                                <option value="3">3 Years (200% of 1 month)</option>
                                <option value="4">4 Years (250% of 1 month)</option>
                                <option value="5">5 Years (300% of 1 month)</option>
                            </select>
                            <div class="form-text text-muted mt-1">
                                <i class="fas fa-info-circle me-1"></i>
                                1st year = 100%, each additional year = +50%
                            </div>
                        </div>
                    }

                    <div class="commission-preview bg-light p-3 rounded mb-3">
                        <h6 class="fw-bold text-uppercase text-secondary mb-3">Commission Breakdown</h6>
                        
                        @if (Model.ListingType == PropertyListingType.Rent)
                        {
                            <div class="d-flex justify-content-between mb-2">
                                <span>Monthly Rent:</span>
                                <span class="fw-bold" id="previewSalePrice">₱@Model.FinalPrice?.ToString("N2")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Lease Term:</span>
                                <span class="fw-bold text-info" id="previewLeaseTerm">1 Year</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Commission Pool:</span>
                                <span class="fw-bold text-primary" id="previewCommissionPool">--</span>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between mb-2">
                                <span>Manager Earnings (60%):</span>
                                <span class="fw-bold text-success" id="previewBrokerEarnings">--</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Agent Payout (40%):</span>
                                <span class="fw-bold text-warning" id="previewAgentEarnings">--</span>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-between mb-2">
                                <span>Sale Price:</span>
                                <span class="fw-bold" id="previewSalePrice">₱@Model.FinalPrice?.ToString("N2")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Commission Pool (5%):</span>
                                <span class="fw-bold text-primary" id="previewCommissionPool">--</span>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between">
                                <span>Manager Earnings (60%):</span>
                                <span class="fw-bold text-success" id="previewBrokerEarnings">--</span>
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Notes</label>
                        <textarea id="saleNotes" class="form-control" rows="2" placeholder="Add any notes about this sale..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0 px-4 py-3">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" id="confirmProcessSale" class="btn btn-success px-5 fw-bold">
                        <i class="fas fa-check-circle me-2"></i> Confirm Sale
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var salePriceInput = document.getElementById('salePrice');
            var previewSalePrice = document.getElementById('previewSalePrice');
            var previewCommissionPool = document.getElementById('previewCommissionPool');
            var previewBrokerEarnings = document.getElementById('previewBrokerEarnings');
            var previewAgentEarnings = document.getElementById('previewAgentEarnings');
            var previewLeaseTerm = document.getElementById('previewLeaseTerm');
            var leaseTermSelect = document.getElementById('leaseTerm');
            var confirmBtn = document.getElementById('confirmProcessSale');

            // Get listing type from model
            var listingType = '@(Model.ListingType == PropertyListingType.Buy ? "Sale" : "Rent")';

            function updatePreview() {
                var price = parseFloat(salePriceInput.value) || 0;
                var commissionPool = 0;
                
                if (listingType === 'Sale') {
                    // Sale: 5% of price
                    commissionPool = price * 0.05;
                } else {
                    // Rent: Multi-year calculation
                    // 1 year = 100%, each additional year = +50%
                    var leaseTerm = leaseTermSelect ? parseInt(leaseTermSelect.value) : 1;
                    var multiplier = 1 + ((leaseTerm - 1) * 0.5); // 1, 1.5, 2, 2.5, 3
                    commissionPool = price * multiplier;
                    
                    // Update lease term display
                    if (previewLeaseTerm) {
                        previewLeaseTerm.textContent = leaseTerm + ' Year' + (leaseTerm > 1 ? 's' : '');
                    }
                }
                
                var brokerEarnings = commissionPool * 0.60;
                var agentEarnings = commissionPool * 0.40;

                previewSalePrice.textContent = '₱' + price.toLocaleString('en-PH', {minimumFractionDigits: 2, maximumFractionDigits: 2});
                previewCommissionPool.textContent = '₱' + commissionPool.toLocaleString('en-PH', {minimumFractionDigits: 2, maximumFractionDigits: 2});
                previewBrokerEarnings.textContent = '₱' + brokerEarnings.toLocaleString('en-PH', {minimumFractionDigits: 2, maximumFractionDigits: 2});
                
                if (previewAgentEarnings) {
                    previewAgentEarnings.textContent = '₱' + agentEarnings.toLocaleString('en-PH', {minimumFractionDigits: 2, maximumFractionDigits: 2});
                }
            }

            salePriceInput.addEventListener('input', updatePreview);
            if (leaseTermSelect) {
                leaseTermSelect.addEventListener('change', updatePreview);
            }
            updatePreview();

            confirmBtn.addEventListener('click', function() {
                var price = parseFloat(salePriceInput.value);
                if (!price || price <= 0) {
                    alert('Please enter a valid sale price.');
                    return;
                }

                var data = {
                    propertyId: @Model.PropertyId,
                    finalPrice: price,
                    notes: document.getElementById('saleNotes').value,
                    leaseTerm: leaseTermSelect ? parseInt(leaseTermSelect.value) : 1
                };

                fetch('/manager/process-sale', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        alert('Sale processed successfully!\n\nStatus: ' + data.data.status + '\n\nCommission Pool: ₱' + data.data.commissionPool.toLocaleString('en-PH', {minimumFractionDigits: 2}) + '\nBroker: ₱' + data.data.brokerEarnings.toLocaleString('en-PH', {minimumFractionDigits: 2}));
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(err => {
                    console.error('Error processing sale:', err);
                    alert('Failed to process sale. Please try again.');
                });
            });
        });
    </script>
}

