@{
    ViewData["Title"] = "Manager Dashboard";
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
}

<div class="container-fluid py-4 manager-dashboard-page">
    <div class="page-head mb-4">
        <h1 class="page-title">Manager Dashboard</h1>
        <p class="page-subtitle mb-0">Revenue, commissions, and platform performance overview.</p>
    </div>

    <!-- REVENUE SUMMARY SECTION -->
    <div class="row g-3 mb-2">
        <div class="col-12">
            <h5 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem; letter-spacing: 1px;">
                <i class="fas fa-chart-line me-2"></i>Platform Revenue (60/40 Split)
            </h5>
        </div>
    </div>
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="metric-card border-start border-4 border-success">
                <div class="metric-top">
                    <span class="metric-label">My Revenue (60%)</span>
                    <div class="metric-icon bg-success"><i class="fas fa-wallet"></i></div>
                </div>
                <div class="metric-value text-success">₱@string.Format("{0:N0}", ViewData["TotalManagerRevenue"] ?? 0m)</div>
                <div class="metric-foot text-success"><i class="fas fa-building"></i> Brokerage Earnings</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="metric-card border-start border-4 border-info">
                <div class="metric-top">
                    <span class="metric-label">Total Commission Pool</span>
                    <div class="metric-icon bg-info"><i class="fas fa-percentage"></i></div>
                </div>
                <div class="metric-value text-info">₱@string.Format("{0:N0}", ViewData["TotalCommissionPool"] ?? 0m)</div>
                <div class="metric-foot text-info"><i class="fas fa-coins"></i> 5% of Total Sales</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="metric-card border-start border-4 border-warning">
                <div class="metric-top">
                    <span class="metric-label">Agent Payouts (40%)</span>
                    <div class="metric-icon bg-warning"><i class="fas fa-hand-holding-usd"></i></div>
                </div>
                <div class="metric-value text-warning">₱@string.Format("{0:N0}", ViewData["TotalAgentPayouts"] ?? 0m)</div>
                <div class="metric-foot text-warning"><i class="fas fa-users"></i> Commission Expenses</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="metric-card border-start border-4 border-primary">
                <div class="metric-top">
                    <span class="metric-label">Today's Revenue</span>
                    <div class="metric-icon bg-primary"><i class="fas fa-calendar-day"></i></div>
                </div>
                <div class="metric-value text-primary">₱@string.Format("{0:N0}", ViewData["TodaysManagerRevenue"] ?? 0m)</div>
                <div class="metric-foot text-primary"><i class="fas fa-chart-bar"></i> @DateTime.Now.ToString("MMM dd")</div>
            </div>
        </div>
    </div>

    <!-- OPERATIONS SECTION -->
    <div class="row g-3 mb-2">
        <div class="col-12">
            <h5 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem; letter-spacing: 1px;">
                <i class="fas fa-tasks me-2"></i>Operations
            </h5>
        </div>
    </div>
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="metric-card">
                <div class="metric-top">
                    <span class="metric-label">Pending Approvals</span>
                    <div class="metric-icon"><i class="fas fa-clock"></i></div>
                </div>
                <div class="metric-value">@(ViewData["PendingApprovals"] ?? 0)</div>
                <div class="metric-foot text-warning"><i class="fas fa-arrow-up"></i> Awaiting review</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="metric-card">
                <div class="metric-top">
                    <span class="metric-label">Approved for Payroll</span>
                    <div class="metric-icon"><i class="fas fa-check-circle"></i></div>
                </div>
                <div class="metric-value">@(ViewData["ApprovedForPayroll"] ?? 0)</div>
                <div class="metric-foot text-success"><i class="fas fa-check"></i> Ready to transfer</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="metric-card">
                <div class="metric-top">
                    <span class="metric-label">Locked Batches</span>
                    <div class="metric-icon"><i class="fas fa-lock"></i></div>
                </div>
                <div class="metric-value">@(ViewData["LockedBatches"] ?? 0)</div>
                <div class="metric-foot text-info"><i class="fas fa-building"></i> In accounting</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="metric-card">
                <div class="metric-top">
                    <span class="metric-label">Completed Payouts</span>
                    <div class="metric-icon"><i class="fas fa-sack-dollar"></i></div>
                </div>
                <div class="metric-value">@(ViewData["CompletedPayouts"] ?? 0)</div>
                <div class="metric-foot text-success"><i class="fas fa-coins"></i> Paid out</div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="metric-card">
                <div class="metric-top">
                    <span class="metric-label">Total Revenue</span>
                    <div class="metric-icon"><i class="fas fa-chart-line"></i></div>
                </div>
                <div class="metric-value">@String.Format("₱{0:N0}", ViewData["TotalRevenue"] ?? 0)</div>
                <div class="metric-foot text-success"><i class="fas fa-arrow-up"></i> Gross commissions</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="metric-card">
                <div class="metric-top">
                    <span class="metric-label">Total Agent Payouts</span>
                    <div class="metric-icon"><i class="fas fa-hand-holding-usd"></i></div>
                </div>
                <div class="metric-value">@String.Format("₱{0:N0}", ViewData["TotalAgentPayouts"] ?? 0)</div>
                <div class="metric-foot text-info"><i class="fas fa-wallet"></i> Paid to agents</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="metric-card">
                <div class="metric-top">
                    <span class="metric-label">Active Agents</span>
                    <div class="metric-icon"><i class="fas fa-users"></i></div>
                </div>
                <div class="metric-value">@(ViewData["AgentCount"] ?? 0)</div>
                <div class="metric-foot text-success"><i class="fas fa-user-check"></i> On team</div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="content-card h-100">
                <div class="content-card-head">
                    <h6>Quick Access</h6>
                    <a href="@Url.Action("DashboardAgents", "Manager")" class="small-link">Open Agent View</a>
                </div>
                <div class="row g-2">
                    <div class="col-md-6">
                        <a href="@Url.Action("CommissionReview", "Manager")" class="quick-btn">
                            <i class="fas fa-check-double"></i>
                            <span>Commission Review</span>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="@Url.Action("AgentAssignment", "Manager")" class="quick-btn">
                            <i class="fas fa-user-check"></i>
                            <span>Agent Assignment</span>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="@Url.Action("PerformanceTracking", "Manager")" class="quick-btn">
                            <i class="fas fa-chart-column"></i>
                            <span>Performance</span>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="@Url.Action("InventoryOverview", "Manager")" class="quick-btn">
                            <i class="fas fa-house"></i>
                            <span>Inventory</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="content-card h-100">
                <div class="content-card-head">
                    <h6>Recent Activity</h6>
                </div>
                <ul class="activity-list">
                    <li><i class="fas fa-check-circle"></i> 3 new properties listed</li>
                    <li><i class="fas fa-check-circle"></i> 5 deals completed this month</li>
                    <li><i class="fas fa-check-circle"></i> 2 agent assignments made</li>
                    <li><i class="fas fa-clock"></i> Team meeting in 2 hours</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- RECENT TRANSACTIONS -->
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="content-card">
                <div class="content-card-head">
                    <h6><i class="fas fa-receipt me-2"></i>Recent Transactions (60/40 Split)</h6>
                    <a href="@Url.Action("CommissionReview", "Manager")" class="small-link">View All</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Transaction ID</th>
                                <th>Total Commission</th>
                                <th class="text-success">Manager's Cut (60%)</th>
                                <th class="text-warning">Agent Cut (40%)</th>
                                <th>Agent</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.RecentTransactions != null)
                            {
                                foreach (var sale in ViewBag.RecentTransactions)
                                {
                                    <tr>
                                        <td><span class="badge bg-dark">#@sale.SaleId</span></td>
                                        <td class="fw-bold">₱@sale.CommissionPool.ToString("N2")</td>
                                        <td class="text-success fw-bold">₱@sale.BrokerEarnings.ToString("N2")</td>
                                        <td class="text-warning fw-bold">₱@sale.AgentEarnings.ToString("N2")</td>
                                        <td>@(sale.Agent?.DisplayName ?? "Unknown")</td>
                                        <td>@sale.TransactionDate.ToString("MMM dd, yyyy")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        <i class="fas fa-inbox fa-2x mb-2"></i><br>
                                        No transactions yet. Process a sale to see revenue here.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- REVENUE SUMMARY CARDS -->
    <div class="row g-3 mb-4">
        <div class="col-12">
            <h5 class="text-uppercase text-muted fw-bold mb-3" style="font-size: 0.75rem; letter-spacing: 1px;">
                <i class="fas fa-chart-pie me-2"></i>Revenue Summary
            </h5>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="metric-card">
                <div class="metric-top">
                    <span class="metric-label">Total Revenue</span>
                    <div class="metric-icon"><i class="fas fa-chart-line"></i></div>
                </div>
                <div class="metric-value">@String.Format("₱{0:N0}", ViewData["TotalManagerRevenue"] ?? 0)</div>
                <div class="metric-foot text-success"><i class="fas fa-arrow-up"></i> Gross commissions</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="metric-card">
                <div class="metric-top">
                    <span class="metric-label">Total Agent Payouts</span>
                    <div class="metric-icon"><i class="fas fa-hand-holding-usd"></i></div>
                </div>
                <div class="metric-value">@String.Format("₱{0:N0}", ViewData["TotalAgentPayouts"] ?? 0)</div>
                <div class="metric-foot text-info"><i class="fas fa-wallet"></i> Paid to agents</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="metric-card">
                <div class="metric-top">
                    <span class="metric-label">Active Agents</span>
                    <div class="metric-icon"><i class="fas fa-users"></i></div>
                </div>
                <div class="metric-value">@(ViewData["AgentCount"] ?? 0)</div>
                <div class="metric-foot text-success"><i class="fas fa-user-check"></i> On team</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="metric-card">
                <div class="metric-top">
                    <span class="metric-label">Total Sales</span>
                    <div class="metric-icon"><i class="fas fa-shopping-cart"></i></div>
                </div>
                <div class="metric-value">@(ViewData["TotalSales"] ?? 0)</div>
                <div class="metric-foot text-primary"><i class="fas fa-check"></i> Completed</div>
            </div>
        </div>
    </div>
</div>

<style>
    .manager-dashboard-page {
        max-width: 1500px;
    }

    .page-title {
        margin: 0;
        font-size: 1.75rem;
        font-weight: 700;
        color: #0f172a;
    }

    .page-subtitle {
        margin-top: 4px;
        color: #64748b;
        font-size: 0.92rem;
    }

    .metric-card {
        background: #fff;
        border: 1px solid #e9edf5;
        border-radius: 12px;
        padding: 16px;
        box-shadow: 0 8px 26px rgba(15, 23, 42, 0.05);
        transition: all 0.2s ease;
    }

    .metric-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 28px rgba(15, 23, 42, 0.08);
    }

    .metric-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }

    .metric-label {
        font-size: 0.78rem;
        color: #64748b;
        font-weight: 600;
    }

    .metric-icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #f97316;
    }

    .metric-value {
        font-size: 1.55rem;
        font-weight: 700;
        color: #1e293b;
    }

    .metric-foot {
        margin-top: 8px;
        font-size: 0.76rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .content-card {
        background: #fff;
        border: 1px solid #e9edf5;
        border-radius: 12px;
        box-shadow: 0 8px 26px rgba(15, 23, 42, 0.04);
        padding: 16px;
    }

    .content-card-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .content-card-head h6 {
        margin: 0;
        font-size: 0.9rem;
        font-weight: 700;
        color: #1f2937;
    }

    .small-link {
        color: #f97316;
        font-size: 0.78rem;
        text-decoration: none;
        font-weight: 600;
    }

    .quick-btn {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border: 1px solid #dbe3ef;
        border-radius: 9px;
        text-decoration: none;
        color: #334155;
        background: #fff;
        font-size: 0.86rem;
        font-weight: 600;
        transition: all 0.2s ease;
    }

    .quick-btn i {
        color: #6d5efc;
    }

    .quick-btn:hover {
        border-color: #f97316;
        color: #f97316;
        background: #fffaf5;
    }

    .activity-list {
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .activity-list li {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 0;
        font-size: 0.84rem;
        color: #334155;
        border-bottom: 1px solid #f1f5f9;
    }

    .activity-list li:last-child {
        border-bottom: 0;
    }

    .activity-list i {
        color: #10b981;
        width: 14px;
    }
</style>
