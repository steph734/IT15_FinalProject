@{
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
    ViewData["Title"] = "Messages";
}

<style>
    .messages-page {
        background: #f4f6fb;
        padding: 20px;
        min-height: calc(100vh - 80px);
    }

    .messages-shell {
        display: grid;
        grid-template-columns: 340px 1fr;
        background: #ffffff;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid #e7ebf3;
        box-shadow: 0 8px 24px rgba(17, 24, 39, 0.06);
        min-height: 720px;
    }

    .chat-sidebar {
        border-right: 1px solid #edf0f6;
        background: #ffffff;
        display: flex;
        flex-direction: column;
    }

    .chat-sidebar-header {
        padding: 16px;
        border-bottom: 1px solid #edf0f6;
    }

    .chat-search {
        width: 100%;
        border: 1px solid #e5e7eb;
        background: #f9fafb;
        border-radius: 8px;
        padding: 10px 12px;
        font-size: 13px;
        color: #374151;
    }

    .chat-search:focus {
        outline: none;
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
        background: #fff;
    }

    .chat-list {
        overflow-y: auto;
        padding: 8px;
    }

    .chat-item {
        display: grid;
        grid-template-columns: 44px 1fr auto;
        gap: 10px;
        align-items: center;
        border-radius: 10px;
        padding: 10px;
        margin-bottom: 6px;
        cursor: pointer;
        transition: background 0.2s ease;
    }

    .chat-item:hover {
        background: #f6f7fb;
    }

    .chat-item.active {
        background: #eef2ff;
    }

    .chat-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: linear-gradient(135deg, #7c3aed, #6366f1);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
    }

    .chat-meta {
        min-width: 0;
    }

    .chat-name {
        font-size: 14px;
        font-weight: 600;
        color: #111827;
        margin-bottom: 2px;
    }

    .chat-preview {
        font-size: 12px;
        color: #9ca3af;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .chat-time {
        font-size: 11px;
        color: #9ca3af;
        white-space: nowrap;
    }

    .chat-area {
        display: flex;
        flex-direction: column;
        background: #ffffff;
    }

    .chat-header {
        padding: 16px 20px;
        border-bottom: 1px solid #edf0f6;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .chat-header-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .chat-header-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #7c3aed, #6366f1);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 700;
    }

    .chat-header-name {
        font-size: 15px;
        font-weight: 600;
        color: #111827;
    }

    .chat-header-status {
        font-size: 12px;
        color: #10b981;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        background: #10b981;
        border-radius: 50%;
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .message-bubble {
        max-width: 70%;
        padding: 12px 16px;
        border-radius: 14px;
        font-size: 13px;
        line-height: 1.5;
        position: relative;
    }

    .message-incoming {
        align-self: flex-start;
        background: #f3f4f6;
        color: #374151;
        border-bottom-left-radius: 4px;
    }

    .message-outgoing {
        align-self: flex-end;
        background: linear-gradient(135deg, #6366f1, #7c3aed);
        color: #fff;
        border-bottom-right-radius: 4px;
    }

    .message-time {
        font-size: 11px;
        color: #9ca3af;
        margin-top: 6px;
        text-align: right;
    }

    .message-outgoing .message-time {
        color: rgba(255, 255, 255, 0.8);
    }

    .chat-input-area {
        padding: 16px 20px;
        border-top: 1px solid #edf0f6;
        display: flex;
        gap: 12px;
        align-items: flex-end;
    }

    .chat-textarea {
        flex: 1;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 12px 16px;
        font-size: 14px;
        resize: none;
        min-height: 44px;
        max-height: 120px;
        font-family: inherit;
    }

    .chat-textarea:focus {
        outline: none;
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
    }

    .chat-send-btn {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        background: linear-gradient(135deg, #6366f1, #7c3aed);
        color: #fff;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s;
    }

    .chat-send-btn:hover {
        transform: scale(1.05);
    }

    .chat-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: #9ca3af;
    }

    .chat-empty i {
        font-size: 48px;
        color: #d1d5db;
        margin-bottom: 12px;
    }

    @@media (max-width: 992px) {
        .messages-shell {
            grid-template-columns: 1fr;
        }

        .chat-sidebar {
            display: none;
        }
    }
</style>

<div class="messages-page">
    <div class="messages-shell">
        <!-- Chat Sidebar -->
        <div class="chat-sidebar">
            <div class="chat-sidebar-header">
                <input type="text" class="chat-search" placeholder="Search conversations..." />
            </div>
            <div class="chat-list">
                <div class="chat-item active">
                    <div class="chat-avatar">JD</div>
                    <div class="chat-meta">
                        <div class="chat-name">John Doe</div>
                        <div class="chat-preview">Hey, are we still on for the meeting?</div>
                    </div>
                    <div class="chat-time">2m</div>
                </div>
                <div class="chat-item">
                    <div class="chat-avatar">SA</div>
                    <div class="chat-meta">
                        <div class="chat-name">Sarah Anderson</div>
                        <div class="chat-preview">The property listing looks great!</div>
                    </div>
                    <div class="chat-time">1h</div>
                </div>
                <div class="chat-item">
                    <div class="chat-avatar">MK</div>
                    <div class="chat-meta">
                        <div class="chat-name">Mike Kim</div>
                        <div class="chat-preview">Can you review the commission report?</div>
                    </div>
                    <div class="chat-time">3h</div>
                </div>
                <div class="chat-item">
                    <div class="chat-avatar">EL</div>
                    <div class="chat-meta">
                        <div class="chat-name">Emily Lee</div>
                        <div class="chat-preview">Thanks for your help today!</div>
                    </div>
                    <div class="chat-time">Yesterday</div>
                </div>
                <div class="chat-item">
                    <div class="chat-avatar">RT</div>
                    <div class="chat-meta">
                        <div class="chat-name">Robert Taylor</div>
                        <div class="chat-preview">I'll send the documents tomorrow</div>
                    </div>
                    <div class="chat-time">2d</div>
                </div>
            </div>
        </div>

        <!-- Chat Area -->
        <div class="chat-area">
            <div class="chat-header">
                <div class="chat-header-info">
                    <div class="chat-header-avatar">JD</div>
                    <div>
                        <div class="chat-header-name">John Doe</div>
                        <div class="chat-header-status">
                            <span class="status-dot"></span> Online
                        </div>
                    </div>
                </div>
                <div>
                    <i class="fas fa-ellipsis-v" style="color: #9ca3af; cursor: pointer;"></i>
                </div>
            </div>

            <div class="chat-messages">
                <div class="message-bubble message-incoming">
                    Hi there! I wanted to check in about the property viewing scheduled for tomorrow.
                    <div class="message-time">10:30 AM</div>
                </div>
                <div class="message-bubble message-outgoing">
                    Yes, everything is confirmed. The client will arrive at 2 PM.
                    <div class="message-time">10:32 AM</div>
                </div>
                <div class="message-bubble message-incoming">
                    Great! I'll make sure the property is ready. Should I prepare any specific documents?
                    <div class="message-time">10:33 AM</div>
                </div>
                <div class="message-bubble message-outgoing">
                    Just the standard viewing packet and the recent inspection report. Thanks!
                    <div class="message-time">10:35 AM</div>
                </div>
                <div class="message-bubble message-incoming">
                    Perfect, I'll have everything ready. See you tomorrow!
                    <div class="message-time">10:36 AM</div>
                </div>
                <div class="message-bubble message-outgoing">
                    Hey, are we still on for the meeting?
                    <div class="message-time">Just now</div>
                </div>
            </div>

            <div class="chat-input-area">
                <textarea class="chat-textarea" rows="1" placeholder="Type a message..."></textarea>
                <button class="chat-send-btn">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const chatItems = document.querySelectorAll('.chat-item');
        chatItems.forEach(item => {
            item.addEventListener('click', function() {
                chatItems.forEach(i => i.classList.remove('active'));
                this.classList.add('active');
            });
        });
    });
</script>
