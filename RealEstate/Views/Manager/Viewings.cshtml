@{
    ViewData["Title"] = "Scheduled Viewings";
    var viewings = ViewBag.Viewings as List<RealEstate.Models.ViewingAppointment>;
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="fas fa-calendar-alt me-2"></i>Scheduled Property Viewings</h2>
            <p class="text-muted">Manage all viewing appointments</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-list me-2"></i>All Viewings (@viewings?.Count)</h5>
        </div>
        <div class="card-body">
            @if (viewings != null && viewings.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Customer Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Scheduled Date</th>
                                <th>Reason</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var viewing in viewings)
                            {
                                <tr>
                                    <td>@viewing.Id</td>
                                    <td><strong>@viewing.CustomerName</strong></td>
                                    <td>@viewing.CustomerEmail</td>
                                    <td>@viewing.CustomerPhone</td>
                                    <td>@viewing.WhenUtc.ToString("MMM dd, yyyy hh:mm tt")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(viewing.Notes))
                                        {
                                            <span class="text-truncate d-inline-block" style="max-width: 200px;" title="@viewing.Notes">
                                                @viewing.Notes
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @switch (viewing.Status)
                                        {
                                            case RealEstate.Models.AppointmentStatus.Scheduled:
                                                <span class="badge bg-warning">Scheduled</span>
                                                break;
                                            case RealEstate.Models.AppointmentStatus.Completed:
                                                <span class="badge bg-success">Completed</span>
                                                break;
                                            case RealEstate.Models.AppointmentStatus.Cancelled:
                                                <span class="badge bg-danger">Cancelled</span>
                                                break;
                                        }
                                    </td>
                                    <td>@viewing.CreatedAtUtc.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        @if (viewing.Status == RealEstate.Models.AppointmentStatus.Scheduled)
                                        {
                                            <a href="/tracking/manager/dashboard" class="btn btn-sm btn-info">
                                                <i class="fas fa-map"></i> Track
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-calendar-times" style="font-size: 4rem; color: #ccc;"></i>
                    <h4 class="mt-3 text-muted">No Viewings Scheduled</h4>
                    <p class="text-muted">Viewing appointments will appear here when customers schedule them.</p>
                </div>
            }
        </div>
    </div>
</div>
