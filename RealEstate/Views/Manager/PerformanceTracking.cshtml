@{
    ViewData["Title"] = "Performance Tracking";
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
}

<div class="container-fluid py-4">
    <h1 class="h4 fw-bold mb-4">📊 Performance Tracking & Analytics</h1>

    <!-- Performance Metrics -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="metric-card">
                <div class="metric-icon">⏱️</div>
                <div class="metric-label">Avg Response Time</div>
                <div class="metric-value">2.4 hrs</div>
                <div class="metric-trend">↓ 0.5h improvement</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <div class="metric-icon">📈</div>
                <div class="metric-label">Conversion Rate</div>
                <div class="metric-value">42%</div>
                <div class="metric-trend">↑ 5% vs last month</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <div class="metric-icon">💰</div>
                <div class="metric-label">Total Sales</div>
                <div class="metric-value">₱45.2M</div>
                <div class="metric-trend">↑ 12% vs last month</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <div class="metric-icon">👥</div>
                <div class="metric-label">Team Size</div>
                <div class="metric-value">8</div>
                <div class="metric-trend">Agents active</div>
            </div>
        </div>
    </div>

    <!-- Agent Rankings -->
    <div class="card border-0 shadow-sm p-4 mb-4">
        <h6 class="mb-3">🏆 Agent Rankings</h6>
        <div class="table-responsive">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Agent Name</th>
                        <th>Deals Closed</th>
                        <th>Total Sales</th>
                        <th>Avg Response</th>
                        <th>Rating</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="rank-1">
                        <td><span class="badge bg-warning">1</span></td>
                        <td><strong>Agen001</strong></td>
                        <td>12</td>
                        <td>₱42.5M</td>
                        <td>1.8 hrs</td>
                        <td>⭐⭐⭐⭐⭐ (4.9)</td>
                    </tr>
                    <tr class="rank-2">
                        <td><span class="badge bg-secondary">2</span></td>
                        <td><strong>Maria</strong></td>
                        <td>9</td>
                        <td>₱28.3M</td>
                        <td>2.1 hrs</td>
                        <td>⭐⭐⭐⭐ (4.7)</td>
                    </tr>
                    <tr class="rank-3">
                        <td><span class="badge bg-danger">3</span></td>
                        <td><strong>John</strong></td>
                        <td>7</td>
                        <td>₱19.8M</td>
                        <td>3.2 hrs</td>
                        <td>⭐⭐⭐⭐ (4.5)</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Charts -->
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm p-4">
                <h6 class="mb-3">Sales Trend (6 Months)</h6>
                <canvas id="salesChart" style="height: 280px;"></canvas>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm p-4">
                <h6 class="mb-3">Conversion Rate Trend</h6>
                <canvas id="conversionChart" style="height: 280px;"></canvas>
            </div>
        </div>
    </div>
</div>

<style>
    .metric-card {
        background: white;
        border: 1px solid #e0e0ff;
        border-radius: 10px;
        padding: 20px;
        text-align: center;
        transition: all 0.3s ease;
    }

    .metric-card:hover {
        border-color: #6366f1;
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15);
        transform: translateY(-4px);
    }

    .metric-icon {
        font-size: 32px;
        margin-bottom: 10px;
    }

    .metric-label {
        font-size: 0.85rem;
        color: #999;
        margin-bottom: 8px;
    }

    .metric-value {
        font-size: 24px;
        font-weight: 700;
        color: #6366f1;
        margin-bottom: 8px;
    }

    .metric-trend {
        font-size: 0.8rem;
        color: #10b981;
    }

    .rank-1 {
        background: #fef9e7;
    }

    .rank-2 {
        background: #f3f3f3;
    }

    .rank-3 {
        background: #fef2f2;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        const salesCtx = document.getElementById('salesChart');
        if (salesCtx) {
            new Chart(salesCtx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                    datasets: [{
                        label: 'Monthly Sales',
                        data: [32, 38, 42, 39, 45, 50],
                        borderColor: '#6366f1',
                        backgroundColor: 'rgba(99, 102, 241, 0.1)',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });
        }

        const conversionCtx = document.getElementById('conversionChart');
        if (conversionCtx) {
            new Chart(conversionCtx, {
                type: 'bar',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                    datasets: [{
                        label: 'Conversion Rate %',
                        data: [35, 38, 40, 39, 42, 42],
                        backgroundColor: '#6366f1'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });
        }
    </script>
}
