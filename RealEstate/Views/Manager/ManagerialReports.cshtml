@{
    ViewData["Title"] = "Managerial Reports";
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
}

<div class="manager-page">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="manager-page-title mb-0">Transactions</h1>
        <select class="form-select form-select-sm manager-month-filter">
            <option>This Month</option>
            <option>Last Month</option>
            <option>Last 3 Months</option>
            <option>This Year</option>
        </select>
    </div>

    <section class="transaction-card">
        <div class="transaction-card-header">
            <h2 class="transaction-card-title">All Transactions List</h2>
        </div>
        <div class="table-responsive">
            <table class="table manager-table align-middle mb-0">
                <thead>
                    <tr>
                        <th><input type="checkbox" /></th>
                        <th>Transaction ID</th>
                        <th>Customer Photo & Name</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Payment Method</th>
                        <th>Agent Name</th>
                        <th>Invested Property</th>
                        <th>Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><input type="checkbox" /></td>
                        <td class="id-cell">TXN-341220</td>
                        <td>
                            <div class="person-cell">
                                <img src="https://i.pravatar.cc/40?img=12" alt="Ray" />
                                <span>Ray C. Nichols</span>
                            </div>
                        </td>
                        <td>05/01/2026</td>
                        <td>$13,987</td>
                        <td><i class="fab fa-cc-mastercard pay-icon mastercard"></i> Mastercard **** 3457</td>
                        <td>Michael A. Miner</td>
                        <td>W. Street 102 DK Denver</td>
                        <td><span class="status-badge status-complete">Completed</span></td>
                        <td class="text-center">
                            <button class="action-icon"><i class="far fa-eye"></i></button>
                            <button class="action-icon"><i class="far fa-pen-to-square"></i></button>
                            <button class="action-icon text-danger"><i class="far fa-trash-can"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" /></td>
                        <td class="id-cell">TXN-547891</td>
                        <td>
                            <div class="person-cell">
                                <img src="https://i.pravatar.cc/40?img=45" alt="Barbara" />
                                <span>Barbara A. Woods</span>
                            </div>
                        </td>
                        <td>14/02/2026</td>
                        <td>$11,345</td>
                        <td><i class="fab fa-cc-visa pay-icon visa"></i> Visa card **** 4722</td>
                        <td>Theresa J. Brose</td>
                        <td>Isaac Lingerlaan 109</td>
                        <td><span class="status-badge status-complete">Completed</span></td>
                        <td class="text-center">
                            <button class="action-icon"><i class="far fa-eye"></i></button>
                            <button class="action-icon"><i class="far fa-pen-to-square"></i></button>
                            <button class="action-icon text-danger"><i class="far fa-trash-can"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" /></td>
                        <td class="id-cell">TXN-230477</td>
                        <td>
                            <div class="person-cell">
                                <img src="https://i.pravatar.cc/40?img=59" alt="Robert" />
                                <span>Robert Mendoza</span>
                            </div>
                        </td>
                        <td>23/03/2026</td>
                        <td>$16,789</td>
                        <td><i class="fab fa-cc-mastercard pay-icon mastercard"></i> Mastercard **** 7263</td>
                        <td>Walter L. Calab</td>
                        <td>123 Maple St, 456 Oak Ave</td>
                        <td><span class="status-badge status-cancel">Canceled</span></td>
                        <td class="text-center">
                            <button class="action-icon"><i class="far fa-eye"></i></button>
                            <button class="action-icon"><i class="far fa-pen-to-square"></i></button>
                            <button class="action-icon text-danger"><i class="far fa-trash-can"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td><input type="checkbox" /></td>
                        <td class="id-cell">TXN-189348</td>
                        <td>
                            <div class="person-cell">
                                <img src="https://i.pravatar.cc/40?img=49" alt="Rita" />
                                <span>Rita Correa</span>
                            </div>
                        </td>
                        <td>11/04/2026</td>
                        <td>$14,567</td>
                        <td><i class="fab fa-paypal pay-icon paypal"></i> Paypal</td>
                        <td>Olive Mizo</td>
                        <td>3822 DT Amersfoort</td>
                        <td><span class="status-badge status-pending">Pending</span></td>
                        <td class="text-center">
                            <button class="action-icon"><i class="far fa-eye"></i></button>
                            <button class="action-icon"><i class="far fa-pen-to-square"></i></button>
                            <button class="action-icon text-danger"><i class="far fa-trash-can"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="d-flex justify-content-end p-3 table-pagination">
            <button class="page-btn">Previous</button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn">3</button>
            <button class="page-btn">Next</button>
        </div>
    </section>
</div>

<style>
    .manager-page-title {
        font-size: 1.05rem;
        font-weight: 600;
        color: #111827;
    }

    .manager-month-filter {
        width: 140px;
        border-radius: 8px;
        border-color: #e5e7eb;
        font-size: 0.8rem;
    }

    .transaction-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        overflow: hidden;
    }

    .transaction-card-header {
        padding: 14px 16px;
        border-bottom: 1px solid #eef0f4;
        background: #fafbfc;
    }

    .transaction-card-title {
        font-size: 0.8rem;
        margin: 0;
        color: #374151;
        font-weight: 600;
    }

    .manager-table thead th {
        color: #6b7280;
        font-size: 0.66rem;
        font-weight: 600;
        text-transform: none;
        padding: 10px 10px;
        border-bottom: 1px solid #eef0f4;
        white-space: nowrap;
    }

    .manager-table tbody td {
        font-size: 0.7rem;
        color: #374151;
        padding: 10px 10px;
        border-color: #f1f3f7;
        white-space: nowrap;
    }

    .manager-table .id-cell {
        color: #2563eb;
        font-weight: 600;
    }

    .status-badge {
        font-size: 0.6rem;
        padding: 0.18rem 0.42rem;
        border-radius: 4px;
        font-weight: 600;
    }

    .status-complete {
        background: #def7e8;
        color: #198754;
    }

    .status-cancel {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-pending {
        background: #ffedd5;
        color: #9a3412;
    }

    .action-icon {
        width: 22px;
        height: 22px;
        border-radius: 4px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #6b7280;
        font-size: 0.62rem;
        margin: 0 2px;
        padding: 0;
    }

    .action-icon:hover {
        border-color: #2563eb;
        color: #2563eb;
    }

    .person-cell {
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .person-cell img {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        object-fit: cover;
    }

    .pay-icon {
        margin-right: 4px;
        font-size: 0.78rem;
    }

    .mastercard {
        color: #f97316;
    }

    .visa {
        color: #1d4ed8;
    }

    .paypal {
        color: #2563eb;
    }

    .table-pagination {
        border-top: 1px solid #eef0f4;
        gap: 4px;
    }

    .page-btn {
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #6b7280;
        font-size: 0.64rem;
        border-radius: 4px;
        padding: 2px 8px;
    }

    .page-btn.active {
        background: #4f46e5;
        color: #fff;
        border-color: #4f46e5;
    }

    @@media (max-width: 991.98px) {
        .manager-page-title {
            font-size: 1rem;
        }
    }
</style>
