@section Scripts {
    <script>
        $(document).ready(function () {
            // Simple frontend filtering
            const filterTable = () => {
                const search = $('#propertySearch').val().toLowerCase();
                const status = $('#statusFilter').val().toLowerCase();
                
                $('.property-row').each(function () {
                    const rowStatus = $(this).data('status');
                    const title = $(this).data('title');
                    const loc = $(this).data('location');
                    
                    const matchSearch = title.includes(search) || loc.includes(search);
                    const matchStatus = status === "" || rowStatus.includes(status);
                    
                    if (matchSearch && matchStatus) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            };

            $('#propertySearch').on('keyup', filterTable);
            $('#statusFilter').on('change', filterTable);

            // Assign Agent Modal functionality - Custom Pure JS
            var agents = [];
            var modalOverlay = document.getElementById('assignAgentModal');
            var closeModalBtn = document.getElementById('closeModalBtn');
            var cancelModalBtn = document.getElementById('cancelModalBtn');

            // Open modal function
            function openModal(propertyId, propertyTitle) {
                $('#modalPropertyId').val(propertyId);
                $('#modalPropertyName').val(propertyTitle);
                $('#assignmentNotes').val('');
                $('#agentSelect').val('');
                
                modalOverlay.classList.add('active');
                document.body.style.overflow = 'hidden';
                
                // Load agents
                loadAgents();
            }

            // Close modal function
            function closeModal() {
                modalOverlay.classList.remove('active');
                document.body.style.overflow = '';
            }

            // Close modal on button clicks
            closeModalBtn.addEventListener('click', closeModal);
            cancelModalBtn.addEventListener('click', closeModal);

            // Close modal on overlay click
            modalOverlay.addEventListener('click', function(e) {
                if (e.target === modalOverlay) {
                    closeModal();
                }
            });

            // Close modal on Escape key
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && modalOverlay.classList.contains('active')) {
                    closeModal();
                }
            });

            // Handle "Assign Agent" button clicks - using event delegation
            $(document).on('click', '[data-bs-toggle="modal"][data-bs-target="#assignAgentModal"]', function(event) {
                event.preventDefault();
                var button = $(this);
                var propertyId = button.data('property-id');
                var propertyTitle = button.data('property-title');
                openModal(propertyId, propertyTitle);
            });

            // Load agents from server
            function loadAgents() {
                $.ajax({
                    url: '/manager/get-agents',
                    type: 'GET',
                    dataType: 'json',
                    success: function (data) {
                        agents = data;
                        var select = $('#agentSelect');
                        select.empty();
                        select.append('<option value="" selected disabled>-- Choose an agent --</option>');
                        
                        $.each(data, function (index, agent) {
                            select.append('<option value="' + agent.agentId + '">' + agent.fullName + '</option>');
                        });
                    },
                    error: function (xhr, status, error) {
                        console.error('Error loading agents:', error);
                        alert('Failed to load agents. Please try again.');
                    }
                });
            }

            // Assign agent button click
            $('#assignAgentBtn').on('click', function () {
                var propertyId = $('#modalPropertyId').val();
                var agentId = $('#agentSelect').val();
                var notes = $('#assignmentNotes').val();

                if (!agentId) {
                    alert('Please select an agent.');
                    return;
                }

                $.ajax({
                    url: '/manager/assign-agent',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        propertyId: propertyId,
                        agentId: agentId,
                        notes: notes
                    }),
                    success: function (response) {
                        if (response.success) {
                            alert('Agent assigned successfully!');
                            closeModal();
                            // Optionally refresh the page or update the UI
                            location.reload();
                        } else {
                            alert('Failed to assign agent: ' + response.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('Error assigning agent:', error);
                        alert('Failed to assign agent. Please try again.');
                    }
                });
            });
        });
    </script>
}
