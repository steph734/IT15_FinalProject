@{
    ViewData["Title"] = "Manager Settings";
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
}

<div class="container-fluid py-4">
    <h1 class="h4 fw-bold mb-4">⚙️ Manager Settings</h1>

    <div class="row g-4">
        <!-- General Settings -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm p-4">
                <h6 class="mb-3">General Settings</h6>
                <div class="mb-3">
                    <label class="form-label">Manager Name</label>
                    <input type="text" class="form-control" value="Manager" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" value="manager@estateflow.com" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone</label>
                    <input type="tel" class="form-control" value="+63 912 345 6789" />
                </div>
                <button class="btn btn-primary">Save Changes</button>
            </div>
        </div>

        <!-- Notification Settings -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm p-4">
                <h6 class="mb-3">Notification Preferences</h6>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="emailNotif" checked />
                    <label class="form-check-label" for="emailNotif">Email Notifications</label>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="dealNotif" checked />
                    <label class="form-check-label" for="dealNotif">Deal Completion Alerts</label>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="reportNotif" checked />
                    <label class="form-check-label" for="reportNotif">Weekly Reports</label>
                </div>
                <button class="btn btn-primary">Save Preferences</button>
            </div>
        </div>
    </div>

    <!-- Report Generation Settings -->
    <div class="card border-0 shadow-sm p-4 mt-4">
        <h6 class="mb-3">Automated Report Generation</h6>
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Weekly Report Day</label>
                <select class="form-select">
                    <option>Monday</option>
                    <option>Tuesday</option>
                    <option>Wednesday</option>
                    <option>Thursday</option>
                    <option>Friday</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Report Time</label>
                <input type="time" class="form-control" value="09:00" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Email Recipients</label>
                <input type="email" class="form-control" placeholder="manager@email.com" />
            </div>
        </div>
        <button class="btn btn-primary mt-3">Save Report Settings</button>
    </div>

    <!-- Performance Targets -->
    <div class="card border-0 shadow-sm p-4 mt-4">
        <h6 class="mb-3">Performance Targets</h6>
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Monthly Sales Target (₱M)</label>
                <input type="number" class="form-control" value="50" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Conversion Rate Target (%)</label>
                <input type="number" class="form-control" value="40" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Response Time Target (hrs)</label>
                <input type="number" class="form-control" value="2" />
            </div>
        </div>
        <button class="btn btn-primary mt-3">Update Targets</button>
    </div>
</div>
