@model RealEstate.Models.TransactionSuccessViewModel
@{
    ViewData["Title"] = "Transaction confirmed";
}

<div class="site-page py-5">
    <div class="container text-center" style="max-width: 560px;">
        <div class="mb-4 text-success" style="font-size: 3rem;" aria-hidden="true">✓</div>
        <h1 class="h3 fw-bold text-site-dark mb-2">Transaction recorded</h1>
        <p class="text-site-muted mb-4">We received your customer details and payment instructions. Our team will verify and contact you to finalize the next steps.</p>

        <div class="card border-0 shadow-sm rounded-4 text-start mb-4">
            <div class="card-body p-4">
                <dl class="row small mb-0">
                    <dt class="col-sm-4 text-site-muted">Reference</dt>
                    <dd class="col-sm-8 fw-semibold text-site-dark">@Model.Reference</dd>
                    <dt class="col-sm-4 text-site-muted">Property</dt>
                    <dd class="col-sm-8">@Model.PropertyTitle</dd>
                    <dt class="col-sm-4 text-site-muted">Initial amount</dt>
                    <dd class="col-sm-8 fw-bold text-site">₱@Model.AmountFormatted</dd>
                </dl>
            </div>
        </div>

        <a class="btn btn-site-primary text-white rounded-pill px-4 me-2" asp-controller="Properties" asp-action="Index">Browse properties</a>
        <a class="btn btn-outline-site rounded-pill px-4" asp-controller="Home" asp-action="Index">Home</a>
    </div>
</div>
