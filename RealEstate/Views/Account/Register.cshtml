@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@model RealEstate.Controllers.RegisterViewModel

<div class="site-inner-body">
    <div class="container-fluid py-4">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <!-- Logo and Title -->
                        <div class="text-center mb-4">
                            <div class="mb-3">
                                <span class="brand-wordmark h3">
                                    <span class="brand-estate">Estate</span><span class="brand-flow">Flow</span>
                                </span>
                            </div>
                            <h4 class="card-title">Create Account</h4>
                            <p class="text-site-muted">Join EstateFlow to schedule property visits</p>
                        </div>

                        <!-- Registration Form -->
                        <form method="post" asp-action="Register">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                            <!-- Full Name -->
                            <div class="form-group mb-3">
                                <label asp-for="FullName" class="form-label">
                                    <i class="fas fa-user me-2"></i>Full Name
                                </label>
                                <input asp-for="FullName" type="text" class="form-control" placeholder="Enter your full name">
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <!-- Email -->
                            <div class="form-group mb-3">
                                <label asp-for="Email" class="form-label">
                                    <i class="fas fa-envelope me-2"></i>Email Address
                                </label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="Enter your email">
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <!-- Username -->
                            <div class="form-group mb-3">
                                <label asp-for="Username" class="form-label">
                                    <i class="fas fa-at me-2"></i>Username
                                </label>
                                <input asp-for="Username" type="text" class="form-control" placeholder="Choose a username">
                                <span asp-validation-for="Username" class="text-danger"></span>
                            </div>

                            <!-- Phone Number -->
                            <div class="form-group mb-3">
                                <label asp-for="PhoneNumber" class="form-label">
                                    <i class="fas fa-phone me-2"></i>Phone Number
                                </label>
                                <input asp-for="PhoneNumber" type="tel" class="form-control" placeholder="Enter your phone number">
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>

                            <!-- Password -->
                            <div class="form-group mb-3">
                                <label asp-for="Password" class="form-label">
                                    <i class="fas fa-lock me-2"></i>Password
                                </label>
                                <div class="input-group">
                                    <input asp-for="Password" type="password" class="form-control" placeholder="Create a password">
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('Password')">
                                        <i class="fas fa-eye" id="PasswordToggle"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger"></span>
                                <small class="text-muted">Password must be at least 6 characters long.</small>
                            </div>

                            <!-- Confirm Password -->
                            <div class="form-group mb-3">
                                <label asp-for="ConfirmPassword" class="form-label">
                                    <i class="fas fa-lock me-2"></i>Confirm Password
                                </label>
                                <div class="input-group">
                                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm your password">
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('ConfirmPassword')">
                                        <i class="fas fa-eye" id="ConfirmPasswordToggle"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>

                            <!-- Terms and Conditions -->
                            <div class="form-group mb-3">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" required>
                                    <label class="form-check-label">
                                        I agree to the <a href="#" class="text-decoration-none">Terms of Service</a> and <a href="#" class="text-decoration-none">Privacy Policy</a>
                                    </label>
                                </div>
                            </div>

                            <!-- Submit Button -->
                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-site-primary btn-lg">
                                    <i class="fas fa-user-plus me-2"></i>Create Account
                                </button>
                            </div>

                            <!-- Login Link -->
                            <div class="text-center">
                                <p class="mb-0 text-site-muted">
                                    Already have an account? 
                                    <a href="/Account/Login" class="text-decoration-none text-site fw-bold">
                                        Sign in here
                                    </a>
                                </p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(fieldId) {
            const passwordInput = document.getElementById(fieldId);
            const toggleIcon = document.getElementById(fieldId + 'Toggle');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('fa-eye');
                toggleIcon.classList.add('fa-eye-slash');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('fa-eye-slash');
                toggleIcon.classList.add('fa-eye');
            }
        }
    </script>
}
