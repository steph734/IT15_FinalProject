@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="site-inner-body">
    <div class="container-fluid py-4">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-5 text-center">
                        <!-- Error Icon -->
                        <div class="mb-4">
                            <div class="rounded-circle bg-danger bg-opacity-10 text-danger d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                <i class="fas fa-exclamation-triangle fa-2x"></i>
                            </div>
                        </div>

                        <!-- Error Message -->
                        <h1 class="h3 mb-3">Access Denied</h1>
                        <p class="text-site-muted lead mb-4">
                            You don't have permission to access this page. Please sign in with an appropriate account or contact an administrator.
                        </p>

                        <!-- Action Buttons -->
                        <div class="d-flex gap-3 justify-content-center flex-wrap">
                            <a href="/Account/Login" class="btn btn-site-primary btn-lg">
                                <i class="fas fa-sign-in-alt me-2"></i>Sign In
                            </a>
                            <a href="/Account/Register" class="btn btn-outline-primary btn-lg">
                                <i class="fas fa-user-plus me-2"></i>Create Account
                            </a>
                            <a href="/" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-home me-2"></i>Go Home
                            </a>
                        </div>

                        <!-- Help Information -->
                        <div class="alert alert-light mt-4">
                            <h6 class="alert-heading">
                                <i class="fas fa-info-circle me-2"></i>Need Help?
                            </h6>
                            <p class="mb-2">
                                If you believe this is an error, please contact our support team:
                            </p>
                            <p class="mb-0">
                                <a href="mailto:support@estateflow.com" class="text-decoration-none">
                                    <i class="fas fa-envelope me-1"></i>support@estateflow.com
                                </a>
                                <span class="mx-2">|</span>
                                <a href="tel:+1234567890" class="text-decoration-none">
                                    <i class="fas fa-phone me-1"></i>+1-234-567-890
                                </a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
