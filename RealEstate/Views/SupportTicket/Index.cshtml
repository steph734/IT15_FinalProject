@model IEnumerable<RealEstate.Models.SupportTicket>

@{
    ViewData["Title"] = "Support Tickets";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Support Tickets</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Create New Ticket
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Ticket ID</th>
                            <th>Subject</th>
                            <th>Customer</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Category</th>
                            <th>Assigned To</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>#@item.TicketId</td>
                                <td>
                                    <strong>@item.Subject</strong>
                                    <br>
                                    <small class="text-muted">@item.Description.Substring(0, Math.Min(50, item.Description.Length))...</small>
                                </td>
                                <td>@item.Customer?.FullName ?? "N/A"</td>
                                <td>
                                    @switch (item.Priority)
                                    {
                                        case "Critical":
                                            <span class="badge bg-danger">@item.Priority</span>
                                            break;
                                        case "High":
                                            <span class="badge bg-warning text-dark">@item.Priority</span>
                                            break;
                                        case "Medium":
                                            <span class="badge bg-info text-dark">@item.Priority</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@item.Priority</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @switch (item.Status)
                                    {
                                        case "Open":
                                            <span class="badge bg-primary">@item.Status</span>
                                            break;
                                        case "In Progress":
                                            <span class="badge bg-info">@item.Status</span>
                                            break;
                                        case "Resolved":
                                            <span class="badge bg-success">@item.Status</span>
                                            break;
                                        case "Closed":
                                            <span class="badge bg-secondary">@item.Status</span>
                                            break;
                                        default:
                                            <span class="badge bg-light text-dark">@item.Status</span>
                                            break;
                                    }
                                </td>
                                <td>@item.Category</td>
                                <td>@item.AssignedEmployee?.User?.FullName ?? "Unassigned"</td>
                                <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.TicketId" class="btn btn-sm btn-info">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.TicketId" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
