<!-- Broker Sidebar Navigation -->
<aside class="broker-sidebar">
    <!-- Logo Section -->
    <div class="sidebar-logo">
        <div class="logo-container">
            <div class="logo-icon">
                <i class="fas fa-building"></i>
            </div>
            <div class="logo-text">
                <span class="logo-estate">Estate</span><span class="logo-flow">Flow</span>
            </div>
        </div>
    </div>

    <!-- Search Section -->
    <div class="sidebar-search">
        <div class="search-wrapper">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Search..." />
        </div>
    </div>

    <!-- Menu Section -->
    <nav class="sidebar-menu">
        <div class="menu-section">
            <div class="menu-label">MAIN</div>
            <ul class="menu-items">
                <li class="menu-item menu-item-expandable">
                    <a href="#" class="menu-link menu-link-toggle" data-target="dashboard-menu">
                        <i class="fas fa-chart-line"></i>
                        <span>Dashboard</span>
                        <i class="fas fa-chevron-down menu-toggle-icon"></i>
                    </a>
                    <ul class="menu-items submenu" id="dashboard-menu">
                        <li class="menu-item">
                            <a href="/broker/dashboard/my-dashboard" class="menu-link submenu-link">
                                <i class="fas fa-table-cells-large"></i>
                                <span>My Dashboard</span>
                            </a>
                        </li>
                        <li class="menu-item">
                            <a href="/broker/sales" class="menu-link submenu-link">
                                <i class="fas fa-handshake"></i>
                                <span>Sales</span>
                            </a>
                        </li>
                        <li class="menu-item">
                            <a href="/broker/dashboard/customers" class="menu-link submenu-link">
                                <i class="fas fa-users"></i>
                                <span>Customers</span>
                            </a>
                        </li>
                        <li class="menu-item">
                            <a href="/broker/dashboard/calendar" class="menu-link submenu-link">
                                <i class="fas fa-calendar-alt"></i>
                                <span>Calendar</span>
                            </a>
                        </li>
                    </ul>
                </li>
            </ul>
        </div>

        <div class="menu-section">
            <div class="menu-label">MANAGEMENT</div>
            <ul class="menu-items">


                <!-- Property Menu Item -->
                <li class="menu-item menu-item-expandable">
                    <a href="#" class="menu-link menu-link-toggle" data-target="property-menu">
                        <i class="fas fa-building"></i>
                        <span>Property</span>
                        <i class="fas fa-chevron-down menu-toggle-icon"></i>
                    </a>
                    <ul class="menu-items submenu" id="property-menu">
                        <li class="menu-item">
                            <a href="/broker/property-grid" class="menu-link submenu-link">
                                <i class="fas fa-th" style="color: #FF9500;"></i>
                                <span>Property Grid</span>
                            </a>
                        </li>
                        <li class="menu-item">
                            <a href="/broker/property-list" class="menu-link submenu-link">
                                <i class="fas fa-list" style="color: #16A39E;"></i>
                                <span>Property List</span>
                            </a>
                        </li>
                        <li class="menu-item">
                            <a href="/properties/details" class="menu-link submenu-link">
                                <i class="fas fa-info-circle" style="color: #1E3A5F;"></i>
                                <span>Property Details</span>
                            </a>
                        </li>
                    </ul>
                </li>

                <li class="menu-item">
                    <a href="/broker/customers" class="menu-link">
                        <i class="fas fa-users"></i>
                        <span>Customers</span>
                    </a>
                </li>

                <li class="menu-item">
                    <a href="/broker/orders" class="menu-link" onclick="window.location.href='/broker/orders'; return false;">
                        <i class="fas fa-shopping-cart"></i>
                        <span>Orders</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/broker/inbox" class="menu-link">
                        <i class="fas fa-inbox"></i>
                        <span>Inbox</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/broker/messages" class="menu-link">
                        <i class="fas fa-comments"></i>
                        <span>Message</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/broker/agent-pickup" class="menu-link">
                        <i class="fas fa-car"></i>
                        <span>Agent Pickup</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="menu-section">
            <div class="menu-label">ANALYTICS</div>
            <ul class="menu-items">

                <li class="menu-item">
                    <a href="/broker/commissions" class="menu-link">
                        <i class="fas fa-dollar-sign"></i>
                        <span>Commissions</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="menu-section">
            <div class="menu-label">ACCOUNT</div>
            <ul class="menu-items">
                <li class="menu-item">
                    <a href="/broker/profile" class="menu-link">
                        <i class="fas fa-user"></i>
                        <span>Profile</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="/broker/settings" class="menu-link">
                        <i class="fas fa-cog"></i>
                        <span>Settings</span>
                    </a>
                </li>
                <li class="menu-item">
                    <form method="post" action="/Account/Logout" style="display: contents;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="menu-link" style="background: none; border: none; cursor: pointer; width: 100%; text-align: left; color: #e4e6eb;">
                            <i class="fas fa-sign-out-alt" style="color: #ef4444;"></i>
                            <span>Logout</span>
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </nav>

    <!-- User Profile Section -->
    <div class="sidebar-footer">
        <div class="user-profile">
            <div class="user-avatar">
                <i class="fas fa-user-circle"></i>
            </div>
            <div class="user-info">
                <div class="user-name">@(ViewData["UserName"] as string ?? "Broker")</div>
                <div class="user-role">Broker</div>
            </div>
        </div>
    </div>
</aside>

<style>
    .broker-sidebar {
        width: 250px;
        background: #1a1f3a;
        color: #e4e6eb;
        display: flex;
        flex-direction: column;
        height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        overflow-y: auto;
        box-shadow: 2px 0 8px rgba(0, 0, 0, 0.15);
        z-index: 1000;
    }

    /* Logo Section */
    .sidebar-logo {
        padding: 24px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .logo-container {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .logo-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: white;
    }

    .logo-text {
        font-size: 16px;
        font-weight: 700;
    }

    .logo-estate {
        color: #ff7a59;
    }

    .logo-flow {
        color: #e4e6eb;
    }

    /* Search Section */
    .sidebar-search {
        padding: 16px 12px;
    }

    .search-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .search-wrapper i {
        position: absolute;
        left: 12px;
        color: #9ca3af;
        font-size: 14px;
    }

    .search-wrapper input {
        width: 100%;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        padding: 10px 12px 10px 36px;
        color: #e4e6eb;
        font-size: 13px;
        transition: all 0.3s ease;
    }

    .search-wrapper input::placeholder {
        color: #9ca3af;
    }

    .search-wrapper input:focus {
        outline: none;
        background: rgba(255, 255, 255, 0.15);
        border-color: rgba(255, 127, 88, 0.5);
        box-shadow: 0 0 0 3px rgba(255, 127, 88, 0.1);
    }

    /* Menu Section */
    .sidebar-menu {
        flex: 1;
        overflow-y: auto;
        padding: 16px 0;
    }

    .menu-section {
        margin-bottom: 8px;
    }

    .menu-label {
        padding: 12px 20px 8px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #9ca3af;
    }

    .menu-items {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .menu-item {
        margin-bottom: 0;
    }

    .menu-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 20px;
        color: #e4e6eb;
        text-decoration: none;
        transition: all 0.2s ease;
        font-size: 14px;
        font-weight: 500;
    }

    .menu-link i {
        width: 20px;
        text-align: center;
        font-size: 16px;
        color: #9ca3af;
        transition: color 0.2s ease;
    }

    .menu-link:hover {
        background: rgba(255, 127, 88, 0.1);
        color: #fff;
    }

    .menu-link:hover i {
        color: #ff7a59;
    }

    .menu-link.active {
        background: linear-gradient(90deg, rgba(249, 115, 22, 0.2), transparent);
        color: #ff7a59;
        border-left: 3px solid #ff7a59;
        padding-left: 17px;
    }

    .menu-link.active i {
        color: #ff7a59;
    }

    /* Scrollbar */
    .sidebar-menu::-webkit-scrollbar {
        width: 6px;
    }

    .sidebar-menu::-webkit-scrollbar-track {
        background: transparent;
    }

    .sidebar-menu::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 3px;
    }

    .sidebar-menu::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.2);
    }

    /* Footer Section */
    .sidebar-footer {
        padding: 16px 20px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .user-profile {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .user-profile:hover {
        opacity: 0.8;
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        background: rgba(255, 127, 88, 0.2);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: #ff7a59;
    }

    .user-info {
        flex: 1;
        min-width: 0;
    }

    .user-name {
        font-size: 13px;
        font-weight: 600;
        color: #e4e6eb;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .user-role {
        font-size: 11px;
        color: #9ca3af;
    }

    /* Submenu */
    .submenu {
        display: none;
        list-style: none;
        padding: 0;
        margin: 0;
        background: rgba(0, 0, 0, 0.2);
    }

    .submenu.active {
        display: block;
    }

    .submenu-link {
        padding-left: 48px !important;
        font-size: 13px;
        color: #b0b4ba;
    }

    .submenu-link i {
        font-size: 14px;
    }

    .submenu-link:hover {
        background: rgba(255, 127, 88, 0.15);
        color: #e4e6eb;
    }

    .submenu-link.active {
        background: rgba(255, 127, 88, 0.2);
        color: #ff7a59;
        border-left: 3px solid #ff7a59;
    }

    /* Menu Toggle Icon */
    .menu-toggle-icon {
        margin-left: auto;
        font-size: 12px;
        transition: transform 0.3s ease;
    }

    .menu-link-toggle {
        cursor: pointer;
    }

    .menu-item-expandable.active .menu-toggle-icon {
        transform: rotate(180deg);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .broker-sidebar {
            width: 200px;
            transform: translateX(-100%);
            transition: transform 0.3s ease;
        }

        .broker-sidebar.active {
            transform: translateX(0);
        }

        .menu-link {
            padding: 10px 16px;
            font-size: 13px;
        }

        .sidebar-logo {
            padding: 16px;
        }

        .logo-text {
            font-size: 14px;
        }

        .logo-icon {
            width: 32px;
            height: 32px;
            font-size: 16px;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const toggleLinks = document.querySelectorAll('.menu-link-toggle');

        toggleLinks.forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const targetId = this.getAttribute('data-target');
                const targetMenu = document.getElementById(targetId);
                const menuItem = this.closest('.menu-item-expandable');

                // Toggle the submenu
                targetMenu.classList.toggle('active');
                menuItem.classList.toggle('active');
            });
        });

        // Set active class based on current URL path
        const currentPath = window.location.pathname.toLowerCase();

        // Handle Dashboard pages
        if (currentPath.includes('/dashboard/')) {
            const dashboardMenu = document.getElementById('dashboard-menu');
            dashboardMenu.classList.add('active');
            dashboardMenu.closest('.menu-item-expandable').classList.add('active');

            // Highlight the current dashboard submenu link
            const dashboardLinks = dashboardMenu.querySelectorAll('.submenu-link');
            dashboardLinks.forEach(link => {
                const href = link.getAttribute('href').toLowerCase();
                if (href === currentPath || href === currentPath + '/' || currentPath.startsWith(href)) {
                    link.classList.add('active');
                }
            });
        }

        // Handle Properties pages
        if (currentPath.includes('/broker/property-grid') || currentPath.includes('/broker/property-list') || currentPath.includes('/properties')) {
            const propertyMenu = document.getElementById('property-menu');
            const propertyExpandable = propertyMenu.closest('.menu-item-expandable');

            // Expand the Property menu
            propertyMenu.classList.add('active');
            propertyExpandable.classList.add('active');

            // Highlight the specific submenu link
            const submenuLinks = propertyMenu.querySelectorAll('.submenu-link');
            submenuLinks.forEach(link => {
                const href = link.getAttribute('href').toLowerCase();
                if (href === currentPath || href === currentPath + '/' || currentPath.startsWith(href)) {
                    link.classList.add('active');
                }
            });
        }

        // Handle Orders page
        if (currentPath.includes('/broker/orders')) {
            const orderLinks = document.querySelectorAll('.menu-link');
            orderLinks.forEach(link => {
                const href = link.getAttribute('href') ? link.getAttribute('href').toLowerCase() : '';
                if (href === '/broker/orders') {
                    link.classList.add('active');
                }
            });
        }

        // Handle Sales page
        if (currentPath.includes('/broker/sales')) {
            const salesLinks = document.querySelectorAll('.menu-link');
            salesLinks.forEach(link => {
                const href = link.getAttribute('href') ? link.getAttribute('href').toLowerCase() : '';
                if (href === '/broker/sales') {
                    link.classList.add('active');
                }
            });
        }

        // Handle Inbox page
        if (currentPath.includes('/broker/inbox')) {
            const inboxLinks = document.querySelectorAll('.menu-link');
            inboxLinks.forEach(link => {
                const href = link.getAttribute('href') ? link.getAttribute('href').toLowerCase() : '';
                if (href === '/broker/inbox') {
                    link.classList.add('active');
                }
            });
        }

        // Handle Messages page
        if (currentPath.includes('/broker/messages')) {
            const messageLinks = document.querySelectorAll('.menu-link');
            messageLinks.forEach(link => {
                const href = link.getAttribute('href') ? link.getAttribute('href').toLowerCase() : '';
                if (href === '/broker/messages') {
                    link.classList.add('active');
                }
            });
        }

        // Handle Agent Pickup page
        if (currentPath.includes('/broker/agent-pickup')) {
            const pickupLinks = document.querySelectorAll('.menu-link');
            pickupLinks.forEach(link => {
                const href = link.getAttribute('href') ? link.getAttribute('href').toLowerCase() : '';
                if (href === '/broker/agent-pickup') {
                    link.classList.add('active');
                }
            });
        }
    });
</script>
