@model RealEstate.Models.Property
@{
    ViewData["Title"] = "Approved Property Details";
    Layout = "~/Views/Shared/_BrokerLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/broker/approved-listings" class="btn btn-outline-secondary btn-sm rounded-pill">
            <i class="fas fa-arrow-left me-1"></i> Back to Listings
        </a>
        <h2 class="mb-0"><i class="fas fa-building text-success me-2"></i> @Model.Title</h2>
        <span class="badge bg-success px-3 py-2 fs-6 ms-auto">Approved</span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Warning"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-times-circle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-8">
            <!-- Property Details Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Property Information</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label class="text-muted small fw-bold">Location</label>
                            <div>@Model.Location</div>
                        </div>
                        <div class="col-sm-6">
                            <label class="text-muted small fw-bold">Property Type</label>
                            <div>@Model.PropertyType</div>
                        </div>
                        <div class="col-sm-3">
                            <label class="text-muted small fw-bold">Bedrooms</label>
                            <div>@Model.Bedrooms</div>
                        </div>
                        <div class="col-sm-3">
                            <label class="text-muted small fw-bold">Bathrooms</label>
                            <div>@Model.Bathrooms</div>
                        </div>
                        <div class="col-sm-3">
                            <label class="text-muted small fw-bold">Parking</label>
                            <div>@Model.ParkingSlots</div>
                        </div>
                        <div class="col-sm-3">
                            <label class="text-muted small fw-bold">Area</label>
                            <div>@Model.Sqft sqm</div>
                        </div>
                        <div class="col-12 mt-3">
                            <label class="text-muted small fw-bold">Description</label>
                            <p class="mb-0">@Model.Description</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Documents Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Attached Documents</h5>
                </div>
                <div class="card-body">
                    @{
                        List<string>? docs = null;
                        try { docs = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.DocumentUrlsJson ?? "[]"); } catch { }
                    }
                    @if (docs != null && docs.Any())
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @for (int i = 0; i < docs.Count; i++)
                            {
                                <a href="@docs[i]" target="_blank" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-file-alt me-1"></i> Document @(i + 1)
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No documents attached.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- Pricing Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body text-center">
                    <h6 class="text-muted fw-bold">FINAL PRICE</h6>
                    <h2 class="text-success fw-bold mb-0">₱@(Model.FinalPrice?.ToString("N0") ?? Model.BasePrice.ToString("N0"))</h2>
                </div>
            </div>

            <!-- Market Data (RentCast) Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">Market Data</h5>
                    <form action="/broker/properties/@Model.PropertyId/refresh-market-data" method="post" class="m-0">
                        <button type="submit" class="btn btn-sm btn-outline-primary" title="Refresh data from RentCast">
                            <i class="fas fa-sync-alt"></i> Refresh
                        </button>
                    </form>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Powered by RentCast API</p>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Market Value:</span>
                        <span class="fw-bold">₱@(Model.MarketValue?.ToString("N0") ?? "N/A")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Rent Estimate:</span>
                        <span class="fw-bold">₱@(Model.RentEstimate?.ToString("N0") ?? "N/A") / mo</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Yield Score (Cap Rate):</span>
                        <span class="fw-bold text-primary">@(Model.YieldScore?.ToString("F2") ?? "N/A")%</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Profitability:</span>
                        @if (!string.IsNullOrEmpty(Model.ProfitabilityRating))
                        {
                            var badgeClass = Model.ProfitabilityRating switch
                            {
                                "Excellent" => "bg-success",
                                "Good" => "bg-primary",
                                "Fair" => "bg-warning",
                                "Poor" => "bg-danger",
                                _ => "bg-secondary"
                            };
                            <span class="badge @badgeClass">@Model.ProfitabilityRating</span>
                        }
                        else
                        {
                            <span class="fw-bold">N/A</span>
                        }
                    </div>
                    @if (Model.RentCastLastUpdated.HasValue)
                    {
                        <div class="text-muted small text-end mt-3 border-top pt-2">
                            Last updated: @Model.RentCastLastUpdated.Value.ToString("MMM dd, yyyy HH:mm")
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
