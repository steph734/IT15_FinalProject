@model List<RealEstate.Models.Property>
@{
    ViewData["Title"] = "Approved Listings";
    Layout = "~/Views/Shared/_BrokerLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold"><i class="fas fa-check-circle text-success me-2"></i>Approved Listings</h2>
            <p class="text-muted mb-0">Browse all properties approved for listing</p>
        </div>
    </div>

    <!-- Filters -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form method="get" action="/broker/approved-listings" class="row g-3">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="search" class="form-control border-start-0" placeholder="Search by title or location..." value="@ViewBag.SearchFilter">
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="type" class="form-select">
                        <option value="">All Property Types</option>
                        <option value="House" selected="@(ViewBag.TypeFilter == "House" ? "selected" : null)">House</option>
                        <option value="Condo" selected="@(ViewBag.TypeFilter == "Condo" ? "selected" : null)">Condominium</option>
                        <option value="Apartment" selected="@(ViewBag.TypeFilter == "Apartment" ? "selected" : null)">Apartment</option>
                        <option value="Land" selected="@(ViewBag.TypeFilter == "Land" ? "selected" : null)">Land</option>
                        <option value="Commercial" selected="@(ViewBag.TypeFilter == "Commercial" ? "selected" : null)">Commercial</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Filter</button>
                </div>
                @if (!string.IsNullOrEmpty(ViewBag.SearchFilter) || !string.IsNullOrEmpty(ViewBag.TypeFilter))
                {
                    <div class="col-md-2">
                        <a href="/broker/approved-listings" class="btn btn-outline-secondary w-100">Clear</a>
                    </div>
                }
            </form>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var property in Model)
            {
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <div class="card h-100 shadow-sm border-0 property-card">
                        <div class="position-relative">
                            @{
                                var coverImage = !string.IsNullOrEmpty(property.CoverImage) ? property.CoverImage : "https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&w=500&q=60";
                            }
                            <img src="@coverImage" class="card-img-top" alt="@property.Title" style="height: 200px; object-fit: cover;">
                            <div class="position-absolute top-0 start-0 m-3">
                                <span class="badge bg-success px-2 py-1"><i class="fas fa-check me-1"></i>Approved</span>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold text-truncate" title="@property.Title">@property.Title</h5>
                            <p class="text-muted small mb-3"><i class="fas fa-map-marker-alt text-danger me-1"></i>@property.Location</p>
                            
                            <div class="d-flex justify-content-between mb-3 border-bottom pb-3">
                                <div class="text-center px-2">
                                    <i class="fas fa-bed text-muted d-block mb-1"></i>
                                    <span class="fw-bold">@property.Bedrooms</span>
                                </div>
                                <div class="text-center px-2 border-start border-end">
                                    <i class="fas fa-bath text-muted d-block mb-1"></i>
                                    <span class="fw-bold">@property.Bathrooms</span>
                                </div>
                                <div class="text-center px-2">
                                    <i class="fas fa-vector-square text-muted d-block mb-1"></i>
                                    <span class="fw-bold">@property.Sqft</span>
                                </div>
                            </div>
                            
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <div>
                                    <small class="text-muted d-block">Price</small>
                                    <span class="fs-5 fw-bold text-primary">₱@(property.FinalPrice?.ToString("N0") ?? property.BasePrice.ToString("N0"))</span>
                                </div>
                                <a href="/broker/approved-listings/@property.PropertyId" class="btn btn-outline-primary btn-sm rounded-pill px-3">View Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white rounded shadow-sm">
            <div class="display-1 text-muted mb-3"><i class="fas fa-search"></i></div>
            <h4>No approved properties found</h4>
            <p class="text-muted">There are currently no properties that match your search criteria.</p>
        </div>
    }
</div>

<style>
    .property-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .property-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
</style>
