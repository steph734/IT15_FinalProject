@{
    ViewData["Title"] = "My Dashboard";
    Layout = "~/Views/Shared/_BrokerLayout.cshtml";
    ViewData["UserName"] = (string?)ViewBag.BrokerName ?? "Broker";
}

<style>
    .my-dashboard-page {
        padding: 20px;
        background: #f5f7fb;
        min-height: calc(100vh - 80px);
    }

    .dash-grid {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 14px;
    }

    .panel {
        background: #fff;
        border: 1px solid #eaedf3;
        border-radius: 10px;
        box-shadow: 0 1px 2px rgba(17, 24, 39, 0.03);
        padding: 14px;
    }

    .mini-card {
        grid-column: span 12;
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 10px;
        padding: 0;
        border: none;
        box-shadow: none;
        background: transparent;
    }

    .metric {
        background: #fff;
        border: 1px solid #eaedf3;
        border-radius: 10px;
        padding: 12px;
    }

    .metric .value {
        font-size: 28px;
        font-weight: 700;
        color: #111827;
        margin: 4px 0;
    }

    .metric .label {
        font-size: 12px;
        color: #64748b;
        font-weight: 600;
    }

    .metric .delta {
        font-size: 11px;
        color: #10b981;
        background: #ecfdf5;
        display: inline-block;
        border-radius: 6px;
        padding: 2px 6px;
    }

    .secondary-metrics {
        grid-column: span 12;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
    }

    .secondary-metrics .metric .value {
        font-size: 24px;
    }

    .project-summary {
        grid-column: span 6;
    }

    .schedule-panel {
        grid-column: span 6;
    }

    .schedule-actions {
        position: relative;
    }

    .dot-menu-btn {
        width: 28px;
        height: 28px;
        border: none;
        background: transparent;
        color: #64748b;
        border-radius: 6px;
        cursor: pointer;
    }

    .dot-menu-btn:hover {
        background: #f1f5f9;
    }

    .schedule-dropdown {
        display: none;
        position: absolute;
        top: 32px;
        right: 0;
        width: 146px;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.1);
        padding: 6px;
        z-index: 20;
    }

    .schedule-dropdown.show {
        display: block;
    }

    .dropdown-option {
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        border: none;
        background: transparent;
        border-radius: 6px;
        padding: 8px;
        color: #475569;
        font-size: 12px;
        text-align: left;
        cursor: pointer;
    }

    .dropdown-option:hover {
        background: #f8fafc;
    }

    .panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }

    .panel-title {
        font-size: 13px;
        font-weight: 700;
        color: #334155;
    }

    .table-list {
        width: 100%;
        border-collapse: collapse;
    }

    .table-list th,
    .table-list td {
        border-bottom: 1px solid #f1f5f9;
        padding: 10px 6px;
        font-size: 12px;
        color: #475569;
        text-align: left;
    }

    .progress-line {
        width: 70px;
        height: 4px;
        border-radius: 999px;
        background: #e5e7eb;
        overflow: hidden;
    }

    .progress-line span {
        display: block;
        height: 100%;
        border-radius: 999px;
    }

    .schedule-item {
        display: grid;
        grid-template-columns: 52px 1fr;
        gap: 10px;
        margin-bottom: 10px;
        align-items: center;
    }

    .time {
        font-size: 11px;
        color: #64748b;
        font-weight: 600;
    }

    .event {
        border-radius: 8px;
        padding: 10px;
        font-size: 12px;
        color: #334155;
        border: 1px solid transparent;
    }

    .e1 { background: #ede9fe; border-color: #ddd6fe; }
    .e2 { background: #dcfce7; border-color: #bbf7d0; }
    .e3 { background: #cffafe; border-color: #a5f3fc; }
    .e4 { background: #ffedd5; border-color: #fed7aa; }

    .conversions {
        grid-column: span 4;
        text-align: center;
    }

    .donut {
        width: 140px;
        height: 140px;
        margin: 8px auto;
        border-radius: 50%;
        background: conic-gradient(#8b5cf6 0 65%, #e5e7eb 65% 100%);
        position: relative;
    }

    .donut:after {
        content: "";
        position: absolute;
        inset: 18px;
        background: #fff;
        border-radius: 50%;
    }

    .kpi-split {
        display: grid;
        grid-template-columns: 1fr 1fr;
        margin-top: 8px;
        font-size: 12px;
        color: #64748b;
    }

    .performance {
        grid-column: span 8;
    }

    .bars {
        margin-top: 12px;
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 10px;
        align-items: end;
        height: 180px;
    }

    .bars .bar {
        border-radius: 8px 8px 4px 4px;
        background: linear-gradient(180deg, #8b5cf6, #6366f1);
    }

    .tasks, .friends, .transactions {
        grid-column: span 4;
    }

    .check-item {
        display: flex;
        gap: 8px;
        align-items: flex-start;
        margin-bottom: 8px;
        font-size: 12px;
        color: #475569;
    }

    .friend-item, .tx-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #f1f5f9;
        font-size: 12px;
        color: #475569;
    }

    .friend-item:last-child, .tx-item:last-child {
        border-bottom: none;
    }

    .chip {
        font-size: 10px;
        border-radius: 999px;
        padding: 2px 7px;
        font-weight: 700;
    }

    .chip.in { background: #dcfce7; color: #166534; }
    .chip.out { background: #fee2e2; color: #991b1b; }

    @@media (max-width: 1200px) {
        .mini-card { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .secondary-metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .project-summary, .schedule-panel, .conversions, .performance, .tasks, .friends, .transactions { grid-column: span 12; }
    }

    @@media (max-width: 640px) {
        .mini-card, .secondary-metrics { grid-template-columns: 1fr; }
    }
</style>

<div class="my-dashboard-page">
    <div class="dash-grid">
        <section class="mini-card">
            <div class="metric"><div class="label">Total Income</div><div class="value">$59.6k</div><span class="delta">+8.7%</span></div>
            <div class="metric"><div class="label">Total Expenses</div><div class="value">$24.03k</div><span class="delta" style="color:#b91c1c;background:#fee2e2;">-3.3%</span></div>
            <div class="metric"><div class="label">Investments</div><div class="value">$48.7k</div><span class="delta" style="color:#b91c1c;background:#fee2e2;">-5.6%</span></div>
            <div class="metric"><div class="label">Savings</div><div class="value">$11.3k</div><span class="delta">+30.5%</span></div>
            <div class="metric"><div class="label">Profits</div><div class="value">$5.5k</div><span class="delta">+2.2%</span></div>
        </section>

        <section class="secondary-metrics">
            <div class="metric"><div class="label">Campaign Sent</div><div class="value">13,647</div><div class="label">Last Month</div></div>
            <div class="metric"><div class="label">New Leads</div><div class="value">9,526</div><div class="label">Last Month</div></div>
            <div class="metric"><div class="label">Deals</div><div class="value">976</div><div class="label">Last Month</div></div>
            <div class="metric"><div class="label">Booked Revenue</div><div class="value">$123.6k</div><div class="label">Last Month</div></div>
        </section>

        <section class="panel project-summary">
            <div class="panel-header">
                <div class="panel-title">Recent Project Summary</div>
                <a href="#" style="font-size:12px;">Export</a>
            </div>
            <table class="table-list">
                <thead><tr><th>Project</th><th>Client</th><th>Deadline</th><th>Progress</th></tr></thead>
                <tbody>
                    <tr><td>Zology</td><td>Daniel Olsen</td><td>12 April 2024</td><td><div class="progress-line"><span style="width:38%; background:#6366f1;"></span></div></td></tr>
                    <tr><td>Shize</td><td>Jack Rolex</td><td>10 April 2024</td><td><div class="progress-line"><span style="width:75%; background:#10b981;"></span></div></td></tr>
                    <tr><td>Hedlenck</td><td>Betty Cox</td><td>31 March 2024</td><td><div class="progress-line"><span style="width:52%; background:#f59e0b;"></span></div></td></tr>
                    <tr><td>Fyyux</td><td>Carlos Johnson</td><td>25 March 2024</td><td><div class="progress-line"><span style="width:91%; background:#8b5cf6;"></span></div></td></tr>
                    <tr><td>Xavlox</td><td>Lorraine Cox</td><td>22 March 2024</td><td><div class="progress-line"><span style="width:46%; background:#ef4444;"></span></div></td></tr>
                </tbody>
            </table>
        </section>

        <section class="panel schedule-panel">
            <div class="panel-header">
                <div class="panel-title">Today's Schedules</div>
                <div class="schedule-actions">
                    <button type="button" class="dot-menu-btn" id="scheduleMenuButton" aria-label="Schedule actions">
                        <i class="fas fa-ellipsis-v"></i>
                    </button>
                    <div class="schedule-dropdown" id="scheduleDropdown">
                        <button class="dropdown-option" type="button"><i class="far fa-square"></i> To Do</button>
                        <button class="dropdown-option" type="button"><i class="fas fa-chart-line"></i> In Progress</button>
                        <button class="dropdown-option" type="button"><i class="far fa-check-square"></i> Completed</button>
                    </div>
                </div>
            </div>
            <div class="schedule-item"><div class="time">09:00</div><div class="event e1">Setup Github Repository<br/><small>09:00 - 10:00</small></div></div>
            <div class="schedule-item"><div class="time">10:00</div><div class="event e2">Design Review - Lahomes Admin<br/><small>10:00 - 10:30</small></div></div>
            <div class="schedule-item"><div class="time">11:00</div><div class="event e3">Meeting with BD Team<br/><small>11:00 - 12:30</small></div></div>
            <div class="schedule-item"><div class="time">01:00</div><div class="event e4">Meeting with Design Studio<br/><small>01:00 - 02:00</small></div></div>
        </section>

        <section class="panel conversions">
            <div class="panel-title">Conversions</div>
            <div class="donut"></div>
            <div style="font-size:24px; font-weight:700;">65.2%</div>
            <div style="font-size:12px; color:#64748b;">Returning Customer</div>
            <div class="kpi-split">
                <div><strong>23.5k</strong><br />This Week</div>
                <div><strong>41.05k</strong><br />Last Week</div>
            </div>
        </section>

        <section class="panel performance">
            <div class="panel-header">
                <div class="panel-title">Performance</div>
                <div style="font-size:11px; color:#94a3b8;">ALL | 1M | 6M | 1Y</div>
            </div>
            <div style="font-size:12px; background:#ecfeff; border:1px solid #bae6fd; color:#475569; padding:8px; border-radius:7px;">
                We regret to inform you that our server is currently experiencing technical difficulties.
            </div>
            <div class="bars">
                <div class="bar" style="height:34%;"></div><div class="bar" style="height:64%;"></div><div class="bar" style="height:45%;"></div>
                <div class="bar" style="height:68%;"></div><div class="bar" style="height:48%;"></div><div class="bar" style="height:60%;"></div>
                <div class="bar" style="height:42%;"></div><div class="bar" style="height:44%;"></div><div class="bar" style="height:76%;"></div>
                <div class="bar" style="height:52%;"></div><div class="bar" style="height:62%;"></div><div class="bar" style="height:66%;"></div>
            </div>
        </section>

        <section class="panel tasks">
            <div class="panel-header"><div class="panel-title">My Tasks</div><button style="font-size:11px;border:none;border-radius:6px;padding:6px 8px;background:#6366f1;color:#fff;">+ Create Task</button></div>
            <div class="check-item"><input type="radio" /> Review system logs for reported errors</div>
            <div class="check-item"><input type="radio" checked /> Conduct user testing to identify bugs</div>
            <div class="check-item"><input type="radio" /> Gather feedback from stakeholders</div>
            <div class="check-item"><input type="radio" /> Prioritize bugs by severity and impact</div>
            <div class="check-item"><input type="radio" /> Investigate root cause of each bug</div>
            <div class="check-item"><input type="radio" /> Complete recurring tasks</div>
        </section>

        <section class="panel friends">
            <div class="panel-header"><div class="panel-title">Friends Request (10)</div><i class="fas fa-ellipsis-v"></i></div>
            <div class="friend-item"><span>Victoria P. Miller</span><small style="color:#94a3b8;">10 mutual friends</small></div>
            <div class="friend-item"><span>Dallas C. Payne</span><small style="color:#94a3b8;">8 mutual friends</small></div>
            <div class="friend-item"><span>Florence A. Lopez</span><small style="color:#94a3b8;">12 mutual friends</small></div>
            <div class="friend-item"><span>Gie A. Nix</span><small style="color:#94a3b8;">11 mutual friends</small></div>
            <div class="friend-item"><span>Lynne J. Petty</span><small style="color:#94a3b8;">9 mutual friends</small></div>
        </section>

        <section class="panel transactions">
            <div class="panel-header"><div class="panel-title">Recent Transactions</div><button style="font-size:11px;border:none;border-radius:6px;padding:6px 8px;background:#6366f1;color:#fff;">+ Add</button></div>
            <div class="tx-item"><span>24 Apr, 2024 · $120.55</span><span class="chip in">Cr</span></div>
            <div class="tx-item"><span>24 Apr, 2024 · $31.68</span><span class="chip in">Cr</span></div>
            <div class="tx-item"><span>20 Apr, 2024 · $105.22</span><span class="chip out">Dr</span></div>
            <div class="tx-item"><span>18 Apr, 2024 · $80.99</span><span class="chip in">Cr</span></div>
            <div class="tx-item"><span>18 Apr, 2024 · $74.09</span><span class="chip out">Dr</span></div>
            <div class="tx-item"><span>17 Apr, 2024 · $455.62</span><span class="chip in">Cr</span></div>
        </section>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const menuButton = document.getElementById('scheduleMenuButton');
        const dropdown = document.getElementById('scheduleDropdown');

        if (!menuButton || !dropdown) return;

        menuButton.addEventListener('click', function (event) {
            event.stopPropagation();
            dropdown.classList.toggle('show');
        });

        document.addEventListener('click', function (event) {
            if (!dropdown.contains(event.target) && !menuButton.contains(event.target)) {
                dropdown.classList.remove('show');
            }
        });
    });
</script>
