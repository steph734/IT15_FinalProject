@model List<RealEstate.Models.Property>
@{
    ViewData["Title"] = "Properties";
    var page = (int?)ViewBag.Page ?? 1;
    var totalPages = (int?)ViewBag.TotalPages ?? 1;
}

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #f8f9fc; font-family: 'Inter', sans-serif; color: #1f2937; }
    .broker-page { display: flex; flex-direction: column; min-height: 100vh; }
    .broker-navbar { background: linear-gradient(135deg, #667eea, #764ba2); padding: 16px 40px; display: flex; justify-content: space-between; align-items: center; color: white; box-shadow: 0 2px 12px rgba(102, 126, 234, 0.15); gap: 40px; }
    .navbar-left { display: flex; align-items: center; gap: 30px; }
    .navbar-brand { display: flex; align-items: center; gap: 12px; font-weight: 700; font-size: 18px; white-space: nowrap; }
    .navbar-brand i { font-size: 24px; }
    .navbar-menu { display: flex; align-items: center; gap: 8px; list-style: none; }
    .navbar-item { position: relative; }
    .navbar-link { display: flex; align-items: center; gap: 8px; padding: 10px 16px; color: rgba(255,255,255,0.9); text-decoration: none; border-radius: 6px; transition: all 0.3s; font-size: 14px; font-weight: 500; white-space: nowrap; }
    .navbar-link:hover { background: rgba(255,255,255,0.2); color: white; }
    .navbar-link.active { background: rgba(255,255,255,0.3); color: white; }
    .navbar-right { display: flex; align-items: center; gap: 16px; }
    .navbar-user { display: flex; align-items: center; gap: 8px; padding: 8px 12px; background: rgba(255,255,255,0.1); border-radius: 6px; font-size: 13px; }
    .main-content { flex: 1; overflow-y: auto; padding: 40px; background: #f8f9fc; }
    .page-header h1 { font-size: 32px; font-weight: 700; color: #1f2937; margin-bottom: 4px; }
    .page-header p { font-size: 14px; color: #6b7280; margin-bottom: 30px; }
    .card { background: white; border-radius: 12px; border: 1px solid #e5e7eb; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    th { background: #f9fafb; padding: 14px; text-align: left; font-weight: 600; color: #6b7280; border-bottom: 1px solid #e5e7eb; }
    td { padding: 14px; border-bottom: 1px solid #e5e7eb; }
    tr:hover { background: #f9fafb; }
    .badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; background: rgba(16, 185, 129, 0.1); color: #059669; }
    .pagination { display: flex; justify-content: center; gap: 8px; margin-top: 24px; }
    .pagination a, .pagination span { padding: 8px 12px; border-radius: 6px; border: 1px solid #e5e7eb; background: white; color: #1f2937; text-decoration: none; transition: all 0.3s; }
    .pagination a:hover { background: #667eea; color: white; border-color: #667eea; }
    .pagination .active { background: #667eea; color: white; border-color: #667eea; }
    @@media (max-width: 768px) { .broker-navbar { flex-wrap: wrap; padding: 12px 20px; gap: 16px; } .navbar-left { width: 100%; gap: 16px; } .navbar-menu { width: 100%; flex-wrap: wrap; } .navbar-right { width: 100%; } .main-content { padding: 20px; } }
</style>

<div class="broker-page">
    <!-- Navbar -->
    <nav class="broker-navbar">
        <div class="navbar-left">
            <div class="navbar-brand">
                <i class="fas fa-building"></i>
                <span>EstateFlow</span>
            </div>
            <ul class="navbar-menu">
                <li class="navbar-item"><a href="@Url.Action("Dashboard", "Broker")" class="navbar-link"><i class="fas fa-chart-line"></i> Overview</a></li>
                <li class="navbar-item"><a href="@Url.Action("Properties", "Broker")" class="navbar-link active"><i class="fas fa-home"></i> Properties</a></li>
                <li class="navbar-item"><a href="@Url.Action("Leads", "Broker")" class="navbar-link"><i class="fas fa-users"></i> Leads</a></li>
                <li class="navbar-item"><a href="@Url.Action("Performance", "Broker")" class="navbar-link"><i class="fas fa-chart-bar"></i> Performance</a></li>
                <li class="navbar-item"><a href="@Url.Action("Commissions", "Broker")" class="navbar-link"><i class="fas fa-dollar-sign"></i> Commissions</a></li>
                <li class="navbar-item"><a href="@Url.Action("Settings", "Broker")" class="navbar-link"><i class="fas fa-cog"></i> Settings</a></li>
            </ul>
        </div>
        <div class="navbar-right">
            <div class="navbar-user">
                <i class="fas fa-user-circle"></i>
                <span>Broker</span>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <div class="page-header">
            <h1>🏠 Properties</h1>
            <p>Manage all broker properties</p>
        </div>

        @if (Model.Any())
        {
            <div class="card">
                <table>
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Location</th>
                            <th>Price</th>
                            <th>Type</th>
                            <th>Beds/Baths</th>
                            <th>Status</th>
                            <th>Leads</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var property in Model)
                        {
                            <tr>
                                <td style="font-weight: 600;">@property.Title</td>
                                <td>@property.Location</td>
                                <td style="color: #10b981; font-weight: 600;">₱@property.Price.ToString("N0")</td>
                                <td>@property.ListingType</td>
                                <td>@property.Bedrooms/@property.Bathrooms</td>
                                <td><span class="badge">Active</span></td>
                                <td style="color: #667eea; font-weight: 600;">24</td>
                                <td><a href="@Url.Action("Details", "Properties", new { id = property.Id })" style="color: #667eea; text-decoration: none; font-weight: 600;">View</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <div class="pagination">
                    @if (page > 1)
                    {
                        <a href="?page=1">« First</a>
                        <a href="?page=@(page - 1)">‹ Previous</a>
                    }
                    @for (int i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
                    {
                        if (i == page)
                        {
                            <span class="active">@i</span>
                        }
                        else
                        {
                            <a href="?page=@i">@i</a>
                        }
                    }
                    @if (page < totalPages)
                    {
                        <a href="?page=@(page + 1)">Next ›</a>
                        <a href="?page=@totalPages">Last »</a>
                    }
                </div>
            }
        }
        else
        {
            <div class="card" style="text-align: center; padding: 60px 20px;">
                <i class="fas fa-home" style="font-size: 48px; opacity: 0.3; display: block; margin-bottom: 16px;"></i>
                <p style="color: #6b7280;">No properties available</p>
            </div>
        }
    </main>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
