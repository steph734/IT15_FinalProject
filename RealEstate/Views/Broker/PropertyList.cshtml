@model List<RealEstate.Models.Property>
@{
    ViewData["Title"] = "Property List";
    var page = (int?)ViewBag.Page ?? 1;
    var totalPages = (int?)ViewBag.TotalPages ?? 1;
    Layout = "~/Views/Shared/_BrokerLayout.cshtml";
}

<style>
    .broker-list-container { padding: 24px; }
    .card { background: white; border-radius: 12px; border: 1px solid #e5e7eb; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    th { background: #f9fafb; padding: 14px; text-align: left; font-weight: 600; color: #6b7280; border-bottom: 1px solid #e5e7eb; }
    td { padding: 14px; border-bottom: 1px solid #e5e7eb; vertical-align: middle; }
    tr:hover { background: #f9fafb; }
    .badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; background: rgba(16, 185, 129, 0.1); color: #059669; }
    .pagination { display: flex; justify-content: center; gap: 8px; margin-top: 24px; }
    .pagination a, .pagination span { padding: 8px 12px; border-radius: 6px; border: 1px solid #e5e7eb; background: white; color: #1f2937; text-decoration: none; transition: all 0.3s; }
    .pagination a:hover { background: #f97316; color: white; border-color: #f97316; }
    .pagination .active { background: #f97316; color: white; border-color: #f97316; }
</style>

<div class="broker-list-container">
    <div style="display:flex; justify-content: space-between; align-items:center; margin-bottom: 24px;">
        <div>
            <h2 style="font-weight:700; color:#1f2937; margin:0;">Property List</h2>
            <p style="color:#6b7280; margin:0;">Manage your assigned properties</p>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <table>
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Location</th>
                        <th>Price</th>
                        <th>Type</th>
                        <th>Beds/Baths</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var property in Model)
                    {
                        <tr>
                            <td style="font-weight: 600;">@property.Title</td>
                            <td>@property.Location</td>
                            <td style="color: #10b981; font-weight: 600;">₱@property.BasePrice.ToString("N0")</td>
                            <td>@property.PropertyType</td>
                            <td>@property.Bedrooms / @property.Bathrooms</td>
                            <td><span class="badge">@property.Status</span></td>
                            <td><a href="@Url.Action("Details", "Properties", new { id = property.PropertyId })" style="color: #f97316; text-decoration: none; font-weight: 600;">View</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <div class="pagination">
                @if (page > 1)
                {
                    <a href="?page=1">« First</a>
                    <a href="?page=@(page - 1)">‹ Previous</a>
                }
                @for (int i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
                {
                    if (i == page)
                    {
                        <span class="active">@i</span>
                    }
                    else
                    {
                        <a href="?page=@i">@i</a>
                    }
                }
                @if (page < totalPages)
                {
                    <a href="?page=@(page + 1)">Next ›</a>
                    <a href="?page=@totalPages">Last »</a>
                }
            </div>
        }
    }
    else
    {
        <div class="card" style="text-align: center; padding: 60px 20px;">
            <i class="fas fa-home" style="font-size: 48px; opacity: 0.3; display: block; margin-bottom: 16px;"></i>
            <p style="color: #6b7280;">No properties assigned to you</p>
        </div>
    }
</div>
