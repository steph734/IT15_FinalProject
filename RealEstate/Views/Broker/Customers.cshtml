@{
    ViewData["Title"] = "Customers";
    Layout = "~/Views/Shared/_BrokerLayout.cshtml";
    ViewData["UserName"] = (string?)ViewBag.BrokerName ?? "Broker";
}

<style>
    .customers-dashboard {
        padding: 20px;
        background: #f5f7fb;
        min-height: calc(100vh - 80px);
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 14px;
    }

    .panel {
        background: #fff;
        border: 1px solid #ebeff5;
        border-radius: 10px;
        box-shadow: 0 1px 2px rgba(17, 24, 39, 0.03);
        padding: 14px;
    }

    .panel-title {
        font-size: 12px;
        font-weight: 700;
        color: #4b5563;
        margin-bottom: 8px;
    }

    .muted {
        color: #9ca3af;
        font-size: 11px;
    }

    .country-card {
        grid-column: span 3;
    }

    .country-flag {
        font-size: 16px;
        margin-right: 6px;
    }

    .country-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 8px;
    }

    .customers-count {
        font-size: 22px;
        font-weight: 700;
        color: #111827;
        margin: 4px 0 8px;
    }

    .mini-progress {
        height: 5px;
        width: 100%;
        background: #eceff6;
        border-radius: 999px;
        overflow: hidden;
    }

    .mini-progress > span {
        display: block;
        height: 100%;
        background: linear-gradient(90deg, #7c3aed, #6366f1);
        border-radius: 999px;
    }

    .investor-panel {
        grid-column: span 4;
    }

    .investor-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
    }

    .avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, #f59e0b, #f97316);
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
    }

    .investor-name {
        font-size: 13px;
        font-weight: 700;
        color: #111827;
    }

    .bar-chart {
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        gap: 8px;
        align-items: end;
        height: 90px;
        margin: 10px 0 12px;
    }

    .bar {
        border-radius: 8px 8px 4px 4px;
        background: #e5e7eb;
    }

    .bar.highlight {
        background: linear-gradient(180deg, #7c3aed, #6366f1);
    }

    .dual-buttons {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .btn-lite {
        border: 1px solid #e5e7eb;
        background: #f8fafc;
        color: #4b5563;
        border-radius: 8px;
        padding: 8px 10px;
        font-size: 12px;
        font-weight: 600;
    }

    .btn-primary-lite {
        border: none;
        background: linear-gradient(135deg, #7c3aed, #6366f1);
        color: white;
        border-radius: 8px;
        padding: 8px 10px;
        font-size: 12px;
        font-weight: 600;
    }

    .invest-chart {
        grid-column: span 7;
    }

    .invest-revenue {
        float: right;
        font-size: 20px;
        font-weight: 700;
        color: #111827;
    }

    .bars-wide {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 14px;
        align-items: end;
        height: 140px;
        margin-top: 16px;
    }

    .bars-wide .col {
        text-align: center;
        font-size: 10px;
        color: #9ca3af;
    }

    .bars-wide .col span {
        display: block;
        width: 24px;
        margin: 0 auto 8px;
        border-radius: 8px;
        background: linear-gradient(180deg, #8b5cf6, #6366f1);
    }

    .country-map {
        grid-column: span 5;
    }

    .map-box {
        border-radius: 10px;
        background: radial-gradient(circle at 40% 40%, #f8fafc, #eef2f7);
        border: 1px dashed #d7deea;
        height: 220px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        font-weight: 600;
    }

    .top-customers {
        grid-column: span 4;
    }

    .customer-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        padding: 10px 0;
        border-bottom: 1px solid #f1f5f9;
    }

    .customer-item:last-child {
        border-bottom: none;
    }

    .customer-meta {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .customer-meta .avatar {
        width: 30px;
        height: 30px;
        font-size: 10px;
    }

    .customer-name {
        font-size: 12px;
        font-weight: 600;
        color: #111827;
    }

    .customer-mail {
        font-size: 10px;
        color: #94a3b8;
    }

    .visit-device {
        grid-column: span 4;
    }

    .line-graph {
        height: 105px;
        border-radius: 10px;
        background: linear-gradient(180deg, rgba(139, 92, 246, 0.1), rgba(99, 102, 241, 0.03));
        border: 1px solid #eef2ff;
        position: relative;
        overflow: hidden;
        margin: 10px 0;
    }

    .line-graph:before {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        top: 56%;
        height: 2px;
        background: linear-gradient(90deg, #7c3aed, #6366f1);
        transform: skewY(-8deg);
    }

    .device-bars {
        display: grid;
        gap: 8px;
    }

    .device-row {
        display: grid;
        grid-template-columns: 85px 1fr 50px;
        align-items: center;
        gap: 8px;
        font-size: 11px;
        color: #64748b;
    }

    .track {
        height: 6px;
        border-radius: 999px;
        background: #eef2f7;
        overflow: hidden;
    }

    .fill {
        height: 100%;
        border-radius: 999px;
    }

    .purchase-property {
        grid-column: span 4;
    }

    .property-image {
        width: 100%;
        border-radius: 8px;
        height: 170px;
        object-fit: cover;
        margin-bottom: 10px;
        border: 1px solid #edf2f7;
    }

    .property-title {
        font-size: 13px;
        font-weight: 700;
        color: #1f2937;
    }

    .price {
        color: #111827;
        font-weight: 700;
        font-size: 13px;
    }

    @@media (max-width: 1280px) {
        .country-card { grid-column: span 4; }
        .investor-panel { grid-column: span 4; }
        .invest-chart { grid-column: span 8; }
        .country-map { grid-column: span 12; }
        .top-customers, .visit-device, .purchase-property { grid-column: span 6; }
    }

    @@media (max-width: 900px) {
        .dashboard-grid > .panel { grid-column: span 12 !important; }
    }
</style>

