@model IReadOnlyList<RealEstate.Models.Property>
@{
    ViewData["Title"] = "My Properties";
    Layout = "~/Views/Shared/_InvestorLayout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h4 fw-bold">My Properties</h1>
        <a href="@Url.Action("Submit", "Investor")" class="btn btn-primary">+ Add New Property</a>
    </div>

    <div class="row g-4">
        @if (Model.Count == 0)
        {
            <div class="col-12">
                <div class="alert alert-info">
                    <strong>No properties yet.</strong> <a href="@Url.Action("Submit", "Investor")">Submit your first property</a>
                </div>
            </div>
        }
        else
        {
            @foreach (var p in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm overflow-hidden">
                        <!-- Image -->
                        <div style="position:relative;height:200px;overflow:hidden;">
                            <img src="@p.ImageUrls?.FirstOrDefault()" class="w-100 h-100" style="object-fit:cover;" alt="@p.Title" />
                            <div style="position:absolute;top:10px;right:10px;">
                                <span class="badge bg-success">Live</span>
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="card-body">
                            <h6 class="mb-1">@p.Title</h6>
                            <p class="small text-muted mb-2">@p.Location</p>
                            
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <div class="small text-muted">Price</div>
                                    <div class="fw-semibold">@String.Format("₱{0:N0}", p.Price)</div>
                                </div>
                                <div class="col-6">
                                    <div class="small text-muted">Type</div>
                                    <div class="fw-semibold">@p.ListingType</div>
                                </div>
                            </div>

                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <div class="small text-muted">Size</div>
                                    <div class="fw-semibold">@p.Sqft sqft</div>
                                </div>
                                <div class="col-6">
                                    <div class="small text-muted">Status</div>
                                    <div class="fw-semibold"><span class="badge bg-primary">Active</span></div>
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <button class="btn btn-sm btn-outline-primary">View Details</button>
                                <button class="btn btn-sm btn-outline-danger">Remove Listing</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
