@{
    ViewData["Title"] = "Help & Support";
    Layout = "~/Views/Shared/_InvestorLayout.cshtml";
}

<div class="container py-4">
    <h1 class="h4 fw-bold mb-4">❓ Help & Support</h1>

    <div class="row g-3">
        <!-- Contact Support -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-4 mb-3">
                <h6 class="mb-3">Contact Support Team</h6>
                <div class="mb-3">
                    <label class="form-label">Subject</label>
                    <input class="form-control" type="text" placeholder="e.g., Issue with property listing" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Message</label>
                    <textarea class="form-control" rows="5" placeholder="Describe your issue or question..."></textarea>
                </div>
                <button class="btn btn-primary">Send Message</button>
            </div>

            <!-- FAQ Section -->
            <div class="card border-0 shadow-sm p-4">
                <h6 class="mb-3">Frequently Asked Questions</h6>
                <div class="accordion" id="faqAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1" aria-expanded="true">
                                How do I submit a new property?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Navigate to <strong>Property Operations → Submit New Property</strong> and follow the 4-step wizard. You'll need property details, photos, geolocation, and legal documents.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                What documents are required?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                You'll need: Land title/ownership document, Tax Declaration (BIR Form 2000), and optionally a Survey Plan. All documents must be valid and not expired.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                How long does approval take?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Typically 1-3 business days. If issues are found, we'll notify you in the Revision Center with specific feedback.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                Can I upgrade my subscription plan?
                            </button>
                        </h2>
                        <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Yes! Go to <strong>Subscription & Billing</strong> and click "Upgrade to Premium" for more features like unlimited listings and priority support.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Support Contacts -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 mb-3">
                <h6 class="mb-3">Direct Support</h6>
                <div class="mb-3">
                    <div class="small text-muted">Agent Support</div>
                    <a href="mailto:support@estateflow.com" class="text-decoration-none">📧 support@estateflow.com</a>
                </div>
                <div class="mb-3">
                    <div class="small text-muted">Phone Support</div>
                    <a href="tel:+639175001234" class="text-decoration-none">📞 +63 917 500 1234</a>
                </div>
                <div class="mb-3">
                    <div class="small text-muted">WhatsApp</div>
                    <a href="https://wa.me/639175001234" target="_blank" class="text-decoration-none">💬 +63 917 500 1234</a>
                </div>
                <div>
                    <div class="small text-muted">Available Hours</div>
                    <div class="small">Monday - Friday: 9AM - 6PM</div>
                    <div class="small">Saturday: 10AM - 4PM</div>
                </div>
            </div>

            <div class="card border-0 shadow-sm p-4">
                <h6 class="mb-3">Resources</h6>
                <a href="#" class="d-block small text-decoration-none mb-2">📖 Property Upload Guide</a>
                <a href="#" class="d-block small text-decoration-none mb-2">📹 Video Tutorials</a>
                <a href="#" class="d-block small text-decoration-none mb-2">📋 Legal Document Checklist</a>
                <a href="#" class="d-block small text-decoration-none">💡 Best Practices for Photos</a>
            </div>
        </div>
    </div>
</div>
