@{
    ViewData["Title"] = "Submit Property";
    Layout = "~/Views/Shared/_InvestorLayout.cshtml";
    var step = ViewData["Step"] as int? ?? 1;
}

<div class="container py-4">
    <h1 class="h4 mb-4">Submit Your Property</h1>

    <!-- Stepper -->
    <div class="d-flex justify-content-center mb-5">
        <div class="d-flex gap-3 align-items-center">
            <div class="text-center">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold text-white" style="width:40px;height:40px;background:@(step >= 1 ? "#ff7a59" : "#e0e0e0")">1</div>
                <div class="small mt-2">Details</div>
            </div>
            <div style="width:60px;height:2px;background:@(step >= 2 ? "#ff7a59" : "#e0e0e0")"></div>
            <div class="text-center">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold text-white" style="width:40px;height:40px;background:@(step >= 2 ? "#ff7a59" : "#e0e0e0")">2</div>
                <div class="small mt-2">Photos</div>
            </div>
            <div style="width:60px;height:2px;background:@(step >= 3 ? "#ff7a59" : "#e0e0e0")"></div>
            <div class="text-center">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold text-white" style="width:40px;height:40px;background:@(step >= 3 ? "#ff7a59" : "#e0e0e0")">3</div>
                <div class="small mt-2">Location</div>
            </div>
            <div style="width:60px;height:2px;background:@(step >= 4 ? "#ff7a59" : "#e0e0e0")"></div>
            <div class="text-center">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold text-white" style="width:40px;height:40px;background:@(step >= 4 ? "#ff7a59" : "#e0e0e0")">4</div>
                <div class="small mt-2">Documents</div>
            </div>
        </div>
    </div>

    <!-- Form -->
    <div class="card p-4 border-0 shadow-sm" style="max-width:600px;margin:0 auto;">
        <form asp-action="Submit" method="post" enctype="multipart/form-data">
            <input type="hidden" name="step" value="@step" />

            @if (step == 1)
            {
                <h6 class="mb-3">Property Details</h6>
                <div class="mb-3">
                    <label class="form-label">Property title</label>
                    <input class="form-control" name="title" placeholder="e.g., Condo in BGC" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Location</label>
                    <input class="form-control" name="location" placeholder="e.g., Bonifacio Global City, Taguig" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" name="description" rows="4" placeholder="Describe your property..." required></textarea>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Price (PHP)</label>
                        <input class="form-control" name="price" type="number" placeholder="15000000" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Property Type</label>
                        <select class="form-control" name="type" required>
                            <option>House</option>
                            <option>Condo</option>
                            <option>Villa</option>
                            <option>Apartment</option>
                        </select>
                    </div>
                </div>
            }
            else if (step == 2)
            {
                <h6 class="mb-3">Upload Photos</h6>
                <div class="mb-3">
                    <label class="form-label">Property Photos</label>
                    <div class="border-2 border-dashed rounded p-4 text-center" style="border-color:#ddd">
                        <input class="form-control" type="file" name="photos" multiple accept="image/*" required />
                        <small class="text-muted mt-2 d-block">Upload at least 3 high-quality photos of your property</small>
                    </div>
                </div>
            }
            else if (step == 3)
            {
                <h6 class="mb-3">Pin Location on Map</h6>
                <div class="mb-3">
                    <label class="form-label">Property Location (Map)</label>
                    <div style="width:100%;height:300px;background:#f0f0f0;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#999;">
                        <span>Map widget would go here (Leaflet/Google Maps)</span>
                    </div>
                    <small class="text-muted mt-2 d-block">Click on the map to pin your property location</small>
                </div>
            }
            else if (step == 4)
            {
                <h6 class="mb-3">Attach Legal Documents</h6>
                <div class="mb-3">
                    <label class="form-label">Title Deed / Ownership Document</label>
                    <input class="form-control" type="file" name="deed" accept=".pdf,.doc,.docx" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Tax Declaration</label>
                    <input class="form-control" type="file" name="taxdec" accept=".pdf,.doc,.docx" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Survey Plan / Lot Plan</label>
                    <input class="form-control" type="file" name="survey" accept=".pdf,.doc,.docx" />
                </div>
            }

            <!-- Buttons -->
            <div class="d-flex gap-2 mt-4">
                @if (step > 1)
                {
                    <a class="btn btn-outline-secondary" asp-action="Submit" asp-route-step="@(step - 1)">← Back</a>
                }
                <button type="submit" class="btn btn-primary ms-auto">@(step < 4 ? "Next →" : "Submit Listing")</button>
            </div>
        </form>
    </div>
</div>
