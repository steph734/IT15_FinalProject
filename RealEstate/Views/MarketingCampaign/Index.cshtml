@model IEnumerable<RealEstate.Models.MarketingCampaign>

@{
    ViewData["Title"] = "Marketing Campaigns";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Marketing Campaigns</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Create Campaign
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Campaign</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Budget</th>
                            <th>Audience</th>
                            <th>Performance</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.Name</strong>
                                    <br>
                                    <small class="text-muted">@item.Description.Substring(0, Math.Min(50, item.Description.Length))...</small>
                                </td>
                                <td>@item.CampaignType</td>
                                <td>
                                    @switch (item.Status)
                                    {
                                        case "Active":
                                            <span class="badge bg-success">@item.Status</span>
                                            break;
                                        case "Completed":
                                            <span class="badge bg-primary">@item.Status</span>
                                            break;
                                        case "Draft":
                                            <span class="badge bg-secondary">@item.Status</span>
                                            break;
                                        case "Scheduled":
                                            <span class="badge bg-info">@item.Status</span>
                                            break;
                                        case "Paused":
                                            <span class="badge bg-warning text-dark">@item.Status</span>
                                            break;
                                        default:
                                            <span class="badge bg-light text-dark">@item.Status</span>
                                            break;
                                    }
                                </td>
                                <td>₱@item.Budget.ToString("N0")</td>
                                <td>@item.TargetAudienceCount</td>
                                <td>
                                    <small class="text-muted">
                                        Open: @item.OpenRate% | Click: @item.ClickRate% | Conv: @item.ConversionRate%
                                    </small>
                                </td>
                                <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.CampaignId" class="btn btn-sm btn-info">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.CampaignId" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    @if (item.Status == "Draft")
                                    {
                                        <form asp-action="Launch" asp-route-id="@item.CampaignId" method="post" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Launch this campaign?')">
                                                <i class="fas fa-rocket"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
