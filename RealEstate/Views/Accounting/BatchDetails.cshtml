@model List<RealEstate.Models.CommissionDeal>
@{
    ViewData["Title"] = "Batch Details";
    Layout = "~/Views/Shared/_AccountingLayout.cshtml";
    var batch = ViewData["Batch"] as RealEstate.Models.CommissionBatch;
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h2 class="h4 fw-bold mb-1">Batch: @batch?.BatchId</h2>
            <div class="text-muted small">Update payout statuses and complete the batch when done.</div>
        </div>
        @if (batch != null)
        {
            <form method="post" action="/accounting/payout-batches/@batch.BatchId/complete">
                <button class="btn btn-success" type="submit">
                    <i class="fas fa-check me-2"></i>Mark Completed
                </button>
            </form>
        }
    </div>

    @if (batch != null)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div class="small text-muted">Batch status</div>
                <form method="post" action="/accounting/payout-batches/@batch.BatchId/set-status" class="d-flex gap-2">
                    <select class="form-select form-select-sm" name="status" style="width: 200px;">
                        <option value="AwaitingReview" selected="@(batch.Status==RealEstate.Models.CommissionBatchStatus.AwaitingReview)">Awaiting Review</option>
                        <option value="Processing" selected="@(batch.Status==RealEstate.Models.CommissionBatchStatus.Processing)">Processing</option>
                        <option value="Released" selected="@(batch.Status==RealEstate.Models.CommissionBatchStatus.Released)">Released</option>
                    </select>
                    <button class="btn btn-sm btn-primary" type="submit">Update</button>
                </form>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Deal</th>
                            <th>Agent payout</th>
                            <th>Accounting status</th>
                            <th>Transferred</th>
                            <th style="width: 360px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.Count > 0)
                        {
                            foreach (var d in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@d.PropertyLabel</td>
                                    <td class="fw-semibold text-success">@d.AgentPayoutAmount.ToString("N2")</td>
                                    <td>
                                        <form method="post" action="/accounting/payout-deals/@d.Id/set-status" class="d-flex gap-2 align-items-center">
                                            <select class="form-select form-select-sm" name="status" style="width: 160px;">
                                                <option value="AwaitingReview" selected="@(d.AccountingPayoutStatus==RealEstate.Models.AccountingPayoutStatus.AwaitingReview)">Awaiting Review</option>
                                                <option value="Processing" selected="@(d.AccountingPayoutStatus==RealEstate.Models.AccountingPayoutStatus.Processing)">Processing</option>
                                                <option value="Released" selected="@(d.AccountingPayoutStatus==RealEstate.Models.AccountingPayoutStatus.Released)">Released</option>
                                            </select>
                                            <button class="btn btn-sm btn-outline-primary" type="submit">Set</button>
                                        </form>
                                    </td>
                                    <td class="small text-muted">@d.TransferredToAccountingAtUtc?.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        <form method="post" action="/accounting/payout-deals/@d.Id/reject" class="d-flex gap-2">
                                            <input class="form-control form-control-sm" name="reason" placeholder="Reject reason (optional)" />
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Reject</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-muted small">No deals in this batch.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

