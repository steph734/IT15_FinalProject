@model List<RealEstate.Models.PaymentTransaction>
@{
    Layout = null;
    string searchFilter = ViewBag.SearchFilter as string ?? "";
    int totalIssued = ViewBag.TotalIssued ?? 0;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
    <title>Receipts | EstateFlow Accounting</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        body{font-family:'Segoe UI',sans-serif;background:#f1f5f9;display:flex;min-height:100vh}
        .page-wrapper{margin-left:250px;flex:1;display:flex;flex-direction:column;padding:28px}
        h1{font-size:22px;font-weight:800;color:#1e293b;margin-bottom:4px}
        .sub{color:#64748b;font-size:14px;margin-bottom:24px}

        /* Receipt Hero */
        .receipt-hero{background:linear-gradient(135deg,#10b981,#059669);border-radius:14px;padding:28px 32px;color:#fff;margin-bottom:24px;display:flex;justify-content:space-between;align-items:center}
        .receipt-hero .rh-label{font-size:13px;font-weight:600;opacity:.85;letter-spacing:.4px;text-transform:uppercase}
        .receipt-hero .rh-value{font-size:36px;font-weight:800;margin-top:4px}
        .receipt-hero .rh-sub{font-size:13px;opacity:.8;margin-top:8px}

        /* Filters */
        .filters{background:#fff;border-radius:12px;padding:16px 20px;box-shadow:0 1px 3px rgba(0,0,0,.06);margin-bottom:20px}
        .filters form{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
        .search-input{padding:9px 14px;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;flex:1;min-width:200px}
        .search-input:focus{outline:none;border-color:#10b981}
        .btn-search{background:#10b981;color:#fff;border:none;border-radius:8px;padding:9px 18px;font-size:13px;font-weight:600;cursor:pointer}

        /* Table */
        .table-card{background:#fff;border-radius:14px;box-shadow:0 1px 3px rgba(0,0,0,.06);overflow:hidden}
        .table-header{padding:18px 22px;border-bottom:1px solid #f1f5f9;display:flex;justify-content:space-between;align-items:center}
        .table-header .th-title{font-size:15px;font-weight:700;color:#1e293b}
        table{width:100%;border-collapse:collapse}
        th{padding:12px 16px;text-align:left;font-size:12px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.4px;background:#f8fafc;border-bottom:1px solid #e2e8f0}
        td{padding:14px 16px;font-size:13px;color:#374151;border-bottom:1px solid #f8fafc}
        tr:last-child td{border-bottom:none}
        tr:hover td{background:#fafafa}

        /* Badge */
        .badge-success{background:#dcfce7;color:#166534;display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:50px;font-size:11px;font-weight:700}

        /* Action */
        .btn-print{background:#f1f5f9;color:#374151;border:none;border-radius:6px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer;text-decoration:none}
        .btn-print:hover{background:#10b981;color:#fff}

        .empty{text-align:center;padding:48px;color:#94a3b8}
        .empty i{font-size:40px;margin-bottom:12px;display:block}

        /* Receipt modal overlay */
        .receipt-icon{color:#10b981;margin-right:6px}
    </style>
</head>
<body>
    @await Html.PartialAsync("_AccountingNav")

    <div class="page-wrapper">
        <h1><i class="fas fa-file-invoice" style="color:#10b981;margin-right:8px"></i>Receipts</h1>
        <p class="sub">Issue and manage payment receipts for validated transactions.</p>

        <!-- Receipt Hero -->
        <div class="receipt-hero">
            <div>
                <div class="rh-label">Total Receipts Issued</div>
                <div class="rh-value">@totalIssued</div>
                <div class="rh-sub"><i class="fas fa-receipt"></i> All validated payments have receipts</div>
            </div>
            <i class="fas fa-file-invoice-dollar" style="font-size:48px;opacity:.3"></i>
        </div>

        <!-- Filters -->
        <div class="filters">
            <form method="get">
                <input type="text" name="search" class="search-input" placeholder="Search by description or payment ID..." value="@searchFilter" />
                <button type="submit" class="btn-search"><i class="fas fa-search"></i> Search</button>
                @if (!string.IsNullOrEmpty(searchFilter))
                {
                    <a href="/accounting/receipts" style="background:#f1f5f9;color:#374151;border:none;border-radius:8px;padding:9px 14px;font-size:13px;text-decoration:none">Clear</a>
                }
            </form>
        </div>

        <!-- Table -->
        <div class="table-card">
            <div class="table-header">
                <span class="th-title">All Receipts (@Model.Count)</span>
            </div>
            @if (Model.Count == 0)
            {
                <div class="empty">
                    <i class="fas fa-file-invoice"></i>
                    No receipts found.
                </div>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Receipt #</th>
                            <th>Description</th>
                            <th>Payment Intent ID</th>
                            <th>Method</th>
                            <th>Amount</th>
                            <th>Payment Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model)
                        {
                            <tr>
                                <td>REC-@(t.Id.ToString("D5"))</td>
                                <td>@(t.Description ?? "—")</td>
                                <td><code style="font-size:11px;color:#64748b;background:#f1f5f9;padding:2px 8px;border-radius:4px">@(t.PayMongoPaymentIntentId ?? "—")</code></td>
                                <td>@(t.PaymentMethod ?? "—")</td>
                                <td><strong>₱@t.Amount.ToString("N2")</strong></td>
                                <td>@t.CreatedDate.ToString("MMM dd, yyyy")</td>
                                <td><span class="badge-success"><i class="fas fa-check-circle"></i> Issued</span></td>
                                <td>
                                    <a href="/accounting/receipts/@t.Id/print" class="btn-print" target="_blank">
                                        <i class="fas fa-print"></i> Print
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</body>
</html>
