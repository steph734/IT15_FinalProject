@model AdminTransactionDetailsViewModel
@using RealEstate.Helpers
@using RealEstate.Models
@using RealEstate.Models.Admin
@{
    ViewData["Title"] = "Transaction " + Model.Deal.TransactionId;
    var d = Model.Deal;
    var p = Model.Listing;
}

<div class="admin-dashboard bg-light min-vh-100 pb-5">
    <div class="container py-4" style="max-width: 900px;">
        <div class="mb-4">
            <a class="small text-decoration-none" asp-controller="AdminTransactions" asp-action="Index">← Back to transactions</a>
            <h1 class="h4 fw-bold text-site-dark mt-2 mb-1">Transaction details</h1>
            <p class="font-monospace small text-site-muted mb-0">@d.TransactionId</p>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h2 class="h6 fw-bold text-site-dark mb-3">Property</h2>
                        @if (p is not null)
                        {
                            <p class="mb-1 fw-semibold">@p.Title</p>
                            <p class="small text-site-muted mb-2">@p.Location</p>
                            <p class="small mb-0">@(p.ListingType == PropertyListingType.Buy ? "For sale" : "For rent") · @p.Sqft sqm · list ₱@p.Price.ToString("N0", Currency.PhilippinePeso)@(p.ListingType == PropertyListingType.Rent ? "/mo" : "")</p>
                        }
                        else
                        {
                            <p class="small text-site-muted mb-0">Property #@d.PropertyId (not found in catalog)</p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h2 class="h6 fw-bold text-site-dark mb-3">Client</h2>
                        <p class="mb-1 fw-semibold">@d.ClientName</p>
                        @if (!string.IsNullOrWhiteSpace(d.ClientEmail))
                        {
                            <p class="small mb-1"><a href="mailto:@d.ClientEmail">@d.ClientEmail</a></p>
                        }
                        @if (!string.IsNullOrWhiteSpace(d.ClientPhone))
                        {
                            <p class="small mb-0">@d.ClientPhone</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <h2 class="h6 fw-bold text-site-dark mb-3">Deal</h2>
                <dl class="row small mb-0">
                    <dt class="col-sm-4 text-site-muted">Type</dt>
                    <dd class="col-sm-8">@(d.DealType == BrokerDealType.Sale ? "Sale" : "Rent")</dd>
                    <dt class="col-sm-4 text-site-muted">Total amount</dt>
                    <dd class="col-sm-8 fw-semibold">₱@d.Amount.ToString("N0", Currency.PhilippinePeso)</dd>
                    <dt class="col-sm-4 text-site-muted">Payment status</dt>
                    <dd class="col-sm-8">@(d.PaymentStatus == BrokerPaymentStatus.Paid ? "Paid" : "Pending")</dd>
                    <dt class="col-sm-4 text-site-muted">Deal status</dt>
                    <dd class="col-sm-8">@(d.Status == BrokerDealStatus.Completed ? "Completed" : "Pending")</dd>
                    <dt class="col-sm-4 text-site-muted">Pipeline</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary">@d.PipelineStage</span>
                    </dd>
                </dl>
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <h2 class="h6 fw-bold text-site-dark mb-3">Commission breakdown</h2>
                <p class="small text-site-muted mb-3">@d.CommissionNotes</p>
                <dl class="row small mb-0">
                    <dt class="col-sm-4 text-site-muted">Rate</dt>
                    <dd class="col-sm-8">
                        @if (d.DealType == BrokerDealType.Sale)
                        {
                            <text>@( (d.CommissionRate * 100).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))% of transaction amount</text>
                        }
                        else
                        {
                            <text>@((d.CommissionRate * 100).ToString("0", System.Globalization.CultureInfo.InvariantCulture))% of first month rent (demo rule)</text>
                        }
                    </dd>
                    <dt class="col-sm-4 text-site-muted">Commission</dt>
                    <dd class="col-sm-8 fw-semibold text-site-dark">₱@d.CommissionAmount.ToString("N0", Currency.PhilippinePeso)</dd>
                    <dt class="col-sm-4 text-site-muted">Paid to broker</dt>
                    <dd class="col-sm-8">@(d.CommissionPaid == BrokerCommissionPaidStatus.Paid ? "Paid" : "Unpaid")</dd>
                </dl>
            </div>
        </div>

        <div class="alert alert-light border shadow-sm mt-4 mb-0 small text-site-muted">
            <strong class="text-site-dark">Flow.</strong> Inquiry → Viewing → Negotiation → closed deal → transaction record → commission calculated → visible here and on the Commission page.
        </div>
    </div>
</div>
