@model AdminTransactionsIndexViewModel
@using RealEstate.Models.Admin
@{
    ViewData["Title"] = "Transactions";
}

<div class="admin-dashboard bg-light min-vh-100 pb-5">
    <div class="container-fluid px-4 py-4" style="max-width: 1400px;">
        <h1 class="h4 fw-bold text-site-dark mb-3">Transactions</h1>
        <p class="text-site-muted small mb-4">All demo deal records. Use <strong>View details</strong> for property, client, and commission breakdown.</p>

        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 small">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Transaction ID</th>
                            <th scope="col">Property</th>
                            <th scope="col">Client</th>
                            <th scope="col">Type</th>
                            <th scope="col" class="text-end">Amount</th>
                            <th scope="col">Status</th>
                            <th scope="col">Date</th>
                            <th scope="col"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Rows)
                        {
                            var statusClass = r.Status == BrokerDealStatus.Completed ? "text-success" : "text-warning";
                            <tr>
                                <td class="font-monospace text-break">@r.TransactionId</td>
                                <td>@r.PropertyTitle</td>
                                <td>@r.ClientName</td>
                                <td>@r.TypeDisplay</td>
                                <td class="text-end">₱@r.AmountFormatted</td>
                                <td><span class="@statusClass fw-semibold">@r.StatusDisplay</span></td>
                                <td>@r.DateDisplay</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" asp-controller="AdminTransactions" asp-action="Details" asp-route-id="@r.TransactionId">View details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
