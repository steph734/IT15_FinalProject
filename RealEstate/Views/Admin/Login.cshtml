@{
    ViewData["Title"] = "Login - EstateFlow";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            width: 100%;
            height: 100vh;
            font-family: 'Inter', sans-serif;
        }

        body {
            overflow: hidden;
        }

        .auth-container {
            display: flex;
            flex-direction: column;
            width: 100%;
            height: 100vh;
        }

        /* Navbar */
        .auth-navbar {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 20px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
            box-shadow: 0 4px 20px rgba(102, 126, 234, 0.15);
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 20px;
            font-weight: 700;
            font-family: 'Plus Jakarta Sans', sans-serif;
            animation: slideInLeft 0.6s ease-out;
        }

        .navbar-brand img {
            height: 40px;
            width: 40px;
            background: rgba(255, 255, 255, 0.2);
            padding: 6px;
            border-radius: 8px;
        }

        .navbar-tagline {
            font-size: 14px;
            font-weight: 500;
            opacity: 0.9;
            animation: slideInRight 0.6s ease-out;
        }

        @@keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(40px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        /* Main Content Area */
        .auth-content {
            display: flex;
            flex: 1;
            width: 100%;
        }

        .auth-left {
            flex: 1;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px 50px;
            color: white;
            overflow: hidden;
        }

        .auth-left::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1200&q=80');
            background-size: cover;
            background-position: center;
            opacity: 0.15;
            z-index: 1;
            animation: zoomIn 8s ease-out forwards;
        }

        .auth-left-content {
            position: relative;
            z-index: 2;
            animation: fadeInUp 0.8s ease-out 0.2s both;
        }

        .auth-left h2 {
            font-size: 42px;
            font-weight: 700;
            margin-bottom: 20px;
            line-height: 1.2;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .auth-left p {
            font-size: 16px;
            line-height: 1.6;
            opacity: 0.95;
            max-width: 400px;
        }

        .auth-left-footer {
            display: none;
        }

        .auth-right {
            flex: 1;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
            animation: fadeInRight 0.8s ease-out;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes zoomIn {
            from {
                transform: scale(1.05);
                opacity: 0;
            }
            to {
                transform: scale(1);
                opacity: 0.15;
            }
        }

        @@keyframes fadeInRight {
            from {
                opacity: 0;
                transform: translateX(40px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .auth-form-wrapper {
            width: 100%;
            max-width: 420px;
            animation: fadeInUp 0.8s ease-out 0.2s both;
        }

        .auth-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .auth-header h1 {
            font-size: 28px;
            font-weight: 700;
            color: #1f2937;
            margin: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .sign-in-btn {
            background: #000;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .sign-in-btn:hover {
            background: #333;
        }

        .auth-subtitle {
            color: #6b7280;
            font-size: 14px;
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 18px;
            animation: fadeIn 0.6s ease-out forwards;
        }

        .form-group:nth-child(1) { animation-delay: 0.25s; }
        .form-group:nth-child(2) { animation-delay: 0.35s; }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        .form-label {
            display: block;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 6px;
            font-size: 13px;
        }

        .form-control {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            font-size: 14px;
            transition: all 0.3s ease;
            background-color: white;
            font-family: 'Inter', sans-serif;
        }

        .form-control:focus {
            outline: none;
            border-color: #1f2937;
            box-shadow: 0 0 0 3px rgba(31, 41, 55, 0.05);
        }

        .form-control::placeholder {
            color: #9ca3af;
        }

        .form-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 16px 0;
            font-size: 13px;
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .remember-me input[type="checkbox"] {
            width: 16px;
            height: 16px;
            cursor: pointer;
            accent-color: #1f2937;
        }

        .remember-me label {
            cursor: pointer;
            color: #1f2937;
            margin: 0;
            font-weight: 500;
        }

        .forgot-password {
            text-align: right;
        }

        .forgot-password a {
            color: #1f2937;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .forgot-password a:hover {
            color: #000;
        }

        .btn-login {
            width: 100%;
            padding: 11px 24px;
            background: #1f2937;
            border: none;
            border-radius: 6px;
            color: white;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin: 24px 0;
            animation: slideInUp 0.6s ease-out 0.3s both;
        }

        @@keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .btn-login:hover {
            background: #000;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .instant-login {
            text-align: center;
            color: #9ca3af;
            font-size: 13px;
            margin: 20px 0;
        }

        .social-login {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 20px;
        }

        .social-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px;
            border: 1px solid #e5e7eb;
            background: white;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 500;
            color: #1f2937;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .social-btn:hover {
            border-color: #d1d5db;
            background: #f9fafb;
        }

        .social-btn i {
            font-size: 16px;
        }

        .social-btn.google {
            color: #3b82f6;
        }

        .social-btn.facebook {
            color: #1877f2;
        }

        .alert {
            border-radius: 6px;
            border: 1px solid #fecaca;
            background-color: #fef2f2;
            color: #991b1b;
            padding: 12px 14px;
            margin-bottom: 20px;
            font-size: 13px;
        }

        .alert strong {
            font-weight: 600;
        }

        .alert-success {
            border-color: #bbf7d0;
            background-color: #f0fdf4;
            color: #166534;
        }

        .auth-footer {
            text-align: center;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #e5e7eb;
            color: #6b7280;
            font-size: 13px;
        }

        .auth-footer a {
            color: #1f2937;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .auth-footer a:hover {
            color: #000;
        }

        /* Tablets - 1024px */
        @@media (max-width: 1024px) {
            .auth-navbar {
                padding: 16px 30px;
            }

            .navbar-brand {
                font-size: 18px;
                gap: 10px;
            }

            .navbar-brand img {
                height: 32px;
                width: 32px;
            }

            .navbar-tagline {
                font-size: 13px;
            }

            .auth-left {
                padding: 40px 30px;
            }

            .auth-left h2 {
                font-size: 36px;
                margin-bottom: 15px;
            }

            .auth-left p {
                font-size: 14px;
            }
        }

        /* Small Tablets - 768px */
        @@media (max-width: 768px) {
            .auth-container {
                flex-direction: column;
                height: auto;
                min-height: 100vh;
            }

            .auth-content {
                flex-direction: column;
            }

            .auth-navbar {
                padding: 14px 20px;
                justify-content: center;
                text-align: center;
            }

            .navbar-brand {
                margin-bottom: 8px;
            }

            .navbar-tagline {
                display: block;
                font-size: 12px;
                margin-top: 8px;
            }

            .auth-left {
                flex: none;
                width: 100%;
                height: auto;
                padding: 30px 20px;
                min-height: 200px;
                justify-content: center;
                text-align: center;
            }

            .auth-left h2 {
                font-size: 24px;
                margin-bottom: 12px;
            }

            .auth-left p {
                font-size: 13px;
                margin-bottom: 0;
            }

            .auth-right {
                flex: none;
                width: 100%;
                padding: 30px 20px;
                min-height: auto;
            }

            .auth-form-wrapper {
                max-width: 100%;
            }

            .auth-header {
                margin-bottom: 25px;
            }

            .auth-header h1 {
                font-size: 24px;
            }

            .sign-in-btn {
                display: none;
            }

            .auth-subtitle {
                margin-bottom: 20px;
            }

            .form-group {
                margin-bottom: 14px;
            }

            .form-control {
                padding: 10px 12px;
                font-size: 16px;
            }

            .btn-login {
                padding: 10px 20px;
                font-size: 13px;
                margin: 20px 0;
            }

            .social-login {
                margin-bottom: 15px;
            }

            .social-btn {
                padding: 9px;
                font-size: 12px;
            }

            .form-row {
                flex-direction: column;
                gap: 12px;
                margin: 14px 0;
            }

            .remember-me,
            .forgot-password {
                text-align: left;
            }

            .auth-footer {
                margin-top: 15px;
                padding-top: 15px;
                font-size: 12px;
            }
        }

        /* Mobile - 480px */
        @@media (max-width: 480px) {
            body {
                overflow: auto;
            }

            .auth-navbar {
                padding: 12px 16px;
            }

            .navbar-brand {
                font-size: 16px;
                gap: 8px;
            }

            .navbar-brand img {
                height: 28px;
                width: 28px;
            }

            .navbar-tagline {
                font-size: 11px;
            }

            .auth-left {
                padding: 20px 16px;
                min-height: 150px;
            }

            .auth-left h2 {
                font-size: 20px;
                margin-bottom: 8px;
            }

            .auth-left p {
                font-size: 12px;
            }

            .auth-right {
                padding: 20px 16px;
                justify-content: flex-start;
                padding-top: 20px;
            }

            .auth-form-wrapper {
                max-width: 100%;
                width: 100%;
            }

            .auth-header {
                margin-bottom: 20px;
            }

            .auth-header h1 {
                font-size: 20px;
            }

            .auth-subtitle {
                font-size: 13px;
                margin-bottom: 15px;
            }

            .form-label {
                font-size: 12px;
                margin-bottom: 5px;
            }

            .form-control {
                padding: 10px 11px;
                font-size: 16px;
                border-radius: 5px;
            }

            .form-group {
                margin-bottom: 12px;
            }

            .form-row {
                gap: 8px;
                margin: 12px 0;
            }

            .remember-me label {
                font-size: 12px;
            }

            .forgot-password a {
                font-size: 12px;
            }

            .instant-login {
                font-size: 12px;
                margin: 15px 0;
            }

            .btn-login {
                padding: 10px 16px;
                font-size: 13px;
                margin: 18px 0;
                border-radius: 5px;
            }

            .social-login {
                grid-template-columns: 1fr 1fr;
                gap: 10px;
                margin-bottom: 12px;
            }

            .social-btn {
                padding: 8px;
                font-size: 11px;
                gap: 4px;
                flex-direction: column;
            }

            .social-btn span {
                display: none;
            }

            .social-btn i {
                font-size: 14px;
            }

            .auth-footer {
                margin-top: 12px;
                padding-top: 12px;
                font-size: 11px;
            }
        }

        /* Extra Small - 360px */
        @@media (max-width: 360px) {
            .auth-left h2 {
                font-size: 18px;
            }

            .auth-header h1 {
                font-size: 18px;
            }

            .navbar-brand {
                font-size: 14px;
            }

            .form-control {
                padding: 9px 10px;
            }

            .btn-login {
                padding: 9px 14px;
            }
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <!-- Navbar -->
        <nav class="auth-navbar">
            <div class="navbar-brand">
                <img src="~/images/estateflow-logo.png" alt="EstateFlow" />
                <span>EstateFlow</span>
            </div>
            <div class="navbar-tagline">
                🏠 Find Your Dream Home - Professional Real Estate Solutions
            </div>
        </nav>

        <!-- Content Area -->
        <div class="auth-content">
            <!-- Left Side - Hero Section -->
            <div class="auth-left">
                <div class="auth-left-content">
                    <h2>Find Your Perfect Home</h2>
                    <p>Discover properties across the Philippines with trusted agents who know every barangay. Fast, easy, reliable.</p>
                </div>
            </div>

            <!-- Right Side - Login Form -->
            <div class="auth-right">
                <div class="auth-form-wrapper">
                    <div class="auth-header">
                        <h1>Sign in</h1>
                    </div>

                    <p class="auth-subtitle">Sign in to your account</p>

                    @if (ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
                    {
                        <div class="alert">
                            <strong>Login Failed:</strong>
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                @foreach (var error in modelState.Errors)
                                {
                                    <div>@error.ErrorMessage</div>
                                }
                            }
                        </div>
                    }

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">
                            <strong>Success!</strong>
                            <div>@TempData["SuccessMessage"]</div>
                        </div>
                    }

                    <form method="post" asp-action="Login">
                        <div class="form-group">
                            <label for="email" class="form-label">Your Email</label>
                            <input type="email" 
                                   class="form-control" 
                                   id="email" 
                                   name="email" 
                                   placeholder="you@example.com" 
                                   required 
                                   autofocus />
                        </div>

                        <div class="form-group">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" 
                                   class="form-control" 
                                   id="password" 
                                   name="password" 
                                   placeholder="••••••••••"
                                   required />
                        </div>

                        <div class="form-row">
                            <div class="remember-me">
                                <input type="checkbox" id="remember" name="remember" />
                                <label for="remember">Remember Me</label>
                            </div>
                            <div class="forgot-password">
                                <a href="#">Forgot Password?</a>
                            </div>
                        </div>

                        <button type="submit" class="btn-login">Login</button>

                        <div class="instant-login">Or continue with</div>

                        <div class="social-login">
                            <a href="#" class="social-btn google">
                                <i class="fab fa-google"></i>
                                <span>Google</span>
                            </a>
                            <a href="#" class="social-btn facebook">
                                <i class="fab fa-facebook-f"></i>
                                <span>Facebook</span>
                            </a>
                        </div>

                        <div class="auth-footer">
                            Don't have an account? <a href="/admin/register">Register here</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
