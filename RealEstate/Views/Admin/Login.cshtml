@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Login - EstateFlow";
    Layout = null;
    var siteKey = Configuration["RecaptchaSettings:SiteKey"];
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            width: 100%;
            height: 100vh;
            font-family: 'Inter', sans-serif;
        }

        body {
            overflow: hidden;
        }

        .auth-container {
            display: flex;
            flex-direction: column;
            width: 100%;
            height: 100vh;
        }

        /* Navbar */
        .auth-navbar {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 20px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
            box-shadow: 0 4px 20px rgba(102, 126, 234, 0.15);
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 20px;
            font-weight: 700;
            font-family: 'Plus Jakarta Sans', sans-serif;
            animation: slideInLeft 0.6s ease-out;
        }

        .navbar-brand img {
            height: 40px;
            width: 40px;
            background: rgba(255, 255, 255, 0.2);
            padding: 6px;
            border-radius: 8px;
        }

        .navbar-tagline {
            font-size: 14px;
            font-weight: 500;
            opacity: 0.9;
            animation: slideInRight 0.6s ease-out;
        }

        @@keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(40px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        /* Main Content Area */
        .auth-content {
            display: flex;
            flex: 1;
            width: 100%;
        }

        .auth-left {
            flex: 1;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px 50px;
            color: white;
            overflow: hidden;
        }

        .auth-left::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1200&q=80');
            background-size: cover;
            background-position: center;
            opacity: 0.15;
            z-index: 1;
            animation: zoomIn 8s ease-out forwards;
        }

        .auth-left-content {
            position: relative;
            z-index: 2;
            animation: fadeInUp 0.8s ease-out 0.2s both;
        }

        .auth-left h2 {
            font-size: 42px;
            font-weight: 700;
            margin-bottom: 20px;
            line-height: 1.2;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .auth-left p {
            font-size: 16px;
            line-height: 1.6;
            opacity: 0.95;
            max-width: 400px;
        }

        .auth-left-footer {
            display: none;
        }

        .auth-right {
            flex: 1;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
            animation: fadeInRight 0.8s ease-out;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes zoomIn {
            from {
                transform: scale(1.05);
                opacity: 0;
            }
            to {
                transform: scale(1);
                opacity: 0.15;
            }
        }

        @@keyframes fadeInRight {
            from {
                opacity: 0;
                transform: translateX(40px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .auth-form-wrapper {
            width: 100%;
            max-width: 420px;
            animation: fadeInUp 0.8s ease-out 0.2s both;
        }

        .auth-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .auth-header h1 {
            font-size: 28px;
            font-weight: 700;
            color: #1f2937;
            margin: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .nav-buttons {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .register-btn {
            color: white;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .register-btn:hover {
            opacity: 0.8;
            text-decoration: underline;
        }

        .sign-in-btn {
            background: #000;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .sign-in-btn:hover {
            background: #333;
        }

        .auth-subtitle {
            color: #6b7280;
            font-size: 14px;
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 18px;
            animation: fadeIn 0.6s ease-out forwards;
        }

        .form-group:nth-child(1) { animation-delay: 0.25s; }
        .form-group:nth-child(2) { animation-delay: 0.35s; }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        .form-label {
            display: block;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 6px;
            font-size: 13px;
        }

        .form-control {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            font-size: 14px;
            transition: all 0.3s ease;
            background-color: white;
            font-family: 'Inter', sans-serif;
        }

        .form-control:focus {
            outline: none;
            border-color: #1f2937;
            box-shadow: 0 0 0 3px rgba(31, 41, 55, 0.05);
        }

        .form-control::placeholder {
            color: #9ca3af;
        }

        .form-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 16px 0;
            font-size: 13px;
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .remember-me input[type="checkbox"] {
            width: 16px;
            height: 16px;
            cursor: pointer;
            accent-color: #1f2937;
        }

        .remember-me label {
            cursor: pointer;
            color: #1f2937;
            margin: 0;
            font-weight: 500;
        }

        .forgot-password {
            text-align: right;
        }

        .forgot-password a {
            color: #1f2937;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .forgot-password a:hover {
            color: #000;
        }

        .btn-login {
            width: 100%;
            padding: 11px 24px;
            background: #1f2937;
            border: none;
            border-radius: 6px;
            color: white;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin: 24px 0;
            animation: slideInUp 0.6s ease-out 0.3s both;
        }

        @@keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .btn-login:hover {
            background: #000;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .instant-login {
            text-align: center;
            color: #9ca3af;
            font-size: 13px;
            margin: 20px 0;
        }

        .social-login {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 20px;
        }

        .social-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px;
            border: 1px solid #e5e7eb;
            background: white;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 500;
            color: #1f2937;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .social-btn:hover {
            border-color: #d1d5db;
            background: #f9fafb;
        }

        .social-btn i {
            font-size: 16px;
        }

        .social-btn.google {
            color: #3b82f6;
        }

        .social-btn.facebook {
            color: #1877f2;
        }

        .alert {
            border-radius: 6px;
            border: 1px solid #fecaca;
            background-color: #fef2f2;
            color: #991b1b;
            padding: 12px 14px;
            margin-bottom: 20px;
            font-size: 13px;
        }

        .alert strong {
            font-weight: 600;
        }

        .alert-success {
            border-color: #bbf7d0;
            background-color: #f0fdf4;
            color: #166534;
        }

        .auth-footer {
            text-align: center;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #e5e7eb;
            color: #6b7280;
            font-size: 13px;
        }

        .auth-footer a {
            color: #1f2937;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .auth-footer a:hover {
            color: #000;
        }

        /* OTP Modal Styles */
        .otp-modal-content {
            border: none;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
            animation: slideDown 0.3s ease-out;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .otp-modal-body {
            padding: 50px 40px;
            text-align: center;
        }

        .otp-modal-title {
            font-size: 36px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 12px;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .otp-modal-subtitle {
            text-align: center;
            color: #6b7280;
            font-size: 16px;
            margin-bottom: 35px;
            line-height: 1.5;
        }

        .otp-inputs-container {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin: 30px 0 35px 0;
        }

        .otp-input {
            width: 55px;
            height: 55px;
            font-size: 24px;
            text-align: center;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-weight: 600;
            color: #1f2937;
            background-color: white;
        }

        .otp-input:focus {
            outline: none;
            border-color: #0066cc;
            box-shadow: 0 0 0 3px rgba(0, 102, 204, 0.1);
        }

        .otp-input::placeholder {
            color: #d1d5db;
        }

        .btn-otp-verify {
            width: 100%;
            padding: 12px 24px;
            background: #0066cc;
            border: none;
            border-radius: 8px;
            color: white;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin: 0 0 20px 0;
        }

        .btn-otp-verify:hover {
            background: #0052a3;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 102, 204, 0.3);
        }

        .btn-otp-verify:active {
            transform: translateY(0);
        }

        .otp-resend-container {
            text-align: center;
            margin-top: 15px;
            font-size: 14px;
        }

        .otp-resend-text {
            color: #6b7280;
            display: inline;
        }

        .otp-resend-btn {
            background: none;
            border: none;
            color: #0066cc;
            text-decoration: underline;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            padding: 0;
            font-size: 14px;
        }

        .otp-resend-btn:hover:not(:disabled) {
            color: #0052a3;
        }

        .otp-resend-btn:disabled {
            color: #d1d5db;
            cursor: not-allowed;
            text-decoration: none;
        }

        .btn-close-modal {
            width: 28px;
            height: 28px;
            opacity: 0.7;
            transition: all 0.3s ease;
        }

        .btn-close-modal:hover {
            opacity: 1;
            transform: scale(1.1);
        }

        .alert-danger {
            border-color: #fecaca;
            background-color: #fef2f2;
            color: #991b1b;
            border-radius: 8px;
            padding: 12px 14px;
            margin-bottom: 20px;
            font-size: 13px;
        }

        .alert-danger strong {
            font-weight: 600;
        }

        /* Tablets - 1024px */
        @@media (max-width: 1024px) {
            .auth-navbar {
                padding: 16px 30px;
            }

            .navbar-brand {
                font-size: 18px;
                gap: 10px;
            }

            .navbar-brand img {
                height: 32px;
                width: 32px;
            }

            .navbar-tagline {
                font-size: 13px;
            }

            .auth-left {
                padding: 40px 30px;
            }

            .auth-left h2 {
                font-size: 36px;
                margin-bottom: 15px;
            }

            .auth-left p {
                font-size: 14px;
            }
        }

        /* Small Tablets - 768px */
        @@media (max-width: 768px) {
            .auth-container {
                flex-direction: column;
                height: auto;
                min-height: 100vh;
            }

            .auth-content {
                flex-direction: column;
            }

            .auth-navbar {
                padding: 14px 20px;
                justify-content: space-between;
                text-align: center;
                flex-wrap: wrap;
            }

            .navbar-brand {
                margin-bottom: 8px;
                flex: 1;
            }

            .navbar-tagline {
                display: block;
                font-size: 12px;
                margin-top: 8px;
                flex: 1;
                order: 3;
                width: 100%;
            }

            .nav-buttons {
                gap: 8px;
            }

            .register-btn,
            .sign-in-btn {
                padding: 6px 14px;
                font-size: 12px;
            }

            .auth-left {
                flex: none;
                width: 100%;
                height: auto;
                padding: 30px 20px;
                min-height: 200px;
                justify-content: center;
                text-align: center;
            }

            .auth-left h2 {
                font-size: 24px;
                margin-bottom: 12px;
            }

            .auth-left p {
                font-size: 13px;
                margin-bottom: 0;
            }

            .auth-right {
                flex: none;
                width: 100%;
                padding: 30px 20px;
                min-height: auto;
            }

            .auth-form-wrapper {
                max-width: 100%;
            }

            .auth-header {
                margin-bottom: 25px;
            }

            .auth-header h1 {
                font-size: 24px;
            }

            .sign-in-btn {
                display: none;
            }

            .auth-subtitle {
                margin-bottom: 20px;
            }

            .form-group {
                margin-bottom: 14px;
            }

            .form-control {
                padding: 10px 12px;
                font-size: 16px;
            }

            .btn-login {
                padding: 10px 20px;
                font-size: 13px;
                margin: 20px 0;
            }

            .social-login {
                margin-bottom: 15px;
            }

            .social-btn {
                padding: 9px;
                font-size: 12px;
            }

            .form-row {
                flex-direction: column;
                gap: 12px;
                margin: 14px 0;
            }

            .remember-me,
            .forgot-password {
                text-align: left;
            }

            .auth-footer {
                margin-top: 15px;
                padding-top: 15px;
                font-size: 12px;
            }
        }

        /* Mobile - 480px */
        @@media (max-width: 480px) {
            body {
                overflow: auto;
            }

            .auth-navbar {
                padding: 12px 16px;
            }

            .navbar-brand {
                font-size: 16px;
                gap: 8px;
            }

            .navbar-brand img {
                height: 28px;
                width: 28px;
            }

            .navbar-tagline {
                font-size: 11px;
            }

            .auth-left {
                padding: 20px 16px;
                min-height: 150px;
            }

            .auth-left h2 {
                font-size: 20px;
                margin-bottom: 8px;
            }

            .auth-left p {
                font-size: 12px;
            }

            .auth-right {
                padding: 20px 16px;
                justify-content: flex-start;
                padding-top: 20px;
            }

            .auth-form-wrapper {
                max-width: 100%;
                width: 100%;
            }

            .auth-header {
                margin-bottom: 20px;
            }

            .auth-header h1 {
                font-size: 20px;
            }

            .auth-subtitle {
                font-size: 13px;
                margin-bottom: 15px;
            }

            .form-label {
                font-size: 12px;
                margin-bottom: 5px;
            }

            .form-control {
                padding: 10px 11px;
                font-size: 16px;
                border-radius: 5px;
            }

            .form-group {
                margin-bottom: 12px;
            }

            .form-row {
                gap: 8px;
                margin: 12px 0;
            }

            .remember-me label {
                font-size: 12px;
            }

            .forgot-password a {
                font-size: 12px;
            }

            .instant-login {
                font-size: 12px;
                margin: 15px 0;
            }

            .btn-login {
                padding: 10px 16px;
                font-size: 13px;
                margin: 18px 0;
                border-radius: 5px;
            }

            .social-login {
                grid-template-columns: 1fr 1fr;
                gap: 10px;
                margin-bottom: 12px;
            }

            .social-btn {
                padding: 8px;
                font-size: 11px;
                gap: 4px;
                flex-direction: column;
            }

            .social-btn span {
                display: none;
            }

            .social-btn i {
                font-size: 14px;
            }

            .auth-footer {
                margin-top: 12px;
                padding-top: 12px;
                font-size: 11px;
            }
        }

        /* Extra Small - 360px */
        @@media (max-width: 360px) {
            .auth-left h2 {
                font-size: 18px;
            }

            .auth-header h1 {
                font-size: 18px;
            }

            .navbar-brand {
                font-size: 14px;
            }

            .form-control {
                padding: 9px 10px;
            }

            .btn-login {
                padding: 9px 14px;
            }
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <!-- Navbar -->
        <nav class="auth-navbar">
            <div class="navbar-brand">
                <img src="~/images/estateflow-logo.png" alt="EstateFlow" />
                <span>EstateFlow</span>
            </div>
            <div class="navbar-tagline">
                🏠 Find Your Dream Home - Professional Real Estate Solutions
            </div>
            <div class="nav-buttons">
                <a href="/admin/register" class="register-btn">Register</a>
            </div>
        </nav>

        <!-- Content Area -->
        <div class="auth-content">
            <!-- Left Side - Hero Section -->
            <div class="auth-left">
                <div class="auth-left-content">
                    <h2>Find Your Perfect Home</h2>
                    <p>Discover properties across the Philippines with trusted agents who know every barangay. Fast, easy, reliable.</p>
                </div>
            </div>

            <!-- Right Side - Login Form -->
            <div class="auth-right">
                <div class="auth-form-wrapper">
                    <div class="auth-header">
                        <h1>Sign in</h1>
                    </div>

                    <p class="auth-subtitle">Sign in to your account</p>

                    @if (ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
                    {
                        <div class="alert">
                            <strong>Login Failed:</strong>
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                @foreach (var error in modelState.Errors)
                                {
                                    <div>@error.ErrorMessage</div>
                                }
                            }
                        </div>
                    }

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">
                            <strong>Success!</strong>
                            <div>@TempData["SuccessMessage"]</div>
                        </div>
                    }

                    <form id="loginForm" method="POST" action="/admin/login">
                        <div class="form-group">
                            <label for="email" class="form-label">Your Email</label>
                            <input type="email" 
                                   class="form-control" 
                                   id="email" 
                                   name="email" 
                                   placeholder="you@example.com" 
                                   required 
                                   autofocus />
                        </div>

                        <div class="form-group">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" 
                                   class="form-control" 
                                   id="password" 
                                   name="password" 
                                   placeholder="••••••••••"
                                   required />
                        </div>

                        <div class="form-row">
                            <div class="remember-me">
                                <input type="checkbox" id="remember" name="remember" />
                                <label for="remember">Remember Me</label>
                            </div>
                            <div class="forgot-password">
                                <a href="#">Forgot Password?</a>
                            </div>
                        </div>

                        <div class="form-group mb-3 d-flex justify-content-center">
                            <div class="g-recaptcha" data-sitekey="@siteKey" id="recaptcha"></div>
                        </div>

                        <div id="loginErrorAlert" class="alert" style="display: none;">
                            <strong>Login Failed:</strong>
                            <div id="loginErrorMessage"></div>
                        </div>

                        <button type="submit" class="btn-login" id="loginBtn">Login</button>

                        <div class="auth-footer">
                            Don't have an account? <a href="/admin/register">Register</a>
                        </div>

                        <div class="instant-login">Or continue with</div>

                        <div class="social-login">
                            <a href="#" class="social-btn google">
                                <i class="fab fa-google"></i>
                                <span>Google</span>
                            </a>
                            <a href="#" class="social-btn facebook">
                                <i class="fab fa-facebook-f"></i>
                                <span>Facebook</span>
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- OTP Verification Modal -->
    <div class="modal fade" id="otpModal" tabindex="-1" aria-labelledby="otpModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content otp-modal-content">
                <button type="button" class="btn-close btn-close-modal" data-bs-dismiss="modal" aria-label="Close" style="position: absolute; top: 15px; right: 15px; z-index: 10;" id="otpModalCloseBtn"></button>
                <div class="modal-body otp-modal-body">
                    <h2 class="otp-modal-title">Verify</h2>
                    <p class="otp-modal-subtitle">Your code was sent to you via email</p>

                    <div id="otpErrorAlert" class="alert alert-danger" style="display: none;">
                        <strong>Error:</strong>
                        <div id="otpErrorMessage"></div>
                    </div>

                    <form id="otpForm">
                        <div class="otp-inputs-container">
                            <input type="text" class="otp-input" maxlength="1" placeholder="0" data-index="0" />
                            <input type="text" class="otp-input" maxlength="1" placeholder="0" data-index="1" />
                            <input type="text" class="otp-input" maxlength="1" placeholder="0" data-index="2" />
                            <input type="text" class="otp-input" maxlength="1" placeholder="0" data-index="3" />
                            <input type="text" class="otp-input" maxlength="1" placeholder="0" data-index="4" />
                            <input type="text" class="otp-input" maxlength="1" placeholder="0" data-index="5" />
                        </div>
                        <input type="hidden" id="otpCodeFull" name="otpCode" />
                        <input type="hidden" id="otpUserId" name="userId" />
                        <input type="hidden" id="otpEmailDisplay" name="otpEmail" />

                        <div style="text-align: center; color: #6b7280; font-size: 12px; margin-bottom: 15px;">
                            Code expires in: <strong id="otpTimer" style="color: #d9534f;">10:00</strong>
                        </div>

                        <button type="submit" class="btn-otp-verify" id="otpSubmitBtn">Verify</button>

                        <div class="otp-resend-container">
                            <span class="otp-resend-text">Didn't receive code? </span>
                            <button type="button" class="otp-resend-btn" id="resendOtpBtn">Request again</button>
                            <span id="resendTimerSpan" style="display: none;">
                                <span style="color: #6b7280;"> in </span>
                                <span id="resendTimer" style="color: #0066cc; font-weight: 600;">30</span>
                                <span style="color: #6b7280;">s</span>
                            </span>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let otpModalInstance = null;
        let otpTimerInterval = null;
        let resendTimerInterval = null;

        document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM Content Loaded - Login page initialized');
        });

        // Handle login form submission
        document.getElementById('loginForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            console.log('Login form submitted');

            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const recaptchaResponse = grecaptcha.getResponse();

            console.log('Email:', email, 'ReCAPTCHA:', recaptchaResponse ? 'Valid' : 'Invalid');

            if (!recaptchaResponse) {
                alert('Please verify that you are not a robot.');
                return;
            }

            // Disable submit button during request
            const loginBtn = document.getElementById('loginBtn');
            loginBtn.disabled = true;
            loginBtn.textContent = 'Logging in...';

            try {
                console.log('Sending login request...');
                const response = await fetch('/admin/login', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'Accept': 'application/json'
                    },
                    body: `email=${encodeURIComponent(email)}&password=${encodeURIComponent(password)}&g-recaptcha-response=${encodeURIComponent(recaptchaResponse)}`
                });

                console.log('Response status:', response.status);

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const data = await response.json();
                console.log('Login response data:', data);

                if (data.success) {
                    console.log('Login successful, showing OTP modal');
                    console.log('Expiry seconds from backend:', data.expirySeconds);
                    // Show OTP modal
                    const otpEmailDisplay = document.getElementById('otpEmailDisplay');
                    const otpUserIdInput = document.getElementById('otpUserId');

                    console.log('Setting OTP modal data - Email:', data.email, 'UserId:', data.userId, 'ExpirySeconds:', data.expirySeconds);

                    if (otpEmailDisplay) otpEmailDisplay.textContent = data.email;
                    if (otpUserIdInput) otpUserIdInput.value = data.userId;

                    clearOTPInputs();
                    startOTPTimer(data.expirySeconds);
                    startResendTimer();

                    const otpModal = document.getElementById('otpModal');
                    console.log('OTP Modal element:', otpModal);

                    if (otpModal) {
                        otpModalInstance = new bootstrap.Modal(otpModal, { backdrop: 'static', keyboard: false });
                        console.log('OTP Modal instance created:', otpModalInstance);
                        otpModalInstance.show();
                        console.log('OTP Modal shown');

                        // Setup event handlers for modal elements
                        setTimeout(() => {
                            console.log('Setting up OTP input handlers');
                            setupOTPInputHandlers();
                            setupOTPFormHandler();
                            setupResendOTPHandler();

                            const firstInput = document.querySelector('.otp-input');
                            console.log('First OTP input element:', firstInput);
                            if (firstInput) firstInput.focus();
                        }, 500);
                    } else {
                        console.error('OTP Modal element not found!');
                    }
                } else {
                    console.log('Login failed:', data.message);
                    document.getElementById('loginErrorAlert').style.display = 'block';
                    document.getElementById('loginErrorMessage').textContent = data.message || 'Login failed. Please try again.';
                    grecaptcha.reset();
                    loginBtn.disabled = false;
                    loginBtn.textContent = 'Login';
                }
            } catch (error) {
                console.error('Login error:', error);
                document.getElementById('loginErrorAlert').style.display = 'block';
                document.getElementById('loginErrorMessage').textContent = 'An error occurred. Please try again.';
                grecaptcha.reset();
                loginBtn.disabled = false;
                loginBtn.textContent = 'Login';
            }
        });

        // OTP Input handling - Moved to function to run after modal appears
        function setupOTPInputHandlers() {
            document.querySelectorAll('.otp-input').forEach((input, index) => {
                input.addEventListener('input', function(e) {
                    if (this.value.length === 1 && /^\d$/.test(this.value)) {
                        if (index < 5) {
                            document.querySelectorAll('.otp-input')[index + 1].focus();
                        }
                    } else if (this.value.length > 1) {
                        this.value = this.value.slice(-1);
                    } else if (!/^\d*$/.test(this.value)) {
                        this.value = '';
                    }
                });

                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Backspace' && this.value === '' && index > 0) {
                        document.querySelectorAll('.otp-input')[index - 1].focus();
                    }
                });

                input.addEventListener('paste', function(e) {
                    e.preventDefault();
                    const pastedData = e.clipboardData.getData('text').slice(0, 6).replace(/\D/g, '');
                    const inputs = document.querySelectorAll('.otp-input');
                    pastedData.split('').forEach((digit, i) => {
                        if (inputs[index + i]) {
                            inputs[index + i].value = digit;
                        }
                    });
                    if (pastedData.length === 6) {
                        inputs[5].focus();
                    }
                });
            });
        }

        // OTP Form submission
        function setupOTPFormHandler() {
            const otpForm = document.getElementById('otpForm');
            if (!otpForm) {
                console.warn('OTP form not found');
                return;
            }

            otpForm.addEventListener('submit', async function(e) {
                e.preventDefault();

                const otpCode = Array.from(document.querySelectorAll('.otp-input'))
                    .map(input => input.value)
                    .join('');

                if (otpCode.length !== 6) {
                    document.getElementById('otpErrorAlert').style.display = 'block';
                    document.getElementById('otpErrorMessage').textContent = 'Please enter all 6 digits.';
                    return;
                }

                document.getElementById('otpCodeFull').value = otpCode;
                const userId = document.getElementById('otpUserId').value;

                // Disable submit button
                const otpSubmitBtn = document.getElementById('otpSubmitBtn');
                otpSubmitBtn.disabled = true;
                otpSubmitBtn.textContent = 'Verifying...';

                try {
                    const response = await fetch('/admin/verify-otp', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'Accept': 'application/json'
                        },
                        body: `userId=${userId}&otpCode=${otpCode}`
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }

                    const data = await response.json();

                    if (data.success) {
                        // Redirect to dashboard
                        window.location.href = data.redirectUrl;
                    } else {
                        document.getElementById('otpErrorAlert').style.display = 'block';
                        document.getElementById('otpErrorMessage').textContent = data.message || 'Invalid OTP. Please try again.';
                        otpSubmitBtn.disabled = false;
                        otpSubmitBtn.textContent = 'Verify';
                    }
                } catch (error) {
                    console.error('OTP verification error:', error);
                    document.getElementById('otpErrorAlert').style.display = 'block';
                    document.getElementById('otpErrorMessage').textContent = 'An error occurred. Please try again.';
                    otpSubmitBtn.disabled = false;
                    otpSubmitBtn.textContent = 'Verify';
                }
            });
        }

        // Resend OTP
        function setupResendOTPHandler() {
            const resendBtn = document.getElementById('resendOtpBtn');
            if (!resendBtn) {
                console.warn('Resend button not found');
                return;
            }

            resendBtn.addEventListener('click', async function(e) {
                e.preventDefault();

                resendBtn.disabled = true;
                const originalText = resendBtn.textContent;
                resendBtn.textContent = 'Sending...';

                try {
                    const userId = document.getElementById('otpUserId').value;
                    const response = await fetch('/admin/resend-otp', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'Accept': 'application/json'
                        },
                        body: `userId=${userId}`
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }

                    const data = await response.json();

                    if (data.success) {
                        clearOTPInputs();
                        startOTPTimer(data.expirySeconds);
                        startResendTimer();
                        document.getElementById('otpErrorAlert').style.display = 'none';
                        resendBtn.textContent = originalText;
                    } else {
                        document.getElementById('otpErrorAlert').style.display = 'block';
                        document.getElementById('otpErrorMessage').textContent = data.message || 'Failed to resend OTP.';
                        resendBtn.disabled = false;
                        resendBtn.textContent = originalText;
                    }
                } catch (error) {
                    console.error('Resend OTP error:', error);
                    document.getElementById('otpErrorAlert').style.display = 'block';
                    document.getElementById('otpErrorMessage').textContent = 'An error occurred. Please try again.';
                    resendBtn.disabled = false;
                    resendBtn.textContent = originalText;
                }
            });
        }

        function clearOTPInputs() {
            document.querySelectorAll('.otp-input').forEach(input => input.value = '');
        }

        function startOTPTimer(seconds) {
            if (otpTimerInterval) clearInterval(otpTimerInterval);

            let remainingSeconds = seconds;
            const timerElement = document.getElementById('otpTimer');

            console.log('Starting OTP timer with seconds:', seconds);

            if (timerElement) {
                timerElement.textContent = formatTime(remainingSeconds);
                console.log('Timer display initialized:', formatTime(remainingSeconds));

                otpTimerInterval = setInterval(() => {
                    remainingSeconds--;
                    timerElement.textContent = formatTime(remainingSeconds);

                    if (remainingSeconds <= 0) {
                        console.log('OTP timer expired');
                        clearInterval(otpTimerInterval);
                    }
                }, 1000);
            } else {
                console.warn('OTP timer element not found');
            }
        }

        function startResendTimer() {
            if (resendTimerInterval) clearInterval(resendTimerInterval);

            let remainingSeconds = 60; // 60 second cooldown
            const resendBtn = document.getElementById('resendOtpBtn');
            const resendTimer = document.getElementById('resendTimer');
            const resendTimerSpan = document.getElementById('resendTimerSpan');

            resendBtn.disabled = true;
            if (resendTimerSpan) resendTimerSpan.style.display = 'inline';
            if (resendTimer) {
                resendTimer.textContent = remainingSeconds;
                resendTimerInterval = setInterval(() => {
                    remainingSeconds--;
                    if (resendTimer) {
                        resendTimer.textContent = remainingSeconds;
                    }

                    if (remainingSeconds <= 0) {
                        clearInterval(resendTimerInterval);
                        resendBtn.disabled = false;
                        if (resendTimerSpan) resendTimerSpan.style.display = 'none';
                    }
                }, 1000);
            }
        }

        function formatTime(seconds) {
            const minutes = Math.floor(seconds / 60);
            const secs = seconds % 60;
            return `${minutes}:${secs.toString().padStart(2, '0')}`;
        }

        // Handle modal close button
        document.addEventListener('DOMContentLoaded', function() {
            const otpModalCloseBtn = document.getElementById('otpModalCloseBtn');
            if (otpModalCloseBtn) {
                otpModalCloseBtn.addEventListener('click', function() {
                    if (otpModalInstance) {
                        otpModalInstance.hide();
                    }
                    // Clear any active timers
                    if (otpTimerInterval) clearInterval(otpTimerInterval);
                    if (resendTimerInterval) clearInterval(resendTimerInterval);
                    // Reset form
                    document.getElementById('otpForm').reset();
                    clearOTPInputs();
                    document.getElementById('otpErrorAlert').style.display = 'none';
                });
            }
        });
    </script>
</body>
</html>
