@{
    ViewData["Title"] = "Register - EstateFlow";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            width: 100%;
            height: 100%;
            font-family: 'Inter', sans-serif;
            overflow: auto;
        }

        .auth-container {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }

        .auth-left {
            flex: 1;
            background: linear-gradient(135deg, #3d4a5c 0%, #566978 100%);
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 60px 50px;
            color: white;
            overflow: hidden;
        }

        .auth-left::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1200&q=80');
            background-size: cover;
            background-position: center;
            opacity: 0.4;
            z-index: 1;
            animation: zoomIn 8s ease-out forwards, slideIn 1s ease-out;
        }

        @@keyframes zoomIn {
            from {
                transform: scale(1.05);
                opacity: 0;
            }
            to {
                transform: scale(1);
                opacity: 0.4;
            }
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(-30px);
            }
            to {
                opacity: 0.4;
                transform: translateX(0);
            }
        }

        .auth-left-content {
            position: relative;
            z-index: 2;
            animation: fadeInUp 0.8s ease-out 0.2s both;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .auth-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 80px;
            animation: slideInLeft 0.6s ease-out;
        }

        @@keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-40px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .auth-brand img {
            height: 40px;
            width: 40px;
            background: white;
            padding: 6px;
            border-radius: 8px;
        }

        .auth-brand-text {
            font-size: 18px;
            font-weight: 700;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .auth-left h2 {
            font-size: 48px;
            font-weight: 700;
            margin-bottom: 20px;
            line-height: 1.2;
            font-family: 'Plus Jakarta Sans', sans-serif;
            animation: slideInDown 0.7s ease-out 0.1s both;
        }

        @@keyframes slideInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .auth-left p {
            font-size: 16px;
            line-height: 1.6;
            opacity: 0.9;
            animation: slideInDown 0.7s ease-out 0.2s both;
        }

        .auth-left-footer {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .slider-dots {
            display: flex;
            gap: 8px;
        }

        .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .dot.active {
            background: white;
            width: 24px;
            border-radius: 4px;
        }

        .auth-right {
            flex: 1;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
            animation: fadeInRight 0.8s ease-out;
        }

        @@keyframes fadeInRight {
            from {
                opacity: 0;
                transform: translateX(40px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .auth-form-wrapper {
            width: 100%;
            max-width: 420px;
            animation: fadeInUp 0.8s ease-out 0.2s both;
        }

        .auth-header {
            margin-bottom: 30px;
        }

        .auth-header h1 {
            font-size: 28px;
            font-weight: 700;
            color: #1f2937;
            margin: 0 0 8px 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .auth-subtitle {
            color: #6b7280;
            font-size: 14px;
            margin: 0;
        }

        .form-group {
            margin-bottom: 16px;
            animation: fadeIn 0.6s ease-out forwards;
        }

        .form-group:nth-child(1) { animation-delay: 0.25s; }
        .form-group:nth-child(2) { animation-delay: 0.35s; }
        .form-group:nth-child(3) { animation-delay: 0.45s; }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        .form-label {
            display: block;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 6px;
            font-size: 13px;
        }

        .form-control {
            width: 100%;
            padding: 11px 12px;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            font-size: 14px;
            transition: all 0.3s ease;
            background-color: white;
            font-family: 'Inter', sans-serif;
        }

        .form-control:focus {
            outline: none;
            border-color: #1f2937;
            box-shadow: 0 0 0 3px rgba(31, 41, 55, 0.05);
        }

        .form-control::placeholder {
            color: #9ca3af;
        }

        .form-control option {
            background-color: white;
            color: #1f2937;
            padding: 8px;
        }

        select.form-control {
            appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%236b7280' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 12px center;
            background-size: 18px;
            padding-right: 36px;
            cursor: pointer;
        }

        select.form-control:focus {
            outline: none;
            border-color: #1f2937;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%231f2937' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
            box-shadow: 0 0 0 3px rgba(31, 41, 55, 0.05);
        }

        .password-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        /* Tablets - 1024px */
        @@media (max-width: 1024px) {
            .auth-left {
                flex: 0.4;
                padding: 40px 30px;
            }

            .auth-left h2 {
                font-size: 32px;
                margin-bottom: 15px;
            }

            .auth-left p {
                font-size: 14px;
            }

            .auth-brand {
                margin-bottom: 50px;
            }

            .auth-brand img {
                height: 32px;
                width: 32px;
            }

            .auth-brand-text {
                font-size: 16px;
            }

            .password-row {
                grid-template-columns: 1fr 1fr;
            }
        }

        /* Small Tablets - 768px */
        @@media (max-width: 768px) {
            .auth-container {
                flex-direction: column;
                height: auto;
                min-height: 100vh;
            }

            .auth-left {
                flex: none;
                width: 100%;
                height: auto;
                padding: 50px 20px;
                min-height: 250px;
                justify-content: center;
            }

            .auth-left::before {
                opacity: 0.3;
            }

            .auth-left h2 {
                font-size: 28px;
                margin-bottom: 12px;
            }

            .auth-left p {
                font-size: 14px;
                margin-bottom: 30px;
            }

            .auth-brand {
                margin-bottom: 30px;
            }

            .auth-right {
                flex: none;
                width: 100%;
                padding: 30px 20px;
                min-height: auto;
                overflow-y: auto;
            }

            .auth-form-wrapper {
                max-width: 100%;
            }

            .auth-header {
                margin-bottom: 25px;
            }

            .auth-header h1 {
                font-size: 24px;
            }

            .auth-subtitle {
                margin-bottom: 20px;
                font-size: 13px;
            }

            .form-group {
                margin-bottom: 14px;
            }

            .form-label {
                font-size: 12px;
                margin-bottom: 5px;
            }

            .form-control {
                padding: 10px 12px;
                font-size: 16px;
            }

            .btn-register {
                padding: 10px 20px;
                font-size: 13px;
                margin-top: 18px;
            }

            .password-row {
                grid-template-columns: 1fr 1fr;
                gap: 10px;
            }

            .form-requirements {
                padding: 9px 11px;
                margin-top: 10px;
                font-size: 11px;
            }

            .auth-footer {
                margin-top: 15px;
                padding-top: 15px;
                font-size: 12px;
            }
        }

        /* Mobile - 480px */
        @@media (max-width: 480px) {
            body {
                overflow: auto;
            }

            .auth-left {
                padding: 30px 16px;
                min-height: 200px;
            }

            .auth-left h2 {
                font-size: 22px;
                margin-bottom: 10px;
            }

            .auth-left p {
                font-size: 13px;
            }

            .auth-brand {
                margin-bottom: 20px;
            }

            .auth-brand img {
                height: 28px;
                width: 28px;
            }

            .auth-brand-text {
                font-size: 14px;
            }

            .auth-right {
                padding: 20px 16px;
                justify-content: flex-start;
                padding-top: 25px;
            }

            .auth-form-wrapper {
                max-width: 100%;
                width: 100%;
            }

            .auth-header {
                margin-bottom: 18px;
            }

            .auth-header h1 {
                font-size: 20px;
            }

            .auth-subtitle {
                font-size: 12px;
                margin-bottom: 12px;
            }

            .form-label {
                font-size: 11px;
                margin-bottom: 4px;
            }

            .form-control {
                padding: 9px 11px;
                font-size: 16px;
                border-radius: 5px;
            }

            .form-group {
                margin-bottom: 11px;
            }

            .password-row {
                grid-template-columns: 1fr;
                gap: 11px;
            }

            .btn-register {
                padding: 10px 16px;
                font-size: 13px;
                margin-top: 16px;
                border-radius: 5px;
            }

            .form-requirements {
                padding: 8px 10px;
                margin-top: 9px;
                font-size: 10px;
                line-height: 1.5;
            }

            .auth-footer {
                margin-top: 12px;
                padding-top: 12px;
                font-size: 11px;
            }

            .slider-dots {
                gap: 6px;
            }

            .dot {
                width: 6px;
                height: 6px;
            }

            .dot.active {
                width: 18px;
            }
        }

        /* Extra Small - 360px */
        @@media (max-width: 360px) {
            .auth-left h2 {
                font-size: 20px;
            }

            .auth-header h1 {
                font-size: 18px;
            }

            .auth-brand-text {
                font-size: 12px;
            }

            .form-control {
                padding: 9px 10px;
            }

            .btn-register {
                padding: 9px 14px;
            }
        }

        .btn-register {
            width: 100%;
            padding: 11px 20px;
            background: #1f2937;
            border: none;
            border-radius: 6px;
            color: white;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 20px;
            animation: slideInUp 0.6s ease-out 0.4s both;
        }

        @@keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .btn-register:hover {
            background: #000;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .alert {
            border-radius: 6px;
            border: 1px solid #fecaca;
            background-color: #fef2f2;
            color: #991b1b;
            padding: 12px 14px;
            margin-bottom: 20px;
            font-size: 13px;
        }

        .alert strong {
            font-weight: 600;
        }

        .form-requirements {
            background-color: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            padding: 10px 12px;
            margin-top: 12px;
            font-size: 12px;
            color: #6b7280;
            line-height: 1.6;
        }

        .form-requirements strong {
            color: #1f2937;
        }

        .auth-footer {
            text-align: center;
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid #e5e7eb;
            color: #6b7280;
            font-size: 13px;
        }

        .auth-footer a {
            color: #1f2937;
            text-decoration: none;
            font-weight: 600;
        }

        .auth-footer a:hover {
            color: #000;
        }

        @@media (max-width: 1024px) {
            .auth-left {
                display: none;
            }

            .auth-container {
                background: linear-gradient(135deg, #3d4a5c 0%, #566978 100%);
            }
        }

        @@media (max-width: 640px) {
            .auth-right {
                padding: 20px;
            }

            .auth-form-wrapper {
                max-width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <!-- Left Side -->
        <div class="auth-left">
            <div class="auth-left-content">
                <div class="auth-brand">
                    <img src="~/images/estateflow-logo.png" alt="EstateFlow" />
                    <span class="auth-brand-text">EstateFlow</span>
                </div>
                <h2>Find Your Sweet Home</h2>
                <p>Visiting your dream property is now just a few clicks away — fast, easy, reliable.</p>
            </div>
            <div class="auth-left-footer">
                <div class="slider-dots">
                    <div class="dot active"></div>
                    <div class="dot"></div>
                    <div class="dot"></div>
                </div>
            </div>
        </div>

        <!-- Right Side -->
        <div class="auth-right">
            <div class="auth-form-wrapper">
                <div class="auth-header">
                    <h1>Create Account</h1>
                    <p class="auth-subtitle">Join EstateFlow today</p>
                </div>

                @if (ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
                {
                    <div class="alert">
                        <strong>Registration Failed:</strong>
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        }
                    </div>
                }

                <form method="post" asp-action="Register">
                    <div class="form-group">
                        <label for="fullName" class="form-label">Full Name</label>
                        <input type="text" 
                               class="form-control" 
                               id="fullName" 
                               name="fullName" 
                               placeholder="Jonathan Reichert" 
                               required 
                               autofocus />
                    </div>

                    <div class="form-group">
                        <label for="email" class="form-label">Email Address</label>
                        <input type="email" 
                               class="form-control" 
                               id="email" 
                               name="email" 
                               placeholder="jonathan@estateflow.com" 
                               required />
                    </div>

                    <div class="form-group">
                        <label for="roleType" class="form-label">Role</label>
                        <select class="form-control" 
                                id="roleType" 
                                name="roleType" 
                                required>
                            <option value="">-- Select a Role --</option>
                            @if (ViewBag.Roles != null)
                            {
                                @foreach (var role in ViewBag.Roles)
                                {
                                    <option value="@role.RoleType">@role.RoleType</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="password-row">
                        <div class="form-group">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" 
                                   class="form-control" 
                                   id="password" 
                                   name="password" 
                                   placeholder="••••••••••" 
                                   required />
                        </div>

                        <div class="form-group">
                            <label for="confirmPassword" class="form-label">Confirm</label>
                            <input type="password" 
                                   class="form-control" 
                                   id="confirmPassword" 
                                   name="confirmPassword" 
                                   placeholder="••••••••••" 
                                   required />
                        </div>
                    </div>

                    <div class="form-requirements">
                        <strong>Requirements:</strong> Minimum 6 characters, passwords must match
                    </div>

                    <button type="submit" class="btn-register">Create Account</button>

                    <div class="auth-footer">
                        Already have an account? <a href="/admin/login">Sign In</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        /* Success Toast Styling */
        .success-toast {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            display: none;
            animation: slideInRight 0.4s ease-out;
        }

        .success-toast.show {
            display: block;
        }

        @@keyframes slideInRight {
            from {
                transform: translateX(400px);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @@keyframes slideOutRight {
            from {
                transform: translateX(0);
                opacity: 1;
            }
            to {
                transform: translateX(400px);
                opacity: 0;
            }
        }

        .success-toast.hide {
            animation: slideOutRight 0.4s ease-out forwards;
        }

        .toast-container {
            background: white;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
            max-width: 320px;
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .toast-checkmark {
            width: 60px;
            height: 60px;
            margin-bottom: 15px;
        }

        .toast-checkmark svg {
            width: 100%;
            height: 100%;
        }

        .toast-title {
            color: #22c55e;
            font-size: 18px;
            font-weight: 700;
            margin: 0 0 8px 0;
            letter-spacing: 0.5px;
        }

        .toast-message {
            color: #4b5563;
            font-size: 13px;
            margin: 0 0 4px 0;
            line-height: 1.4;
        }

        .toast-redirect {
            color: #9ca3af;
            font-size: 12px;
            margin: 0;
            line-height: 1.4;
        }

        .toast-redirect strong {
            color: #22c55e;
            font-weight: 600;
        }

        .toast-close {
            position: absolute;
            top: 10px;
            right: 10px;
            background: none;
            border: none;
            cursor: pointer;
            width: 24px;
            height: 24px;
            color: #d1d5db;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: color 0.2s;
        }

        .toast-close:hover {
            color: #6b7280;
        }

        .toast-close svg {
            width: 100%;
            height: 100%;
        }

        @@media (max-width: 480px) {
            .success-toast {
                top: 10px;
                right: 10px;
                left: 10px;
            }

            .toast-container {
                max-width: none;
                padding: 20px;
            }

            .toast-title {
                font-size: 16px;
            }

            .toast-message {
                font-size: 12px;
            }
        }
    </style>

    <script>
        function closeToast() {
            const toast = document.getElementById('successToast');
            if (toast) {
                toast.classList.remove('show');
                toast.classList.add('hide');
            }
        }

        // Check if registration was successful
        const urlParams = new URLSearchParams(window.location.search);
        const registered = urlParams.get('registered');

        if (registered === 'true') {
            // Show success toast
            const toast = document.getElementById('successToast');
            if (toast) {
                // Small delay to ensure DOM is ready
                setTimeout(() => {
                    toast.classList.add('show');
                }, 100);

                // Countdown and redirect
                let seconds = 5;
                const countdownEl = document.getElementById('toastCountdown');

                const countdownInterval = setInterval(() => {
                    seconds--;
                    if (countdownEl) {
                        countdownEl.textContent = seconds;
                    }

                    if (seconds === 0) {
                        clearInterval(countdownInterval);
                        window.location.href = '/admin/login';
                    }
                }, 1000);

                // Allow manual close
                const closeBtn = document.querySelector('.toast-close');
                if (closeBtn) {
                    closeBtn.addEventListener('click', () => {
                        clearInterval(countdownInterval);
                        closeToast();
                        // Redirect immediately to login
                        setTimeout(() => {
                            window.location.href = '/admin/login';
                        }, 400);
                    });
                }
            }
        }
    </script>

    <script>
        // Real-time password validation
        const passwordInput = document.getElementById('password');
        const confirmPasswordInput = document.getElementById('confirmPassword');

        function validatePasswords() {
            if (passwordInput && confirmPasswordInput) {
                if (passwordInput.value && confirmPasswordInput.value) {
                    if (passwordInput.value !== confirmPasswordInput.value) {
                        confirmPasswordInput.style.borderColor = '#ef4444';
                        confirmPasswordInput.style.boxShadow = '0 0 0 3px rgba(239, 68, 68, 0.1)';
                    } else {
                        confirmPasswordInput.style.borderColor = '#22c55e';
                        confirmPasswordInput.style.boxShadow = '0 0 0 3px rgba(34, 197, 94, 0.1)';
                    }
                }
            }
        }

        if (passwordInput && confirmPasswordInput) {
            passwordInput.addEventListener('input', validatePasswords);
            confirmPasswordInput.addEventListener('input', validatePasswords);
        }
    </script>
</body>
</html>
