@model AdminSalesHistoryViewModel
@using RealEstate.Models.Admin
@{
    ViewData["Title"] = "Sales history";
}

<div class="admin-dashboard bg-light min-vh-100 pb-5">
    <div class="container-fluid px-4 py-4" style="max-width: 1400px;">
        <h1 class="h4 fw-bold text-site-dark mb-2">Sales history</h1>
        <p class="text-site-muted small mb-4">Completed deals only. Filter by date range, property, or client name.</p>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-6 col-md-3">
                        <label class="form-label small fw-semibold" for="from">From</label>
                        <input type="date" class="form-control form-control-sm" id="from" name="from"
                               value="@(Model.FilterFromUtc?.ToString("yyyy-MM-dd"))" />
                    </div>
                    <div class="col-6 col-md-3">
                        <label class="form-label small fw-semibold" for="to">To</label>
                        <input type="date" class="form-control form-control-sm" id="to" name="to"
                               value="@(Model.FilterToUtc?.ToString("yyyy-MM-dd"))" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold" for="propertyId">Property</label>
                        <select class="form-select form-select-sm" id="propertyId" name="propertyId">
                            <option value="">All</option>
                            @foreach (var opt in Model.PropertyOptions)
                            {
                                if (Model.FilterPropertyId == opt.Id)
                                {
                                    <option value="@opt.Id" selected>@opt.Title</option>
                                }
                                else
                                {
                                    <option value="@opt.Id">@opt.Title</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold" for="client">Client</label>
                        <input type="search" class="form-control form-control-sm" id="client" name="client"
                               value="@Model.FilterClient" placeholder="Name contains…" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-site-primary text-white btn-sm px-4">Apply filters</button>
                        <a class="btn btn-outline-secondary btn-sm" asp-controller="AdminSalesHistory" asp-action="Index">Clear</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 small">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Transaction ID</th>
                            <th scope="col">Property</th>
                            <th scope="col">Client</th>
                            <th scope="col">Type</th>
                            <th scope="col" class="text-end">Amount</th>
                            <th scope="col">Date</th>
                            <th scope="col"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Rows.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="text-center text-site-muted py-4">No completed deals match your filters.</td>
                            </tr>
                        }
                        @foreach (var r in Model.Rows)
                        {
                            <tr>
                                <td class="font-monospace">@r.TransactionId</td>
                                <td>@r.PropertyTitle</td>
                                <td>@r.ClientName</td>
                                <td>@r.TypeDisplay</td>
                                <td class="text-end">₱@r.AmountFormatted</td>
                                <td>@r.DateDisplay</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" asp-controller="AdminTransactions" asp-action="Details" asp-route-id="@r.TransactionId">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
