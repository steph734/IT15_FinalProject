@model List<RealEstate.Models.Property>
@{
    ViewData["Title"] = "My Properties";
    var agentId = (int?)ViewBag.AgentId;
    var agentName = (string?)ViewBag.AgentName ?? "Agent";
    var page = (int?)ViewBag.Page ?? 1;
    var pageSize = (int?)ViewBag.PageSize ?? 10;
    var totalCount = (int?)ViewBag.TotalCount ?? 0;
    var totalPages = (int?)ViewBag.TotalPages ?? 1;
}

<style>
    .properties-page {
        background: #f9fafb;
        min-height: 100vh;
        padding: 40px 20px;
    }

    .page-header {
        max-width: 1400px;
        margin: 0 auto 40px;
        background: white;
        padding: 32px;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    }

    .page-header h1 {
        font-size: 32px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 8px;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .page-header p {
        font-size: 14px;
        color: #6b7280;
    }

    .properties-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .properties-table {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    }

    .properties-table table {
        width: 100%;
        border-collapse: collapse;
    }

    .properties-table thead {
        background: #f3f4f6;
        border-bottom: 1px solid #e5e7eb;
    }

    .properties-table th {
        padding: 16px;
        text-align: left;
        font-weight: 600;
        color: #6b7280;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .properties-table td {
        padding: 16px;
        border-bottom: 1px solid #f3f4f6;
        font-size: 14px;
        color: #1f2937;
    }

    .properties-table tbody tr:hover {
        background: #f9fafb;
    }

    .property-title {
        font-weight: 600;
        color: #3b82f6;
    }

    .property-location {
        font-size: 13px;
        color: #6b7280;
    }

    .price-badge {
        background: #dbeafe;
        color: #1e40af;
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 13px;
    }

    .status-badge {
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 12px;
    }

    .status-active {
        background: #d1fae5;
        color: #065f46;
    }

    .status-inactive {
        background: #fee2e2;
        color: #7f1d1d;
    }

    .action-btns {
        display: flex;
        gap: 8px;
    }

    .action-btn {
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 12px;
        border: none;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-view {
        background: #dbeafe;
        color: #1e40af;
    }

    .btn-view:hover {
        background: #bfdbfe;
    }

    .btn-edit {
        background: #fef3c7;
        color: #92400e;
    }

    .btn-edit:hover {
        background: #fed7aa;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }

    .empty-icon {
        font-size: 64px;
        margin-bottom: 16px;
    }

    .empty-state h3 {
        font-size: 20px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 8px;
    }

    .empty-state p {
        font-size: 14px;
        color: #6b7280;
    }

    .pagination {
        display: flex;
        justify-content: center;
        gap: 8px;
        margin-top: 24px;
        align-items: center;
    }

    .pagination a, .pagination span {
        padding: 8px 12px;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        background: white;
        color: #1f2937;
        text-decoration: none;
        font-size: 13px;
        transition: all 0.3s ease;
    }

    .pagination a:hover {
        background: #3b82f6;
        color: white;
        border-color: #3b82f6;
    }

    .pagination .active {
        background: #3b82f6;
        color: white;
        border-color: #3b82f6;
    }

    @@media (max-width: 768px) {
        .properties-table {
            font-size: 12px;
        }

        .properties-table th, .properties-table td {
            padding: 12px 8px;
        }

        .action-btns {
            gap: 4px;
            flex-direction: column;
        }

        .action-btn {
            padding: 4px 8px;
            font-size: 11px;
        }
    }
</style>

<div class="properties-page">
    <div class="page-header">
        <h1>My Properties</h1>
        <p>Manage all your active listings</p>
    </div>

    <div class="properties-container">
        @if (Model.Any())
        {
            <div class="properties-table">
                <table>
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Location</th>
                            <th>Price</th>
                            <th>Type</th>
                            <th>Beds/Baths</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var property in Model)
                        {
                            <tr>
                                <td>
                                    <div class="property-title">@property.Title</div>
                                    <div class="property-location">@property.Location</div>
                                </td>
                                <td>@property.Location</td>
                                <td>
                                    <span class="price-badge">₱@property.Price.ToString("N0")</span>
                                </td>
                                <td>@property.ListingType</td>
                                <td>@property.Bedrooms / @property.Bathrooms</td>
                                <td>
                                    <span class="status-badge status-active">Active</span>
                                </td>
                                <td>
                                    <div class="action-btns">
                                        <a href="@Url.Action("Details", "Properties", new { id = property.Id })" class="action-btn btn-view">View</a>
                                        <a href="#" class="action-btn btn-edit">Edit</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <div class="pagination">
                    @if (page > 1)
                    {
                        <a href="?page=1">« First</a>
                        <a href="?page=@(page - 1)">‹ Previous</a>
                    }

                    @for (int i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
                    {
                        if (i == page)
                        {
                            <span class="active">@i</span>
                        }
                        else
                        {
                            <a href="?page=@i">@i</a>
                        }
                    }

                    @if (page < totalPages)
                    {
                        <a href="?page=@(page + 1)">Next ›</a>
                        <a href="?page=@totalPages">Last »</a>
                    }
                </div>
            }
        }
        else
        {
            <div class="properties-table" style="background: white; border-radius: 12px; padding: 0;">
                <div class="empty-state">
                    <div class="empty-icon">🏠</div>
                    <h3>No Properties Yet</h3>
                    <p>You haven't listed any properties yet. Submit your first property to get started!</p>
                </div>
            </div>
        }
    </div>
</div>
