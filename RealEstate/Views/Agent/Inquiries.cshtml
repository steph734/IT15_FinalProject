@{
    ViewData["Title"] = "Inquiries";
    var agentId = (int?)ViewBag.AgentId;
}

<style>
    .inquiries-page {
        background: #f9fafb;
        min-height: 100vh;
        padding: 40px 20px;
    }

    .page-header {
        max-width: 1400px;
        margin: 0 auto 40px;
        background: white;
        padding: 32px;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    }

    .page-header h1 {
        font-size: 32px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 8px;
    }

    .inquiries-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .inquiry-card {
        background: white;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 16px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
        border-left: 4px solid #3b82f6;
    }

    .inquiry-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 16px;
    }

    .inquiry-title {
        font-size: 16px;
        font-weight: 700;
        color: #1f2937;
    }

    .inquiry-date {
        font-size: 13px;
        color: #6b7280;
    }

    .inquiry-status {
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        background: #dbeafe;
        color: #1e40af;
    }

    .inquiry-content {
        color: #6b7280;
        font-size: 14px;
        line-height: 1.6;
        margin-bottom: 16px;
    }

    .inquiry-client {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 12px;
        margin-bottom: 16px;
        padding-bottom: 16px;
        border-bottom: 1px solid #f3f4f6;
    }

    .client-info {
        font-size: 13px;
    }

    .client-label {
        color: #9ca3af;
        text-transform: uppercase;
        font-size: 11px;
        margin-bottom: 4px;
    }

    .client-value {
        color: #1f2937;
        font-weight: 600;
    }

    .inquiry-actions {
        display: flex;
        gap: 8px;
    }

    .action-btn {
        padding: 8px 16px;
        border-radius: 6px;
        border: none;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-reply {
        background: #3b82f6;
        color: white;
    }

    .btn-reply:hover {
        background: #2563eb;
    }

    .btn-mark-read {
        background: #f3f4f6;
        color: #1f2937;
        border: 1px solid #e5e7eb;
    }

    .btn-mark-read:hover {
        background: #e5e7eb;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 12px;
    }

    .empty-icon {
        font-size: 64px;
        margin-bottom: 16px;
    }

    .empty-state h3 {
        font-size: 20px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 8px;
    }

    .empty-state p {
        font-size: 14px;
        color: #6b7280;
    }
</style>

<div class="inquiries-page">
    <div class="page-header">
        <h1>📧 Inquiries</h1>
        <p>View and manage all client inquiries</p>
    </div>

    <div class="inquiries-container">
        <div class="inquiry-card">
            <div class="inquiry-header">
                <div>
                    <div class="inquiry-title">Interest in Luxury Minimalist Duplex</div>
                    <div class="inquiry-date">2 hours ago</div>
                </div>
                <span class="inquiry-status">New</span>
            </div>
            <div class="inquiry-content">
                I'm very interested in the Luxury Minimalist Duplex in Taguig. Would it be possible to schedule a viewing for this weekend? I'm also interested in learning more about the financing options available.
            </div>
            <div class="inquiry-client">
                <div class="client-info">
                    <div class="client-label">Name</div>
                    <div class="client-value">John Doe</div>
                </div>
                <div class="client-info">
                    <div class="client-label">Email</div>
                    <div class="client-value">john@example.com</div>
                </div>
                <div class="client-info">
                    <div class="client-label">Phone</div>
                    <div class="client-value">+63 917 123 4567</div>
                </div>
            </div>
            <div class="inquiry-actions">
                <button class="action-btn btn-reply">Reply</button>
                <button class="action-btn btn-mark-read">Mark as Read</button>
            </div>
        </div>

        <div class="inquiry-card">
            <div class="inquiry-header">
                <div>
                    <div class="inquiry-title">Question about BGC Condo</div>
                    <div class="inquiry-date">5 hours ago</div>
                </div>
                <span class="inquiry-status">Replied</span>
            </div>
            <div class="inquiry-content">
                What is the current status of the BGC Condo? Is it still available for viewing? Also, do you have any similar properties in the same area?
            </div>
            <div class="inquiry-client">
                <div class="client-info">
                    <div class="client-label">Name</div>
                    <div class="client-value">Maria Santos</div>
                </div>
                <div class="client-info">
                    <div class="client-label">Email</div>
                    <div class="client-value">maria@example.com</div>
                </div>
                <div class="client-info">
                    <div class="client-label">Phone</div>
                    <div class="client-value">+63 908 765 4321</div>
                </div>
            </div>
            <div class="inquiry-actions">
                <button class="action-btn btn-reply">Reply</button>
            </div>
        </div>
    </div>
</div>
