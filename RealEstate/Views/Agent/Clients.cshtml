@{
    ViewData["Title"] = "My Clients";
    var agentId = (int?)ViewBag.AgentId;
}

<style>
    .clients-page {
        background: #f9fafb;
        min-height: 100vh;
        padding: 40px 20px;
    }

    .page-header {
        max-width: 1400px;
        margin: 0 auto 40px;
        background: white;
        padding: 32px;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    }

    .page-header h1 {
        font-size: 32px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 8px;
    }

    .clients-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .clients-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 24px;
    }

    .client-card {
        background: white;
        border-radius: 12px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
        transition: all 0.3s ease;
    }

    .client-card:hover {
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
        transform: translateY(-4px);
    }

    .client-avatar {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 28px;
        margin-bottom: 16px;
    }

    .client-name {
        font-size: 16px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 4px;
    }

    .client-type {
        font-size: 13px;
        color: #3b82f6;
        font-weight: 600;
        text-transform: uppercase;
        margin-bottom: 16px;
    }

    .client-info {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .client-actions {
        display: flex;
        gap: 8px;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid #f3f4f6;
    }

    .action-btn {
        flex: 1;
        padding: 8px 12px;
        border-radius: 6px;
        border: none;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        text-align: center;
    }

    .btn-contact {
        background: #3b82f6;
        color: white;
    }

    .btn-contact:hover {
        background: #2563eb;
    }

    .btn-history {
        background: #f3f4f6;
        color: #1f2937;
        border: 1px solid #e5e7eb;
    }

    .btn-history:hover {
        background: #e5e7eb;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 12px;
    }

    .empty-icon {
        font-size: 64px;
        margin-bottom: 16px;
    }

    .empty-state h3 {
        font-size: 20px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 8px;
    }

    .empty-state p {
        font-size: 14px;
        color: #6b7280;
    }
</style>

<div class="clients-page">
    <div class="page-header">
        <h1>👥 My Clients</h1>
        <p>Manage your client relationships and interactions</p>
    </div>

    <div class="clients-container">
        <div class="clients-grid">
            <div class="client-card">
                <div class="client-avatar">JD</div>
                <div class="client-name">John Doe</div>
                <div class="client-type">Buyer</div>
                <div class="client-info">
                    <span>📧</span> john@example.com
                </div>
                <div class="client-info">
                    <span>📱</span> +63 917 123 4567
                </div>
                <div class="client-info">
                    <span>🎯</span> Looking for 3+ bedroom condo
                </div>
                <div class="client-actions">
                    <button class="action-btn btn-contact">Contact</button>
                    <button class="action-btn btn-history">History</button>
                </div>
            </div>

            <div class="client-card">
                <div class="client-avatar">MS</div>
                <div class="client-name">Maria Santos</div>
                <div class="client-type">Renter</div>
                <div class="client-info">
                    <span>📧</span> maria@example.com
                </div>
                <div class="client-info">
                    <span>📱</span> +63 908 765 4321
                </div>
                <div class="client-info">
                    <span>🎯</span> Interested in Makati area
                </div>
                <div class="client-actions">
                    <button class="action-btn btn-contact">Contact</button>
                    <button class="action-btn btn-history">History</button>
                </div>
            </div>

            <div class="client-card">
                <div class="client-avatar">RP</div>
                <div class="client-name">Robert Perez</div>
                <div class="client-type">Seller</div>
                <div class="client-info">
                    <span>📧</span> robert@example.com
                </div>
                <div class="client-info">
                    <span>📱</span> +63 912 345 6789
                </div>
                <div class="client-info">
                    <span>🎯</span> Selling family home in BGC
                </div>
                <div class="client-actions">
                    <button class="action-btn btn-contact">Contact</button>
                    <button class="action-btn btn-history">History</button>
                </div>
            </div>
        </div>
    </div>
</div>
