@{
    ViewData["Title"] = "Agent Tracking";
    var appointment = ViewBag.Appointment as RealEstate.Models.ViewingAppointment;
    var property = ViewBag.Property as RealEstate.Models.Property;
}

<div class="container-fluid p-0">
    <div class="tracking-header">
        <div class="container">
            <div class="row align-items-center">
                <div class="col">
                    <h2><i class="fas fa-map-marked-alt me-2"></i>Agent Tracking</h2>
                    <p class="mb-0">Navigate to customer and property</p>
                </div>
                <div class="col-auto">
                    <button id="startTrackingBtn" class="btn btn-success btn-lg" onclick="startTracking()">
                        <i class="fas fa-play me-2"></i>Start Session
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="map" style="height: calc(100vh - 100px); width: 100%;"></div>

    <div class="tracking-info-panel">
        <div class="card">
            <div class="card-body">
                <h5><i class="fas fa-user me-2"></i>Customer: @appointment?.CustomerName</h5>
                <p class="mb-1"><i class="fas fa-phone me-2"></i>@appointment?.CustomerPhone</p>
                <p class="mb-1"><i class="fas fa-envelope me-2"></i>@appointment?.CustomerEmail</p>
                <p class="mb-0"><i class="fas fa-home me-2"></i>@property?.Title</p>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
.tracking-header {
    background: linear-gradient(135deg, #2563EB 0%, #1e3a8a 100%);
    color: white;
    padding: 1rem 0;
}
.tracking-info-panel {
    position: fixed;
    bottom: 20px;
    left: 20px;
    max-width: 400px;
    z-index: 1000;
}
</style>

<script>
let map, customerMarker, agentMarker, propertyMarker, watchId;
let isTracking = false;
const appointmentId = @appointment?.Id;
const propertyLat = @property?.Latitude ?? 0;
const propertyLng = @property?.Longitude ?? 0;

function initMap() {
    map = L.map('map').setView([propertyLat, propertyLng], 15);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

    const propertyIcon = L.divIcon({
        html: '<i class="fas fa-home" style="font-size: 24px; color: #2563EB;"></i>',
        iconSize: [30, 30],
        className: 'custom-div-icon'
    });

    propertyMarker = L.marker([propertyLat, propertyLng], { icon: propertyIcon })
        .addTo(map)
        .bindPopup('<b>Property</b>');
}

function startTracking() {
    if (!navigator.geolocation) {
        alert('Geolocation not supported');
        return;
    }

    isTracking = true;
    document.getElementById('startTrackingBtn').innerHTML = '<i class="fas fa-stop me-2"></i>End Session';
    document.getElementById('startTrackingBtn').classList.replace('btn-success', 'btn-danger');
    document.getElementById('startTrackingBtn').onclick = endSession;

    watchId = navigator.geolocation.watchPosition(updatePosition, handleError, {
        enableHighAccuracy: true,
        maximumAge: 5000
    });

    setInterval(shareLocation, 5000);
    setInterval(fetchCustomerLocation, 10000);
}

function updatePosition(position) {
    const lat = position.coords.latitude;
    const lng = position.coords.longitude;

    if (agentMarker) {
        agentMarker.setLatLng([lat, lng]);
    } else {
        const icon = L.divIcon({
            html: '<i class="fas fa-car" style="font-size: 24px; color: #F59E0B;"></i>',
            iconSize: [30, 30],
            className: 'custom-div-icon'
        });
        agentMarker = L.marker([lat, lng], { icon }).addTo(map).bindPopup('<b>Your Location</b>');
    }
}

async function shareLocation() {
    if (!isTracking || !agentMarker) return;
    
    try {
        await fetch(`/tracking/agent/${appointmentId}/share-location`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                latitude: agentMarker.getLatLng().lat,
                longitude: agentMarker.getLatLng().lng
            })
        });
    } catch (error) {
        console.error('Error:', error);
    }
}

async function fetchCustomerLocation() {
    // Fetch and display customer location on map
}

function endSession() {
    if (confirm('End tracking session?')) {
        isTracking = false;
        if (watchId) navigator.geolocation.clearWatch(watchId);
        stopTracking();
    }
}

function handleError(error) {
    alert('Location error: ' + error.message);
}

document.addEventListener('DOMContentLoaded', initMap);
</script>
