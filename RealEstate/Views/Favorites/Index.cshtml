@model IReadOnlyList<RealEstate.Models.Property>
@using RealEstate.Models
@{
    ViewData["Title"] = "My Favorites";
}

<div class="site-page py-4">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h4">My Favorites</h1>
            <a class="btn btn-outline-secondary" asp-controller="Properties" asp-action="Index">Browse</a>
        </div>

        @if (Model.Count == 0)
        {
            <div class="alert alert-light">You haven't added any favorites yet.</div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var p in Model)
                {
                    <div class="col-sm-6 col-xl-4">
                        <article class="card border-0 shadow-sm h-100">
                            <a asp-controller="Properties" asp-action="Details" asp-route-id="@p.Id" class="text-decoration-none text-reset d-block">
                                <div class="ratio ratio-4x3">
                                    <img src="@p.ImageUrls.FirstOrDefault()" alt="" class="object-fit-cover w-100 h-100" />
                                </div>
                                <div class="p-3">
                                    <h3 class="h6 mb-1">@p.Title</h3>
                                    <p class="small text-muted mb-1">@p.Location</p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="fw-bold">@p.Price.ToString("C0", Currency.PhilippinePeso)</span>
                                        <form method="post" asp-controller="Favorites" asp-action="Remove" class="m-0">
                                            <input type="hidden" name="id" value="@p.Id" />
                                            <button class="btn btn-sm btn-outline-danger">Remove</button>
                                        </form>
                                    </div>
                                </div>
                            </a>
                        </article>
                    </div>
                }
            </div>
        }
    </div>
</div>
