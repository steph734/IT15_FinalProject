@* filepath: c:\Users\ADMIN\source\repos\real\RealEstate\Views\SuperAdmin\EditUser.cshtml *@
@model RealEstate.Models.ApplicationUser
@{
    ViewData["Title"] = "Edit User";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="table-card">
            <div class="table-header">
                <div class="d-flex align-items-center gap-3">
                    <a href="/superadmin/users" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-arrow-left"></i>
                    </a>
                    <h5 style="font-weight: 700; margin: 0;">Edit User - @Model.FullName</h5>
                </div>
            </div>
            
            <div class="p-4">
                <form method="post" action="/superadmin/users/edit/@Model.UserId">
                    @Html.AntiForgeryToken()
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                            <input type="text" name="FullName" class="form-control" required value="@Model.FullName" />
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Email Address <span class="text-danger">*</span></label>
                            <input type="email" name="Email" class="form-control" required value="@Model.Email" />
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Role <span class="text-danger">*</span></label>
                            <select name="Role" class="form-select" required>
                                @foreach (var role in ViewBag.Roles)
                                {
                                    <option value="@role" selected="@(Model.Role == role ? "selected" : null)">@role</option>
                                }
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Phone Number</label>
                            <input type="tel" name="PhoneNumber" class="form-control" value="@Model.PhoneNumber" />
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">New Password</label>
                            <input type="password" name="newPassword" class="form-control" minlength="8" placeholder="Leave blank to keep current" />
                            <small class="text-muted">Minimum 8 characters</small>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Status</label>
                            <div class="form-check form-switch mt-2">
                                <input type="checkbox" name="IsActive" class="form-check-input" value="true" @(Model.IsActive ? "checked" : "") />
                                <label class="form-check-label">Active Account</label>
                            </div>
                        </div>
                        
                        <div class="col-12 mt-3">
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                <strong>Account Information:</strong><br>
                                Created: @Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")<br>
                                Last Login: @(Model.LastLogin?.ToString("MMM dd, yyyy HH:mm") ?? "Never")<br>
                                User ID: #@Model.UserId
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn-primary-custom">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a href="/superadmin/users" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
