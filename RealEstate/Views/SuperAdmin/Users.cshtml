@* filepath: c:\Users\ADMIN\source\repos\real\RealEstate\Views\SuperAdmin\Users.cshtml *@
@model List<RealEstate.Models.ApplicationUser>
@{
    ViewData["Title"] = "User Management";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

<div class="row g-4">
    <!-- Stats Cards -->
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: #dbeafe; color: #2563eb;">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-value">@Model.Count</div>
            <div class="stat-label">Total Users</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: #d1fae5; color: #059669;">
                <i class="fas fa-user-check"></i>
            </div>
            <div class="stat-value">@Model.Count(u => u.IsActive)</div>
            <div class="stat-label">Active Users</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: #fee2e2; color: #dc2626;">
                <i class="fas fa-user-slash"></i>
            </div>
            <div class="stat-value">@Model.Count(u => !u.IsActive)</div>
            <div class="stat-label">Inactive Users</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: #fef3c7; color: #d97706;">
                <i class="fas fa-user-plus"></i>
            </div>
            <div class="stat-value">@Model.Count(u => u.CreatedAt > DateTime.UtcNow.AddDays(-7))</div>
            <div class="stat-label">New This Week</div>
        </div>
    </div>
</div>

<!-- Filters & Actions -->
<div class="row mt-4">
    <div class="col-12">
        <div class="table-card">
            <div class="table-header">
                <h5 style="font-weight: 700; margin: 0;">All Users</h5>
                <div class="d-flex gap-2">
                    <form method="get" class="d-flex gap-2">
                        <input type="text" name="search" class="form-control" placeholder="Search users..." value="@ViewBag.Search" style="width: 200px;" />
                        <select name="role" class="form-select" style="width: 150px;">
                            <option value="">All Roles</option>
                            @foreach (var role in ViewBag.Roles)
                            {
                                <option value="@role" selected="@(ViewBag.Role == role ? "selected" : null)">@role</option>
                            }
                        </select>
                        <select name="isActive" class="form-select" style="width: 120px;">
                            <option value="">All Status</option>
                            <option value="true" selected="@(ViewBag.IsActive == true ? "selected" : null)">Active</option>
                            <option value="false" selected="@(ViewBag.IsActive == false ? "selected" : null)">Inactive</option>
                        </select>
                        <button type="submit" class="btn btn-outline-primary">
                            <i class="fas fa-filter"></i>
                        </button>
                    </form>
                    <a href="/superadmin/users/create" class="btn-primary-custom text-decoration-none">
                        <i class="fas fa-plus me-2"></i>Add User
                    </a>
                </div>
            </div>
            
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Last Login</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width: 40px; height: 40px; background: linear-gradient(135deg, #7c3aed, #a78bfa); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700;">
                                        @user.FullName?.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div style="font-weight: 600;">@user.FullName</div>
                                        <small style="color: #64748b;">ID: #@user.UserId</small>
                                    </div>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge bg-secondary">@user.Role</span>
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="status-badge status-active">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge status-inactive">Inactive</span>
                                }
                            </td>
                            <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>@(user.LastLogin?.ToString("MMM dd, HH:mm") ?? "Never")</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="/superadmin/users/edit/@user.UserId" class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" action="/superadmin/users/toggle-status/@user.UserId" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")" title="@(user.IsActive ? "Deactivate" : "Activate")">
                                            <i class="fas @(user.IsActive ? "fa-pause" : "fa-play")"></i>
                                        </button>
                                    </form>
                                    <form method="post" action="/superadmin/users/delete/@user.UserId" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
