@model List<RealEstate.Models.AuditLog>
@{
    ViewData["Title"] = "Audit Logs";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="table-card">
            <div class="table-header">
                <h5 style="font-weight: 700; margin: 0;">System Audit Logs</h5>
                <form method="get" class="d-flex gap-2">
                    <input type="date" name="fromDate" class="form-control" style="width: 140px;" value="@(ViewBag.FromDate?.ToString("yyyy-MM-dd") ?? "")" />
                    <input type="date" name="toDate" class="form-control" style="width: 140px;" value="@(ViewBag.ToDate?.ToString("yyyy-MM-dd") ?? "")" />
                    <input type="text" name="userEmail" class="form-control" placeholder="User email..." style="width: 180px;" value="@(ViewBag.UserEmail ?? "")" />
                    <input type="text" name="action" class="form-control" placeholder="Action..." style="width: 140px;" value="@(ViewBag.Action ?? "")" />
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="fas fa-filter"></i>
                    </button>
                </form>
            </div>
            
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Details</th>
                        <th>IP Address</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight: 600;">@log.CreatedAt.ToString("MMM dd, yyyy")</div>
                                    <small style="color: #64748b;">@log.CreatedAt.ToString("HH:mm:ss")</small>
                                </td>
                                <td>@(log.User?.Email ?? "System")</td>
                                <td>
                                    <span class="badge @(log.Action.Contains("DELETE") ? "bg-danger" : log.Action.Contains("CREATE") ? "bg-success" : log.Action.Contains("UPDATE") ? "bg-warning" : "bg-info")">
                                        @log.Action
                                    </span>
                                </td>
                                <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis;">@log.Description</td>
                                <td><small>@log.IPAddress</small></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="fas fa-history fa-3x text-muted mb-3"></i>
                                <p class="text-muted">No audit logs found</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
