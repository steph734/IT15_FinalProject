@model RealEstate.Controllers.SuperAdminDashboardStats
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

<div class="row g-4">
    <!-- Statistics Cards -->
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: #dbeafe; color: #2563eb;">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-value">@Model.TotalUsers</div>
            <div class="stat-label">Total Users</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: #d1fae5; color: #059669;">
                <i class="fas fa-user-check"></i>
            </div>
            <div class="stat-value">@Model.ActiveUsers</div>
            <div class="stat-label">Active Users</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: #fef3c7; color: #d97706;">
                <i class="fas fa-home"></i>
            </div>
            <div class="stat-value">@Model.TotalProperties</div>
            <div class="stat-label">Total Properties</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: #fce7f3; color: #c026d3;">
                <i class="fas fa-list"></i>
            </div>
            <div class="stat-value">@Model.TotalListings</div>
            <div class="stat-label">Total Listings</div>
        </div>
    </div>
</div>

<div class="row g-4 mt-2">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: #fee2e2; color: #dc2626;">
                <i class="fas fa-clock"></i>
            </div>
            <div class="stat-value">@Model.PendingReviews</div>
            <div class="stat-label">Pending Reviews</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: #e0e7ff; color: #4f46e5;">
                <i class="fas fa-dollar-sign"></i>
            </div>
            <div class="stat-value">@Model.TotalSales</div>
            <div class="stat-label">Total Sales</div>
        </div>
    </div>
</div>

<!-- Recent Activity -->
<div class="row mt-4">
    <div class="col-lg-6">
        <div class="table-card">
            <div class="table-header">
                <h5 style="font-weight: 700; margin: 0;">Recent Users</h5>
            </div>
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Role</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentUsers.Any())
                    {
                        @foreach (var user in Model.RecentUsers)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight: 600;">@user.FullName</div>
                                    <small style="color: #64748b;">@user.Email</small>
                                </td>
                                <td><span class="badge bg-secondary">@user.Role</span></td>
                                <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">No recent users</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="col-lg-6">
        <div class="table-card">
            <div class="table-header">
                <h5 style="font-weight: 700; margin: 0;">Recent Activity</h5>
            </div>
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Action</th>
                        <th>User</th>
                        <th>Time</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentActivity.Any())
                    {
                        @foreach (var log in Model.RecentActivity)
                        {
                            <tr>
                                <td>
                                    <span class="badge @(log.Action.Contains("DELETE") ? "bg-danger" : log.Action.Contains("CREATE") ? "bg-success" : "bg-info")">
                                        @log.Action
                                    </span>
                                </td>
                                <td>@(log.User?.Email ?? "System")</td>
                                <td>@log.CreatedAt.ToString("HH:mm")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">No recent activity</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row mt-4">
    <div class="col-12">
        <div class="table-card">
            <div class="table-header">
                <h5 style="font-weight: 700; margin: 0;">Quick Actions</h5>
            </div>
            <div class="p-4">
                <div class="row g-3">
                    <div class="col-md-3">
                        <a href="/superadmin/users/create" class="btn-primary-custom text-decoration-none d-block text-center py-3">
                            <i class="fas fa-user-plus me-2"></i>Add New User
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a href="/superadmin/users" class="btn btn-outline-primary d-block text-center py-3">
                            <i class="fas fa-users me-2"></i>Manage Users
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a href="/superadmin/audit-logs" class="btn btn-outline-primary d-block text-center py-3">
                            <i class="fas fa-history me-2"></i>View Audit Logs
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a href="/superadmin/settings" class="btn btn-outline-primary d-block text-center py-3">
                            <i class="fas fa-cog me-2"></i>System Settings
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
