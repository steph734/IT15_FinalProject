@* filepath: c:\Users\ADMIN\source\repos\real\RealEstate\Views\SuperAdmin\Database.cshtml *@
@{
    ViewData["Title"] = "Database Management";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="table-card">
            <div class="table-header">
                <h5 style="font-weight: 700; margin: 0;">Database Management</h5>
            </div>
            
            <div class="p-4">
                <div class="alert alert-warning mb-4">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <strong>Warning:</strong> Database operations are irreversible. Proceed with caution.
                </div>
                
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="stat-card h-100">
                            <h6 class="fw-bold mb-3" style="color: #7c3aed;">
                                <i class="fas fa-database me-2"></i>Database Status
                            </h6>
                            <div class="mb-3">
                                <small class="text-muted">Connection:</small>
                                <div class="fw-semibold text-success">
                                    <i class="fas fa-check-circle me-2"></i>Connected
                                </div>
                            </div>
                            <div class="mb-3">
                                <small class="text-muted">Database Name:</small>
                                <div class="fw-semibold">RealEstateDB</div>
                            </div>
                            <div>
                                <small class="text-muted">Last Backup:</small>
                                <div class="fw-semibold">@(DateTime.UtcNow.AddDays(-1).ToString("MMM dd, yyyy HH:mm"))</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="stat-card h-100">
                            <h6 class="fw-bold mb-3" style="color: #7c3aed;">
                                <i class="fas fa-table me-2"></i>Table Statistics
                            </h6>
                            <div class="mb-2 d-flex justify-content-between">
                                <span>Users</span>
                                <span class="fw-bold">124</span>
                            </div>
                            <div class="mb-2 d-flex justify-content-between">
                                <span>Properties</span>
                                <span class="fw-bold">89</span>
                            </div>
                            <div class="mb-2 d-flex justify-content-between">
                                <span>Seller Listings</span>
                                <span class="fw-bold">156</span>
                            </div>
                            <div class="mb-2 d-flex justify-content-between">
                                <span>Transactions</span>
                                <span class="fw-bold">42</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Audit Logs</span>
                                <span class="fw-bold">1,234</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <h6 class="fw-bold mt-4 mb-3" style="color: #7c3aed;">
                    <i class="fas fa-tools me-2"></i>Maintenance Actions
                </h6>
                
                <div class="row g-3">
                    <div class="col-md-4">
                        <button class="btn btn-outline-primary w-100 py-3">
                            <i class="fas fa-download me-2"></i>Backup Database
                        </button>
                    </div>
                    <div class="col-md-4">
                        <button class="btn btn-outline-success w-100 py-3">
                            <i class="fas fa-sync me-2"></i>Run Migrations
                        </button>
                    </div>
                    <div class="col-md-4">
                        <button class="btn btn-outline-warning w-100 py-3">
                            <i class="fas fa-broom me-2"></i>Clean Audit Logs
                        </button>
                    </div>
                </div>
                
                <div class="mt-4">
                    <button class="btn btn-outline-danger" onclick="if(confirm('Are you sure you want to reset the database? This action cannot be undone!')) { alert('Database reset initiated (not implemented in demo)'); }">
                        <i class="fas fa-trash me-2"></i>Reset Database (Dangerous)
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
